---
interface Props {
  title: string;
  description?: string;
  breadcrumbs?: Array<{ label: string; href: string }>;
}

const { title, description = "Interactive visualizations for understanding distributed systems", breadcrumbs } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <title>{title} | Systems Explained</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Cloudflare Web Analytics: add beacon token when ready -->
</head>
<body>
    <nav class="nav">
        <div class="nav-container">
            <a href="/" class="nav-logo">⚡ Systems Explained</a>
            <div class="nav-links">
                <div class="nav-dropdown">
                    <button class="nav-dropdown-trigger">Databases <span class="nav-caret">▾</span></button>
                    <div class="nav-dropdown-menu">
                        <a href="/postgresql/">🐘 PostgreSQL</a>
                        <a href="/mongodb/">🍃 MongoDB</a>
                        <a href="/redis/">🔴 Redis</a>
                        <a href="/cassandra/">👁️ Cassandra</a>
                        <a href="/elasticsearch/">🔍 Elasticsearch</a>
                        <a href="/clickhouse/">🏠 ClickHouse</a>
                        <a href="/dynamodb/">⚡ DynamoDB</a>
                        <a href="/tidb/">🔷 TiDB</a>
                        <a href="/cockroachdb/">🔥 CockroachDB</a>
                        <a href="/vitess/">🔱 Vitess</a>
                        <a href="/spanner/">⚡ Spanner</a>
                        <a href="/rocksdb/">🛡️ RocksDB</a>
                    </div>
                </div>
                <div class="nav-dropdown">
                    <button class="nav-dropdown-trigger">Streaming <span class="nav-caret">▾</span></button>
                    <div class="nav-dropdown-menu">
                        <a href="/kafka/">📨 Kafka</a>
                        <a href="/nats/">📡 NATS</a>
                        <a href="/spark/">⚡ Spark</a>
                    </div>
                </div>
                <div class="nav-dropdown">
                    <button class="nav-dropdown-trigger">Infrastructure <span class="nav-caret">▾</span></button>
                    <div class="nav-dropdown-menu">
                        <a href="/kubernetes/">☸️ Kubernetes</a>
                        <a href="/docker/">🐳 Docker</a>
                        <a href="/envoy/">🔺 Envoy</a>
                        <a href="/prometheus/">📊 Prometheus</a>
                        <a href="/grpc/">🔌 gRPC</a>
                    </div>
                </div>
                <div class="nav-dropdown">
                    <button class="nav-dropdown-trigger">Fundamentals <span class="nav-caret">▾</span></button>
                    <div class="nav-dropdown-menu">
                        <a href="/consensus/">🗳️ Consensus</a>
                        <a href="/etcd/">🔑 etcd</a>
                        <a href="/zookeeper/">🦁 ZooKeeper</a>
                        <a href="/linux/">🐧 Linux</a>
                        <a href="/dns/">🌍 DNS</a>
                        <a href="/tls/">🔒 TLS</a>
                    </div>
                </div>
                <div class="nav-dropdown">
                    <button class="nav-dropdown-trigger">Blockchain <span class="nav-caret">▾</span></button>
                    <div class="nav-dropdown-menu">
                        <a href="/ethereum/">⟠ Ethereum</a>
                    </div>
                </div>
                <a href="/about/" class="nav-link">About</a>
            </div>
            <button class="nav-hamburger" id="navHamburger" aria-label="Toggle menu">
                <span></span><span></span><span></span>
            </button>
        </div>

        <!-- Mobile menu -->
        <div class="nav-mobile" id="navMobile">
            <div class="nav-mobile-group">
                <div class="nav-mobile-heading">Databases</div>
                <a href="/postgresql/">🐘 PostgreSQL</a>
                <a href="/mongodb/">🍃 MongoDB</a>
                <a href="/redis/">🔴 Redis</a>
                <a href="/cassandra/">👁️ Cassandra</a>
                <a href="/elasticsearch/">🔍 Elasticsearch</a>
                <a href="/clickhouse/">🏠 ClickHouse</a>
                <a href="/dynamodb/">⚡ DynamoDB</a>
                <a href="/tidb/">🔷 TiDB</a>
                <a href="/cockroachdb/">🔥 CockroachDB</a>
                <a href="/vitess/">🔱 Vitess</a>
                <a href="/spanner/">⚡ Spanner</a>
                <a href="/rocksdb/">🛡️ RocksDB</a>
            </div>
            <div class="nav-mobile-group">
                <div class="nav-mobile-heading">Streaming</div>
                <a href="/kafka/">📨 Kafka</a>
                <a href="/nats/">📡 NATS</a>
                <a href="/spark/">⚡ Spark</a>
            </div>
            <div class="nav-mobile-group">
                <div class="nav-mobile-heading">Infrastructure</div>
                <a href="/kubernetes/">☸️ Kubernetes</a>
                <a href="/docker/">🐳 Docker</a>
                <a href="/envoy/">🔺 Envoy</a>
                <a href="/prometheus/">📊 Prometheus</a>
                <a href="/grpc/">🔌 gRPC</a>
            </div>
            <div class="nav-mobile-group">
                <div class="nav-mobile-heading">Fundamentals</div>
                <a href="/consensus/">🗳️ Consensus</a>
                <a href="/etcd/">🔑 etcd</a>
                <a href="/zookeeper/">🦁 ZooKeeper</a>
                <a href="/linux/">🐧 Linux</a>
                <a href="/dns/">🌍 DNS</a>
                <a href="/tls/">🔒 TLS</a>
            </div>
            <div class="nav-mobile-group">
                <div class="nav-mobile-heading">Blockchain</div>
                <a href="/ethereum/">⟠ Ethereum</a>
            </div>
            <div class="nav-mobile-group">
                <a href="/about/">About</a>
            </div>
        </div>
    </nav>

    {breadcrumbs && (
        <div class="breadcrumbs">
            <div class="breadcrumbs-container">
                {breadcrumbs.map((crumb, i) => (
                    <>
                        {i > 0 && <span class="breadcrumb-sep">›</span>}
                        <a href={crumb.href}>{crumb.label}</a>
                    </>
                ))}
            </div>
        </div>
    )}

    <main>
        <slot />
    </main>

    <footer class="footer">
        <div class="footer-container">
            <div class="footer-cta">
                <h3>📬 Get notified when we publish new visualizations</h3>
                <form class="newsletter-form" id="subscribeForm">
                    <input type="email" id="subEmail" placeholder="you@example.com" required>
                    <button type="submit" id="subBtn">Subscribe</button>
                </form>
                <p class="sub-status" id="subStatus" style="display:none; margin-top:8px; font-size:0.9rem;"></p>
                <script is:inline>
                  document.getElementById('subscribeForm').addEventListener('submit', function(e) {
                    e.preventDefault();
                    var email = document.getElementById('subEmail').value;
                    var btn = document.getElementById('subBtn');
                    var status = document.getElementById('subStatus');
                    btn.disabled = true;
                    btn.textContent = '...';
                    fetch('/api/subscribe', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ email: email })
                    }).then(function(r) { return r.json(); }).then(function(data) {
                      status.style.display = 'block';
                      status.style.color = '#22c55e';
                      status.textContent = data.message || 'Subscribed!';
                      btn.textContent = '✓';
                    }).catch(function() {
                      status.style.display = 'block';
                      status.style.color = '#ef4444';
                      status.textContent = 'Error — try again later';
                      btn.disabled = false;
                      btn.textContent = 'Subscribe';
                    });
                  });
                </script>
            </div>
            <div class="footer-links">
                <a href="https://twitter.com/systemsexplain" target="_blank">𝕏 Twitter</a>
                <a href="https://youtube.com/@systeminternals" target="_blank">▶ YouTube</a>
                <a href="https://github.com/systeminternals" target="_blank">⌨ GitHub</a>
            </div>
            <script is:inline>
              (function() {
                var btn = document.getElementById('navHamburger');
                var menu = document.getElementById('navMobile');
                if (btn && menu) {
                  btn.addEventListener('click', function() {
                    btn.classList.toggle('open');
                    menu.classList.toggle('open');
                  });
                }
              })();
            </script>
            <p class="footer-tagline">Built by engineers, for engineers.</p>
            <p class="footer-copy">© 2026 Systems Explained</p>
        </div>
    </footer>
</body>
</html>

<style is:global>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #0f0f1a 100%);
        background-attachment: fixed;
        color: #e0e0e0;
        min-height: 100vh;
        line-height: 1.6;
    }

    a {
        color: #00d4ff;
        text-decoration: none;
        transition: color 0.2s;
    }

    a:hover {
        color: #7c3aed;
    }

    .nav {
        background: rgba(15, 15, 26, 0.95);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
        display: flex;
        align-items: center;
        height: 56px;
    }

    .nav-logo {
        font-size: 1.2rem;
        font-weight: 700;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-right: 32px;
        flex-shrink: 0;
    }

    .nav-logo:hover { color: #fff; }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 4px;
        flex: 1;
    }

    .nav-link {
        color: #999;
        font-weight: 500;
        font-size: 0.9rem;
        padding: 8px 12px;
        border-radius: 8px;
        transition: all 0.2s;
    }

    .nav-link:hover { color: #fff; background: rgba(255,255,255,0.06); }

    /* Dropdown */
    .nav-dropdown { position: relative; }

    .nav-dropdown-trigger {
        background: none;
        border: none;
        color: #999;
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: 500;
        padding: 8px 12px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .nav-dropdown-trigger:hover, .nav-dropdown:hover .nav-dropdown-trigger {
        color: #fff;
        background: rgba(255,255,255,0.06);
    }

    .nav-caret { font-size: 0.7rem; opacity: 0.6; transition: transform 0.2s; }
    .nav-dropdown:hover .nav-caret { transform: rotate(180deg); }

    .nav-dropdown-menu {
        display: none;
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        background: rgba(20, 20, 35, 0.98);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        padding: 8px;
        min-width: 200px;
        box-shadow: 0 12px 40px rgba(0,0,0,0.5);
        z-index: 200;
    }

    .nav-dropdown:hover .nav-dropdown-menu { display: block; }

    .nav-dropdown-menu a {
        display: block;
        padding: 8px 14px;
        color: #bbb;
        font-size: 0.88rem;
        font-weight: 500;
        border-radius: 8px;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .nav-dropdown-menu a:hover {
        color: #fff;
        background: rgba(52,211,153,0.1);
    }

    /* Hamburger */
    .nav-hamburger {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px;
        margin-left: auto;
        flex-direction: column;
        gap: 5px;
    }

    .nav-hamburger span {
        display: block;
        width: 22px;
        height: 2px;
        background: #ccc;
        border-radius: 2px;
        transition: all 0.3s;
    }

    .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-hamburger.open span:nth-child(2) { opacity: 0; }
    .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* Mobile menu */
    .nav-mobile {
        display: none;
        padding: 12px 20px 20px;
        border-top: 1px solid rgba(255,255,255,0.06);
        max-height: 70vh;
        overflow-y: auto;
    }

    .nav-mobile.open { display: block; }

    .nav-mobile-group { margin-bottom: 16px; }

    .nav-mobile-heading {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #666;
        padding: 4px 12px;
        margin-bottom: 4px;
    }

    .nav-mobile-group a {
        display: block;
        padding: 8px 12px;
        color: #bbb;
        font-size: 0.9rem;
        border-radius: 8px;
        transition: background 0.15s;
    }

    .nav-mobile-group a:hover {
        background: rgba(52,211,153,0.1);
        color: #fff;
    }

    .breadcrumbs {
        background: rgba(255, 255, 255, 0.02);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .breadcrumbs-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 12px 20px;
        font-size: 0.9rem;
        color: #888;
    }

    .breadcrumbs a {
        color: #888;
    }

    .breadcrumbs a:hover {
        color: #00d4ff;
    }

    .breadcrumb-sep {
        margin: 0 8px;
        color: #555;
    }

    main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    .footer {
        margin-top: 60px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(0, 0, 0, 0.2);
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
        text-align: center;
    }

    .footer-cta {
        margin-bottom: 30px;
    }

    .footer-cta h3 {
        font-size: 1.2rem;
        margin-bottom: 15px;
        color: #fff;
    }

    .newsletter-form {
        display: flex;
        gap: 10px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .newsletter-form input {
        padding: 12px 16px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
        font-size: 1rem;
        width: 280px;
    }

    .newsletter-form input::placeholder {
        color: #666;
    }

    .newsletter-form button {
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        background: linear-gradient(135deg, #00d4ff, #7c3aed);
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .newsletter-form button:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(0, 212, 255, 0.3);
    }

    .footer-links {
        display: flex;
        gap: 24px;
        justify-content: center;
        margin-bottom: 20px;
    }

    .footer-links a {
        color: #888;
    }

    .footer-tagline {
        color: #666;
        font-size: 0.95rem;
        margin-bottom: 8px;
    }

    .footer-copy {
        color: #555;
        font-size: 0.85rem;
    }

    @media (max-width: 900px) {
        .nav-links { display: none; }
        .nav-hamburger { display: flex; }
    }

    @media (max-width: 768px) {
        .newsletter-form {
            flex-direction: column;
            align-items: center;
        }

        .newsletter-form input {
            width: 100%;
            max-width: 300px;
        }
    }
</style>
