---
interface Props {
  title: string;
  description?: string;
  breadcrumbs?: Array<{ label: string; href: string }>;
}

const { title, description = "Interactive visualizations for understanding distributed systems", breadcrumbs } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <title>{title} | Systems Explained</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Cloudflare Web Analytics -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "REPLACE_WITH_BEACON_TOKEN"}'></script>
</head>
<body>
    <nav class="nav">
        <div class="nav-container">
            <a href="/" class="nav-logo">⚡ Systems Explained</a>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/consensus/">Consensus</a>
                <a href="/kafka/">Kafka</a>
                <a href="/redis/">Redis</a>
                <a href="/postgresql/">PostgreSQL</a>
                <a href="/elasticsearch/">Elasticsearch</a>
                <a href="/kubernetes/">Kubernetes</a>
                <a href="/etcd/">etcd</a>
                <a href="/zookeeper/">ZooKeeper</a>
                <a href="/cassandra/">Cassandra</a>
                <a href="/mongodb/">MongoDB</a>
                <a href="/tidb/">TiDB</a>
                <a href="/clickhouse/">ClickHouse</a>
                <a href="/dynamodb/">DynamoDB</a>
                <a href="/grpc/">gRPC</a>
                <a href="/spark/">Spark</a>
                <a href="/about/">About</a>
            </div>
        </div>
    </nav>

    {breadcrumbs && (
        <div class="breadcrumbs">
            <div class="breadcrumbs-container">
                {breadcrumbs.map((crumb, i) => (
                    <>
                        {i > 0 && <span class="breadcrumb-sep">›</span>}
                        <a href={crumb.href}>{crumb.label}</a>
                    </>
                ))}
            </div>
        </div>
    )}

    <main>
        <slot />
    </main>

    <footer class="footer">
        <div class="footer-container">
            <div class="footer-cta">
                <h3>📬 Get notified when we publish new visualizations</h3>
                <form class="newsletter-form" id="subscribeForm">
                    <input type="email" id="subEmail" placeholder="you@example.com" required>
                    <button type="submit" id="subBtn">Subscribe</button>
                </form>
                <p class="sub-status" id="subStatus" style="display:none; margin-top:8px; font-size:0.9rem;"></p>
                <script is:inline>
                  document.getElementById('subscribeForm').addEventListener('submit', function(e) {
                    e.preventDefault();
                    var email = document.getElementById('subEmail').value;
                    var btn = document.getElementById('subBtn');
                    var status = document.getElementById('subStatus');
                    btn.disabled = true;
                    btn.textContent = '...';
                    fetch('/api/subscribe', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ email: email })
                    }).then(function(r) { return r.json(); }).then(function(data) {
                      status.style.display = 'block';
                      status.style.color = '#22c55e';
                      status.textContent = data.message || 'Subscribed!';
                      btn.textContent = '✓';
                    }).catch(function() {
                      status.style.display = 'block';
                      status.style.color = '#ef4444';
                      status.textContent = 'Error — try again later';
                      btn.disabled = false;
                      btn.textContent = 'Subscribe';
                    });
                  });
                </script>
            </div>
            <div class="footer-links">
                <a href="https://twitter.com/systemsexplain" target="_blank">𝕏 Twitter</a>
                <a href="https://youtube.com/@systeminternals" target="_blank">▶ YouTube</a>
                <a href="https://github.com/systeminternals" target="_blank">⌨ GitHub</a>
            </div>
            <p class="footer-tagline">Built by engineers, for engineers.</p>
            <p class="footer-copy">© 2026 Systems Explained</p>
        </div>
    </footer>
</body>
</html>

<style is:global>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #0f0f1a 100%);
        background-attachment: fixed;
        color: #e0e0e0;
        min-height: 100vh;
        line-height: 1.6;
    }

    a {
        color: #00d4ff;
        text-decoration: none;
        transition: color 0.2s;
    }

    a:hover {
        color: #7c3aed;
    }

    .nav {
        background: rgba(15, 15, 26, 0.9);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 16px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .nav-logo {
        font-size: 1.3rem;
        font-weight: 700;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .nav-links {
        display: flex;
        gap: 24px;
    }

    .nav-links a {
        color: #aaa;
        font-weight: 500;
    }

    .nav-links a:hover {
        color: #fff;
    }

    .breadcrumbs {
        background: rgba(255, 255, 255, 0.02);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .breadcrumbs-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 12px 20px;
        font-size: 0.9rem;
        color: #888;
    }

    .breadcrumbs a {
        color: #888;
    }

    .breadcrumbs a:hover {
        color: #00d4ff;
    }

    .breadcrumb-sep {
        margin: 0 8px;
        color: #555;
    }

    main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    .footer {
        margin-top: 60px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(0, 0, 0, 0.2);
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
        text-align: center;
    }

    .footer-cta {
        margin-bottom: 30px;
    }

    .footer-cta h3 {
        font-size: 1.2rem;
        margin-bottom: 15px;
        color: #fff;
    }

    .newsletter-form {
        display: flex;
        gap: 10px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .newsletter-form input {
        padding: 12px 16px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
        font-size: 1rem;
        width: 280px;
    }

    .newsletter-form input::placeholder {
        color: #666;
    }

    .newsletter-form button {
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        background: linear-gradient(135deg, #00d4ff, #7c3aed);
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .newsletter-form button:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(0, 212, 255, 0.3);
    }

    .footer-links {
        display: flex;
        gap: 24px;
        justify-content: center;
        margin-bottom: 20px;
    }

    .footer-links a {
        color: #888;
    }

    .footer-tagline {
        color: #666;
        font-size: 0.95rem;
        margin-bottom: 8px;
    }

    .footer-copy {
        color: #555;
        font-size: 0.85rem;
    }

    @media (max-width: 768px) {
        .nav-container {
            flex-direction: column;
            gap: 12px;
        }

        .nav-links {
            gap: 16px;
        }

        .newsletter-form {
            flex-direction: column;
            align-items: center;
        }

        .newsletter-form input {
            width: 100%;
            max-width: 300px;
        }
    }
</style>
