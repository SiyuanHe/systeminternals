  }

  .share-btn:hover { background: rgba(255, 255, 255, 0.2); color: #fff; }

  @media (max-width: 768px) {
    .viz-header h1 { font-size: 1.8rem; }
    .sim-layout { grid-template-columns: 1fr; }
    .netpol-demo { grid-template-columns: 1fr; }
    .net-cluster { grid-template-columns: 1fr; }
    .netpol-cluster { grid-template-columns: repeat(2, 1fr); }
