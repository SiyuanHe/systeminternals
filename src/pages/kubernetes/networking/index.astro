    .ingress-rules { grid-template-columns: 1fr; }
    .dns-step-row { flex-direction: column; }
  }
</style>

<script is:inline>
  // ============================================================
  // KUBERNETES NETWORKING SIMULATION
  // ============================================================

  // --- Cluster Definition ---
  var clusterNodes = [
    {
      name: "node-1", ip: "10.0.1.10",
      pods: [
        { name: "web-1", app: "web", ip: "10.244.1.2", port: 8080 },
        { name: "api-1", app: "api", ip: "10.244.1.3", port: 3000 }
      ]
    },
    {
      name: "node-2", ip: "10.0.1.11",
      pods: [
        { name: "web-2", app: "web", ip: "10.244.2.2", port: 8080 },
        { name: "db-1", app: "db", ip: "10.244.2.4", port: 5432 }
      ]
    },
    {
      name: "node-3", ip: "10.0.1.12",
      pods: [
        { name: "web-3", app: "web", ip: "10.244.3.2", port: 8080 },
        { name: "api-2", app: "api", ip: "10.244.3.3", port: 3000 },
        { name: "db-2", app: "db", ip: "10.244.3.5", port: 5432 }
      ]
    }
  ];

  var services = {
    "web-svc": { clusterIP: "10.96.0.10", port: 80, targetPort: 8080, type: "ClusterIP", app: "web" },
    "api-svc": { clusterIP: "10.96.0.20", port: 8080, targetPort: 3000, type: "NodePort", nodePort: 31080, app: "api" },
    "db-svc": { clusterIP: "10.96.0.30", port: 5432, targetPort: 5432, type: "ClusterIP", app: "db" }
  };

  // --- Render Network Cluster ---
  function renderNetCluster(activeNodeIdx, targetedPodName) {
    var el = document.getElementById("netCluster");
    var html = "";
    for (var i = 0; i < clusterNodes.length; i++) {
      var n = clusterNodes[i];
      var nodeCls = "net-node";
      if (activeNodeIdx === i) nodeCls += " active-node";

      html += '<div class="' + nodeCls + '">';
      html += '<div class="net-node-name">' + n.name + '</div>';
      html += '<div class="net-node-ip">' + n.ip + '</div>';
      html += '<div class="net-pods">';
      for (var p = 0; p < n.pods.length; p++) {
        var pod = n.pods[p];
        var podCls = "net-pod " + pod.app;
        if (targetedPodName === pod.name) podCls += " targeted";
        html += '<div class="' + podCls + '">' + pod.name + '<br><span style="font-size:0.6rem;opacity:0.7">' + pod.ip + '</span></div>';
      }
      html += '</div>';

      // Show services hosted here
      var proxyMode = document.getElementById("proxyMode").value;
      html += '<div class="net-proxy-badge">kube-proxy: ' + proxyMode + '</div>';
      html += '</div>';
    }
    el.innerHTML = html;
  }

  // --- Trace Log ---
  var traceEl = document.getElementById("traceLog");

  function clearTrace() {
    traceEl.innerHTML = '<div class="log-empty">Configure a request and click "Send Request"...</div>';
  }

  function addTrace(msg, cls) {
    if (traceEl.querySelector(".log-empty")) traceEl.innerHTML = "";
    var div = document.createElement("div");
    div.className = "log-line " + (cls || "");
    div.textContent = msg;
    traceEl.appendChild(div);
    traceEl.scrollTop = traceEl.scrollHeight;
  }

  // --- Send Request ---
  function sendRequest() {
    var svcName = document.getElementById("targetSvc").value;
    var proxyMode = document.getElementById("proxyMode").value;
    var source = document.getElementById("requestSource").value;
    var svc = services[svcName];
    var btn = document.getElementById("sendReqBtn");
    btn.disabled = true;

    clearTrace();

    // Highlight service type card
    document.querySelectorAll(".service-type-card").forEach(function(c) { c.classList.remove("active-svc"); });
    if (svc.type === "ClusterIP") document.getElementById("svcClusterIP").classList.add("active-svc");
    else if (svc.type === "NodePort") document.getElementById("svcNodePort").classList.add("active-svc");
    else document.getElementById("svcLoadBalancer").classList.add("active-svc");

    var delay = 0;

    // Step 1: DNS Resolution
    setTimeout(function() {
      addTrace("== Request to " + svcName + " (" + svc.type + ") ==", "info");
      addTrace("1. DNS: " + svcName + ".default.svc.cluster.local", "dns");
    }, delay);
    delay += 500;

    setTimeout(function() {
      addTrace("   → CoreDNS resolves to ClusterIP: " + svc.clusterIP, "dns");
    }, delay);
    delay += 500;

    // Step 2: Source routing
    if (source === "external" && svc.type === "NodePort") {
      setTimeout(function() {
        addTrace("2. External → NodePort " + clusterNodes[0].ip + ":" + svc.nodePort, "svc");
      }, delay);
      delay += 500;
    } else if (source === "external" && svc.type === "ClusterIP") {
      setTimeout(function() {
        addTrace("2. ⚠ ClusterIP is internal-only! External client cannot reach " + svc.clusterIP, "error");
        addTrace("   → Use NodePort or LoadBalancer for external access", "error");
        btn.disabled = false;
      }, delay);
      return;
    } else {
      setTimeout(function() {
        addTrace("2. Pod → ClusterIP " + svc.clusterIP + ":" + svc.port, "svc");
      }, delay);
      delay += 500;
    }

    // Step 3: kube-proxy
    setTimeout(function() {
      if (proxyMode === "iptables") {
        addTrace("3. kube-proxy (iptables): DNAT via chain KUBE-SVC-" + svcName.toUpperCase().replace(/-/g, ""), "proxy");
        addTrace("   → iptables -t nat -A KUBE-SVC-xxx -m statistic --mode random --probability 0.33 -j KUBE-SEP-xxx", "proxy");
      } else if (proxyMode === "ipvs") {
        addTrace("3. kube-proxy (IPVS): hash lookup in virtual server table", "proxy");
        addTrace("   → ipvsadm: " + svc.clusterIP + ":" + svc.port + " rr", "proxy");
      } else {
        addTrace("3. Cilium (eBPF): BPF map lookup at socket/TC layer", "proxy");
        addTrace("   → bpf_map_lookup(svc=" + svc.clusterIP + ") → backend selected in O(1)", "proxy");
      }
    }, delay);
    delay += 600;

    // Step 4: Select backend pod
    var backends = [];
    for (var ni = 0; ni < clusterNodes.length; ni++) {
      for (var pi = 0; pi < clusterNodes[ni].pods.length; pi++) {
        var pod = clusterNodes[ni].pods[pi];
        if (pod.app === svc.app) {
          backends.push({ pod: pod, nodeIdx: ni });
        }
      }
    }

    var chosen = backends[Math.floor(Math.random() * backends.length)];

    setTimeout(function() {
      addTrace("4. Endpoints: [" + backends.map(function(b) { return b.pod.ip + ":" + b.pod.port; }).join(", ") + "]", "svc");
    }, delay);
    delay += 400;

    setTimeout(function() {
      addTrace("   → Selected: " + chosen.pod.name + " (" + chosen.pod.ip + ":" + chosen.pod.port + ")", "pod");
      renderNetCluster(chosen.nodeIdx, chosen.pod.name);
    }, delay);
    delay += 400;

    setTimeout(function() {
      addTrace("5. ✅ Request delivered to " + chosen.pod.name + " on " + clusterNodes[chosen.nodeIdx].name, "pod");

      if (proxyMode === "iptables") {
        addTrace("   ℹ iptables: ~100μs rule traversal for small clusters, O(n) with services", "info");
      } else if (proxyMode === "ipvs") {
        addTrace("   ℹ IPVS: ~20μs hash lookup, O(1), supports rr/lc/sh algorithms", "info");
      } else {
        addTrace("   ℹ eBPF: ~5μs at socket layer, bypasses netfilter entirely", "info");
      }

      btn.disabled = false;
    }, delay);
  }

  document.getElementById("sendReqBtn").addEventListener("click", sendRequest);

  document.getElementById("resetClusterBtn").addEventListener("click", function() {
    clearTrace();
    document.querySelectorAll(".service-type-card").forEach(function(c) { c.classList.remove("active-svc"); });
    renderNetCluster(-1, null);
    document.getElementById("sendReqBtn").disabled = false;
  });

  // --- DNS Resolution Demo ---
  var dnsRecords = {
    "web-svc.default.svc.cluster.local": { ip: "10.96.0.10", type: "A" },
    "api-svc.kube-system.svc.cluster.local": { ip: "10.96.0.20", type: "A" },
    "db-svc.default.svc.cluster.local": { ip: "10.96.0.30", type: "A" },
    "web-svc.default": { ip: "10.96.0.10", type: "A", expand: "web-svc.default.svc.cluster.local" }
  };

  document.querySelectorAll(".dns-preset").forEach(function(btn) {
    btn.addEventListener("click", function() {
      var query = this.getAttribute("data-query");
      document.getElementById("dnsQuery").value = query;
      document.querySelectorAll(".dns-preset").forEach(function(b) { b.classList.remove("active"); });
      this.classList.add("active");
    });
  });

  document.getElementById("dnsResolveBtn").addEventListener("click", function() {
    var query = document.getElementById("dnsQuery").value;
    var stepsEl = document.getElementById("dnsSteps");
    stepsEl.innerHTML = "";
    var record = dnsRecords[query];
    var delay = 0;

    // Step 1: Query
    var s1 = document.createElement("div");
    s1.className = "dns-step query-step";
    s1.textContent = "Query: " + query;
    stepsEl.appendChild(s1);
    setTimeout(function() { s1.classList.add("visible"); }, delay);
    delay += 400;

    // Arrow
    var a1 = document.createElement("div");
    a1.className = "dns-arrow";
    a1.textContent = "→";
    stepsEl.appendChild(a1);
    setTimeout(function() { a1.classList.add("visible"); }, delay);
    delay += 300;

    // Step 2: Search domain expansion
    if (record && record.expand) {
      var s2 = document.createElement("div");
      s2.className = "dns-step search-step";
      s2.textContent = "Expand: " + record.expand;
      stepsEl.appendChild(s2);
      setTimeout(function() { s2.classList.add("visible"); }, delay);
      delay += 400;

      var a2 = document.createElement("div");
      a2.className = "dns-arrow";
      a2.textContent = "→";
      stepsEl.appendChild(a2);
      setTimeout(function() { a2.classList.add("visible"); }, delay);
      delay += 300;
    } else {
      var s2b = document.createElement("div");
      s2b.className = "dns-step search-step";
      s2b.textContent = "CoreDNS lookup";
      stepsEl.appendChild(s2b);
      setTimeout(function() { s2b.classList.add("visible"); }, delay);
      delay += 400;

      var a2b = document.createElement("div");
      a2b.className = "dns-arrow";
      a2b.textContent = "→";
      stepsEl.appendChild(a2b);
      setTimeout(function() { a2b.classList.add("visible"); }, delay);
      delay += 300;
    }

    // Step 3: Resolution
    var s3 = document.createElement("div");
    s3.className = "dns-step resolve-step";
    if (record) {
      s3.textContent = record.type + ": " + record.ip;
    } else {
      s3.textContent = "NXDOMAIN";
      s3.style.color = "#f87171";
      s3.style.borderColor = "rgba(239, 68, 68, 0.3)";
      s3.style.background = "rgba(239, 68, 68, 0.15)";
    }
    stepsEl.appendChild(s3);
    setTimeout(function() { s3.classList.add("visible"); }, delay);
  });

  // --- Ingress Routing ---
  var ingressRules = [
    { host: "app.example.com", paths: [
      { path: "/api/", backend: "api-svc:8080" },
      { path: "/ws", backend: "ws-svc:9090" },
      { path: "/", backend: "web-svc:80" }
    ]},
    { host: "admin.example.com", paths: [
      { path: "/", backend: "admin-svc:3000" }
    ]}
  ];

  document.getElementById("ingressTestBtn").addEventListener("click", function() {
    var urlStr = document.getElementById("ingressUrl").value;
    var resultEl = document.getElementById("ingressResult");

    // Parse URL
    var hostMatch = urlStr.match(/\/\/([^\/]+)/);
    var pathMatch = urlStr.match(/\/\/[^\/]+(\/[^\?#]*)/);
    var host = hostMatch ? hostMatch[1] : "";
    var path = pathMatch ? pathMatch[1] : "/";

    // Clear highlights
    document.querySelectorAll(".ingress-rule").forEach(function(r) { r.classList.remove("matched-rule"); });
    document.querySelectorAll(".ingress-path").forEach(function(p) { p.classList.remove("matched-path"); });

    var matched = null;
    for (var r = 0; r < ingressRules.length; r++) {
      var rule = ingressRules[r];
      if (rule.host === host) {
        var ruleEls = document.querySelectorAll(".ingress-rule");
        ruleEls[r].classList.add("matched-rule");

        for (var p = 0; p < rule.paths.length; p++) {
          if (path.indexOf(rule.paths[p].path) === 0 || rule.paths[p].path === "/") {
            matched = rule.paths[p];
            var pathEls = ruleEls[r].querySelectorAll(".ingress-path");
            pathEls[p].classList.add("matched-path");
            break;
          }
        }
        break;
      }
    }

    if (matched) {
      resultEl.className = "ingress-result routed";
      resultEl.textContent = "✅ " + host + path + " → " + matched.backend;
    } else {
      resultEl.className = "ingress-result no-match";
      resultEl.textContent = "❌ No matching Ingress rule for " + host + path;
    }
  });

  // --- Network Policy Editor ---
  var netpolPods = [
    { name: "web-1", app: "web" },
    { name: "web-2", app: "web" },
    { name: "api-1", app: "api" },
    { name: "api-2", app: "api" },
    { name: "db-1", app: "db" },
    { name: "db-2", app: "db" },
    { name: "external", app: "external" },
    { name: "dns", app: "dns" }
  ];

  function renderNetpol(target, allowFrom, denyFrom) {
    var el = document.getElementById("netpolCluster");
    var html = "";
    for (var i = 0; i < netpolPods.length; i++) {
      var pod = netpolPods[i];
      var cls = "netpol-pod";
      var status = "";
      var statusCls = "";

      if (pod.app === target) {
        cls += " target-pod";
        status = "🎯 target";
        statusCls = "target";
      } else if (allowFrom.indexOf(pod.app) >= 0) {
        cls += " allowed-pod";
        status = "✅ allowed";
        statusCls = "allow";
      } else {
        cls += " denied-pod";
        status = "🚫 denied";
        statusCls = "deny";
      }

      html += '<div class="' + cls + '">';
      html += '<div class="netpol-pod-name">' + pod.name + '</div>';
      html += '<div class="netpol-pod-label">app=' + pod.app + '</div>';
      html += '<div class="netpol-pod-status ' + statusCls + '">' + status + '</div>';
      html += '</div>';
    }
    el.innerHTML = html;
  }

  function generateYaml(target, ingressAllow, egressAllow) {
    var yaml = "apiVersion: networking.k8s.io/v1\n";
    yaml += "kind: NetworkPolicy\n";
    yaml += "metadata:\n";
    yaml += "  name: " + target + "-policy\n";
    yaml += "  namespace: default\n";
    yaml += "spec:\n";
    yaml += "  podSelector:\n";
    yaml += "    matchLabels:\n";
    yaml += "      app: " + target + "\n";
    yaml += "  policyTypes:\n";
    yaml += "    - Ingress\n";
    yaml += "    - Egress\n";
    yaml += "  ingress:\n";

    if (ingressAllow.length > 0) {
      yaml += "    - from:\n";
      for (var i = 0; i < ingressAllow.length; i++) {
        if (ingressAllow[i] === "external") {
          yaml += "        - ipBlock:\n";
          yaml += "            cidr: 0.0.0.0/0\n";
        } else {
          yaml += "        - podSelector:\n";
          yaml += "            matchLabels:\n";
          yaml += "              app: " + ingressAllow[i] + "\n";
        }
      }
    } else {
      yaml += "    [] # deny all ingress\n";
    }

    yaml += "  egress:\n";
    if (egressAllow.length > 0) {
      for (var e = 0; e < egressAllow.length; e++) {
        if (egressAllow[e] === "dns") {
          yaml += "    - to: []\n";
          yaml += "      ports:\n";
          yaml += "        - port: 53\n";
          yaml += "          protocol: UDP\n";
          yaml += "        - port: 53\n";
          yaml += "          protocol: TCP\n";
        } else if (egressAllow[e] === "internet") {
          yaml += "    - to:\n";
          yaml += "        - ipBlock:\n";
          yaml += "            cidr: 0.0.0.0/0\n";
          yaml += "            except:\n";
          yaml += "              - 10.0.0.0/8\n";
        } else {
          yaml += "    - to:\n";
          yaml += "        - podSelector:\n";
          yaml += "            matchLabels:\n";
          yaml += "              app: " + egressAllow[e] + "\n";
        }
      }
    } else {
      yaml += "    [] # deny all egress\n";
    }

    return yaml;
  }

  function applyNetpol() {
    var target = document.getElementById("polTarget").value;
    var allowFrom = [];
    if (document.getElementById("polAllowWeb").checked) allowFrom.push("web");
    if (document.getElementById("polAllowApi").checked) allowFrom.push("api");
    if (document.getElementById("polAllowDb").checked) allowFrom.push("db");
    if (document.getElementById("polAllowExt").checked) allowFrom.push("external");

    var egressAllow = [];
    if (document.getElementById("polEgressDns").checked) egressAllow.push("dns");
    if (document.getElementById("polEgressDb").checked) egressAllow.push("db");
    if (document.getElementById("polEgressExt").checked) egressAllow.push("internet");

    renderNetpol(target, allowFrom);
    document.getElementById("netpolYamlCode").textContent = generateYaml(target, allowFrom, egressAllow);
  }

  document.getElementById("polApplyBtn").addEventListener("click", applyNetpol);

  document.getElementById("polResetBtn").addEventListener("click", function() {
    document.getElementById("polAllowWeb").checked = true;
    document.getElementById("polAllowApi").checked = true;
    document.getElementById("polAllowDb").checked = false;
    document.getElementById("polAllowExt").checked = false;
    document.getElementById("polEgressDns").checked = true;
    document.getElementById("polEgressDb").checked = true;
    document.getElementById("polEgressExt").checked = false;
    document.getElementById("polTarget").value = "web";
    applyNetpol();
  });

  // --- Init ---
  renderNetCluster(-1, null);
  applyNetpol();
</script>
</BaseLayout>
