  }

  /* Network Policy */
  .netpol-section {
    margin-bottom: 50px;
  }

  .netpol-demo {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 24px;
  }

  .netpol-editor {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 20px;
  }

  .netpol-editor h3 {
    font-size: 1rem;
    color: #fff;
    margin-bottom: 16px;
    font-weight: 600;
  }

  .checkbox-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .cb-label {
    font-size: 0.85rem;
    color: #aaa;
    display: flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
  }

  .cb-label input[type="checkbox"] {
    accent-color: #60a5fa;
  }

  .netpol-editor .action-btn {
    width: 100%;
    margin-top: 8px;
  }

  .netpol-viz {
    min-width: 0;
  }

  .netpol-cluster {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 16px;
  }

  .netpol-pod {
    background: rgba(255, 255, 255, 0.04);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 14px;
    text-align: center;
    transition: all 0.4s;
    position: relative;
  }

  .netpol-pod.target-pod {
    border-color: rgba(96, 165, 250, 0.6);
    background: rgba(96, 165, 250, 0.08);
    box-shadow: 0 0 20px rgba(96, 165, 250, 0.15);
  }

  .netpol-pod.allowed-pod {
    border-color: rgba(74, 222, 128, 0.5);
    background: rgba(74, 222, 128, 0.05);
  }

  .netpol-pod.denied-pod {
    border-color: rgba(239, 68, 68, 0.4);
    background: rgba(239, 68, 68, 0.05);
    opacity: 0.5;
  }

  .netpol-pod-name {
    font-weight: 700;
    font-size: 0.8rem;
    color: #fff;
    margin-bottom: 4px;
  }

  .netpol-pod-label {
    font-size: 0.7rem;
    color: #888;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }

  .netpol-pod-status {
    margin-top: 6px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .netpol-pod-status.allow { color: #4ade80; }
  .netpol-pod-status.deny { color: #f87171; }
  .netpol-pod-status.target { color: #60a5fa; }

  .netpol-yaml {
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 16px;
    max-height: 300px;
    overflow-y: auto;
  }

  .netpol-yaml h4 {
    font-size: 0.85rem;
