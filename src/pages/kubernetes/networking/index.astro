  }

  .netpol-yaml pre {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    line-height: 1.6;
    color: #aaa;
    white-space: pre-wrap;
    margin: 0;
  }

  /* Footer */
  .viz-footer {
    text-align: center;
    color: #666;
    font-size: 0.9rem;
    padding: 20px 0;
    border-top: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 30px;
  }

  .viz-footer a { color: #60a5fa; }

  .share-buttons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .share-buttons span { color: #666; }

  .share-btn {
    padding: 10px 20px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: #fff;
    font-size: 0.9rem;
