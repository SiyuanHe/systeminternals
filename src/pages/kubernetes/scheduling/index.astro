</style>

<script is:inline>
  // ============================================================
  // KUBERNETES SCHEDULER SIMULATION
  // ============================================================

  // --- Cluster Definition ---
  var nodes = [
    { name: "node-1", zone: "zone-a", cpu: 4000, mem: 8192, labels: ["gpu"], taints: [], usedCpu: 1200, usedMem: 2048, pods: [{ name: "ml-train", cpu: 800, mem: 1024, type: "web", priority: 1 }, { name: "api-srv", cpu: 400, mem: 1024, type: "web", priority: 1 }] },
    { name: "node-2", zone: "zone-a", cpu: 2000, mem: 4096, labels: [], taints: ["dedicated=ml:NoSchedule"], usedCpu: 500, usedMem: 1024, pods: [{ name: "ml-infer", cpu: 500, mem: 1024, type: "db", priority: 0 }] },
    { name: "node-3", zone: "zone-b", cpu: 4000, mem: 8192, labels: [], taints: [], usedCpu: 3200, usedMem: 6144, pods: [{ name: "web-1", cpu: 1000, mem: 2048, type: "web", priority: 1 }, { name: "web-2", cpu: 1000, mem: 2048, type: "web", priority: 0 }, { name: "cache", cpu: 1200, mem: 2048, type: "db", priority: 0 }] },
    { name: "node-4", zone: "zone-b", cpu: 8000, mem: 16384, labels: ["gpu"], taints: ["spot=true:NoSchedule"], usedCpu: 2000, usedMem: 4096, pods: [{ name: "batch-1", cpu: 1000, mem: 2048, type: "db", priority: 0 }, { name: "batch-2", cpu: 1000, mem: 2048, type: "db", priority: 1 }] },
    { name: "node-5", zone: "zone-c", cpu: 2000, mem: 4096, labels: [], taints: [], usedCpu: 400, usedMem: 512, pods: [{ name: "monitor", cpu: 400, mem: 512, type: "web", priority: 0 }] }
  ];

  var origNodes = JSON.parse(JSON.stringify(nodes));

  function resetNodes() {
    nodes = JSON.parse(JSON.stringify(origNodes));
  }

  // --- Render Nodes ---
  function renderNodes(filterResults, scoreResults, selectedIdx) {
    var grid = document.getElementById("nodesGrid");
    var html = "";
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      var cls = "node-card";
      if (filterResults && !filterResults[i]) cls += " filtered-out";
      else if (selectedIdx === i) cls += " selected";
      else if (scoreResults && scoreResults[i] !== undefined) cls += " scoring";

      var cpuPct = Math.round((n.usedCpu / n.cpu) * 100);
      var memPct = Math.round((n.usedMem / n.mem) * 100);

      html += '<div class="' + cls + '">';
      html += '<div class="node-score">' + (scoreResults && scoreResults[i] !== undefined ? scoreResults[i] : "") + '</div>';
      html += '<div class="node-name">' + n.name + '</div>';
      html += '<div class="node-zone">' + n.zone + '</div>';
      html += '<div class="node-labels">';
      for (var l = 0; l < n.labels.length; l++) {
        html += '<span class="node-label-tag">' + n.labels[l] + '</span>';
      }
      for (var t = 0; t < n.taints.length; t++) {
        html += '<span class="node-label-tag taint">⚠ ' + n.taints[t].split(":")[0] + '</span>';
      }
      html += '</div>';
      html += '<div class="node-resources">';
      html += 'CPU: ' + n.usedCpu + 'm / ' + n.cpu + 'm';
      html += '<div class="resource-bar"><div class="resource-bar-fill cpu" style="width:' + cpuPct + '%"></div></div>';
      html += 'Mem: ' + n.usedMem + 'Mi / ' + n.mem + 'Mi';
      html += '<div class="resource-bar"><div class="resource-bar-fill mem" style="width:' + memPct + '%"></div></div>';
      html += '</div>';
      html += '<div class="node-pods">';
      for (var p = 0; p < n.pods.length; p++) {
        var podCls = "pod-chip";
        if (n.pods[p].isNew) podCls += " new-pod";
        html += '<span class="' + podCls + '">' + n.pods[p].name + '</span>';
      }
      html += '</div>';
      html += '</div>';
    }
    grid.innerHTML = html;
  }

  // --- Log ---
  var logEl = document.getElementById("schedLog");

  function clearLog() {
    logEl.innerHTML = '<div class="log-empty">Configure a Pod and click "Schedule Pod"...</div>';
  }

  function addLog(msg, cls) {
    if (logEl.querySelector(".log-empty")) logEl.innerHTML = "";
    var div = document.createElement("div");
    div.className = "log-line " + (cls || "");
    div.textContent = msg;
    logEl.appendChild(div);
    logEl.scrollTop = logEl.scrollHeight;
  }

  // --- Pipeline highlight ---
  function setPipelineStage(stage) {
    var stages = ["pipeFilter", "pipeScore", "pipeBind"];
    for (var s = 0; s < stages.length; s++) {
      var el = document.getElementById(stages[s]);
      el.classList.remove("active", "done");
      if (s < stage) el.classList.add("done");
      if (s === stage) el.classList.add("active");
    }
  }

  function clearPipeline() {
    var stages = ["pipeFilter", "pipeScore", "pipeBind"];
    for (var s = 0; s < stages.length; s++) {
      document.getElementById(stages[s]).classList.remove("active", "done");
    }
  }

  // --- Scheduler ---
  function schedulePod() {
    var cpuReq = parseInt(document.getElementById("cpuReqSlider").value);
    var memReq = parseInt(document.getElementById("memReqSlider").value);
    var prioVal = parseInt(document.getElementById("prioritySlider").value);
    var affinity = document.getElementById("affinitySelect").value;
    var toleration = document.getElementById("tolerationSelect").value;
    var antiAff = document.getElementById("antiAffinitySelect").value;

    var prioNames = ["Low", "Medium", "High"];
    var prioName = prioNames[prioVal];

    clearLog();
    addLog("== Scheduling Pod: cpu=" + cpuReq + "m, mem=" + memReq + "Mi, priority=" + prioName + " ==", "info");

    var schedBtn = document.getElementById("scheduleBtn");
    schedBtn.disabled = true;

    // Phase 1: Filtering
    var filterResults = [];
    var delay = 0;

    setTimeout(function() {
      setPipelineStage(0);
      addLog("--- Phase 1: Filtering ---", "info");
    }, delay);
    delay += 400;

    for (var i = 0; i < nodes.length; i++) {
      (function(idx) {
        setTimeout(function() {
          var n = nodes[idx];
          var pass = true;
          var reason = "";

          // Resource check
          if (n.cpu - n.usedCpu < cpuReq) {
            pass = false;
            reason = "insufficient CPU (free: " + (n.cpu - n.usedCpu) + "m, need: " + cpuReq + "m)";
          } else if (n.mem - n.usedMem < memReq) {
            pass = false;
            reason = "insufficient memory (free: " + (n.mem - n.usedMem) + "Mi, need: " + memReq + "Mi)";
          }

          // Taint check
          if (pass && n.taints.length > 0) {
            var tolerated = false;
            for (var t = 0; t < n.taints.length; t++) {
              var taintKey = n.taints[t].split("=")[0];
              if (toleration === taintKey) { tolerated = true; break; }
            }
            if (!tolerated) {
              pass = false;
              reason = "taint " + n.taints[0].split(":")[0] + " not tolerated";
            }
          }

          // Hard node affinity (gpu requirement)
          if (pass && affinity === "gpu") {
            if (n.labels.indexOf("gpu") === -1) {
              pass = false;
              reason = "missing label: gpu";
            }
          }

          // Hard anti-affinity
          if (pass && antiAff !== "none") {
            for (var p = 0; p < n.pods.length; p++) {
              if (n.pods[p].type === antiAff) {
                pass = false;
                reason = "anti-affinity: has " + antiAff + " pod (" + n.pods[p].name + ")";
                break;
              }
            }
          }

          filterResults[idx] = pass;
          if (pass) {
            addLog("  ✅ " + n.name + " — passed all predicates", "pass");
          } else {
            addLog("  ❌ " + n.name + " — filtered: " + reason, "filter");
          }
          renderNodes(filterResults, null, -1);
        }, delay);
        delay += 350;
      })(i);
    }

    // Phase 2: Scoring
    var scoreResults = [];
    setTimeout(function() {
      setPipelineStage(1);
      addLog("--- Phase 2: Scoring ---", "info");

      var survivors = [];
      for (var i = 0; i < nodes.length; i++) {
        if (filterResults[i]) survivors.push(i);
      }

      if (survivors.length === 0) {
        addLog("  ⚠️ No nodes passed filtering! Pod stays Pending.", "filter");
        clearPipeline();
        schedBtn.disabled = false;
        return;
      }

      var scoringDelay = 0;
      for (var s = 0; s < survivors.length; s++) {
        (function(idx) {
          setTimeout(function() {
            var n = nodes[idx];

            // LeastRequested score
            var cpuFree = (n.cpu - n.usedCpu - cpuReq) / n.cpu;
            var memFree = (n.mem - n.usedMem - memReq) / n.mem;
            var leastReq = Math.round(((cpuFree + memFree) / 2) * 100);

            // BalancedAllocation score
            var cpuRatio = (n.usedCpu + cpuReq) / n.cpu;
            var memRatio = (n.usedMem + memReq) / n.mem;
            var balanced = Math.round((1 - Math.abs(cpuRatio - memRatio)) * 100);

            // Zone affinity bonus
            var affinityScore = 0;
            if (affinity === "zone-a" && n.zone === "zone-a") affinityScore = 20;
            if (affinity === "zone-b" && n.zone === "zone-b") affinityScore = 20;

            var total = Math.max(0, Math.min(100, Math.round(leastReq * 0.5 + balanced * 0.3 + affinityScore * 0.2 + affinityScore)));
            scoreResults[idx] = total;

            addLog("  📊 " + n.name + ": LeastReq=" + leastReq + " Balanced=" + balanced + " Affinity=+" + affinityScore + " → Total=" + total, "score");
            renderNodes(filterResults, scoreResults, -1);
          }, scoringDelay);
          scoringDelay += 400;
        })(survivors[s]);
      }

      // Phase 3: Binding
      setTimeout(function() {
        setPipelineStage(2);
        addLog("--- Phase 3: Binding ---", "info");

        var bestIdx = -1;
        var bestScore = -1;
        for (var i = 0; i < nodes.length; i++) {
          if (scoreResults[i] !== undefined && scoreResults[i] > bestScore) {
            bestScore = scoreResults[i];
            bestIdx = i;
          }
        }

        if (bestIdx >= 0) {
          var podName = "new-pod-" + Math.floor(Math.random() * 1000);
          nodes[bestIdx].pods.push({ name: podName, cpu: cpuReq, mem: memReq, type: "web", priority: prioVal, isNew: true });
          nodes[bestIdx].usedCpu += cpuReq;
          nodes[bestIdx].usedMem += memReq;
          addLog("  🔗 Bound to " + nodes[bestIdx].name + " (score: " + bestScore + ")", "bind");
          renderNodes(filterResults, scoreResults, bestIdx);
        }

        setTimeout(function() {
          clearPipeline();
          schedBtn.disabled = false;
        }, 2000);
      }, scoringDelay + 300);
    }, delay + 200);
  }

  // --- Slider Labels ---
  document.getElementById("cpuReqSlider").addEventListener("input", function() {
    document.getElementById("cpuReqLabel").textContent = this.value + "m";
  });
  document.getElementById("memReqSlider").addEventListener("input", function() {
    document.getElementById("memReqLabel").textContent = this.value + "Mi";
  });
  document.getElementById("prioritySlider").addEventListener("input", function() {
    var names = ["Low", "Medium", "High"];
    document.getElementById("priorityLabel").textContent = names[parseInt(this.value)];
  });
  document.getElementById("skewSlider").addEventListener("input", function() {
    document.getElementById("skewLabel").textContent = this.value;
  });

  // --- Schedule Button ---
  document.getElementById("scheduleBtn").addEventListener("click", schedulePod);

  // --- Reset ---
  document.getElementById("resetBtn").addEventListener("click", function() {
    resetNodes();
    clearLog();
    clearPipeline();
    renderNodes(null, null, -1);
    document.getElementById("scheduleBtn").disabled = false;
  });

  // --- Preemption Demo ---
  var preemptPods = [
    { name: "batch-low", cpu: 1000, priority: 0, cls: "low" },
    { name: "web-med", cpu: 1000, priority: 1, cls: "medium" },
    { name: "cache-low", cpu: 1000, priority: 0, cls: "low" },
    { name: "api-med", cpu: 500, priority: 1, cls: "medium" }
  ];
  var preemptOrigPods = JSON.parse(JSON.stringify(preemptPods));
  var preemptUsed = 3500;
  var preemptTotal = 4000;

  function renderPreemption() {
    var el = document.getElementById("preemptPods");
    var html = "";
    for (var i = 0; i < preemptPods.length; i++) {
      html += '<span class="preempt-pod ' + preemptPods[i].cls + '">' + preemptPods[i].name + ' (' + preemptPods[i].cpu + 'm, pri=' + preemptPods[i].priority + ')</span>';
    }
    el.innerHTML = html;
    var pct = Math.round((preemptUsed / preemptTotal) * 100);
    document.getElementById("preemptBarFill").style.width = pct + "%";
  }

  document.getElementById("preemptBtn").addEventListener("click", function() {
    var logEl2 = document.getElementById("preemptLog");
    var btn = document.getElementById("preemptBtn");
    btn.disabled = true;
    logEl2.innerHTML = '<span style="color:#f87171;">⚡ High-priority Pod needs 1500m CPU. Current free: ' + (preemptTotal - preemptUsed) + 'm</span>';

    setTimeout(function() {
      // Find low-priority pods to evict
      var freed = 0;
      var toEvict = [];
      // Sort by priority ascending
      var sorted = preemptPods.slice().sort(function(a, b) { return a.priority - b.priority; });
      for (var i = 0; i < sorted.length && freed < 1500 - (preemptTotal - preemptUsed); i++) {
        if (sorted[i].priority < 2) {
          toEvict.push(sorted[i].name);
          freed += sorted[i].cpu;
        }
      }

      logEl2.innerHTML += '<br><span style="color:#fbbf24;">🔍 Need to free ' + (1500 - (preemptTotal - preemptUsed)) + 'm more. Evicting: ' + toEvict.join(", ") + '</span>';

      setTimeout(function() {
        // Evict pods
        for (var e = 0; e < toEvict.length; e++) {
          for (var p = preemptPods.length - 1; p >= 0; p--) {
            if (preemptPods[p].name === toEvict[e]) {
              preemptUsed -= preemptPods[p].cpu;
              preemptPods.splice(p, 1);
              break;
            }
          }
        }
        renderPreemption();
        logEl2.innerHTML += '<br><span style="color:#4ade80;">✅ Evicted ' + toEvict.length + ' low-priority pods. Free: ' + (preemptTotal - preemptUsed) + 'm</span>';

        setTimeout(function() {
          preemptPods.push({ name: "critical-svc", cpu: 1500, priority: 2, cls: "high" });
          preemptUsed += 1500;
          renderPreemption();
          logEl2.innerHTML += '<br><span style="color:#60a5fa;">🔗 High-priority Pod "critical-svc" scheduled!</span>';
          btn.disabled = false;
        }, 800);
      }, 800);
    }, 600);
  });

  document.getElementById("preemptResetBtn").addEventListener("click", function() {
    preemptPods = JSON.parse(JSON.stringify(preemptOrigPods));
    preemptUsed = 3500;
    renderPreemption();
    document.getElementById("preemptLog").innerHTML = "";
    document.getElementById("preemptBtn").disabled = false;
  });

  // --- Topology Spread ---
  var topoZones = [
    { name: "zone-a", pods: 0 },
    { name: "zone-b", pods: 0 },
    { name: "zone-c", pods: 0 }
  ];
  var topoCounter = 0;

  function renderTopo() {
    var el = document.getElementById("topoZones");
    var html = "";
    for (var z = 0; z < topoZones.length; z++) {
      var zone = topoZones[z];
      html += '<div class="topo-zone" id="topoZone' + z + '">';
      html += '<div class="topo-zone-name">' + zone.name + '</div>';
      html += '<div class="topo-zone-count">' + zone.pods + ' pods</div>';
      html += '<div class="topo-pods">';
      for (var p = 0; p < zone.pods; p++) {
        html += '<div class="topo-pod">☸</div>';
      }
      html += '</div></div>';
    }
    el.innerHTML = html;
  }

  function addTopoReplica() {
    var maxSkew = parseInt(document.getElementById("skewSlider").value);
    // Find zone with minimum pods
    var minPods = Infinity;
    for (var z = 0; z < topoZones.length; z++) {
      if (topoZones[z].pods < minPods) minPods = topoZones[z].pods;
    }

    // Candidates: zones where adding wouldn't violate maxSkew
    var candidates = [];
    for (var z = 0; z < topoZones.length; z++) {
      if (topoZones[z].pods - minPods < maxSkew || topoZones[z].pods === minPods) {
        candidates.push(z);
      }
    }

    // Prefer zone with fewest pods among candidates
    candidates.sort(function(a, b) { return topoZones[a].pods - topoZones[b].pods; });

    // Among tied candidates, pick randomly
    var minCandPods = topoZones[candidates[0]].pods;
    var tied = candidates.filter(function(c) { return topoZones[c].pods === minCandPods; });
    var chosen = tied[Math.floor(Math.random() * tied.length)];

    topoZones[chosen].pods++;
    topoCounter++;
    renderTopo();

    // Highlight the receiving zone
    var zoneEl = document.getElementById("topoZone" + chosen);
    if (zoneEl) {
      zoneEl.classList.add("receiving");
      setTimeout(function() { zoneEl.classList.remove("receiving"); }, 500);
    }
  }

  document.getElementById("topoAddBtn").addEventListener("click", addTopoReplica);

  document.getElementById("topoAdd3Btn").addEventListener("click", function() {
    addTopoReplica();
    setTimeout(addTopoReplica, 300);
    setTimeout(addTopoReplica, 600);
  });

  document.getElementById("topoResetBtn").addEventListener("click", function() {
    for (var z = 0; z < topoZones.length; z++) topoZones[z].pods = 0;
    topoCounter = 0;
    renderTopo();
  });

  // --- Init ---
  renderNodes(null, null, -1);
  renderPreemption();
  renderTopo();
</script>
