  }

  .highlight-card {
    border-color: rgba(96,165,250,0.3);
    background: linear-gradient(135deg, rgba(96,165,250,0.08), rgba(167,139,250,0.04));
  }

  /* Footer */
  .viz-footer {
    text-align: center;
    color: #666;
    font-size: 0.9rem;
    padding: 20px 0;
    border-top: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 30px;
  }

  .viz-footer a { color: #60a5fa; }

  .share-buttons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .share-buttons span { color: #666; }

  .share-btn {
    padding: 10px 20px;
    background: rgba(255,255,255,0.1);
    border-radius: 8px;
    color: #fff;
    font-size: 0.9rem;
    transition: background 0.2s;
  }

  .share-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  @media (max-width: 768px) {
    .viz-header h1 { font-size: 1.8rem; }
