    .webhook-demo { grid-template-columns: 1fr; }
    .pipeline { flex-direction: column; }
    .pipeline-arrow { transform: rotate(90deg); }
    .explain-grid { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  // ============================================================
  // RBAC & ADMISSION CONTROL INTERACTIVE
  // ============================================================

  // --- RBAC Diagram Hover ---
  (function() {
    var subjects = document.querySelectorAll('.rbac-item.subject');
    var bindings = document.querySelectorAll('.rbac-item.binding');
    var roles = document.querySelectorAll('.rbac-item.role');
    var allItems = document.querySelectorAll('.rbac-item');
    var infoEl = document.getElementById('rbacInfo');

    function clearHighlights() {
      allItems.forEach(function(el) {
        el.classList.remove('highlighted', 'dimmed');
      });
      infoEl.innerHTML = '<p>Hover over any subject, binding, or role to see connections highlighted.</p>';
    }

    function dimAll() {
      allItems.forEach(function(el) { el.classList.add('dimmed'); });
    }

    subjects.forEach(function(s) {
      s.addEventListener('mouseenter', function() {
        var sid = s.getAttribute('data-id');
        dimAll();
        s.classList.remove('dimmed');
        s.classList.add('highlighted');
        bindings.forEach(function(b) {
          if (b.getAttribute('data-from') === sid) {
            b.classList.remove('dimmed');
            b.classList.add('highlighted');
            var rid = b.getAttribute('data-to');
            roles.forEach(function(r) {
              if (r.getAttribute('data-id') === rid) {
                r.classList.remove('dimmed');
                r.classList.add('highlighted');
              }
            });
          }
        });
      });
      s.addEventListener('mouseleave', clearHighlights);
    });

    roles.forEach(function(r) {
      r.addEventListener('mouseenter', function() {
        var rid = r.getAttribute('data-id');
        dimAll();
        r.classList.remove('dimmed');
        r.classList.add('highlighted');
        bindings.forEach(function(b) {
          if (b.getAttribute('data-to') === rid) {
            b.classList.remove('dimmed');
            b.classList.add('highlighted');
            var sid = b.getAttribute('data-from');
            subjects.forEach(function(s2) {
              if (s2.getAttribute('data-id') === sid) {
                s2.classList.remove('dimmed');
                s2.classList.add('highlighted');
              }
            });
          }
        });
      });
      r.addEventListener('mouseleave', clearHighlights);
    });

    bindings.forEach(function(b) {
      b.addEventListener('mouseenter', function() {
        dimAll();
        b.classList.remove('dimmed');
        b.classList.add('highlighted');
        var sid = b.getAttribute('data-from');
        var rid = b.getAttribute('data-to');
        subjects.forEach(function(s2) {
          if (s2.getAttribute('data-id') === sid) { s2.classList.remove('dimmed'); s2.classList.add('highlighted'); }
        });
        roles.forEach(function(r2) {
          if (r2.getAttribute('data-id') === rid) { r2.classList.remove('dimmed'); r2.classList.add('highlighted'); }
        });
      });
      b.addEventListener('mouseleave', clearHighlights);
    });
  })();

  // --- Policy Builder ---
  (function() {
    var roleTypeEl = document.getElementById('roleType');
    var nsGroupEl = document.getElementById('nsGroup');
    var roleNsEl = document.getElementById('roleNs');
    var apiGroupEl = document.getElementById('apiGroup');
    var yamlEl = document.getElementById('yamlPreview');
    var testEl = document.getElementById('testRequests');

    var testCases = [
      { verb: 'get', resource: 'pods', ns: 'default' },
      { verb: 'list', resource: 'pods', ns: 'default' },
      { verb: 'create', resource: 'pods', ns: 'default' },
      { verb: 'delete', resource: 'pods', ns: 'default' },
      { verb: 'get', resource: 'secrets', ns: 'default' },
      { verb: 'list', resource: 'deployments', ns: 'default' },
      { verb: 'create', resource: 'deployments', ns: 'production' },
      { verb: 'get', resource: 'nodes', ns: '' },
      { verb: 'delete', resource: 'namespaces', ns: '' },
      { verb: 'get', resource: 'configmaps', ns: 'kube-system' },
    ];

    function getSelectedValues(containerId) {
      var checks = document.querySelectorAll('#' + containerId + ' input[type="checkbox"]');
      var vals = [];
      checks.forEach(function(c) { if (c.checked) vals.push(c.value); });
      return vals;
    }

    function updatePolicy() {
      var type = roleTypeEl.value;
      var ns = roleNsEl.value;
      var group = apiGroupEl.value;
      var resources = getSelectedValues('resourceChecks');
      var verbs = getSelectedValues('verbChecks');

      nsGroupEl.style.display = type === 'Role' ? 'block' : 'none';

      // YAML preview
      var yaml = 'apiVersion: rbac.authorization.k8s.io/v1\n';
      yaml += 'kind: ' + type + '\n';
      yaml += 'metadata:\n';
      yaml += '  name: custom-role\n';
      if (type === 'Role') yaml += '  namespace: ' + ns + '\n';
      yaml += 'rules:\n';
      yaml += '- apiGroups: ["' + group + '"]\n';
      yaml += '  resources: [' + resources.map(function(r) { return '"' + r + '"'; }).join(', ') + ']\n';
      yaml += '  verbs: [' + verbs.map(function(v) { return '"' + v + '"'; }).join(', ') + ']';
      yamlEl.textContent = yaml;

      // Evaluate test requests
      var html = '';
      testCases.forEach(function(tc) {
        var allowed = false;
        var resourceMatch = resources.indexOf(tc.resource) !== -1;
        var verbMatch = verbs.indexOf(tc.verb) !== -1;

        if (resourceMatch && verbMatch) {
          if (type === 'ClusterRole') {
            allowed = true;
          } else {
            allowed = tc.ns === ns;
          }
        }

        var cls = allowed ? 'allowed' : 'denied';
        var result = allowed ? '✅ ALLOW' : '❌ DENY';
        var nsLabel = tc.ns ? tc.ns : 'cluster';
        html += '<div class="test-req ' + cls + '">';
        html += '<span class="req-desc">' + tc.verb + ' ' + tc.resource + ' [' + nsLabel + ']</span>';
        html += '<span class="req-result">' + result + '</span>';
        html += '</div>';
      });
      testEl.innerHTML = html;
    }

    roleTypeEl.addEventListener('change', updatePolicy);
    roleNsEl.addEventListener('change', updatePolicy);
    apiGroupEl.addEventListener('change', updatePolicy);
    document.querySelectorAll('#resourceChecks input, #verbChecks input').forEach(function(c) {
      c.addEventListener('change', updatePolicy);
    });

    // Custom request
    document.getElementById('addCustomReq').addEventListener('click', function() {
      var form = document.getElementById('customReqForm');
      form.style.display = form.style.display === 'none' ? 'block' : 'none';
    });

    document.getElementById('submitCustomReq').addEventListener('click', function() {
      var verb = document.getElementById('customVerb').value;
      var resource = document.getElementById('customResource').value.trim().toLowerCase();
      var ns = document.getElementById('customNs').value.trim();
      if (!resource) return;
      testCases.push({ verb: verb, resource: resource, ns: ns });
      updatePolicy();
      document.getElementById('customReqForm').style.display = 'none';
    });

    updatePolicy();
  })();

  // --- Admission Webhook Demo ---
  (function() {
    var stages = ['whIncoming', 'whMutating', 'whValidating', 'whResult'];

    function clearStages() {
      stages.forEach(function(id) {
        var el = document.getElementById(id);
        el.classList.remove('active', 'done', 'rejected');
        var detail = document.getElementById(id + 'Detail');
        if (detail) detail.textContent = '';
      });
    }

    function setStage(id, cls, detail) {
      var el = document.getElementById(id);
      el.classList.add(cls);
      var detailEl = document.getElementById(id + 'Detail');
      if (detailEl && detail) detailEl.textContent = detail;
    }

    // Pipeline animation for admission
    var pipeStages = ['pipeAuth', 'pipeAuthz', 'pipeMutate', 'pipeValidate', 'pipeEtcd'];

    function clearPipeline() {
      pipeStages.forEach(function(id) {
        document.getElementById(id).classList.remove('active', 'done', 'rejected');
      });
    }

    document.getElementById('sendAdmissionBtn').addEventListener('click', function() {
      var btn = this;
      btn.disabled = true;
      clearStages();
      clearPipeline();

      var injectSidecar = document.getElementById('toggleMutating').checked;
      var addLabels = document.getElementById('toggleLabels').checked;
      var noLatest = document.getElementById('togglePolicy').checked;
      var requireLimits = document.getElementById('toggleLimits').checked;
      var imageTag = document.getElementById('podImageTag').value;
      var hasLimits = document.getElementById('podLimits').value === 'yes';

      var mutations = [];
      var rejections = [];

      // Step 1: Incoming
      setTimeout(function() {
        document.getElementById('pipeAuth').classList.add('done');
        document.getElementById('pipeAuthz').classList.add('done');
        setStage('whIncoming', 'active', 'Pod nginx:' + imageTag + (hasLimits ? ' (limits set)' : ' (no limits)'));
      }, 300);

      // Step 2: Mutating
      setTimeout(function() {
        setStage('whIncoming', 'done', 'Pod nginx:' + imageTag);
        document.getElementById('pipeMutate').classList.add('active');
        setStage('whMutating', 'active', 'Processing...');
      }, 900);

      setTimeout(function() {
        if (injectSidecar) mutations.push('+sidecar container');
        if (addLabels) mutations.push('+labels: app=nginx, env=prod');
        var mutateMsg = mutations.length > 0 ? 'Mutated: ' + mutations.join('; ') : 'No mutations applied';
        setStage('whMutating', 'done', mutateMsg);
        document.getElementById('whMutating').classList.remove('active');
        document.getElementById('pipeMutate').classList.remove('active');
        document.getElementById('pipeMutate').classList.add('done');
      }, 1600);

      // Step 3: Validating
      setTimeout(function() {
        document.getElementById('pipeValidate').classList.add('active');
        setStage('whValidating', 'active', 'Checking policies...');
      }, 2100);

      setTimeout(function() {
        if (noLatest && imageTag === 'latest') rejections.push('Image tag :latest not allowed');
        if (requireLimits && !hasLimits) rejections.push('Resource limits required');

        var rejected = rejections.length > 0;
        document.getElementById('pipeValidate').classList.remove('active');

        if (rejected) {
          setStage('whValidating', 'rejected', 'REJECTED: ' + rejections.join('; '));
          document.getElementById('pipeValidate').classList.add('rejected');
          setStage('whResult', 'rejected', '❌ Request denied by admission webhook');
        } else {
          setStage('whValidating', 'done', 'All validations passed');
          document.getElementById('pipeValidate').classList.add('done');
          document.getElementById('pipeEtcd').classList.add('done');
          setStage('whResult', 'done', '✅ Pod created and persisted to etcd');
        }

        btn.disabled = false;
      }, 2800);
    });

    document.getElementById('resetAdmissionBtn').addEventListener('click', function() {
      clearStages();
      clearPipeline();
      document.getElementById('sendAdmissionBtn').disabled = false;
    });
  })();
</script>
