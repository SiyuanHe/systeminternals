  .explain-card h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: 10px; color: #fff; }
  .explain-card p { font-size: 0.95rem; color: #aaa; line-height: 1.7; }
  .explain-card strong { color: #fff; }
  .explain-card em { color: #60a5fa; font-style: normal; }
  .explain-card code {
    background: rgba(0,0,0,0.3);
    padding: 2px 6px;
    border-radius: 4px;
