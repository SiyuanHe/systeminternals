---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="RBAC & Admission Control" 
  description="Interactive visualization of Kubernetes RBAC roles, bindings, and admission webhook pipeline"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "Kubernetes", href: "/kubernetes/" },
    { label: "RBAC & Admission Control", href: "/kubernetes/rbac/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>☸️ RBAC & Admission Control</h1>
      <p class="subtitle">Roles, Bindings &amp; Webhooks — Who Can Do What in Your Cluster</p>
    </header>

    <!-- Overview -->
    <section class="overview-section">
      <div class="overview-card">
        <p>
          Every API request to Kubernetes passes through <strong>Authentication</strong> (who are you?),
          <strong>Authorization</strong> (are you allowed?), and <strong>Admission Control</strong>
          (should we modify or reject this?). <em>RBAC</em> (Role-Based Access Control) is the standard
          authorization module. It uses <strong>Roles</strong> and <strong>ClusterRoles</strong> to define
          permissions, and <strong>RoleBindings</strong> / <strong>ClusterRoleBindings</strong> to grant
          them to users or service accounts. After authorization, <em>admission webhooks</em> can
          mutate or validate the request before it's persisted to etcd.
        </p>
      </div>
    </section>

    <!-- API Request Pipeline -->
    <section class="pipeline-section">
      <h2>🔀 API Request Pipeline</h2>
      <p class="section-desc">Every request passes through these gates before reaching etcd.</p>
      <div class="pipeline">
        <div class="pipeline-step" id="pipeAuth">
          <div class="pipe-icon">🔑</div>
          <div class="pipe-label">AuthN</div>
          <div class="pipe-desc">Who are you?</div>
        </div>
        <div class="pipeline-arrow">→</div>
        <div class="pipeline-step" id="pipeAuthz">
          <div class="pipe-icon">🛡️</div>
          <div class="pipe-label">AuthZ (RBAC)</div>
          <div class="pipe-desc">Are you allowed?</div>
        </div>
        <div class="pipeline-arrow">→</div>
        <div class="pipeline-step" id="pipeMutate">
          <div class="pipe-icon">✏️</div>
          <div class="pipe-label">Mutating</div>
          <div class="pipe-desc">Modify the request</div>
        </div>
        <div class="pipeline-arrow">→</div>
        <div class="pipeline-step" id="pipeValidate">
          <div class="pipe-icon">✅</div>
          <div class="pipe-label">Validating</div>
          <div class="pipe-desc">Final check</div>
        </div>
        <div class="pipeline-arrow">→</div>
        <div class="pipeline-step" id="pipeEtcd">
          <div class="pipe-icon">💾</div>
          <div class="pipe-label">etcd</div>
          <div class="pipe-desc">Persisted</div>
        </div>
      </div>
    </section>

    <!-- RBAC Visualization -->
    <section class="rbac-section">
      <h2>🛡️ RBAC Model</h2>
      <p class="section-desc">Roles define permissions. Bindings grant them to subjects.</p>

      <div class="rbac-diagram">
        <div class="rbac-column">
          <h3>👤 Subjects</h3>
          <div class="rbac-items" id="rbacSubjects">
            <div class="rbac-item subject" data-id="dev-alice">
              <span class="rbac-icon">👩‍💻</span> alice (developer)
            </div>
            <div class="rbac-item subject" data-id="admin-bob">
              <span class="rbac-icon">👨‍💼</span> bob (cluster-admin)
            </div>
            <div class="rbac-item subject" data-id="sa-monitoring">
              <span class="rbac-icon">🤖</span> SA: monitoring
            </div>
            <div class="rbac-item subject" data-id="sa-deploy">
              <span class="rbac-icon">🤖</span> SA: deploy-bot
            </div>
          </div>
        </div>

        <div class="rbac-column bindings-col">
          <h3>🔗 Bindings</h3>
          <div class="rbac-items" id="rbacBindings">
            <div class="rbac-item binding" data-from="dev-alice" data-to="role-dev">
              <span class="binding-type">RoleBinding</span>
              <span class="binding-ns">ns: default</span>
            </div>
            <div class="rbac-item binding" data-from="admin-bob" data-to="role-admin">
              <span class="binding-type">ClusterRoleBinding</span>
              <span class="binding-ns">cluster-wide</span>
            </div>
            <div class="rbac-item binding" data-from="sa-monitoring" data-to="role-readonly">
              <span class="binding-type">ClusterRoleBinding</span>
              <span class="binding-ns">cluster-wide</span>
            </div>
            <div class="rbac-item binding" data-from="sa-deploy" data-to="role-deploy">
              <span class="binding-type">RoleBinding</span>
              <span class="binding-ns">ns: production</span>
            </div>
          </div>
        </div>

        <div class="rbac-column">
          <h3>📋 Roles</h3>
          <div class="rbac-items" id="rbacRoles">
            <div class="rbac-item role" data-id="role-dev">
              <div class="role-name">developer (Role)</div>
              <div class="role-rules">pods: get, list, watch<br/>deployments: get, list<br/>services: get, list</div>
            </div>
            <div class="rbac-item role" data-id="role-admin">
              <div class="role-name">cluster-admin (CR)</div>
              <div class="role-rules">*: * (all resources, all verbs)</div>
            </div>
            <div class="rbac-item role" data-id="role-readonly">
              <div class="role-name">view (ClusterRole)</div>
              <div class="role-rules">most resources: get, list, watch</div>
            </div>
            <div class="rbac-item role" data-id="role-deploy">
              <div class="role-name">deployer (Role)</div>
              <div class="role-rules">deployments: get, list, create, update<br/>pods: get, list, delete<br/>services: get, list, create</div>
            </div>
          </div>
        </div>
      </div>

      <div class="rbac-hover-info" id="rbacInfo">
        <p>Hover over any subject, binding, or role to see connections highlighted.</p>
      </div>
    </section>

    <!-- Interactive Policy Builder -->
    <section class="builder-section">
      <h2>🔧 Interactive Policy Builder</h2>
      <p class="section-desc">Build an RBAC policy and test API requests against it.</p>

      <div class="builder-layout">
        <div class="builder-panel">
          <h3>Define a Role</h3>

          <div class="config-group">
            <label>Role Type</label>
            <select id="roleType" class="config-select">
              <option value="Role">Role (namespaced)</option>
              <option value="ClusterRole">ClusterRole (cluster-wide)</option>
            </select>
          </div>

          <div class="config-group" id="nsGroup">
            <label>Namespace</label>
            <select id="roleNs" class="config-select">
              <option value="default">default</option>
              <option value="production">production</option>
              <option value="kube-system">kube-system</option>
            </select>
          </div>

          <div class="config-group">
            <label>API Group</label>
            <select id="apiGroup" class="config-select">
              <option value="">core (v1)</option>
              <option value="apps">apps</option>
              <option value="batch">batch</option>
              <option value="networking.k8s.io">networking.k8s.io</option>
            </select>
          </div>

          <div class="config-group">
            <label>Resources (select multiple)</label>
            <div class="checkbox-group" id="resourceChecks">
              <label class="cb-label"><input type="checkbox" value="pods" checked> pods</label>
              <label class="cb-label"><input type="checkbox" value="services"> services</label>
              <label class="cb-label"><input type="checkbox" value="deployments"> deployments</label>
              <label class="cb-label"><input type="checkbox" value="configmaps"> configmaps</label>
              <label class="cb-label"><input type="checkbox" value="secrets"> secrets</label>
              <label class="cb-label"><input type="checkbox" value="namespaces"> namespaces</label>
              <label class="cb-label"><input type="checkbox" value="nodes"> nodes</label>
              <label class="cb-label"><input type="checkbox" value="ingresses"> ingresses</label>
            </div>
          </div>

          <div class="config-group">
            <label>Verbs (select multiple)</label>
            <div class="checkbox-group" id="verbChecks">
              <label class="cb-label"><input type="checkbox" value="get" checked> get</label>
              <label class="cb-label"><input type="checkbox" value="list" checked> list</label>
              <label class="cb-label"><input type="checkbox" value="watch"> watch</label>
              <label class="cb-label"><input type="checkbox" value="create"> create</label>
              <label class="cb-label"><input type="checkbox" value="update"> update</label>
              <label class="cb-label"><input type="checkbox" value="patch"> patch</label>
              <label class="cb-label"><input type="checkbox" value="delete"> delete</label>
            </div>
          </div>

          <div class="yaml-preview" id="yamlPreview"></div>
        </div>

        <div class="test-panel">
          <h3>Test API Requests</h3>
          <p class="test-desc">See which requests your policy allows or denies.</p>

          <div class="test-requests" id="testRequests">
            <!-- Rendered by JS -->
          </div>

          <button id="addCustomReq" class="action-btn primary-btn" style="margin-top:12px;">+ Custom Request</button>

          <div id="customReqForm" class="custom-form" style="display:none;">
            <div class="config-group">
              <label>Verb</label>
              <select id="customVerb" class="config-select">
                <option>get</option><option>list</option><option>watch</option>
                <option>create</option><option>update</option><option>patch</option><option>delete</option>
              </select>
            </div>
            <div class="config-group">
              <label>Resource</label>
              <input type="text" id="customResource" class="config-input" placeholder="e.g. pods" />
            </div>
            <div class="config-group">
              <label>Namespace</label>
              <input type="text" id="customNs" class="config-input" placeholder="e.g. default" />
            </div>
            <button id="submitCustomReq" class="action-btn election-btn">Test Request</button>
          </div>
        </div>
      </div>
    </section>

    <!-- Admission Webhook Flow -->
    <section class="webhook-section">
      <h2>🔗 Admission Webhook Flow</h2>
      <p class="section-desc">After RBAC authorization, admission controllers can mutate or reject requests.</p>

      <div class="webhook-demo">
        <div class="webhook-config">
          <h3>Webhook Configuration</h3>

          <div class="webhook-toggle">
            <label class="toggle-label">
              <input type="checkbox" id="toggleMutating" checked>
              <span class="toggle-text">Mutating: Inject sidecar</span>
            </label>
          </div>
          <div class="webhook-toggle">
            <label class="toggle-label">
              <input type="checkbox" id="toggleLabels" checked>
              <span class="toggle-text">Mutating: Add default labels</span>
            </label>
          </div>
          <div class="webhook-toggle">
            <label class="toggle-label">
              <input type="checkbox" id="togglePolicy">
              <span class="toggle-text">Validating: No 'latest' tag</span>
            </label>
          </div>
          <div class="webhook-toggle">
            <label class="toggle-label">
              <input type="checkbox" id="toggleLimits" checked>
              <span class="toggle-text">Validating: Require resource limits</span>
            </label>
          </div>

          <div class="config-group" style="margin-top:16px;">
            <label>Pod Image Tag</label>
            <select id="podImageTag" class="config-select">
              <option value="v1.2.3">nginx:v1.2.3</option>
              <option value="latest">nginx:latest</option>
            </select>
          </div>

          <div class="config-group">
            <label>Resource Limits Set?</label>
            <select id="podLimits" class="config-select">
              <option value="yes">Yes — cpu: 500m, memory: 256Mi</option>
              <option value="no">No limits defined</option>
            </select>
          </div>

          <button id="sendAdmissionBtn" class="action-btn chaos-btn">⚡ Submit Pod</button>
          <button id="resetAdmissionBtn" class="action-btn reset-btn">🔄 Reset</button>
        </div>

        <div class="webhook-flow">
          <div class="webhook-stages" id="webhookStages">
            <div class="wh-stage" id="whIncoming">
              <div class="wh-stage-icon">📨</div>
              <div class="wh-stage-label">Incoming Pod</div>
              <div class="wh-stage-detail" id="whIncomingDetail"></div>
            </div>
            <div class="wh-arrow">↓</div>
            <div class="wh-stage" id="whMutating">
              <div class="wh-stage-icon">✏️</div>
              <div class="wh-stage-label">Mutating Webhooks</div>
              <div class="wh-stage-detail" id="whMutatingDetail"></div>
            </div>
            <div class="wh-arrow">↓</div>
            <div class="wh-stage" id="whValidating">
              <div class="wh-stage-icon">✅</div>
              <div class="wh-stage-label">Validating Webhooks</div>
              <div class="wh-stage-detail" id="whValidatingDetail"></div>
            </div>
            <div class="wh-arrow">↓</div>
            <div class="wh-stage" id="whResult">
              <div class="wh-stage-icon">💾</div>
              <div class="wh-stage-label">Result</div>
              <div class="wh-stage-detail" id="whResultDetail"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Explainers -->
    <section class="explain-section">
      <h2>📖 Key Concepts</h2>
      <div class="explain-grid">
        <div class="explain-card">
          <h3>📋 Role vs ClusterRole</h3>
          <p>
            A <strong>Role</strong> grants permissions within a single <em>namespace</em>.
            A <strong>ClusterRole</strong> grants permissions cluster-wide — including
            non-namespaced resources like <code>nodes</code>, <code>namespaces</code>, and
            <code>persistentvolumes</code>.
          </p>
        </div>
        <div class="explain-card">
          <h3>🔗 RoleBinding vs ClusterRoleBinding</h3>
          <p>
            A <strong>RoleBinding</strong> connects a subject to a Role (or ClusterRole) within
            a namespace. A <strong>ClusterRoleBinding</strong> grants cluster-wide access.
            You can bind a ClusterRole with a RoleBinding to limit it to one namespace.
          </p>
        </div>
        <div class="explain-card highlight-card">
          <h3>🔑 Subjects</h3>
          <p>
            <strong>Users</strong> — identified by certificates or tokens (no User API object).<br/>
            <strong>Groups</strong> — logical groupings from your identity provider.<br/>
            <strong>ServiceAccounts</strong> — in-cluster identities for Pods, namespaced.
          </p>
        </div>
        <div class="explain-card">
          <h3>✏️ Mutating Admission</h3>
          <p>
            Mutating webhooks can <strong>modify</strong> the incoming object. Common uses:
            inject sidecar containers (Istio), add default labels, set resource defaults.
            They run <em>before</em> validating webhooks.
          </p>
        </div>
        <div class="explain-card">
          <h3>✅ Validating Admission</h3>
          <p>
            Validating webhooks can <strong>accept or reject</strong> but cannot modify.
            Common uses: enforce image policies (no <code>:latest</code>), require resource
            limits, block privileged containers.
          </p>
        </div>
        <div class="explain-card highlight-card">
          <h3>⚠️ Least Privilege</h3>
          <p>
            Always follow the principle of <strong>least privilege</strong>: grant only the
            permissions needed. Avoid <code>cluster-admin</code> for applications. Use
            namespaced Roles when possible. Audit with <code>kubectl auth can-i --list</code>.
          </p>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on the <a href="https://kubernetes.io/docs/reference/access-authn-authz/rbac/" target="_blank">Kubernetes RBAC Documentation</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share this visualization:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20Kubernetes%20RBAC%20%26%20Admission%20Control%20visualizer&url=https://systeminternals.dev/kubernetes/rbac/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/kubernetes/rbac/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/kubernetes/rbac/&t=Interactive%20Kubernetes%20RBAC%20Visualizer" target="_blank" class="share-btn">🟧 Hacker News</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .viz-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #60a5fa, #a78bfa, #f472b6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #888;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 12px;
  }

  .section-desc {
    color: #888;
    margin-bottom: 24px;
    font-size: 1rem;
  }

  /* Overview */
  .overview-section { margin-bottom: 50px; }

  .overview-card {
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.1), rgba(167, 139, 250, 0.05));
    border: 1px solid rgba(96, 165, 250, 0.3);
    border-radius: 16px;
    padding: 24px 28px;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #ccc;
  }

  .overview-card strong { color: #fff; }
  .overview-card em { color: #60a5fa; font-style: normal; font-weight: 500; }

  /* Pipeline */
  .pipeline-section { margin-bottom: 50px; }

  .pipeline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .pipeline-step {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 16px;
    padding: 20px 24px;
    text-align: center;
    transition: all 0.4s;
    min-width: 120px;
  }

  .pipeline-step.active {
    border-color: rgba(96,165,250,0.6);
    background: rgba(96,165,250,0.1);
    box-shadow: 0 0 30px rgba(96,165,250,0.2);
    transform: scale(1.05);
  }

  .pipeline-step.done {
    border-color: rgba(74,222,128,0.5);
    background: rgba(74,222,128,0.08);
  }

  .pipeline-step.rejected {
    border-color: rgba(239,68,68,0.6);
    background: rgba(239,68,68,0.1);
    box-shadow: 0 0 30px rgba(239,68,68,0.2);
  }

  .pipe-icon { font-size: 1.8rem; margin-bottom: 6px; }
  .pipe-label { font-size: 1rem; font-weight: 700; color: #fff; }
  .pipe-desc { font-size: 0.8rem; color: #888; margin-top: 4px; }

  .pipeline-arrow { font-size: 1.5rem; color: #555; font-weight: bold; }

  /* Action Buttons */
  .action-btn {
    padding: 10px 20px;
    border: none;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .action-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .primary-btn {
    background: linear-gradient(135deg, #60a5fa, #3b82f6);
    color: white;
  }

  .primary-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(59,130,246,0.4);
  }

  .election-btn {
    background: linear-gradient(135deg, #4ade80, #22c55e);
    color: white;
  }

  .election-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(34,197,94,0.4);
  }

  .chaos-btn {
    background: linear-gradient(135deg, #f472b6, #ef4444);
    color: white;
  }

  .chaos-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(239,68,68,0.4);
  }

  .reset-btn {
    background: rgba(255,255,255,0.1);
    color: #aaa;
  }

  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  /* RBAC Diagram */
  .rbac-section { margin-bottom: 50px; }

  .rbac-diagram {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
    margin-bottom: 16px;
  }

  .rbac-column h3 {
    font-size: 1rem;
    color: #fff;
    margin-bottom: 12px;
    text-align: center;
  }

  .rbac-items {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .rbac-item {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    padding: 12px 14px;
    transition: all 0.3s;
    cursor: pointer;
    font-size: 0.9rem;
    color: #ccc;
  }

  .rbac-item:hover, .rbac-item.highlighted {
    border-color: rgba(96,165,250,0.5);
    background: rgba(96,165,250,0.08);
  }

  .rbac-item.dimmed {
    opacity: 0.25;
  }

  .rbac-icon { margin-right: 6px; }

  .binding .binding-type {
    display: block;
    font-weight: 600;
    color: #a78bfa;
    font-size: 0.8rem;
  }

  .binding .binding-ns {
    font-size: 0.75rem;
    color: #888;
  }

  .role .role-name {
    font-weight: 600;
    color: #4ade80;
    font-size: 0.85rem;
    margin-bottom: 6px;
  }

  .role .role-rules {
    font-size: 0.75rem;
    color: #888;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    line-height: 1.5;
  }

  .rbac-hover-info {
    text-align: center;
    color: #555;
    font-size: 0.85rem;
    padding: 8px;
  }

  .rbac-hover-info p { margin: 0; }

  /* Policy Builder */
  .builder-section { margin-bottom: 50px; }

  .builder-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .builder-panel, .test-panel {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 20px;
  }

  .builder-panel h3, .test-panel h3 {
    font-size: 1rem;
    color: #fff;
    margin-bottom: 16px;
    font-weight: 600;
  }

  .config-group {
    margin-bottom: 14px;
  }

  .config-group label {
    display: block;
    font-size: 0.85rem;
    color: #aaa;
    margin-bottom: 6px;
  }

  .config-select, .config-input {
    width: 100%;
    padding: 8px 10px;
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    color: #ddd;
    font-size: 0.85rem;
  }

  .checkbox-group {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .cb-label {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.8rem;
    color: #aaa;
    background: rgba(0,0,0,0.3);
    padding: 4px 8px;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.2s;
  }

