<script>
  // Helper
  function addEvent(container, text, cls) {
    const el = document.createElement('div');
    el.className = 'event-entry ' + cls;
    el.textContent = `[${new Date().toISOString().slice(11,23)}] ${text}`;
    container.appendChild(el);
    container.scrollTop = container.scrollHeight;
  }

  // Chart Anatomy
  const chartInfoData = {
    'chart-yaml': { title: 'Chart.yaml', desc: 'The chart\'s metadata file. Contains name, version (the chart version), appVersion (the app it deploys), description, type (application or library), dependencies, maintainers, and keywords. This is the only required file — everything else is optional. The version field follows SemVer and determines how Helm resolves chart dependencies.' },
    'values-yaml': { title: 'values.yaml', desc: 'Default configuration values for the chart. Users override these with --set flags, -f custom-values.yaml, or environment-specific files. Every key here is accessible in templates as .Values.keyName. Good values.yaml files are well-commented and serve as documentation for the chart\'s configuration surface.' },
    'templates-dir': { title: 'templates/', desc: 'Contains Go template files that Helm renders into Kubernetes manifests. Files ending in .yaml or .yml are rendered; files starting with _ are helpers (not rendered directly). The rendering engine has access to .Values, .Release, .Chart, .Capabilities, and .Template built-in objects.' },
    'tpl-deploy': { title: 'templates/deployment.yaml', desc: 'A Go template that renders into a Kubernetes Deployment manifest. Typically parameterizes replicas, image, resources, env vars, probes, and affinity rules. Uses {{ include "chart.labels" . }} for consistent labeling across resources.' },
    'tpl-service': { title: 'templates/service.yaml', desc: 'Renders a Service manifest. Parameterizes type (ClusterIP/NodePort/LoadBalancer), port mappings, and annotations. Often conditionally includes cloud provider annotations for load balancer configuration.' },
    'tpl-ingress': { title: 'templates/ingress.yaml', desc: 'Often wrapped in {{ if .Values.ingress.enabled }} to be optional. Parameterizes hosts, paths, TLS configuration, and ingress class. One of the most complex templates due to API version differences between networking.k8s.io/v1 and v1beta1.' },
    'tpl-helpers': { title: 'templates/_helpers.tpl', desc: 'Defines reusable named templates (partials) with {{ define "name" }}. Common helpers: chart.name, chart.fullname, chart.labels, chart.selectorLabels. The underscore prefix tells Helm not to render this file as a manifest — it\'s only included by other templates.' },
    'tpl-notes': { title: 'templates/NOTES.txt', desc: 'A Go template rendered after install/upgrade and printed to the user. Typically shows how to access the application: port-forward commands, ingress URLs, or initial credentials. This is your chart\'s post-install README.' },
    'tpl-tests': { title: 'templates/tests/', desc: 'Contains Pod manifests annotated with "helm.sh/hook": test. Running helm test creates these pods and checks exit codes. Common tests: HTTP health check, database connectivity, config validation. Tests are deleted after completion by default.' },
    'charts-dir': { title: 'charts/', desc: 'Contains dependency charts as .tgz archives. When you declare dependencies in Chart.yaml and run helm dependency update, Helm downloads them here. Subcharts can be overridden via parent values using the subchart name as a key: subchart.key: value.' },
    'crds-dir': { title: 'crds/', desc: 'CRD manifests placed here are installed before any templates are rendered (since templates may create CRs that need the CRD first). CRDs in this directory are NOT templated — they\'re applied as-is. They\'re also never upgraded or deleted by Helm to prevent accidental data loss.' },
    'chart-lock': { title: 'Chart.lock', desc: 'Auto-generated lockfile from helm dependency update. Pins exact versions and digests of all dependencies, ensuring reproducible builds. Commit this to version control. Run helm dependency build to install from the lockfile without resolving.' }
  };

  document.querySelectorAll('.tree-item').forEach(el => {
    el.addEventListener('click', () => {
      document.querySelectorAll('.tree-item').forEach(t => t.classList.remove('highlight'));
      el.classList.add('highlight');
      const d = chartInfoData[el.dataset.item];
      if (d) {
        document.getElementById('chartInfo').innerHTML = `<div class="chart-info-title">${d.title}</div><div class="chart-info-desc">${d.desc}</div>`;
      }
    });
  });

  // Template Rendering
  function flashRendered(id) {
    const el = document.getElementById(id);
    el.classList.add('flash');
    setTimeout(() => el.classList.remove('flash'), 600);
  }

  function renderOutput() {
    const replicas = document.getElementById('valReplicas').textContent;
    const image = document.getElementById('valImage').textContent;
    const tag = document.getElementById('valTag').textContent;
    const port = document.getElementById('valPort').textContent;

    document.getElementById('outReplicas').textContent = replicas;
    document.getElementById('outImage').textContent = `${image}:${tag}`;
    document.getElementById('outPort').textContent = port;

    flashRendered('outReplicas');
    flashRendered('outImage');
    flashRendered('outPort');
  }

  document.getElementById('renderBtn').addEventListener('click', renderOutput);

  document.getElementById('setOverrideBtn').addEventListener('click', () => {
    document.getElementById('valTag').textContent = '2.0.0';
    renderOutput();
  });

  document.getElementById('resetTemplateBtn').addEventListener('click', () => {
    document.getElementById('valReplicas').textContent = '3';
    document.getElementById('valImage').textContent = 'nginx';
    document.getElementById('valTag').textContent = '1.25.3';
    document.getElementById('valSvcType').textContent = 'ClusterIP';
    document.getElementById('valPort').textContent = '80';
    renderOutput();
  });

  // Make editable values clickable
  document.querySelectorAll('.tpl-val.editable').forEach(el => {
    el.addEventListener('click', () => {
      const current = el.textContent;
      const input = prompt(`Enter new value for ${el.dataset.field}:`, current);
      if (input !== null && input !== '') {
        el.textContent = input;
        renderOutput();
      }
    });
  });

  // Go Template Patterns
  const patternData = {
    'if': { title: 'Conditionals', code: '{{ if .Values.ingress.enabled }}\napiVersion: networking.k8s.io/v1\nkind: Ingress\n...\n{{ end }}', desc: 'Conditionally include entire resources or blocks. Falsy values: false, 0, "", nil, empty collections. Use <code>{{ if and .Values.a .Values.b }}</code> for compound conditions. The <code>{{- if ... }}</code> syntax (note the dash) trims leading whitespace to keep YAML clean.' },
    'range': { title: 'Loops (range)', code: '{{ range .Values.ingress.hosts }}\n- host: {{ .host | quote }}\n  paths:\n  {{ range .paths }}\n  - path: {{ .path }}\n  {{ end }}\n{{ end }}', desc: 'Iterate over lists and maps. Inside range, the dot (.) is rebound to the current element. Use <code>{{ range $key, $val := .Values.env }}</code> for maps. <code>{{ range $i, $e := .Values.list }}</code> gives you the index.' },
    'with': { title: 'Scope (with)', code: '{{ with .Values.nodeSelector }}\nnodeSelector:\n  {{ toYaml . | nindent 2 }}\n{{ end }}', desc: 'Changes the scope of dot (.) to the specified object. If the value is falsy, the block is skipped entirely — so it doubles as a conditional. Use <code>{{ $.Values.x }}</code> to access the root scope from inside a with block.' },
    'include': { title: 'Named Templates (include)', code: '{{/* _helpers.tpl */}}\n{{ define "mychart.labels" }}\napp: {{ include "mychart.name" . }}\nrelease: {{ .Release.Name }}\n{{ end }}\n\n{{/* deployment.yaml */}}\nlabels:\n  {{ include "mychart.labels" . | nindent 4 }}', desc: 'Reusable template fragments defined with <code>{{ define }}</code> and called with <code>{{ include }}</code>. Unlike <code>{{ template }}</code>, include captures the output as a string so you can pipe it through functions like nindent. Always define helpers in _helpers.tpl.' },
    'toYaml': { title: 'YAML Helpers', code: 'resources:\n  {{ toYaml .Values.resources | nindent 2 }}\n\nannotations:\n  {{ include "mychart.annotations" . | nindent 4 }}', desc: '<code>toYaml</code> converts a Go object to YAML string. <code>nindent N</code> adds a newline then indents N spaces — essential for proper YAML formatting. <code>indent N</code> indents without the newline. <code>quote</code> wraps in double quotes. These are the most-used Helm template functions.' },
    'default': { title: 'Defaults & Coalesce', code: 'image: {{ .Values.image | default "nginx" }}\nreplicas: {{ .Values.replicas | default 1 }}\nname: {{ coalesce .Values.nameOverride .Chart.Name }}', desc: '<code>default</code> provides a fallback when the value is empty/nil. <code>coalesce</code> returns the first non-empty value from a list. <code>required "msg" .Values.x</code> fails the render if the value is missing — use it for values that must be set.' },
    'tpl': { title: 'Dynamic Templates (tpl)', code: '# values.yaml\nannotation: "app-{{ .Release.Name }}"\n\n# template\nannotations:\n  custom: {{ tpl .Values.annotation . }}', desc: '<code>tpl</code> renders a string as a Go template. This lets users put template expressions in their values.yaml. Powerful but dangerous — it executes arbitrary template code from user input. Use sparingly and document the supported expressions.' },
    'lookup': { title: 'Cluster Lookup', code: '{{ $secret := lookup "v1" "Secret" "default" "my-secret" }}\n{{ if $secret }}\n# Secret exists, use its data\n{{ end }}', desc: '<code>lookup</code> queries the Kubernetes API during rendering. Useful for conditional logic based on existing resources (e.g., don\'t create a Secret if one exists). Returns empty during helm template (no cluster access) — always guard with {{ if }}. Avoid in library charts.' }
  };

  document.querySelectorAll('.pattern-card').forEach(el => {
    el.addEventListener('click', () => {
      document.querySelectorAll('.pattern-card').forEach(c => c.classList.remove('active'));
      el.classList.add('active');
      const d = patternData[el.dataset.pattern];
      if (d) {
        document.getElementById('patternDetail').innerHTML = `<div class="pattern-detail-title">${d.title}</div><div class="pattern-detail-code">${d.code.replace(/\n/g, '<br/>')}</div><div class="pattern-detail-desc">${d.desc}</div>`;
      }
    });
  });

  // Release Simulator
  const relReplicasSlider = document.getElementById('relReplicasSlider');
  relReplicasSlider.addEventListener('input', () => document.getElementById('relReplicasLabel').textContent = relReplicasSlider.value);

  let revisions = [];
  let currentRevision = 0;

  function addRevision(chart, status, replicas) {
    currentRevision++;
    // Mark previous as superseded
    revisions.forEach(r => { if (r.status === 'deployed') r.status = 'superseded'; });
    revisions.push({ rev: currentRevision, chart: `mychart-${chart}`, status, replicas });
    renderRevisions();
  }

  function renderRevisions() {
    const container = document.getElementById('revisionHistory');
    container.innerHTML = '<div class="rev-header">Revision History</div>';
    revisions.forEach(r => {
      const cls = r.status === 'deployed' ? 'current' : 'superseded';
      container.innerHTML += `<div class="rev-entry ${cls}"><span class="rev-num">#${r.rev}</span><span class="rev-chart">${r.chart}</span><span class="rev-status ${r.status}">${r.status}</span><span style="color:#888;font-size:0.75rem">replicas: ${r.replicas}</span></div>`;
    });
  }

  document.getElementById('helmInstallBtn').addEventListener('click', async () => {
    if (currentRevision > 0) return;
    const events = document.getElementById('releaseEvents');
    const status = document.getElementById('relStatus');
    const chart = document.getElementById('chartVersion').value;
    const replicas = relReplicasSlider.value;

    status.textContent = 'Installing...';
    status.className = 'rel-status upgrading';
    addEvent(events, `helm install my-app mychart --version ${chart}`, 'info');
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, 'Rendering templates with merged values...', 'info');
    await new Promise(r => setTimeout(r, 300));
    addEvent(events, 'Running pre-install hooks...', 'info');
    await new Promise(r => setTimeout(r, 500));
    addEvent(events, 'Creating Deployment, Service, ConfigMap...', 'info');
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, `Storing release secret: sh.helm.release.v1.my-app.v1`, 'info');
    await new Promise(r => setTimeout(r, 300));
    addEvent(events, 'Running post-install hooks...', 'info');
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, 'Release "my-app" installed ✓', 'success');

    addRevision(chart, 'deployed', replicas);
    document.getElementById('relRevision').textContent = currentRevision;
    status.textContent = 'Deployed';
    status.className = 'rel-status deployed';

    document.getElementById('helmInstallBtn').disabled = true;
    document.getElementById('helmUpgradeBtn').disabled = false;
    document.getElementById('helmUninstallBtn').disabled = false;
  });

  document.getElementById('helmUpgradeBtn').addEventListener('click', async () => {
    if (currentRevision === 0) return;
    const events = document.getElementById('releaseEvents');
    const status = document.getElementById('relStatus');
    const chart = document.getElementById('chartVersion').value;
    const replicas = relReplicasSlider.value;

    status.textContent = 'Upgrading...';
    status.className = 'rel-status upgrading';
    addEvent(events, `helm upgrade my-app mychart --version ${chart} --set replicaCount=${replicas}`, 'info');
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, 'Computing 3-way merge diff...', 'info');
    await new Promise(r => setTimeout(r, 300));
    addEvent(events, 'Running pre-upgrade hooks...', 'info');
    await new Promise(r => setTimeout(r, 500));
    addEvent(events, 'Applying updated manifests...', 'info');
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, `Storing release secret: sh.helm.release.v1.my-app.v${currentRevision + 1}`, 'info');
    await new Promise(r => setTimeout(r, 300));
    addEvent(events, `Release "my-app" upgraded to revision ${currentRevision + 1} ✓`, 'success');

    addRevision(chart, 'deployed', replicas);
    document.getElementById('relRevision').textContent = currentRevision;
    status.textContent = 'Deployed';
    status.className = 'rel-status deployed';
    document.getElementById('helmRollbackBtn').disabled = false;
  });

  document.getElementById('helmRollbackBtn').addEventListener('click', async () => {
    if (currentRevision < 2) return;
    const events = document.getElementById('releaseEvents');
    const status = document.getElementById('relStatus');
    const targetRev = currentRevision - 1;
    const targetData = revisions[targetRev - 1];

    status.textContent = 'Rolling back...';
    status.className = 'rel-status rolling-back';
    addEvent(events, `helm rollback my-app ${targetRev}`, 'warning');
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, `Loading revision ${targetRev} manifest from secret...`, 'info');
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, 'Running pre-rollback hooks...', 'info');
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, `Restoring manifests from revision ${targetRev}...`, 'info');
    await new Promise(r => setTimeout(r, 500));
    addEvent(events, `Rollback to revision ${targetRev} complete — creates new revision ${currentRevision + 1} ✓`, 'success');

    addRevision(targetData.chart.replace('mychart-', ''), 'deployed', targetData.replicas);
    document.getElementById('relRevision').textContent = currentRevision;
    status.textContent = 'Deployed';
    status.className = 'rel-status deployed';
  });

  document.getElementById('helmUninstallBtn').addEventListener('click', async () => {
    const events = document.getElementById('releaseEvents');
    const status = document.getElementById('relStatus');

    addEvent(events, 'helm uninstall my-app', 'warning');
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, 'Running pre-delete hooks...', 'info');
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, 'Deleting all release resources...', 'warning');
    await new Promise(r => setTimeout(r, 500));
    addEvent(events, 'Removing release secrets...', 'warning');
    await new Promise(r => setTimeout(r, 300));
    addEvent(events, 'Release "my-app" uninstalled ✓', 'error');

    revisions = [];
    currentRevision = 0;
    renderRevisions();
    document.getElementById('relRevision').textContent = '—';
    status.textContent = 'Not installed';
    status.className = 'rel-status';
    document.getElementById('helmInstallBtn').disabled = false;
    document.getElementById('helmUpgradeBtn').disabled = true;
    document.getElementById('helmRollbackBtn').disabled = true;
    document.getElementById('helmUninstallBtn').disabled = true;
  });

  // Hooks
  const hookData = {
    'pre-install': { title: 'pre-install', desc: 'Runs after templates are rendered but before any resources are created in Kubernetes. Common uses: database migrations, schema creation, prerequisite checks. The hook Job must succeed before installation proceeds. If it fails, the release is marked as failed.' },
    'post-install': { title: 'post-install', desc: 'Runs after all resources are created. Common uses: seed data, send notifications, register with external services. The release is already "installed" at this point — a hook failure here marks the release as failed but resources still exist.' },
    'pre-upgrade': { title: 'pre-upgrade', desc: 'Runs before an upgrade. Common uses: database migrations for the new version, backup current state, validate upgrade path. If this hook fails, the upgrade is aborted and the release stays at its current revision.' },
    'post-upgrade': { title: 'post-upgrade', desc: 'Runs after upgrade completes. Common uses: cache warming, integration tests, notification. Similar to post-install but for upgrade operations.' },
    'pre-rollback': { title: 'pre-rollback', desc: 'Runs before a rollback. Common uses: reverse database migrations, snapshot current state for debugging. Useful when you need to undo schema changes that went with the now-failed upgrade.' },
    'pre-delete': { title: 'pre-delete', desc: 'Runs before the release is deleted. Common uses: final backup, deregister from service mesh, clean up external resources (DNS records, cloud load balancers). This is your last chance to do cleanup with the release context available.' },
    'test': { title: 'test (helm test)', desc: 'Runs when you execute helm test <release>. Creates Pods that verify the release is working: HTTP health checks, database connectivity, smoke tests. Pods are expected to exit 0 for success. Use hook-delete-policy to clean up test pods.' }
  };

  document.querySelectorAll('.hook-item').forEach(el => {
    el.addEventListener('click', () => {
      document.querySelectorAll('.hook-item').forEach(h => h.classList.remove('active'));
      el.classList.add('active');
      const d = hookData[el.dataset.hook];
      if (d) {
        document.getElementById('hookDetail').innerHTML = `<div class="hook-detail-title">${d.title}</div><div class="hook-detail-desc">${d.desc}</div>`;
      }
    });
  });

  // Kustomize Overlays
  const kustEnvData = {
    dev: { prefix: 'dev-', replicas: 1, tag: 'dev-abc123', mem: '128Mi' },
    staging: { prefix: 'staging-', replicas: 3, tag: 'v1.2.0-rc1', mem: '256Mi' },
    prod: { prefix: '', replicas: 5, tag: 'v1.2.0', mem: '512Mi' }
  };

  function updateKustOverlay() {
    const env = document.getElementById('kustEnv').value;
    const d = kustEnvData[env];
    document.getElementById('kustPrefix').textContent = d.prefix || '(none)';
    document.getElementById('kustOverlayReplicas').textContent = d.replicas;
    document.getElementById('kustOverlayTag').textContent = d.tag;
    document.getElementById('kustOverlayPatch').textContent = `memory: ${d.mem}`;
  }

  document.getElementById('kustEnv').addEventListener('change', updateKustOverlay);

  document.getElementById('kustBuildBtn').addEventListener('click', () => {
    const env = document.getElementById('kustEnv').value;
    const d = kustEnvData[env];
    document.getElementById('kustOutName').textContent = `${d.prefix}my-app`;
    document.getElementById('kustOutReplicas').textContent = d.replicas;
    document.getElementById('kustOutImage').textContent = `my-app:${d.tag}`;
    document.getElementById('kustOutMem').textContent = d.mem;

    // Flash
    ['kustOutName','kustOutReplicas','kustOutImage','kustOutMem'].forEach(id => {
      const el = document.getElementById(id);
      el.classList.add('flash');
      setTimeout(() => el.classList.remove('flash'), 600);
    });
  });

  document.getElementById('kustResetBtn').addEventListener('click', () => {
    document.getElementById('kustEnv').value = 'dev';
    updateKustOverlay();
    document.getElementById('kustOutName').textContent = 'dev-my-app';
    document.getElementById('kustOutReplicas').textContent = '1';
    document.getElementById('kustOutImage').textContent = 'my-app:dev-abc123';
    document.getElementById('kustOutMem').textContent = '128Mi';
  });

  // Compare toggle highlight
  document.querySelectorAll('.compare-card').forEach(el => {
    el.addEventListener('click', () => {
      document.querySelectorAll('.compare-card').forEach(c => c.classList.remove('active'));
      el.classList.add('active');
      const approach = el.dataset.approach;
      document.querySelectorAll('.compare-cell.highlight').forEach(c => c.classList.remove('highlight'));
      const rows = document.querySelectorAll('.compare-row:not(.header)');
      rows.forEach(row => {
        const cells = row.querySelectorAll('.compare-cell');
        const idx = approach === 'helm' ? 1 : 2;
        if (cells[idx]) cells[idx].classList.add('highlight');
      });
    });
  });
</script>
