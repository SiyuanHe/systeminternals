---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Storage & CSI Internals" 
  description="Interactive visualization of Kubernetes PV/PVC lifecycle, StorageClass, CSI driver architecture, dynamic provisioning, and volume attach/mount flow"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "Kubernetes", href: "/kubernetes/" },
    { label: "Storage & CSI", href: "/kubernetes/storage/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>💾 Storage & CSI Internals</h1>
      <p class="subtitle">PV/PVC Lifecycle, StorageClass, CSI Driver Architecture, Dynamic Provisioning & Volume Mount Flow</p>
    </header>

    <section class="overview-section">
      <div class="overview-card">
        <p>
          Containers are ephemeral — when a pod dies, its filesystem vanishes. Kubernetes solves this with
          <strong>Persistent Volumes (PV)</strong> and <strong>Persistent Volume Claims (PVC)</strong>,
          an abstraction layer that decouples storage provisioning from consumption. The
          <strong>Container Storage Interface (CSI)</strong> is the plugin standard that lets any storage
          vendor — cloud block stores, network filesystems, local SSDs — integrate with Kubernetes through
          a uniform API. Understanding this pipeline — from a PVC request to bytes on disk — is essential
          for running stateful workloads reliably.
        </p>
      </div>
    </section>

    <!-- PV/PVC Lifecycle -->
    <section class="sim-section">
      <h2>🔄 PV/PVC Lifecycle</h2>
      <p class="section-desc">A PersistentVolumeClaim goes through distinct phases. Click each phase to understand the transitions.</p>

      <div class="lifecycle-diagram">
        <div class="lifecycle-phases">
          <div class="lc-phase active" data-phase="pending">
            <div class="lc-icon">⏳</div>
            <div class="lc-label">Pending</div>
          </div>
          <div class="lc-arrow">→</div>
          <div class="lc-phase" data-phase="bound">
            <div class="lc-icon">🔗</div>
            <div class="lc-label">Bound</div>
          </div>
          <div class="lc-arrow">→</div>
          <div class="lc-phase" data-phase="released">
            <div class="lc-icon">🔓</div>
            <div class="lc-label">Released</div>
          </div>
          <div class="lc-arrow">→</div>
          <div class="lc-phase" data-phase="reclaim">
            <div class="lc-icon">♻️</div>
            <div class="lc-label">Reclaim</div>
          </div>
        </div>
        <div class="lc-detail" id="lcDetail">
          <div class="lc-detail-title">Pending</div>
          <div class="lc-detail-desc">
            The PVC has been created but no matching PV exists yet. The PV controller is actively searching for
            a PV that satisfies the claim's requirements (size, access mode, StorageClass). If dynamic provisioning
            is enabled, the external provisioner will create a new volume. The PVC stays Pending until a match is found
            or provisioning completes.
          </div>
        </div>
      </div>
    </section>

    <!-- StorageClass Anatomy -->
    <section class="sim-section">
      <h2>📝 StorageClass Anatomy</h2>
      <p class="section-desc">Click each part of a StorageClass to understand its role in provisioning.</p>

      <div class="sc-anatomy">
        <div class="sc-yaml">
          <div class="yaml-line" data-part="sc-api">
            <span class="yaml-key">apiVersion:</span> storage.k8s.io/v1
          </div>
          <div class="yaml-line" data-part="sc-kind">
            <span class="yaml-key">kind:</span> StorageClass
          </div>
          <div class="yaml-line" data-part="sc-meta">
            <span class="yaml-key">metadata:</span>
          </div>
          <div class="yaml-line indent" data-part="sc-meta">
            <span class="yaml-key">name:</span> fast-ssd
          </div>
          <div class="yaml-line indent" data-part="sc-default">
            <span class="yaml-key">annotations:</span>
          </div>
          <div class="yaml-line indent2" data-part="sc-default">
            <span class="yaml-key">storageclass.kubernetes.io/is-default-class:</span> "true"
          </div>
          <div class="yaml-line" data-part="sc-provisioner">
            <span class="yaml-key">provisioner:</span> ebs.csi.aws.com
          </div>
          <div class="yaml-line" data-part="sc-params">
            <span class="yaml-key">parameters:</span>
          </div>
          <div class="yaml-line indent" data-part="sc-params">
            <span class="yaml-key">type:</span> gp3
          </div>
          <div class="yaml-line indent" data-part="sc-params">
            <span class="yaml-key">iops:</span> "5000"
          </div>
          <div class="yaml-line indent" data-part="sc-params">
            <span class="yaml-key">throughput:</span> "250"
          </div>
          <div class="yaml-line" data-part="sc-reclaim">
            <span class="yaml-key">reclaimPolicy:</span> Delete
          </div>
          <div class="yaml-line" data-part="sc-binding">
            <span class="yaml-key">volumeBindingMode:</span> WaitForFirstConsumer
          </div>
          <div class="yaml-line" data-part="sc-expand">
            <span class="yaml-key">allowVolumeExpansion:</span> true
          </div>
          <div class="yaml-line" data-part="sc-topology">
            <span class="yaml-key">allowedTopologies:</span>
          </div>
          <div class="yaml-line indent" data-part="sc-topology">
            - <span class="yaml-key">matchLabelExpressions:</span>
          </div>
          <div class="yaml-line indent2" data-part="sc-topology">
            - <span class="yaml-key">key:</span> topology.ebs.csi.aws.com/zone
          </div>
          <div class="yaml-line indent3" data-part="sc-topology">
            <span class="yaml-key">values:</span> [us-east-1a, us-east-1b]
          </div>
        </div>

        <div class="sc-info-panel" id="scInfo">
          <div class="sc-info-title">Click a section</div>
          <div class="sc-info-desc">Click any line in the StorageClass to learn what it does.</div>
        </div>
      </div>
    </section>

    <!-- CSI Architecture -->
    <section class="sim-section">
      <h2>🏗️ CSI Driver Architecture</h2>
      <p class="section-desc">CSI splits storage operations into three gRPC services running as sidecars alongside your driver. Click each component.</p>

      <div class="csi-arch">
        <div class="csi-control-plane">
          <div class="csi-plane-label">Control Plane (Deployment)</div>
          <div class="csi-components">
            <div class="csi-comp" data-comp="provisioner">
              <div class="csi-comp-icon">📦</div>
              <div class="csi-comp-name">external-provisioner</div>
              <div class="csi-comp-desc">Watches PVCs, calls CreateVolume</div>
            </div>
            <div class="csi-comp" data-comp="attacher">
              <div class="csi-comp-icon">🔌</div>
              <div class="csi-comp-name">external-attacher</div>
              <div class="csi-comp-desc">Watches VolumeAttachments</div>
            </div>
            <div class="csi-comp" data-comp="resizer">
              <div class="csi-comp-icon">📐</div>
              <div class="csi-comp-name">external-resizer</div>
              <div class="csi-comp-desc">Handles volume expansion</div>
            </div>
            <div class="csi-comp" data-comp="snapshotter">
              <div class="csi-comp-icon">📸</div>
              <div class="csi-comp-name">external-snapshotter</div>
              <div class="csi-comp-desc">Creates VolumeSnapshots</div>
            </div>
            <div class="csi-comp highlight-driver" data-comp="controller">
              <div class="csi-comp-icon">⚙️</div>
              <div class="csi-comp-name">CSI Controller Plugin</div>
              <div class="csi-comp-desc">Your driver's control logic</div>
            </div>
          </div>
        </div>

        <div class="csi-node-plane">
          <div class="csi-plane-label">Node (DaemonSet)</div>
          <div class="csi-components">
            <div class="csi-comp" data-comp="registrar">
              <div class="csi-comp-icon">📋</div>
              <div class="csi-comp-name">node-driver-registrar</div>
              <div class="csi-comp-desc">Registers driver with kubelet</div>
            </div>
            <div class="csi-comp highlight-driver" data-comp="node">
              <div class="csi-comp-icon">💽</div>
              <div class="csi-comp-name">CSI Node Plugin</div>
              <div class="csi-comp-desc">NodeStage / NodePublish</div>
            </div>
          </div>
        </div>
      </div>

      <div class="csi-detail" id="csiDetail">
        <div class="csi-detail-title">Click a component</div>
        <div class="csi-detail-desc">Click any CSI component above to learn about its role in the storage pipeline.</div>
      </div>
    </section>

    <!-- Dynamic Provisioning Simulator -->
    <section class="sim-section">
      <h2>🎮 Dynamic Provisioning Simulator</h2>
      <p class="section-desc">Create a PVC and watch the entire provisioning pipeline unfold step by step.</p>

      <div class="provision-sim">
        <div class="provision-config">
          <h3>PVC Spec</h3>
          <div class="config-group">
            <label>StorageClass</label>
            <select id="provSC" class="config-select">
              <option value="fast-ssd">fast-ssd (gp3)</option>
              <option value="standard">standard (gp2)</option>
              <option value="local-path">local-path</option>
            </select>
          </div>
          <div class="config-group">
            <label>Size: <strong id="provSizeLabel">10Gi</strong></label>
            <input type="range" id="provSizeSlider" min="1" max="100" value="10" step="1" class="slider">
          </div>
          <div class="config-group">
            <label>Access Mode</label>
            <select id="provAccess" class="config-select">
              <option value="RWO">ReadWriteOnce (RWO)</option>
              <option value="ROX">ReadOnlyMany (ROX)</option>
              <option value="RWX">ReadWriteMany (RWX)</option>
            </select>
          </div>
          <button class="action-btn primary-btn" id="createPvcBtn">📥 Create PVC</button>
          <button class="action-btn election-btn" id="mountPvcBtn" style="margin-top: 8px" disabled>🔗 Mount in Pod</button>
          <button class="action-btn chaos-btn" id="deletePvcBtn" style="margin-top: 8px" disabled>🗑️ Delete PVC</button>
          <button class="action-btn reset-btn" id="resetProvBtn" style="margin-top: 8px">↺ Reset</button>
        </div>

        <div class="provision-display">
          <div class="provision-status-bar">
            <div class="prov-phase" id="provPhase">No PVC</div>
            <div class="prov-vol" id="provVol">Volume: —</div>
          </div>

          <div class="provision-events" id="provisionEvents">
            <div class="event-header">Provisioning Events</div>
          </div>

          <div class="provision-resources">
            <div class="resource-group">
              <div class="rg-label">PVC</div>
              <div class="rg-items" id="provPVC"></div>
            </div>
            <div class="resource-group">
              <div class="rg-label">PV</div>
              <div class="rg-items" id="provPV"></div>
            </div>
            <div class="resource-group">
              <div class="rg-label">VolumeAttachment</div>
              <div class="rg-items" id="provVA"></div>
            </div>
            <div class="resource-group">
              <div class="rg-label">Mount</div>
              <div class="rg-items" id="provMount"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Volume Attach/Mount Flow -->
    <section class="sim-section">
      <h2>🔌 Volume Attach & Mount Flow</h2>
      <p class="section-desc">When a pod using a PVC is scheduled, the volume goes through attach → stage → publish. Click "Start Flow" to animate.</p>

      <div class="attach-flow">
        <div class="af-stages">
          <div class="af-stage" id="afSchedule">
            <div class="af-icon">📋</div>
            <div class="af-label">Schedule</div>
            <div class="af-desc">Scheduler picks a node</div>
          </div>
          <div class="af-arrow">→</div>
          <div class="af-stage" id="afAttach">
            <div class="af-icon">🔌</div>
            <div class="af-label">ControllerPublish</div>
            <div class="af-desc">Attach volume to node (API call to cloud)</div>
          </div>
          <div class="af-arrow">→</div>
          <div class="af-stage" id="afStage">
            <div class="af-icon">💿</div>
            <div class="af-label">NodeStage</div>
            <div class="af-desc">Format & mount to global dir</div>
          </div>
          <div class="af-arrow">→</div>
          <div class="af-stage" id="afPublish">
            <div class="af-icon">📂</div>
            <div class="af-label">NodePublish</div>
            <div class="af-desc">Bind-mount into pod's container</div>
          </div>
          <div class="af-arrow">→</div>
          <div class="af-stage" id="afReady">
            <div class="af-icon">✅</div>
            <div class="af-label">Ready</div>
            <div class="af-desc">Pod can read/write volume</div>
          </div>
        </div>

        <div class="af-detail" id="afDetail">
          <p>Click "Start Flow" to see the full attach → stage → mount pipeline with timing details.</p>
        </div>

        <div class="action-bar">
          <button class="action-btn primary-btn" id="startFlowBtn">▶ Start Flow</button>
          <button class="action-btn chaos-btn" id="detachFlowBtn">⏪ Detach Flow</button>
          <button class="action-btn reset-btn" id="resetFlowBtn">↺ Reset</button>
        </div>
      </div>
    </section>

    <!-- Access Modes & Reclaim Policies -->
    <section class="sim-section">
      <h2>📊 Access Modes & Reclaim Policies</h2>
      <p class="section-desc">Click each mode/policy to understand when to use it and the tradeoffs involved.</p>

      <div class="modes-grid">
        <div class="modes-column">
          <h3>Access Modes</h3>
          <div class="mode-card active" data-mode="rwo">
            <div class="mode-name">ReadWriteOnce (RWO)</div>
            <div class="mode-icon">📝→🖥️</div>
          </div>
          <div class="mode-card" data-mode="rox">
            <div class="mode-name">ReadOnlyMany (ROX)</div>
            <div class="mode-icon">📖→🖥️🖥️🖥️</div>
          </div>
          <div class="mode-card" data-mode="rwx">
            <div class="mode-name">ReadWriteMany (RWX)</div>
            <div class="mode-icon">📝→🖥️🖥️🖥️</div>
          </div>
          <div class="mode-card" data-mode="rwop">
            <div class="mode-name">ReadWriteOncePod (RWOP)</div>
            <div class="mode-icon">📝→🫛</div>
          </div>
        </div>
        <div class="modes-column">
          <h3>Reclaim Policies</h3>
          <div class="mode-card" data-mode="delete">
            <div class="mode-name">Delete</div>
            <div class="mode-icon">🗑️</div>
          </div>
          <div class="mode-card" data-mode="retain">
            <div class="mode-name">Retain</div>
            <div class="mode-icon">🔒</div>
          </div>
        </div>
        <div class="mode-detail" id="modeDetail">
          <div class="mode-detail-title">ReadWriteOnce (RWO)</div>
          <div class="mode-detail-desc">
            The volume can be mounted as read-write by a <strong>single node</strong>. Multiple pods on the same
            node can still access it. This is the most common mode for block storage (EBS, Persistent Disk, Azure Disk).
            If a pod moves to a different node, the volume must be detached and reattached.
          </div>
        </div>
      </div>
    </section>

    <!-- Volume Expansion -->
    <section class="sim-section">
      <h2>📐 Online Volume Expansion</h2>
      <p class="section-desc">Resize a bound PVC and watch the controller expand the underlying volume, then the filesystem.</p>

      <div class="expand-viz">
        <div class="expand-bar">
          <div class="expand-current" id="expandCurrent" style="width: 30%">
            <span>10Gi</span>
          </div>
          <div class="expand-target" id="expandTarget" style="width: 0%"></div>
        </div>
        <div class="expand-controls">
          <div class="config-group">
            <label>New Size: <strong id="expandLabel">20Gi</strong></label>
            <input type="range" id="expandSlider" min="11" max="100" value="20" step="1" class="slider">
          </div>
          <div class="action-bar">
            <button class="action-btn primary-btn" id="expandBtn">📐 Expand Volume</button>
            <button class="action-btn reset-btn" id="resetExpandBtn">↺ Reset</button>
          </div>
        </div>
        <div class="expand-events" id="expandEvents">
          <div class="event-header">Expansion Events</div>
        </div>
      </div>
    </section>

    <!-- Popular CSI Drivers -->
    <section class="sim-section">
      <h2>🏆 Popular CSI Drivers</h2>
      <p class="section-desc">Real-world CSI implementations across cloud and on-prem environments.</p>

      <div class="operators-grid">
        <div class="operator-card">
          <div class="op-icon">☁️</div>
          <h3>AWS EBS CSI</h3>
          <p>Manages Amazon EBS volumes — gp3/io2 types, snapshots, encryption with KMS, and cross-AZ awareness. Handles attach/detach via EC2 API.</p>
          <div class="op-crd">Driver: ebs.csi.aws.com</div>
        </div>
        <div class="operator-card">
          <div class="op-icon">🌐</div>
          <h3>GCP PD CSI</h3>
          <p>Google Persistent Disk integration — SSD/balanced/standard tiers, regional replication, snapshots. Supports volume cloning and topology.</p>
          <div class="op-crd">Driver: pd.csi.storage.gke.io</div>
        </div>
        <div class="operator-card">
          <div class="op-icon">🗄️</div>
          <h3>Longhorn</h3>
          <p>Cloud-native distributed storage for bare-metal Kubernetes. Replicates data across nodes, supports backup to S3, incremental snapshots.</p>
          <div class="op-crd">Driver: driver.longhorn.io</div>
        </div>
        <div class="operator-card">
          <div class="op-icon">🐙</div>
          <h3>Ceph (Rook)</h3>
          <p>Enterprise-grade distributed storage — RBD block, CephFS filesystem, and S3-compatible object storage. Rook operator manages the Ceph cluster.</p>
          <div class="op-crd">Driver: rbd.csi.ceph.com</div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .viz-container { max-width: 1100px; margin: 0 auto; }
  .viz-header { margin-bottom: 40px; }
  .viz-header h1 { font-size: 2.2rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
  .subtitle { font-size: 1.1rem; color: #888; }
  .overview-section { margin-bottom: 50px; }
  .overview-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 24px; }
  .overview-card p { color: #ccc; line-height: 1.8; font-size: 1.05rem; }
  .overview-card strong { color: #60a5fa; }
  .overview-card em { color: #fbbf24; }
  .overview-card code { background: rgba(96,165,250,0.15); padding: 2px 6px; border-radius: 4px; font-size: 0.9rem; color: #60a5fa; }

  h2 { font-size: 1.5rem; color: #fff; margin-bottom: 8px; }
  .section-desc { color: #888; margin-bottom: 24px; font-size: 0.95rem; }
  .sim-section { margin-bottom: 50px; }

  /* Lifecycle Diagram */
  .lifecycle-diagram { margin-top: 16px; }
  .lifecycle-phases { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: center; margin-bottom: 20px; }
  .lc-phase { background: rgba(255,255,255,0.04); border: 2px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 16px 24px; text-align: center; cursor: pointer; transition: all 0.3s; min-width: 100px; }
  .lc-phase:hover, .lc-phase.active { border-color: rgba(96,165,250,0.6); background: rgba(96,165,250,0.1); }
  .lc-icon { font-size: 1.8rem; margin-bottom: 6px; }
  .lc-label { font-weight: 700; color: #fff; font-size: 0.95rem; }
  .lc-arrow { font-size: 1.3rem; color: #555; font-weight: bold; }
  .lc-detail { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 20px; }
  .lc-detail-title { font-weight: 700; color: #60a5fa; font-size: 1.05rem; margin-bottom: 8px; }
  .lc-detail-desc { color: #ccc; line-height: 1.7; font-size: 0.95rem; }

  /* StorageClass Anatomy */
  .sc-anatomy { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .sc-yaml { background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 20px; font-family: 'SF Mono','Fira Code',monospace; font-size: 0.82rem; line-height: 1.8; }
  .yaml-line { padding: 2px 8px; border-radius: 4px; cursor: pointer; transition: all 0.2s; color: #ccc; }
  .yaml-line:hover { background: rgba(96,165,250,0.1); }
  .yaml-line.highlight { background: rgba(96,165,250,0.15); border-left: 3px solid #60a5fa; }
  .yaml-key { color: #60a5fa; }
  .indent { padding-left: 28px; }
  .indent2 { padding-left: 48px; }
  .indent3 { padding-left: 68px; }
  .sc-info-panel { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 20px; }
  .sc-info-title { font-weight: 700; color: #60a5fa; font-size: 1.05rem; margin-bottom: 8px; }
  .sc-info-desc { color: #ccc; line-height: 1.7; font-size: 0.95rem; }

  /* CSI Architecture */
  .csi-arch { display: flex; flex-direction: column; gap: 20px; margin-bottom: 20px; }
  .csi-plane-label { font-size: 0.85rem; font-weight: 700; color: #fbbf24; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
  .csi-control-plane, .csi-node-plane { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 20px; }
  .csi-components { display: flex; gap: 12px; flex-wrap: wrap; }
  .csi-comp { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 14px; text-align: center; cursor: pointer; transition: all 0.3s; flex: 1; min-width: 120px; }
  .csi-comp:hover, .csi-comp.active { border-color: rgba(96,165,250,0.5); background: rgba(96,165,250,0.1); }
  .csi-comp.highlight-driver { border-color: rgba(251,191,36,0.3); background: rgba(251,191,36,0.05); }
  .csi-comp.highlight-driver:hover, .csi-comp.highlight-driver.active { border-color: rgba(251,191,36,0.6); background: rgba(251,191,36,0.1); }
  .csi-comp-icon { font-size: 1.5rem; margin-bottom: 4px; }
  .csi-comp-name { font-weight: 700; color: #fff; font-size: 0.8rem; }
  .csi-comp-desc { font-size: 0.7rem; color: #888; margin-top: 2px; }
  .csi-detail { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 20px; margin-top: 16px; }
  .csi-detail-title { font-weight: 700; color: #60a5fa; font-size: 1.05rem; margin-bottom: 8px; }
  .csi-detail-desc { color: #ccc; line-height: 1.7; font-size: 0.95rem; }

  /* Provisioning Sim */
  .provision-sim { display: grid; grid-template-columns: 260px 1fr; gap: 24px; }
  .provision-config { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 20px; }
  .provision-config h3 { font-size: 1rem; color: #fff; margin-bottom: 16px; }
  .provision-display { display: flex; flex-direction: column; gap: 16px; }
  .provision-status-bar { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: rgba(255,255,255,0.03); border-radius: 10px; }
  .prov-phase { font-weight: 700; font-size: 0.9rem; color: #888; }
  .prov-phase.pending { color: #fbbf24; }
  .prov-phase.bound { color: #4ade80; }
  .prov-phase.released { color: #f59e0b; }
  .prov-vol { font-size: 0.85rem; color: #888; }
  .provision-events { background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 12px; max-height: 200px; overflow-y: auto; font-family: 'SF Mono',monospace; font-size: 0.75rem; }
  .event-header { color: #888; font-weight: 600; margin-bottom: 8px; }
  .event-entry { padding: 2px 0; }
  .event-entry.info { color: #60a5fa; }
  .event-entry.success { color: #4ade80; }
  .event-entry.warning { color: #fbbf24; }
  .event-entry.error { color: #f87171; }
  .provision-resources { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; }
  .resource-group { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 12px; }
  .rg-label { font-size: 0.8rem; font-weight: 600; color: #aaa; margin-bottom: 8px; }
  .rg-items { display: flex; flex-direction: column; gap: 4px; }
  .resource-item { font-size: 0.75rem; color: #aaa; padding: 4px 8px; background: rgba(255,255,255,0.04); border-radius: 6px; }
  .resource-item.active { color: #4ade80; border-left: 2px solid #4ade80; }
  .resource-item.pending { color: #fbbf24; border-left: 2px solid #fbbf24; }

  /* Attach Flow */
  .attach-flow { margin-top: 16px; }
  .af-stages { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: center; margin-bottom: 20px; }
  .af-stage { background: rgba(255,255,255,0.04); border: 2px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 14px; text-align: center; min-width: 110px; transition: all 0.4s; }
  .af-stage.active { border-color: rgba(96,165,250,0.6); background: rgba(96,165,250,0.1); transform: scale(1.05); }
  .af-stage.done { border-color: rgba(74,222,128,0.5); background: rgba(74,222,128,0.05); }
  .af-icon { font-size: 1.5rem; margin-bottom: 4px; }
  .af-label { font-weight: 700; color: #fff; font-size: 0.85rem; }
  .af-desc { font-size: 0.7rem; color: #888; margin-top: 2px; }
  .af-arrow { font-size: 1.3rem; color: #555; font-weight: bold; }
  .af-detail { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 16px; margin-bottom: 16px; color: #ccc; font-size: 0.9rem; line-height: 1.7; }

  /* Access Modes */
  .modes-grid { display: grid; grid-template-columns: 1fr 1fr 2fr; gap: 20px; }
  .modes-column h3 { font-size: 1rem; color: #fff; margin-bottom: 12px; }
  .mode-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px; cursor: pointer; transition: all 0.3s; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; }
  .mode-card:hover, .mode-card.active { border-color: rgba(96,165,250,0.5); background: rgba(96,165,250,0.1); }
  .mode-name { font-weight: 600; color: #fff; font-size: 0.85rem; }
  .mode-icon { font-size: 0.9rem; }
  .mode-detail { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 20px; }
  .mode-detail-title { font-weight: 700; color: #60a5fa; font-size: 1.05rem; margin-bottom: 8px; }
  .mode-detail-desc { color: #ccc; line-height: 1.7; font-size: 0.95rem; }
  .mode-detail-desc strong { color: #fbbf24; }

  /* Volume Expansion */
  .expand-viz { margin-top: 16px; }
  .expand-bar { height: 40px; background: rgba(255,255,255,0.06); border-radius: 10px; overflow: hidden; position: relative; margin-bottom: 16px; display: flex; }
  .expand-current { background: linear-gradient(90deg, #3b82f6, #60a5fa); display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 700; color: #fff; transition: width 1s; border-radius: 10px 0 0 10px; }
  .expand-target { background: linear-gradient(90deg, #4ade80, #22c55e); display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 700; color: #fff; transition: width 1s; }
  .expand-controls { margin-bottom: 16px; }
  .expand-events { background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 12px; max-height: 180px; overflow-y: auto; font-family: 'SF Mono',monospace; font-size: 0.75rem; }

  /* Operators Grid (reused) */
  .operators-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
  .operator-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 20px; transition: all 0.3s; }
  .operator-card:hover { border-color: rgba(96,165,250,0.3); transform: translateY(-2px); }
  .op-icon { font-size: 1.8rem; margin-bottom: 8px; }
  .operator-card h3 { font-size: 1.05rem; color: #fff; margin-bottom: 8px; }
  .operator-card p { font-size: 0.85rem; color: #888; line-height: 1.6; margin-bottom: 10px; }
  .op-crd { font-size: 0.75rem; color: #60a5fa; font-family: 'SF Mono',monospace; }

  /* Shared */
  .action-bar { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; }
  .action-btn { padding: 10px 20px; border: none; border-radius: 10px; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .action-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .primary-btn { background: linear-gradient(135deg, #60a5fa, #3b82f6); color: white; }
  .primary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(59,130,246,0.4); }
  .election-btn { background: linear-gradient(135deg, #4ade80, #22c55e); color: white; }
  .election-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(34,197,94,0.4); }
  .chaos-btn { background: linear-gradient(135deg, #f472b6, #ef4444); color: white; }
  .chaos-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(239,68,68,0.4); }
  .reset-btn { background: rgba(255,255,255,0.1); color: #aaa; }
  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }
  .config-group { margin-bottom: 16px; }
  .config-group label { display: block; font-size: 0.85rem; color: #aaa; margin-bottom: 6px; }
  .config-group label strong { color: #60a5fa; }
  .slider { width: 100%; height: 6px; -webkit-appearance: none; background: rgba(255,255,255,0.15); border-radius: 3px; cursor: pointer; }
  .slider::-webkit-slider-thumb { -webkit-appearance: none; width: 16px; height: 16px; border-radius: 50%; background: #60a5fa; cursor: pointer; }
  .config-select { width: 100%; padding: 8px 10px; background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: #ddd; font-size: 0.85rem; }

  @media (max-width: 768px) {
    .sc-anatomy, .provision-sim { grid-template-columns: 1fr; }
    .modes-grid { grid-template-columns: 1fr; }
    .af-stages { flex-direction: column; }
  }
</style>

<script>
  // Helper
  function addEvent(container, text, cls) {
    const el = document.createElement('div');
    el.className = 'event-entry ' + cls;
    el.textContent = `[${new Date().toISOString().slice(11,23)}] ${text}`;
    container.appendChild(el);
    container.scrollTop = container.scrollHeight;
  }

  // PV/PVC Lifecycle
  const lcData = {
    pending: { title: 'Pending', desc: 'The PVC has been created but no matching PV exists yet. The PV controller searches for a PV that satisfies the claim\'s requirements (size, access mode, StorageClass). If dynamic provisioning is enabled, the external-provisioner sidecar calls CreateVolume on the CSI driver. The PVC stays Pending until a match is found or provisioning completes.' },
    bound: { title: 'Bound', desc: 'A PV has been matched (or dynamically created) and bound to this PVC. The binding is exclusive — a 1:1 relationship. The PV\'s .spec.claimRef points to the PVC, and the PVC\'s .spec.volumeName points to the PV. The volume is now available for pods to mount. The PV\'s capacity may exceed what was requested.' },
    released: { title: 'Released', desc: 'The PVC has been deleted, but the PV still exists and retains the data. The PV is marked "Released" because it\'s still associated with the old claim\'s data. No new PVC can bind to it automatically — an admin must manually reclaim it (delete and recreate, or clear the claimRef).' },
    reclaim: { title: 'Reclaim Policy', desc: 'What happens to the PV after release depends on the reclaim policy. "Delete" removes the PV and the underlying storage (e.g., deletes the EBS volume). "Retain" keeps everything — the admin must clean up manually. The deprecated "Recycle" policy used to run rm -rf on the volume, but is no longer recommended.' }
  };

  document.querySelectorAll('.lc-phase').forEach(el => {
    el.addEventListener('click', () => {
      document.querySelectorAll('.lc-phase').forEach(p => p.classList.remove('active'));
      el.classList.add('active');
      const d = lcData[el.dataset.phase];
      document.getElementById('lcDetail').innerHTML = `<div class="lc-detail-title">${d.title}</div><div class="lc-detail-desc">${d.desc}</div>`;
    });
  });

  // StorageClass Anatomy
  const scInfoData = {
    'sc-api': { title: 'API Version', desc: 'StorageClass is part of the storage.k8s.io API group. It\'s a cluster-scoped resource — not namespaced — because storage policies typically apply across the entire cluster.' },
    'sc-kind': { title: 'Kind: StorageClass', desc: 'A StorageClass provides a way for administrators to describe "classes" of storage. Different classes might map to quality-of-service levels, backup policies, or arbitrary policies determined by the cluster administrators.' },
    'sc-meta': { title: 'Metadata & Name', desc: 'The name is what PVCs reference in their storageClassName field. Choose descriptive names like "fast-ssd", "cold-hdd", or "replicated-nvme".' },
    'sc-default': { title: 'Default StorageClass', desc: 'When a PVC doesn\'t specify a storageClassName, it gets the default class. Only one StorageClass should be marked as default. If multiple are marked, the PVC stays Pending. The DefaultStorageClass admission controller handles this.' },
    'sc-provisioner': { title: 'Provisioner', desc: 'The CSI driver name that will handle volume creation. This must match the driver name registered by the CSI node plugin. Examples: ebs.csi.aws.com, pd.csi.storage.gke.io, driver.longhorn.io.' },
    'sc-params': { title: 'Parameters', desc: 'Opaque key-value pairs passed directly to the CSI driver\'s CreateVolume call. Each driver defines its own parameters — disk type, IOPS, throughput, encryption settings, replication factor, etc.' },
    'sc-reclaim': { title: 'Reclaim Policy', desc: '"Delete" removes the underlying volume when the PVC is deleted (default for dynamic provisioning). "Retain" keeps the volume for manual cleanup. Choose Retain for production databases where you never want accidental data loss.' },
    'sc-binding': { title: 'Volume Binding Mode', desc: '"Immediate" provisions the volume as soon as the PVC is created. "WaitForFirstConsumer" delays provisioning until a pod actually uses the PVC. WaitForFirstConsumer is critical for topology-aware provisioning — it ensures the volume is created in the same zone as the pod.' },
    'sc-expand': { title: 'Volume Expansion', desc: 'When true, PVCs using this class can be resized by editing their spec.resources.requests.storage. The CSI driver must support ControllerExpandVolume. Some drivers also support online expansion (no pod restart needed).' },
    'sc-topology': { title: 'Allowed Topologies', desc: 'Restricts which zones/regions volumes can be provisioned in. Combined with WaitForFirstConsumer, this ensures volumes are co-located with their pods. Without this, a volume might be created in us-east-1c while the pod runs in us-east-1a.' }
  };

  document.querySelectorAll('.sc-yaml .yaml-line').forEach(el => {
    el.addEventListener('click', () => {
      document.querySelectorAll('.sc-yaml .yaml-line').forEach(l => l.classList.remove('highlight'));
      const part = el.dataset.part;
      document.querySelectorAll(`.sc-yaml [data-part="${part}"]`).forEach(l => l.classList.add('highlight'));
      const info = scInfoData[part];
      if (info) {
        document.getElementById('scInfo').innerHTML = `<div class="sc-info-title">${info.title}</div><div class="sc-info-desc">${info.desc}</div>`;
      }
    });
  });

  // CSI Component Details
  const csiData = {
    provisioner: { title: 'external-provisioner', desc: 'Watches for PVCs that reference a StorageClass with this driver\'s provisioner name. When a new PVC appears, it calls the CSI driver\'s CreateVolume RPC. After the volume is created in the backend storage, it creates a PV object in Kubernetes and binds it to the PVC. Also handles volume deletion when PVCs with Delete reclaim policy are removed.' },
    attacher: { title: 'external-attacher', desc: 'Watches VolumeAttachment objects created by the AD controller. When a pod is scheduled to a node, the AD controller creates a VolumeAttachment. The external-attacher then calls ControllerPublishVolume on the CSI driver, which attaches the volume to the node (e.g., attaching an EBS volume to an EC2 instance). It updates the VolumeAttachment status when complete.' },
    resizer: { title: 'external-resizer', desc: 'Watches for PVC edits where the requested size increases. It calls ControllerExpandVolume on the CSI driver to resize the backend volume, then updates the PV capacity. If the driver requires filesystem expansion, it sets a condition on the PVC that triggers kubelet to call NodeExpandVolume on the next mount.' },
    snapshotter: { title: 'external-snapshotter', desc: 'Manages VolumeSnapshot and VolumeSnapshotContent objects. When a user creates a VolumeSnapshot, it calls CreateSnapshot on the CSI driver. Supports scheduled snapshots, snapshot-based cloning, and restoring volumes from snapshots. Works with VolumeSnapshotClass for snapshot policies.' },
    controller: { title: 'CSI Controller Plugin', desc: 'Your driver\'s server-side logic. Implements the CSI Controller service: CreateVolume, DeleteVolume, ControllerPublishVolume (attach), ControllerUnpublishVolume (detach), CreateSnapshot, ExpandVolume. Runs as a Deployment (usually 1 replica with leader election). Communicates with your storage backend\'s API.' },
    registrar: { title: 'node-driver-registrar', desc: 'Runs on every node as part of a DaemonSet. It registers the CSI driver with kubelet using the Kubelet Plugin Registration mechanism. This tells kubelet which Unix socket to use when it needs to call NodeStageVolume or NodePublishVolume for this driver.' },
    node: { title: 'CSI Node Plugin', desc: 'Your driver\'s node-side logic. Implements NodeStageVolume (format + mount to a staging directory), NodePublishVolume (bind-mount from staging into the pod\'s directory), and their reverse operations. Also implements NodeGetInfo to report topology labels (zone, region) back to the scheduler.' }
  };

  document.querySelectorAll('.csi-comp').forEach(el => {
    el.addEventListener('click', () => {
      document.querySelectorAll('.csi-comp').forEach(c => c.classList.remove('active'));
      el.classList.add('active');
      const d = csiData[el.dataset.comp];
      if (d) {
        document.getElementById('csiDetail').innerHTML = `<div class="csi-detail-title">${d.title}</div><div class="csi-detail-desc">${d.desc}</div>`;
      }
    });
  });

  // Provisioning Simulator
  const provSizeSlider = document.getElementById('provSizeSlider');
  provSizeSlider.addEventListener('input', () => document.getElementById('provSizeLabel').textContent = provSizeSlider.value + 'Gi');

  let provState = 'none';
  let volId = 0;

  document.getElementById('createPvcBtn').addEventListener('click', async () => {
    if (provState !== 'none') return;
    provState = 'provisioning';
    volId++;
    const sc = document.getElementById('provSC').value;
    const size = provSizeSlider.value;
    const access = document.getElementById('provAccess').value;
    const events = document.getElementById('provisionEvents');
    const phase = document.getElementById('provPhase');

    phase.textContent = 'Pending';
    phase.className = 'prov-phase pending';
    document.getElementById('provPVC').innerHTML = `<div class="resource-item pending">my-pvc (${size}Gi, ${access})</div>`;

    addEvent(events, `PVC my-pvc created: ${size}Gi, ${access}, class=${sc}`, 'info');
    await new Promise(r => setTimeout(r, 500));

    if (sc === 'local-path') {
      addEvent(events, 'volumeBindingMode: WaitForFirstConsumer — waiting for pod...', 'warning');
      await new Promise(r => setTimeout(r, 800));
      addEvent(events, 'Pod scheduled → triggering provisioning', 'info');
    }

    addEvent(events, `external-provisioner: CreateVolume(${size}Gi) → CSI driver`, 'info');
    await new Promise(r => setTimeout(r, 700));
    addEvent(events, `CSI driver: volume vol-${volId} created on backend`, 'success');
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, `PV pv-vol-${volId} created and bound to my-pvc`, 'success');

    document.getElementById('provPV').innerHTML = `<div class="resource-item active">pv-vol-${volId} (${size}Gi)</div>`;
    document.getElementById('provVol').textContent = `Volume: vol-${volId}`;
    phase.textContent = 'Bound';
    phase.className = 'prov-phase bound';
    provState = 'bound';
    document.getElementById('mountPvcBtn').disabled = false;
    document.getElementById('deletePvcBtn').disabled = false;
    document.getElementById('createPvcBtn').disabled = true;
  });

  document.getElementById('mountPvcBtn').addEventListener('click', async () => {
    if (provState !== 'bound') return;
    const events = document.getElementById('provisionEvents');
    provState = 'mounting';

    addEvent(events, 'Pod my-app scheduled to node-1', 'info');
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, `AD controller: VolumeAttachment created for vol-${volId} → node-1`, 'info');
    document.getElementById('provVA').innerHTML = `<div class="resource-item pending">vol-${volId} → node-1</div>`;
    await new Promise(r => setTimeout(r, 600));
    addEvent(events, `external-attacher: ControllerPublishVolume → attached`, 'success');
    document.getElementById('provVA').innerHTML = `<div class="resource-item active">vol-${volId} → node-1 ✓</div>`;
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, `kubelet: NodeStageVolume (format ext4, mount to /var/lib/kubelet/plugins/...)`, 'info');
    await new Promise(r => setTimeout(r, 500));
    addEvent(events, `kubelet: NodePublishVolume (bind-mount to /var/lib/kubelet/pods/.../volumes/...)`, 'info');
    await new Promise(r => setTimeout(r, 300));
    addEvent(events, 'Volume mounted in pod my-app at /data ✓', 'success');
    document.getElementById('provMount').innerHTML = `<div class="resource-item active">/data → vol-${volId}</div>`;
    provState = 'mounted';
    document.getElementById('mountPvcBtn').disabled = true;
  });

  document.getElementById('deletePvcBtn').addEventListener('click', async () => {
    if (provState !== 'bound' && provState !== 'mounted') return;
    const events = document.getElementById('provisionEvents');
    const phase = document.getElementById('provPhase');

    if (provState === 'mounted') {
      addEvent(events, 'Pod my-app terminating...', 'warning');
      await new Promise(r => setTimeout(r, 400));
      addEvent(events, `kubelet: NodeUnpublishVolume`, 'info');
      await new Promise(r => setTimeout(r, 300));
      addEvent(events, `kubelet: NodeUnstageVolume`, 'info');
      document.getElementById('provMount').innerHTML = '';
      await new Promise(r => setTimeout(r, 300));
      addEvent(events, `external-attacher: ControllerUnpublishVolume → detached`, 'info');
      document.getElementById('provVA').innerHTML = '';
    }

    addEvent(events, 'PVC my-pvc deleted', 'warning');
    await new Promise(r => setTimeout(r, 400));
    phase.textContent = 'Released';
    phase.className = 'prov-phase released';
    addEvent(events, `Reclaim policy: Delete → external-provisioner: DeleteVolume(vol-${volId})`, 'warning');
    await new Promise(r => setTimeout(r, 500));
    addEvent(events, `PV pv-vol-${volId} deleted, backend volume destroyed`, 'error');

    document.getElementById('provPVC').innerHTML = '';
    document.getElementById('provPV').innerHTML = '';
    phase.textContent = 'Deleted';
    phase.className = 'prov-phase';
    provState = 'none';
    document.getElementById('createPvcBtn').disabled = false;
    document.getElementById('mountPvcBtn').disabled = true;
    document.getElementById('deletePvcBtn').disabled = true;
  });

  document.getElementById('resetProvBtn').addEventListener('click', () => {
    provState = 'none';
    document.getElementById('provPhase').textContent = 'No PVC';
    document.getElementById('provPhase').className = 'prov-phase';
    document.getElementById('provVol').textContent = 'Volume: —';
    document.getElementById('provisionEvents').innerHTML = '<div class="event-header">Provisioning Events</div>';
    ['provPVC','provPV','provVA','provMount'].forEach(id => document.getElementById(id).innerHTML = '');
    document.getElementById('createPvcBtn').disabled = false;
    document.getElementById('mountPvcBtn').disabled = true;
    document.getElementById('deletePvcBtn').disabled = true;
  });

  // Attach/Mount Flow Animation
  const flowStages = ['afSchedule','afAttach','afStage','afPublish','afReady'];
  const flowDetails = [
    'Scheduler selects a node for the pod. If volumeBindingMode is WaitForFirstConsumer, provisioning happens now. The scheduler considers topology constraints to place the pod near the volume.',
    'The Attach/Detach (AD) controller creates a VolumeAttachment object. The external-attacher calls ControllerPublishVolume on the CSI driver. For cloud providers, this means API calls like ec2:AttachVolume. This can take 5-30 seconds depending on the backend.',
    'Kubelet calls NodeStageVolume on the CSI node plugin. The driver formats the block device (ext4/xfs) if needed and mounts it to a staging directory (/var/lib/kubelet/plugins/...). This is a global mount — shared if multiple pods on the same node use the same volume.',
    'Kubelet calls NodePublishVolume to create a bind-mount from the staging directory into the pod\'s volume directory (/var/lib/kubelet/pods/<uid>/volumes/...). Mount propagation settings control visibility. The container runtime then mounts this path into the container.',
    'The volume is fully mounted and the pod\'s container can read and write to the volume path. The kubelet reports the volume as mounted in the pod status. If the volume supports metrics, usage data flows to the Metrics Server for monitoring.'
  ];

  document.getElementById('startFlowBtn').addEventListener('click', async () => {
    flowStages.forEach(id => { const e = document.getElementById(id); e.classList.remove('active','done'); });
    for (let i = 0; i < flowStages.length; i++) {
      const el = document.getElementById(flowStages[i]);
      el.classList.add('active');
      document.getElementById('afDetail').innerHTML = `<p><strong>${el.querySelector('.af-label').textContent}:</strong> ${flowDetails[i]}</p>`;
      await new Promise(r => setTimeout(r, 1200));
      el.classList.remove('active');
      el.classList.add('done');
    }
  });

  document.getElementById('detachFlowBtn').addEventListener('click', async () => {
    const reverseDetails = [
      'Pod is terminating. Kubelet begins the unmount sequence.',
      'NodeUnpublishVolume: Remove the bind-mount from the pod directory.',
      'NodeUnstageVolume: Unmount the volume from the staging directory.',
      'ControllerUnpublishVolume: Detach the volume from the node (e.g., ec2:DetachVolume).',
      'Volume is fully detached and available for reattachment to another node.'
    ];
    for (let i = flowStages.length - 1; i >= 0; i--) {
      const el = document.getElementById(flowStages[i]);
      el.classList.remove('done');
      el.classList.add('active');
      document.getElementById('afDetail').innerHTML = `<p><strong>Detach step:</strong> ${reverseDetails[flowStages.length - 1 - i]}</p>`;
      await new Promise(r => setTimeout(r, 900));
      el.classList.remove('active');
    }
    document.getElementById('afDetail').innerHTML = '<p>Detach complete. Volume is free.</p>';
  });

  document.getElementById('resetFlowBtn').addEventListener('click', () => {
    flowStages.forEach(id => { const e = document.getElementById(id); e.classList.remove('active','done'); });
    document.getElementById('afDetail').innerHTML = '<p>Click "Start Flow" to see the full attach → stage → mount pipeline with timing details.</p>';
  });

  // Access Modes
  const modeData = {
    rwo: { title: 'ReadWriteOnce (RWO)', desc: 'The volume can be mounted as read-write by a <strong>single node</strong>. Multiple pods on the same node can still access it. This is the most common mode for block storage (EBS, Persistent Disk, Azure Disk). If a pod moves to a different node, the volume must be detached and reattached.' },
    rox: { title: 'ReadOnlyMany (ROX)', desc: 'The volume can be mounted as <strong>read-only by many nodes</strong> simultaneously. Useful for sharing configuration data, ML models, or static assets across many pods. The volume must be pre-populated — you can\'t write to it once mounted as ROX.' },
    rwx: { title: 'ReadWriteMany (RWX)', desc: 'The volume can be mounted as <strong>read-write by many nodes</strong>. Required for shared filesystems (NFS, CephFS, EFS). Block storage drivers (EBS, PD) generally don\'t support this. Be careful with concurrent writes — the application must handle locking.' },
    rwop: { title: 'ReadWriteOncePod (RWOP)', desc: 'Kubernetes 1.29+ stable feature. The volume can only be mounted by a <strong>single pod</strong> in the entire cluster. Stricter than RWO (which allows multiple pods on the same node). Essential for applications that must guarantee exclusive access, like databases with WAL files.' },
    delete: { title: 'Delete Reclaim Policy', desc: 'When the PVC is deleted, the PV and the underlying storage volume are <strong>automatically deleted</strong>. This is the default for dynamically provisioned volumes. Good for ephemeral workloads and dev environments. Dangerous for production — accidental PVC deletion means permanent data loss.' },
    retain: { title: 'Retain Reclaim Policy', desc: 'When the PVC is deleted, the PV transitions to "Released" and the underlying storage is <strong>preserved</strong>. An admin must manually clean up: delete the PV, optionally delete the storage, or clear the claimRef to allow rebinding. Always use Retain for production databases and critical data.' }
  };

  document.querySelectorAll('.mode-card').forEach(el => {
    el.addEventListener('click', () => {
      document.querySelectorAll('.mode-card').forEach(c => c.classList.remove('active'));
      el.classList.add('active');
      const d = modeData[el.dataset.mode];
      if (d) {
        document.getElementById('modeDetail').innerHTML = `<div class="mode-detail-title">${d.title}</div><div class="mode-detail-desc">${d.desc}</div>`;
      }
    });
  });

  // Volume Expansion
  const expandSlider = document.getElementById('expandSlider');
  expandSlider.addEventListener('input', () => document.getElementById('expandLabel').textContent = expandSlider.value + 'Gi');

  document.getElementById('expandBtn').addEventListener('click', async () => {
    const newSize = parseInt(expandSlider.value);
    const events = document.getElementById('expandEvents');
    const currentBar = document.getElementById('expandCurrent');
    const targetBar = document.getElementById('expandTarget');

    addEvent(events, `PVC edit: spec.resources.requests.storage → ${newSize}Gi`, 'info');
    await new Promise(r => setTimeout(r, 500));
    addEvent(events, 'external-resizer detected PVC size change', 'info');
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, `ControllerExpandVolume(${newSize}Gi) → CSI driver`, 'info');

    targetBar.style.width = (newSize - 10) + '%';
    targetBar.innerHTML = `<span>+${newSize - 10}Gi</span>`;
    await new Promise(r => setTimeout(r, 800));
    addEvent(events, 'Backend volume expanded ✓', 'success');
    await new Promise(r => setTimeout(r, 400));
    addEvent(events, 'FileSystemResizePending condition set on PVC', 'warning');
    await new Promise(r => setTimeout(r, 500));
    addEvent(events, 'kubelet: NodeExpandVolume → resize ext4 filesystem online', 'info');
    await new Promise(r => setTimeout(r, 600));
    addEvent(events, `Filesystem expanded to ${newSize}Gi ✓`, 'success');

    currentBar.style.width = (newSize) + '%';
    currentBar.innerHTML = `<span>${newSize}Gi</span>`;
    targetBar.style.width = '0%';
    targetBar.innerHTML = '';
  });

  document.getElementById('resetExpandBtn').addEventListener('click', () => {
    document.getElementById('expandCurrent').style.width = '30%';
    document.getElementById('expandCurrent').innerHTML = '<span>10Gi</span>';
    document.getElementById('expandTarget').style.width = '0%';
    document.getElementById('expandTarget').innerHTML = '';
    document.getElementById('expandEvents').innerHTML = '<div class="event-header">Expansion Events</div>';
  });
</script>
