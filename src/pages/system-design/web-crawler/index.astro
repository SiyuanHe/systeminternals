  ::-webkit-scrollbar-thumb { background: #475569; border-radius: 3px; }
</style>

<script>
  // =============================================
  // SECTION 1: BFS / DFS GRAPH CRAWL
  // =============================================
  (function() {
    const canvas = document.getElementById('graphCanvas');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    canvas.width = 700 * dpr;
    canvas.height = 450 * dpr;
    ctx.scale(dpr, dpr);

    const STATES = { UNVISITED: 0, FRONTIER: 1, CRAWLING: 2, VISITED: 3 };
    const COLORS = { 0: '#475569', 1: '#fbbf24', 2: '#f97316', 3: '#4ade80' };

    // Generate a web graph
    let nodes = [];
    let edges = [];
    let nodeStates = [];
    let frontier = [];
    let visited = new Set();
    let crawlStrategy = 'bfs';
    let crawlInterval = null;
    let crawlRunning = false;
    let totalDiscovered = 0;

    function generateGraph() {
      const seedUrl = document.getElementById('seedUrlInput').value || 'example.com';
      const pages = [
        seedUrl,
        seedUrl + '/about',
        seedUrl + '/blog',
        seedUrl + '/blog/post-1',
        seedUrl + '/blog/post-2',
        seedUrl + '/products',
        seedUrl + '/products/item-a',
        seedUrl + '/products/item-b',
        seedUrl + '/contact',
        seedUrl + '/faq',
        seedUrl + '/blog/post-3',
        seedUrl + '/products/item-c',
        'docs.' + seedUrl,
        'docs.' + seedUrl + '/api',
        'shop.' + seedUrl,
      ];

      const positions = [
        [350,40],[180,120],[520,120],[100,220],[260,220],
        [440,220],[360,320],[520,320],[180,340],[60,340],
        [420,130],[600,230],[150,50],[80,130],[600,40]
      ];

      nodes = pages.map((url, i) => ({
        id: i, url: url, x: positions[i][0], y: positions[i][1], radius: 18
      }));

      edges = [
        [0,1],[0,2],[0,8],[1,3],[1,4],[2,5],[2,10],
        [5,6],[5,7],[3,9],[4,10],[6,11],[0,12],[12,13],[2,14]
      ];

      nodeStates = new Array(nodes.length).fill(STATES.UNVISITED);
    }

    function drawGraph() {
      ctx.clearRect(0, 0, 700, 450);

      // Draw edges
      edges.forEach(([a, b]) => {
        ctx.beginPath();
        ctx.moveTo(nodes[a].x, nodes[a].y);
        ctx.lineTo(nodes[b].x, nodes[b].y);
        ctx.strokeStyle = 'rgba(71,85,105,0.5)';
        ctx.lineWidth = 1.5;
        ctx.stroke();

        // Arrow
        const dx = nodes[b].x - nodes[a].x;
        const dy = nodes[b].y - nodes[a].y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        const nx = dx/dist, ny = dy/dist;
        const ax = nodes[b].x - nx * nodes[b].radius;
        const ay = nodes[b].y - ny * nodes[b].radius;
        ctx.beginPath();
        ctx.moveTo(ax, ay);
        ctx.lineTo(ax - nx*8 - ny*4, ay - ny*8 + nx*4);
        ctx.lineTo(ax - nx*8 + ny*4, ay - ny*8 - nx*4);
        ctx.fillStyle = 'rgba(71,85,105,0.5)';
        ctx.fill();
      });

      // Draw nodes
      nodes.forEach((node, i) => {
        const state = nodeStates[i];
        ctx.beginPath();
        ctx.arc(node.x, node.y, node.radius, 0, Math.PI*2);

        if (state === STATES.CRAWLING) {
          ctx.shadowBlur = 15;
          ctx.shadowColor = '#f97316';
        } else {
          ctx.shadowBlur = 0;
        }

        ctx.fillStyle = state === STATES.CRAWLING
          ? 'rgba(249,115,22,0.3)'
          : state === STATES.VISITED
            ? 'rgba(74,222,128,0.15)'
            : state === STATES.FRONTIER
              ? 'rgba(251,191,36,0.15)'
              : 'rgba(71,85,105,0.2)';
        ctx.fill();

        ctx.strokeStyle = COLORS[state];
        ctx.lineWidth = state === STATES.CRAWLING ? 3 : 2;
        ctx.stroke();
        ctx.shadowBlur = 0;

        // Label
        const label = node.url.split('/').pop() || node.url.replace(/https?:\/\//, '').split('/')[0];
        ctx.fillStyle = COLORS[state];
        ctx.font = '10px sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText(label.slice(0, 12), node.x, node.y + 4);
      });
    }

    function getNeighbors(nodeId) {
      const neighbors = [];
      edges.forEach(([a, b]) => {
        if (a === nodeId && !visited.has(b)) neighbors.push(b);
      });
      return neighbors;
    }

    function updateFrontierUI() {
      const list = document.getElementById('frontierList');
      const title = document.getElementById('frontierTitle');
      title.textContent = crawlStrategy === 'bfs'
        ? '\u{1F4E5} URL Frontier (Queue - BFS)'
        : '\u{1F4E5} URL Frontier (Stack - DFS)';
      list.innerHTML = '';
      frontier.forEach(id => {
        const el = document.createElement('div');
        el.className = 'frontier-item';
        el.textContent = nodes[id].url;
        list.appendChild(el);
      });
      document.getElementById('visitedCount').textContent = visited.size;
      document.getElementById('frontierCount').textContent = frontier.length;
      document.getElementById('totalFound').textContent = totalDiscovered;
    }

    function addLog(msg, type) {
      const log = document.getElementById('crawlLog');
      const entry = document.createElement('div');
      entry.className = 'log-entry ' + type;
      entry.textContent = msg;
      log.insertBefore(entry, log.firstChild);
      if (log.children.length > 50) log.removeChild(log.lastChild);
    }

    function crawlStep() {
      // Finish current crawling
      nodes.forEach((_, i) => {
        if (nodeStates[i] === STATES.CRAWLING) nodeStates[i] = STATES.VISITED;
      });

      if (frontier.length === 0) {
        stopCrawl();
        addLog('Crawl complete!', 'discover');
        return;
      }

      const current = crawlStrategy === 'bfs' ? frontier.shift() : frontier.pop();
      if (visited.has(current)) { drawGraph(); updateFrontierUI(); return; }

      visited.add(current);
      nodeStates[current] = STATES.CRAWLING;
      addLog('FETCH ' + nodes[current].url, 'fetch');

      const neighbors = getNeighbors(current);
      neighbors.forEach(n => {
        if (!visited.has(n) && !frontier.includes(n)) {
          frontier.push(n);
          nodeStates[n] = STATES.FRONTIER;
          totalDiscovered++;
          addLog('  Found link: ' + nodes[n].url, 'discover');
        } else if (visited.has(n)) {
          addLog('  Already visited: ' + nodes[n].url, 'skip');
        }
      });

      drawGraph();
      updateFrontierUI();
    }

    function startCrawl() {
      if (crawlRunning) return;
      if (frontier.length === 0 && visited.size === 0) {
        frontier.push(0);
        nodeStates[0] = STATES.FRONTIER;
        totalDiscovered = 1;
      }
      crawlRunning = true;
      const speed = 1100 - document.getElementById('crawlSpeed').value * 100;
      crawlInterval = setInterval(crawlStep, speed);
      document.getElementById('startCrawlBtn').textContent = '\u23F8\uFE0F Pause';
    }

    function stopCrawl() {
      crawlRunning = false;
      clearInterval(crawlInterval);
      document.getElementById('startCrawlBtn').textContent = '\u25B6\uFE0F Start Crawl';
    }

    function resetCrawl() {
      stopCrawl();
      frontier = [];
      visited = new Set();
      totalDiscovered = 0;
      generateGraph();
      drawGraph();
      updateFrontierUI();
      document.getElementById('crawlLog').innerHTML = '';
    }

    document.getElementById('startCrawlBtn').addEventListener('click', () => {
      crawlRunning ? stopCrawl() : startCrawl();
    });

    document.getElementById('resetCrawlBtn').addEventListener('click', resetCrawl);

    document.getElementById('stepCrawlBtn').addEventListener('click', () => {
      if (crawlRunning) stopCrawl();
      if (frontier.length === 0 && visited.size === 0) {
        frontier.push(0);
        nodeStates[0] = STATES.FRONTIER;
        totalDiscovered = 1;
        updateFrontierUI();
      }
      crawlStep();
    });

    document.querySelectorAll('[data-strategy]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-strategy]').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        crawlStrategy = btn.dataset.strategy;
        updateFrontierUI();
      });
    });

    document.getElementById('crawlSpeed').addEventListener('input', (e) => {
      document.getElementById('speedLabel').textContent = e.target.value;
      if (crawlRunning) {
        stopCrawl();
        startCrawl();
      }
    });

    generateGraph();
    drawGraph();
    updateFrontierUI();
  })();

  // =============================================
  // SECTION 2: URL FRONTIER & PRIORITY QUEUE
  // =============================================
  (function() {
    const frontQueues = { high: [], medium: [], low: [] };
    const backQueues = {};
    let totalEnqueued = 0, totalDequeued = 0;
    let autoInterval = null;

    const sampleUrls = [
      { url: 'https://google.com/search', priority: 'high' },
      { url: 'https://wikipedia.org/wiki/Main', priority: 'high' },
      { url: 'https://news.ycombinator.com/', priority: 'high' },
      { url: 'https://github.com/trending', priority: 'medium' },
      { url: 'https://stackoverflow.com/questions', priority: 'medium' },
      { url: 'https://reddit.com/r/programming', priority: 'medium' },
      { url: 'https://blog.example.com/post-1', priority: 'low' },
      { url: 'https://docs.example.com/api/v2', priority: 'low' },
      { url: 'https://shop.example.com/items', priority: 'low' },
      { url: 'https://google.com/maps', priority: 'high' },
      { url: 'https://github.com/explore', priority: 'medium' },
      { url: 'https://blog.example.com/post-2', priority: 'low' },
    ];

    function getDomain(url) {
      try {
        return url.replace(/https?:\/\//, '').split('/')[0];
      } catch { return 'unknown'; }
    }

    function enqueueUrl(url, priority) {
      frontQueues[priority].push(url);
      const domain = getDomain(url);
      if (!backQueues[domain]) backQueues[domain] = [];
      backQueues[domain].push(url);
      totalEnqueued++;
      renderFrontier();
    }

    function dequeueUrl() {
      let url = null;
      for (const p of ['high', 'medium', 'low']) {
        if (frontQueues[p].length > 0) {
          url = frontQueues[p].shift();
          break;
        }
      }
      if (!url) return;

      const domain = getDomain(url);
      if (backQueues[domain]) {
        const idx = backQueues[domain].indexOf(url);
        if (idx !== -1) backQueues[domain].splice(idx, 1);
        if (backQueues[domain].length === 0) delete backQueues[domain];
      }
      totalDequeued++;
      renderFrontier();
    }

    function renderFrontier() {
      ['high', 'medium', 'low'].forEach(p => {
        const container = document.getElementById('pq' + p.charAt(0).toUpperCase() + p.slice(1) + 'Items');
        container.innerHTML = '';
        frontQueues[p].forEach(url => {
          const el = document.createElement('div');
          el.className = 'pq-item';
          el.textContent = url.replace(/https?:\/\//, '');
          el.title = url;
          container.appendChild(el);
        });
      });

      const dqContainer = document.getElementById('domainQueues');
      dqContainer.innerHTML = '';
      Object.keys(backQueues).sort().forEach(domain => {
        const dq = document.createElement('div');
        dq.className = 'domain-queue';
        dq.innerHTML = '<div class="domain-queue-header"><span>' + domain + '</span><span>' + backQueues[domain].length + ' URLs</span></div>';
        const items = document.createElement('div');
        items.className = 'domain-queue-items';
        backQueues[domain].forEach(url => {
          const el = document.createElement('div');
          el.className = 'dq-item';
          el.textContent = url.replace(/https?:\/\//, '').replace(domain, '').slice(1) || '/';
          items.appendChild(el);
        });
        dq.appendChild(items);
        dqContainer.appendChild(dq);
      });

      document.getElementById('totalEnqueued').textContent = totalEnqueued;
      document.getElementById('totalDequeued').textContent = totalDequeued;
      document.getElementById('domainCount').textContent = Object.keys(backQueues).length;
    }

    document.getElementById('enqueueBtn').addEventListener('click', () => {
      const url = document.getElementById('newUrlInput').value.trim();
      const priority = document.getElementById('prioritySelect').value;
      if (url) enqueueUrl(url, priority);
    });

    document.getElementById('dequeueBtn').addEventListener('click', dequeueUrl);

    document.getElementById('autoFrontierBtn').addEventListener('click', () => {
      if (autoInterval) {
        clearInterval(autoInterval);
        autoInterval = null;
        document.getElementById('autoFrontierBtn').textContent = '\u25B6\uFE0F Auto Demo';
        return;
      }
      let idx = 0;
      document.getElementById('autoFrontierBtn').textContent = '\u23F9\uFE0F Stop';
      autoInterval = setInterval(() => {
        if (idx < sampleUrls.length) {
          enqueueUrl(sampleUrls[idx].url, sampleUrls[idx].priority);
          idx++;
        } else {
          if (Object.keys(backQueues).length > 0) {
            dequeueUrl();
          } else {
            clearInterval(autoInterval);
            autoInterval = null;
            document.getElementById('autoFrontierBtn').textContent = '\u25B6\uFE0F Auto Demo';
          }
        }
      }, 600);
    });

    renderFrontier();
  })();

  // =============================================
  // SECTION 3: POLITENESS & ROBOTS.TXT
  // =============================================
  (function() {
    const genericRules = {
      disallow: ['/admin/', '/private/', '/api/internal/'],
      allow: ['/api/public/'],
      crawlDelay: 2
    };
    const mybotRules = {
      disallow: ['/secret/'],
      allow: ['/'],
      crawlDelay: 1
    };

    const testUrls = [
      '/about', '/admin/settings', '/blog/post-1', '/private/data',
      '/api/internal/users', '/api/public/docs', '/products/shoes',
      '/secret/keys', '/contact', '/admin/login'
    ];

    function getRules() {
      return document.getElementById('userAgentSelect').value === 'mybot' ? mybotRules : genericRules;
    }

    function isAllowed(path) {
      const rules = getRules();
      // Check allow first (more specific)
      for (const a of rules.allow) {
        if (path.startsWith(a)) return true;
      }
      for (const d of rules.disallow) {
        if (path.startsWith(d)) return false;
      }
      return true;
    }

    function renderUrlTests() {
      const list = document.getElementById('urlTestList');
      list.innerHTML = '';
      testUrls.forEach(url => {
        const allowed = isAllowed(url);
        const el = document.createElement('div');
        el.className = 'url-test-item ' + (allowed ? 'allowed' : 'disallowed');
        el.innerHTML = '<span class="url-test-status">' + (allowed ? '\u2705' : '\u274C') + '</span><span>' + url + '</span>';
        list.appendChild(el);
      });
      document.getElementById('currentDelay').textContent = getRules().crawlDelay;
    }

    document.getElementById('testUrlBtn').addEventListener('click', () => {
      const path = document.getElementById('testUrlInput').value.trim();
      if (!path) return;
      if (!testUrls.includes(path)) testUrls.push(path);
      renderUrlTests();
    });

    document.getElementById('userAgentSelect').addEventListener('change', renderUrlTests);

    // Timeline visualization
    let timelineRunning = false;
    document.getElementById('startTimelineBtn').addEventListener('click', () => {
      if (timelineRunning) return;
      timelineRunning = true;
      const viz = document.getElementById('timelineViz');
      viz.innerHTML = '';
      const rules = getRules();
      const delay = rules.crawlDelay;
      const requests = ['/page1', '/page2', '/page3', '/page4', '/page5'];

      const bar = document.createElement('div');
      bar.className = 'timeline-bar';
      bar.innerHTML = '<span class="timeline-label">host: example.com</span>';
      const track = document.createElement('div');
      track.className = 'timeline-track';
      bar.appendChild(track);
      viz.appendChild(bar);

      const label = document.createElement('div');
      label.style.cssText = 'font-size:0.75rem;color:#64748b;margin-top:4px;';
      viz.appendChild(label);

      let i = 0;
      const interval = setInterval(() => {
        if (i >= requests.length) {
          clearInterval(interval);
          timelineRunning = false;
          label.textContent = 'All requests sent with ' + delay + 's delay between each.';
          return;
        }
        const req = document.createElement('div');
        req.className = 'timeline-request allowed-req';
        req.style.left = (i * (delay * 40 + 20)) + 'px';
        req.textContent = (i + 1);
        req.title = requests[i];
        track.appendChild(req);
        label.textContent = 'Request ' + (i+1) + ': ' + requests[i] + ' (t=' + (i*delay) + 's)';
        i++;
      }, delay * 500);
    });

    renderUrlTests();
  })();

  // =============================================
  // SECTION 4: BLOOM FILTER
  // =============================================
  (function() {
    const BLOOM_SIZE = 64;
    const NUM_HASHES = 3;
    let bitArray = new Array(BLOOM_SIZE).fill(0);
    let addedUrls = new Set();
    let urlsAdded = 0;
    let falsePositiveCount = 0;
    let autoBloomInterval = null;

    function hashStr(str, seed) {
      let h = seed;
      for (let i = 0; i < str.length; i++) {
        h = ((h << 5) - h + str.charCodeAt(i)) | 0;
        h = (h * 2654435761) | 0;
      }
      return Math.abs(h) % BLOOM_SIZE;
    }

    function getHashes(url) {
      return [hashStr(url, 0x9e3779b9), hashStr(url, 0x517cc1b7), hashStr(url, 0x6a09e667)];
    }

    function renderBitArray(highlights, isFalsePos) {
      const container = document.getElementById('bitArray');
      container.innerHTML = '';
      for (let i = 0; i < BLOOM_SIZE; i++) {
        const cell = document.createElement('div');
        cell.className = 'bit-cell';
        if (bitArray[i]) cell.classList.add('set');
        if (highlights && highlights.includes(i)) {
          cell.classList.add(isFalsePos ? 'false-pos' : 'highlight');
        }
        cell.textContent = bitArray[i];
        container.appendChild(cell);
      }

      const bitsSetCount = bitArray.filter(b => b).length;
      document.getElementById('bloomAdded').textContent = urlsAdded;
      document.getElementById('bitsSet').textContent = bitsSetCount;
      document.getElementById('fillRatio').textContent = Math.round(bitsSetCount / BLOOM_SIZE * 100) + '%';
      document.getElementById('falsePositives').textContent = falsePositiveCount;

      // Space comparison
      const bloomBytes = BLOOM_SIZE / 8;
      const hashsetBytes = urlsAdded * 40;
      document.getElementById('bloomSpaceVal').textContent = bloomBytes + ' bytes';
      document.getElementById('hashsetSpaceVal').textContent = hashsetBytes + ' bytes';
      const maxBytes = Math.max(bloomBytes, hashsetBytes, 1);
      document.getElementById('bloomSpaceBar').style.width = Math.max(5, (bloomBytes / maxBytes) * 100) + '%';
      document.getElementById('hashsetSpaceBar').style.width = Math.max(urlsAdded ? 5 : 0, (hashsetBytes / maxBytes) * 100) + '%';
    }

    function addUrl(url) {
      const hashes = getHashes(url);
      hashes.forEach(h => { bitArray[h] = 1; });
      addedUrls.add(url);
      urlsAdded++;
      document.getElementById('bloomHashInfo').textContent =
        'ADD "' + url.slice(0, 40) + '" \u2192 bits [' + hashes.join(', ') + ']';
      addBloomLog('ADD: ' + url + ' \u2192 bits [' + hashes.join(', ') + ']', 'added');
      renderBitArray(hashes, false);
    }

    function checkUrl(url) {
      const hashes = getHashes(url);
      const mightExist = hashes.every(h => bitArray[h] === 1);
      const actuallyExists = addedUrls.has(url);

      if (mightExist && !actuallyExists) {
        falsePositiveCount++;
        document.getElementById('bloomHashInfo').textContent =
          'FALSE POSITIVE! "' + url.slice(0, 30) + '" bits [' + hashes.join(', ') + '] all set but URL was never added';
        addBloomLog('FALSE POSITIVE: ' + url, 'false-positive');
        renderBitArray(hashes, true);
      } else if (mightExist) {
        document.getElementById('bloomHashInfo').textContent =
          'FOUND: "' + url.slice(0, 35) + '" bits [' + hashes.join(', ') + '] all set (true positive)';
        addBloomLog('FOUND: ' + url, 'found');
        renderBitArray(hashes, false);
      } else {
        document.getElementById('bloomHashInfo').textContent =
          'NOT FOUND: "' + url.slice(0, 35) + '" some bits not set (definitely not in set)';
        addBloomLog('NOT FOUND: ' + url + ' (definite negative)', 'not-found');
        renderBitArray(hashes, false);
      }
    }

    function addBloomLog(msg, type) {
      const log = document.getElementById('bloomLog');
      const entry = document.createElement('div');
      entry.className = 'bloom-log-entry ' + type;
      entry.textContent = msg;
      log.insertBefore(entry, log.firstChild);
      if (log.children.length > 30) log.removeChild(log.lastChild);
    }

    document.getElementById('bloomAddBtn').addEventListener('click', () => {
      const url = document.getElementById('bloomUrlInput').value.trim();
      if (url) addUrl(url);
    });

    document.getElementById('bloomCheckBtn').addEventListener('click', () => {
      const url = document.getElementById('bloomUrlInput').value.trim();
      if (url) checkUrl(url);
    });

    document.getElementById('bloomResetBtn').addEventListener('click', () => {
      bitArray = new Array(BLOOM_SIZE).fill(0);
      addedUrls = new Set();
      urlsAdded = 0;
      falsePositiveCount = 0;
      document.getElementById('bloomLog').innerHTML = '';
      document.getElementById('bloomHashInfo').textContent = 'Add a URL to see which bits get set';
      renderBitArray();
    });

    document.getElementById('bloomDemoBtn').addEventListener('click', () => {
      if (autoBloomInterval) {
        clearInterval(autoBloomInterval);
        autoBloomInterval = null;
        document.getElementById('bloomDemoBtn').textContent = '\u25B6\uFE0F Auto Demo';
        return;
      }

      const demoUrls = [
        'https://example.com/page1', 'https://example.com/page2',
        'https://example.com/page3', 'https://news.com/article',
        'https://blog.com/post', 'https://shop.com/item',
      ];
      const checkUrls = [
        'https://example.com/page1', 'https://never-added.com/xyz',
        'https://false-positive-test.com/abc', 'https://blog.com/post',
        'https://unknown.com/page', 'https://example.com/page2',
      ];

      let idx = 0;
      document.getElementById('bloomDemoBtn').textContent = '\u23F9\uFE0F Stop';
      autoBloomInterval = setInterval(() => {
        if (idx < demoUrls.length) {
          addUrl(demoUrls[idx]);
        } else if (idx < demoUrls.length + checkUrls.length) {
          checkUrl(checkUrls[idx - demoUrls.length]);
        } else {
          clearInterval(autoBloomInterval);
          autoBloomInterval = null;
          document.getElementById('bloomDemoBtn').textContent = '\u25B6\uFE0F Auto Demo';
        }
        idx++;
      }, 700);
    });

    renderBitArray();
  })();

  // =============================================
  // SECTION 5: DISTRIBUTED CRAWLING
  // =============================================
  (function() {
    const hashCanvas = document.getElementById('hashRingCanvas');
    const hctx = hashCanvas.getContext('2d');
    const hdpr = window.devicePixelRatio || 1;
    hashCanvas.width = 300 * hdpr;
    hashCanvas.height = 300 * hdpr;
    hctx.scale(hdpr, hdpr);

    let workerNum = 4;
    let workers = [];
    let domains = [
      'google.com', 'wikipedia.org', 'github.com', 'stackoverflow.com',
      'reddit.com', 'amazon.com', 'nytimes.com', 'bbc.co.uk'
    ];
    let domainAssignments = {};
    let distRunning = false;
    let distInterval = null;
    let totalCrawledCount = 0;

    const workerColors = ['#60a5fa', '#4ade80', '#fbbf24', '#f87171', '#a78bfa', '#f97316', '#06b6d4', '#e879f9'];

    function simpleHash(str) {
      let h = 0;
      for (let i = 0; i < str.length; i++) {
        h = ((h << 5) - h + str.charCodeAt(i)) | 0;
      }
      return Math.abs(h);
    }

    function assignDomains() {
      domainAssignments = {};
      workers.forEach(w => { w.domains = []; w.crawled = 0; w.status = 'idle'; });
      domains.forEach(domain => {
        const hash = simpleHash(domain);
        const workerIdx = hash % workerNum;
        domainAssignments[domain] = workerIdx;
        workers[workerIdx].domains.push(domain);
      });
    }

    function initWorkers() {
      workerNum = parseInt(document.getElementById('workerCount').value);
      workers = [];
      for (let i = 0; i < workerNum; i++) {
        workers.push({
          id: i,
          name: 'Worker-' + (i + 1),
          color: workerColors[i % workerColors.length],
          domains: [],
          crawled: 0,
          status: 'idle'
        });
      }
      totalCrawledCount = 0;
      assignDomains();
      renderWorkers();
      renderHashRing();
      renderCoordQueue();
      updateDistStats();
    }

    function renderHashRing() {
      hctx.clearRect(0, 0, 300, 300);
      const cx = 150, cy = 150, r = 110;

      // Ring
      hctx.beginPath();
      hctx.arc(cx, cy, r, 0, Math.PI * 2);
      hctx.strokeStyle = 'rgba(71,85,105,0.5)';
      hctx.lineWidth = 3;
      hctx.stroke();

      // Worker positions on ring
      workers.forEach((w, i) => {
        const angle = (i / workerNum) * Math.PI * 2 - Math.PI / 2;
        const wx = cx + r * Math.cos(angle);
        const wy = cy + r * Math.sin(angle);

        hctx.beginPath();
        hctx.arc(wx, wy, 12, 0, Math.PI * 2);
        hctx.fillStyle = w.color;
        hctx.globalAlpha = 0.3;
        hctx.fill();
        hctx.globalAlpha = 1;
        hctx.strokeStyle = w.color;
        hctx.lineWidth = 2;
        hctx.stroke();

        hctx.fillStyle = w.color;
        hctx.font = '10px sans-serif';
        hctx.textAlign = 'center';
        hctx.fillText('W' + (i + 1), wx, wy + 4);
      });

      // Domain positions
      domains.forEach(domain => {
        const hash = simpleHash(domain);
        const angle = ((hash % 360) / 360) * Math.PI * 2 - Math.PI / 2;
        const dx = cx + (r - 30) * Math.cos(angle);
        const dy = cy + (r - 30) * Math.sin(angle);
        const workerIdx = domainAssignments[domain];
        const color = workerIdx !== undefined ? workers[workerIdx].color : '#64748b';

        hctx.beginPath();
        hctx.arc(dx, dy, 4, 0, Math.PI * 2);
        hctx.fillStyle = color;
        hctx.fill();

        hctx.fillStyle = '#94a3b8';
        hctx.font = '8px sans-serif';
        hctx.textAlign = 'center';
        const short = domain.split('.')[0].slice(0, 6);
        hctx.fillText(short, dx, dy - 8);
      });

      // Center label
      hctx.fillStyle = '#64748b';
      hctx.font = '11px sans-serif';
      hctx.textAlign = 'center';
      hctx.fillText('Hash Ring', cx, cy - 5);
      hctx.fillText(domains.length + ' domains', cx, cy + 10);
    }

    function renderWorkers() {
      const grid = document.getElementById('workersGrid');
      grid.innerHTML = '';
      workers.forEach(w => {
        const card = document.createElement('div');
        card.className = 'worker-card' + (w.status === 'busy' ? ' active crawling-now' : '');
        card.innerHTML =
          '<div class="worker-header">' +
            '<span class="worker-name" style="color:' + w.color + '">' + w.name + '</span>' +
            '<span class="worker-status ' + w.status + '">' + w.status + '</span>' +
          '</div>' +
          '<div class="worker-domains">Domains: ' + (w.domains.length > 0 ? w.domains.join(', ') : 'none') + '</div>' +
          '<div class="worker-progress"><div class="worker-progress-bar" style="width:' + Math.min(100, w.crawled * 5) + '%"></div></div>' +
          '<div class="worker-count">Crawled: ' + w.crawled + ' pages</div>';
        grid.appendChild(card);
      });
    }

    function renderCoordQueue() {
      const queue = document.getElementById('coordQueue');
      queue.innerHTML = '';
      domains.slice(0, 6).forEach(d => {
        const el = document.createElement('div');
        el.className = 'coord-item';
        const wIdx = domainAssignments[d];
        el.textContent = d + ' \u2192 W' + (wIdx + 1);
        queue.appendChild(el);
      });
    }

    function updateDistStats() {
      document.getElementById('activeWorkers').textContent = workerNum;
      document.getElementById('domainsAssigned').textContent = domains.length;
      document.getElementById('totalCrawled').textContent = totalCrawledCount;
      const rate = distRunning ? Math.round(workerNum * 2.5) : 0;
      document.getElementById('crawlRate').textContent = rate;
    }

    function distStep() {
      workers.forEach(w => {
        if (w.domains.length > 0) {
          w.status = 'busy';
          w.crawled += Math.floor(Math.random() * 3) + 1;
          totalCrawledCount += Math.floor(Math.random() * 3) + 1;
        }
      });
      renderWorkers();
      renderHashRing();
      updateDistStats();
    }

    document.getElementById('workerCount').addEventListener('input', (e) => {
      document.getElementById('workerLabel').textContent = e.target.value;
    });

    document.getElementById('startDistBtn').addEventListener('click', () => {
      if (distRunning) {
        distRunning = false;
        clearInterval(distInterval);
        workers.forEach(w => { w.status = 'idle'; });
        renderWorkers();
        updateDistStats();
        document.getElementById('startDistBtn').textContent = '\u25B6\uFE0F Start Distributed Crawl';
        return;
      }
      initWorkers();
      distRunning = true;
      distInterval = setInterval(distStep, 800);
      document.getElementById('startDistBtn').textContent = '\u23F9\uFE0F Stop';
    });

    document.getElementById('resetDistBtn').addEventListener('click', () => {
      distRunning = false;
      clearInterval(distInterval);
      initWorkers();
      document.getElementById('startDistBtn').textContent = '\u25B6\uFE0F Start Distributed Crawl';
    });

    document.getElementById('addDomainBtn').addEventListener('click', () => {
      const newDomains = ['medium.com', 'dev.to', 'hackernews.com', 'lobste.rs', 'techcrunch.com', 'wired.com', 'arstechnica.com'];
      const available = newDomains.filter(d => !domains.includes(d));
      if (available.length > 0) {
        domains.push(available[0]);
        assignDomains();
        renderWorkers();
        renderHashRing();
        renderCoordQueue();
        updateDistStats();
      }
    });

    initWorkers();
  })();

  // =============================================
  // SECTION 6: DECISION CARDS TOGGLE
  // =============================================
  (function() {
    document.querySelectorAll('.decision-header').forEach(header => {
      header.addEventListener('click', () => {
        const card = header.parentElement;
        card.classList.toggle('open');
      });
    });
    // Open first card by default
    const firstCard = document.querySelector('.decision-card');
    if (firstCard) firstCard.classList.add('open');
  })();
</script>
