<script>
  // ==========================================================
  // CDN ROUTING VISUALIZATION
  // ==========================================================
  (function() {
    const svg = document.getElementById('cdnMap');
    const animGroup = document.getElementById('cdnAnimGroup');
    const latencyOverlay = document.getElementById('cdnLatencyOverlay');
    const infoEl = document.getElementById('cdnInfo');
    const users = svg.querySelectorAll('.cdn-user');
    const edges = {};
    let autoInterval = null;

    svg.querySelectorAll('.cdn-edge').forEach(e => {
      edges[e.dataset.edge] = {
        x: parseFloat(e.dataset.x),
        y: parseFloat(e.dataset.y)
      };
    });

    const originX = 450, originY = 215;
    const latencies = {
      'us-east': { edge: 12, origin: 85 },
      'us-west': { edge: 18, origin: 120 },
      'eu-west': { edge: 8, origin: 45 },
      'asia-east': { edge: 15, origin: 180 },
      'asia-south': { edge: 20, origin: 140 },
      'sa-east': { edge: 25, origin: 200 },
      'au': { edge: 22, origin: 220 }
    };
    const userNames = {
      'ny': 'New York', 'la': 'Los Angeles', 'london': 'London',
      'tokyo': 'Tokyo', 'mumbai': 'Mumbai', 'saopaulo': 'Sao Paulo', 'sydney': 'Sydney'
    };

    function clearAnim() {
      animGroup.innerHTML = '';
      latencyOverlay.innerHTML = '';
    }

    function animateRoute(userEl) {
      clearAnim();
      const ux = parseFloat(userEl.dataset.x);
      const uy = parseFloat(userEl.dataset.y);
      const nearestId = userEl.dataset.nearest;
      const edge = edges[nearestId];
      const lat = latencies[nearestId];
      const userId = userEl.dataset.user;

      document.getElementById('cdnDetailUser').textContent = userNames[userId];
      document.getElementById('cdnDetailEdge').textContent = nearestId.toUpperCase();
      document.getElementById('cdnDetailEdgeLat').textContent = lat.edge + ' ms';
      document.getElementById('cdnDetailOriginLat').textContent = lat.origin + ' ms';
      const savings = Math.round((1 - lat.edge / lat.origin) * 100);
      document.getElementById('cdnDetailSavings').textContent = savings + '% faster';
      infoEl.textContent = userNames[userId] + ' → ' + nearestId.toUpperCase();

      // Draw path: origin -> edge
      const path1 = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      path1.setAttribute('x1', originX); path1.setAttribute('y1', originY);
      path1.setAttribute('x2', edge.x); path1.setAttribute('y2', edge.y);
      path1.setAttribute('stroke', '#ff6b35'); path1.setAttribute('stroke-width', '1');
      path1.setAttribute('stroke-dasharray', '4'); path1.setAttribute('opacity', '0.5');
      animGroup.appendChild(path1);

      // Draw path: edge -> user
      const path2 = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      path2.setAttribute('x1', edge.x); path2.setAttribute('y1', edge.y);
      path2.setAttribute('x2', ux); path2.setAttribute('y2', uy);
      path2.setAttribute('stroke', '#00c9a7'); path2.setAttribute('stroke-width', '1.5');
      path2.setAttribute('stroke-dasharray', '4'); path2.setAttribute('opacity', '0.7');
      animGroup.appendChild(path2);

      // Animate packets: origin -> edge
      animatePacket(originX, originY, edge.x, edge.y, '#ff6b35', 800, () => {
        // Then edge -> user
        animatePacket(edge.x, edge.y, ux, uy, '#00c9a7', 400, null);
      });

      // Latency labels
      const midX1 = (originX + edge.x) / 2, midY1 = (originY + edge.y) / 2 - 10;
      addLabel(midX1, midY1, lat.origin + 'ms (origin)', '#ff9a6c');
      const midX2 = (edge.x + ux) / 2, midY2 = (edge.y + uy) / 2 - 10;
      addLabel(midX2, midY2, lat.edge + 'ms (edge)', '#4dffd4');
    }

    function animatePacket(x1, y1, x2, y2, color, duration, onDone) {
      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('r', '4');
      circle.setAttribute('fill', color);
      circle.setAttribute('cx', x1);
      circle.setAttribute('cy', y1);
      animGroup.appendChild(circle);
      let start = null;
      function step(ts) {
        if (!start) start = ts;
        const p = Math.min((ts - start) / duration, 1);
        circle.setAttribute('cx', x1 + (x2 - x1) * p);
        circle.setAttribute('cy', y1 + (y2 - y1) * p);
        if (p < 1) {
          requestAnimationFrame(step);
        } else {
          if (onDone) onDone();
        }
      }
      requestAnimationFrame(step);
    }

    function addLabel(x, y, text, color) {
      const t = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      t.setAttribute('x', x); t.setAttribute('y', y);
      t.setAttribute('text-anchor', 'middle');
      t.setAttribute('fill', color);
      t.setAttribute('font-size', '9');
      t.setAttribute('font-weight', 'bold');
      t.textContent = text;
      latencyOverlay.appendChild(t);
    }

    users.forEach(u => u.addEventListener('click', () => animateRoute(u)));

    document.getElementById('cdnResetBtn').addEventListener('click', () => {
      clearAnim();
      if (autoInterval) { clearInterval(autoInterval); autoInterval = null; }
      infoEl.textContent = 'Click a user icon to start routing';
      ['cdnDetailUser','cdnDetailEdge','cdnDetailEdgeLat','cdnDetailOriginLat','cdnDetailSavings'].forEach(id => {
        document.getElementById(id).textContent = '—';
      });
    });

    document.getElementById('cdnAutoBtn').addEventListener('click', () => {
      if (autoInterval) return;
      let idx = 0;
      const userArr = Array.from(users);
      animateRoute(userArr[0]);
      autoInterval = setInterval(() => {
        idx = (idx + 1) % userArr.length;
        animateRoute(userArr[idx]);
      }, 2000);
    });
  })();

  // ==========================================================
  // ADAPTIVE BITRATE SWITCHING
  // ==========================================================
  (function() {
    const canvas = document.getElementById('abrChart');
    const ctx = canvas.getContext('2d');
    const W = canvas.width, H = canvas.height;
    const tiers = [
      { label: '1080p', bitrate: 5.0, id: 'tier1080' },
      { label: '720p', bitrate: 2.5, id: 'tier720' },
      { label: '480p', bitrate: 1.2, id: 'tier480' },
      { label: '360p', bitrate: 0.6, id: 'tier360' },
      { label: '240p', bitrate: 0.3, id: 'tier240' }
    ];

    let bwHistory = [];
    let qualityHistory = [];
    let running = false;
    let bandwidth = 4.0;
    let bufferLevel = 0;
    let switchCount = 0;
    let rebufferCount = 0;
    let currentTier = 0;
    let qualitySum = 0;
    let qualitySamples = 0;
    let animFrame = null;
    let forceBwTarget = null;
    const MAX_POINTS = 120;
    const MAX_BUFFER = 30;

    function pickQuality(bw, buf) {
      // Buffer-based + throughput hybrid ABR
      let chosen = tiers.length - 1;
      for (let i = 0; i < tiers.length; i++) {
        if (bw >= tiers[i].bitrate * 1.2 && buf > 5) {
          chosen = i; break;
        } else if (bw >= tiers[i].bitrate) {
          chosen = i; break;
        }
      }
      // If buffer is low, be more conservative
      if (buf < 3) {
        chosen = Math.max(chosen, Math.min(tiers.length - 1, currentTier + 1));
      }
      return chosen;
    }

    function updateTierIndicators(idx) {
      tiers.forEach((t, i) => {
        document.getElementById(t.id).classList.toggle('active', i === idx);
      });
    }

    function drawChart() {
      ctx.clearRect(0, 0, W, H);
      const pad = { l: 50, r: 10, t: 15, b: 30 };
      const cw = W - pad.l - pad.r;
      const ch = H - pad.t - pad.b;
      const maxBw = 8;

      // Grid
      ctx.strokeStyle = '#1a2a4a';
      ctx.lineWidth = 0.5;
      for (let i = 0; i <= 4; i++) {
        const y = pad.t + ch * (1 - i / 4);
        ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(W - pad.r, y); ctx.stroke();
        ctx.fillStyle = '#64748b';
        ctx.font = '10px sans-serif';
        ctx.textAlign = 'right';
        ctx.fillText((maxBw * i / 4).toFixed(1) + ' Mbps', pad.l - 5, y + 3);
      }

      // Bandwidth line
      if (bwHistory.length > 1) {
        ctx.beginPath();
        ctx.strokeStyle = '#6c5ce7';
        ctx.lineWidth = 2;
        bwHistory.forEach((v, i) => {
          const x = pad.l + (i / MAX_POINTS) * cw;
          const y = pad.t + ch * (1 - v / maxBw);
          i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        });
        ctx.stroke();
      }

      // Quality line (step)
      if (qualityHistory.length > 1) {
        ctx.beginPath();
        ctx.strokeStyle = '#00c9a7';
        ctx.lineWidth = 2.5;
        qualityHistory.forEach((v, i) => {
          const x = pad.l + (i / MAX_POINTS) * cw;
          const y = pad.t + ch * (1 - v / maxBw);
          if (i === 0) ctx.moveTo(x, y);
          else {
            const prevX = pad.l + ((i - 1) / MAX_POINTS) * cw;
            ctx.lineTo(x, y);
          }
        });
        ctx.stroke();
      }

      // Tier threshold lines
      ctx.setLineDash([3, 3]);
      ctx.lineWidth = 0.5;
      tiers.forEach(t => {
        const y = pad.t + ch * (1 - t.bitrate / maxBw);
        ctx.strokeStyle = '#2a4a6f';
        ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(W - pad.r, y); ctx.stroke();
        ctx.fillStyle = '#4a5568';
        ctx.textAlign = 'left';
        ctx.fillText(t.label, W - pad.r - 35, y - 3);
      });
      ctx.setLineDash([]);
    }

    function tick() {
      if (!running) return;
      // Bandwidth simulation
      if (forceBwTarget !== null) {
        bandwidth += (forceBwTarget - bandwidth) * 0.15;
        if (Math.abs(bandwidth - forceBwTarget) < 0.1) forceBwTarget = null;
      } else {
        bandwidth += (Math.random() - 0.5) * 0.4;
        bandwidth = Math.max(0.15, Math.min(7.5, bandwidth));
      }

      const newTier = pickQuality(bandwidth, bufferLevel);
      if (newTier !== currentTier) {
        switchCount++;
        document.getElementById('abrSwitchCount').textContent = switchCount;
      }
      currentTier = newTier;
      const tierBitrate = tiers[currentTier].bitrate;

      // Buffer: gains from download, drains from playback
      const downloadRate = Math.max(0, bandwidth - tierBitrate);
      bufferLevel += downloadRate * 0.15;
      bufferLevel -= 0.5; // playback drain
      if (bufferLevel > MAX_BUFFER) bufferLevel = MAX_BUFFER;
      if (bufferLevel < 0) {
        bufferLevel = 0;
        rebufferCount++;
        document.getElementById('abrRebufferCount').textContent = rebufferCount;
      }

      bwHistory.push(bandwidth);
      qualityHistory.push(tierBitrate);
      if (bwHistory.length > MAX_POINTS) { bwHistory.shift(); qualityHistory.shift(); }

      qualitySum += tierBitrate;
      qualitySamples++;

      // Update UI
      document.getElementById('abrCurrentQuality').textContent = tiers[currentTier].label;
      document.getElementById('abrCurrentBitrate').textContent = tierBitrate.toFixed(1) + ' Mbps';
      updateTierIndicators(currentTier);
      const bufPct = (bufferLevel / MAX_BUFFER) * 100;
      document.getElementById('abrBufferBar').style.width = bufPct + '%';
      document.getElementById('abrBufferValue').textContent = bufferLevel.toFixed(1) + 's';

      // Avg quality
      const avgBr = qualitySum / qualitySamples;
      let avgLabel = '240p';
      for (const t of tiers) { if (avgBr >= t.bitrate) { avgLabel = t.label; break; } }
      document.getElementById('abrAvgQuality').textContent = avgLabel;

      drawChart();
      animFrame = setTimeout(tick, 200);
    }

    document.getElementById('abrStartBtn').addEventListener('click', () => {
      if (running) return;
      running = true;
      tick();
    });
    document.getElementById('abrStopBtn').addEventListener('click', () => {
      running = false;
      if (animFrame) clearTimeout(animFrame);
    });
    document.getElementById('abrDropBtn').addEventListener('click', () => {
      forceBwTarget = 0.2 + Math.random() * 0.3;
    });
    document.getElementById('abrSpikeBtn').addEventListener('click', () => {
      forceBwTarget = 5.0 + Math.random() * 2.5;
    });
    document.getElementById('abrResetBtn').addEventListener('click', () => {
      running = false;
      if (animFrame) clearTimeout(animFrame);
      bwHistory = []; qualityHistory = [];
      bandwidth = 4.0; bufferLevel = 0; switchCount = 0; rebufferCount = 0;
      currentTier = 0; qualitySum = 0; qualitySamples = 0; forceBwTarget = null;
      document.getElementById('abrCurrentQuality').textContent = '—';
      document.getElementById('abrCurrentBitrate').textContent = '— Mbps';
      document.getElementById('abrBufferBar').style.width = '0%';
      document.getElementById('abrBufferValue').textContent = '0.0s';
      document.getElementById('abrSwitchCount').textContent = '0';
      document.getElementById('abrRebufferCount').textContent = '0';
      document.getElementById('abrAvgQuality').textContent = '—';
      tiers.forEach(t => document.getElementById(t.id).classList.remove('active'));
      drawChart();
    });

    drawChart();
  })();

  // ==========================================================
  // ENCODING PIPELINE
  // ==========================================================
  (function() {
    const stages = [1, 2, 3, 4, 5];
    const renditions = [
      { res: '1080p', bitrate: '5.0 Mbps', size: '375 MB', chunks: 150 },
      { res: '720p', bitrate: '2.5 Mbps', size: '188 MB', chunks: 150 },
      { res: '480p', bitrate: '1.2 Mbps', size: '90 MB', chunks: 150 },
      { res: '360p', bitrate: '0.6 Mbps', size: '45 MB', chunks: 150 },
      { res: '240p', bitrate: '0.3 Mbps', size: '23 MB', chunks: 150 }
    ];
    let encoding = false;

    function resetPipeline() {
      encoding = false;
      stages.forEach(s => {
        document.getElementById('pipeStage' + s).classList.remove('active', 'done');
        document.getElementById('pipeProgress' + s).style.width = '0%';
      });
      document.getElementById('encodingOutputs').classList.remove('visible');
      document.getElementById('renditionGrid').innerHTML = '';
      // Reset size labels
      document.querySelectorAll('.pipeline-stage-size').forEach((el, i) => {
        el.textContent = i === 0 ? '18 GB' : '—';
      });
    }

    function animateStage(stageNum, duration) {
      return new Promise(resolve => {
        const el = document.getElementById('pipeStage' + stageNum);
        const prog = document.getElementById('pipeProgress' + stageNum);
        el.classList.add('active');
        let start = performance.now();
        function step(ts) {
          const p = Math.min((ts - start) / duration, 1);
          prog.style.width = (p * 100) + '%';
          if (p < 1) {
            requestAnimationFrame(step);
          } else {
            el.classList.remove('active');
            el.classList.add('done');
            resolve();
          }
        }
        requestAnimationFrame(step);
      });
    }

    async function runPipeline() {
      if (encoding) return;
      encoding = true;
      resetPipeline();
      encoding = true;

      // Stage 1: Upload
      await animateStage(1, 800);

      // Stage 2: Transcode
      document.querySelectorAll('.pipeline-stage-size')[1].textContent = 'H.265';
      await animateStage(2, 1200);

      // Stage 3: Multi-resolution
      document.querySelectorAll('.pipeline-stage-size')[2].textContent = '5 tiers';
      await animateStage(3, 1000);

      // Stage 4: Segmentation
      document.querySelectorAll('.pipeline-stage-size')[3].textContent = '750 chunks';
      await animateStage(4, 800);

      // Stage 5: Store
      document.querySelectorAll('.pipeline-stage-size')[4].textContent = '~721 MB';
      await animateStage(5, 600);

      // Show outputs
      const grid = document.getElementById('renditionGrid');
      const outputsEl = document.getElementById('encodingOutputs');
      outputsEl.classList.add('visible');
      for (let i = 0; i < renditions.length; i++) {
        await new Promise(r => setTimeout(r, 200));
        const r = renditions[i];
        const card = document.createElement('div');
        card.className = 'rendition-card';
        card.innerHTML = `<div class="rendition-res">${r.res}</div><div class="rendition-detail">${r.bitrate}</div><div class="rendition-size">${r.size}</div><div class="rendition-chunks">${r.chunks} chunks (4s each)</div>`;
        grid.appendChild(card);
      }
      encoding = false;
    }

    document.getElementById('encodeStartBtn').addEventListener('click', runPipeline);
    document.getElementById('encodeResetBtn').addEventListener('click', resetPipeline);
  })();

  // ==========================================================
  // CHUNK DELIVERY SIMULATION
  // ==========================================================
  (function() {
    const TOTAL_CHUNKS = 15;
    const timeline = document.getElementById('chunkTimeline');
    const playhead = document.getElementById('chunkPlayhead');
    const screen = document.getElementById('chunkScreen');
    const spinner = document.getElementById('chunkSpinner');
    const screenText = document.getElementById('chunkScreenText');
    const qualityBadge = document.getElementById('chunkQualityBadge');

    let chunks = [];
    let downloadIdx = 0;
    let playIdx = -1;
    let playing = false;
    let networkSpeed = 'fast'; // fast or slow
    let downloadTimer = null;
    let playTimer = null;

    function initTimeline() {
      timeline.innerHTML = '';
      chunks = [];
      for (let i = 0; i < TOTAL_CHUNKS; i++) {
        const cell = document.createElement('div');
        cell.className = 'chunk-cell';
        cell.dataset.idx = i;
        timeline.appendChild(cell);
        chunks.push({ el: cell, state: 'empty' });
      }
      downloadIdx = 0;
      playIdx = -1;
      playhead.style.left = '0%';
      updateChunkStats();
    }

    function updateChunkStats() {
      const dl = chunks.filter(c => c.state !== 'empty').length;
      const played = chunks.filter(c => c.state === 'played' || c.state === 'playing').length;
      const bufferAhead = chunks.filter(c => c.state === 'downloaded').length;
      document.getElementById('chunkDownloaded').textContent = dl + ' / ' + TOTAL_CHUNKS;
      document.getElementById('chunkPlaying').textContent = played + ' / ' + TOTAL_CHUNKS;
      document.getElementById('chunkBufferAhead').textContent = bufferAhead + ' chunks';
      document.getElementById('chunkNetworkSpeed').textContent = networkSpeed === 'fast' ? 'Fast' : 'Slow';
    }

    function downloadNext() {
      if (downloadIdx >= TOTAL_CHUNKS) return;
      chunks[downloadIdx].state = 'downloaded';
      chunks[downloadIdx].el.className = 'chunk-cell downloaded';
      downloadIdx++;
      updateChunkStats();
      const delay = networkSpeed === 'fast' ? 300 : 1500;
      downloadTimer = setTimeout(downloadNext, delay);
    }

    function playNext() {
      if (!playing) return;
      const nextIdx = playIdx + 1;
      if (nextIdx >= TOTAL_CHUNKS) {
        playing = false;
        screenText.textContent = 'Playback Complete';
        screen.classList.remove('playing', 'buffering');
        return;
      }
      // Mark current as played
      if (playIdx >= 0) {
        chunks[playIdx].state = 'played';
        chunks[playIdx].el.className = 'chunk-cell played';
      }
      // Check if next chunk is downloaded
      if (chunks[nextIdx].state === 'downloaded' || chunks[nextIdx].state === 'playing') {
        playIdx = nextIdx;
        chunks[playIdx].state = 'playing';
        chunks[playIdx].el.className = 'chunk-cell playing';
        screen.classList.add('playing');
        screen.classList.remove('buffering');
        spinner.style.display = 'none';
        qualityBadge.textContent = '720p';
        playhead.style.left = ((playIdx + 1) / TOTAL_CHUNKS * 100) + '%';
        updateChunkStats();
        playTimer = setTimeout(playNext, 800);
      } else {
        // Buffering!
        screen.classList.add('buffering');
        screen.classList.remove('playing');
        spinner.style.display = 'flex';
        qualityBadge.textContent = 'Buffering';
        // Wait for chunk to download
        const waitForChunk = () => {
          if (chunks[nextIdx].state === 'downloaded') {
            playNext();
          } else {
            playTimer = setTimeout(waitForChunk, 100);
          }
        };
        playTimer = setTimeout(waitForChunk, 100);
      }
    }

    document.getElementById('chunkPlayBtn').addEventListener('click', () => {
      if (playing) return;
      if (playIdx >= TOTAL_CHUNKS - 1) {
        initTimeline();
      }
      playing = true;
      screenText.textContent = '';
      screen.classList.add('playing');
      downloadNext();
      setTimeout(playNext, 500);
    });

    document.getElementById('chunkPauseBtn').addEventListener('click', () => {
      playing = false;
      clearTimeout(downloadTimer);
      clearTimeout(playTimer);
    });

    document.getElementById('chunkSlowBtn').addEventListener('click', () => {
      networkSpeed = 'slow';
      updateChunkStats();
    });

    document.getElementById('chunkFastBtn').addEventListener('click', () => {
      networkSpeed = 'fast';
      updateChunkStats();
    });

    document.getElementById('chunkResetBtn').addEventListener('click', () => {
      playing = false;
      clearTimeout(downloadTimer);
      clearTimeout(playTimer);
      screen.classList.remove('playing', 'buffering');
      spinner.style.display = 'none';
      screenText.textContent = 'Press Play';
      qualityBadge.textContent = '—';
      initTimeline();
    });

    initTimeline();
  })();

  // ==========================================================
  // VIDEO PLAYER BUFFER VISUALIZATION
  // ==========================================================
  (function() {
    const TOTAL_DURATION = 120; // 2 minutes
    let playbackPos = 0;
    let bufferEnd = 0;
    let running = false;
    let stalling = false;
    let rebuffers = 0;
    let timer = null;

    const playedEl = document.getElementById('bufferPlayed');
    const loadedEl = document.getElementById('bufferLoaded');
    const markerEl = document.getElementById('bufferPlayheadMarker');
    const healthArc = document.getElementById('healthArc');
    const healthVal = document.getElementById('healthValue');
    const eventsEl = document.getElementById('bufferEvents');

    function logEvent(text, cls) {
      const div = document.createElement('div');
      div.className = 'buffer-event' + (cls ? ' ' + cls : '');
      const t = formatTime(playbackPos);
      div.innerHTML = `<span class="ev-time">[${t}]</span> ${text}`;
      eventsEl.prepend(div);
      if (eventsEl.children.length > 50) eventsEl.lastChild.remove();
    }

    function formatTime(s) {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return m + ':' + (sec < 10 ? '0' : '') + sec;
    }

    function updateUI() {
      const playedPct = (playbackPos / TOTAL_DURATION) * 100;
      const loadedPct = (bufferEnd / TOTAL_DURATION) * 100;
      playedEl.style.width = playedPct + '%';
      loadedEl.style.width = loadedPct + '%';
      markerEl.style.left = playedPct + '%';

      const bufDur = Math.max(0, bufferEnd - playbackPos);
      const health = Math.min(100, (bufDur / 15) * 100);
      const arcLen = (health / 100) * 157;
      healthArc.setAttribute('stroke-dasharray', arcLen + ' 157');
      if (health > 60) healthArc.setAttribute('stroke', '#00c9a7');
      else if (health > 30) healthArc.setAttribute('stroke', '#ff9a6c');
      else healthArc.setAttribute('stroke', '#ff4757');
      healthVal.textContent = Math.round(health) + '%';

      document.getElementById('bufferPos').textContent = formatTime(playbackPos);
      document.getElementById('bufferEnd').textContent = formatTime(bufferEnd);
      document.getElementById('bufferDuration').textContent = bufDur.toFixed(1) + 's';
      document.getElementById('bufferState').textContent = stalling ? 'Rebuffering' : (running ? 'Playing' : 'Idle');
      document.getElementById('bufferRebuffers').textContent = rebuffers;
    }

    function tick() {
      if (!running) return;

      if (!stalling) {
        // Download ahead
        if (bufferEnd < TOTAL_DURATION) {
          bufferEnd += 1.5 + Math.random() * 0.5;
          if (bufferEnd > TOTAL_DURATION) bufferEnd = TOTAL_DURATION;
        }
        // Playback
        playbackPos += 0.5;
        if (playbackPos >= bufferEnd && playbackPos < TOTAL_DURATION) {
          stalling = true;
          rebuffers++;
          logEvent('Rebuffering! Buffer depleted.', 'ev-warn');
        }
        if (playbackPos >= TOTAL_DURATION) {
          playbackPos = TOTAL_DURATION;
          running = false;
          logEvent('Playback complete.', 'ev-good');
        }
      } else {
        // Stalling: download but don't advance playback
        bufferEnd += 2.0;
        if (bufferEnd > TOTAL_DURATION) bufferEnd = TOTAL_DURATION;
        if (bufferEnd - playbackPos > 3) {
          stalling = false;
          logEvent('Resumed playback. Buffer refilled.', 'ev-good');
        }
      }

      updateUI();
      timer = setTimeout(tick, 200);
    }

    document.getElementById('bufferStartBtn').addEventListener('click', () => {
      if (running) return;
      if (playbackPos >= TOTAL_DURATION) {
        playbackPos = 0; bufferEnd = 0; rebuffers = 0; stalling = false;
        eventsEl.innerHTML = '';
      }
      running = true;
      logEvent('Playback started.', 'ev-good');
      tick();
    });

    document.getElementById('bufferStallBtn').addEventListener('click', () => {
      if (!running) return;
      // Simulate a network stall: freeze buffer downloads
      const savedBufEnd = bufferEnd;
      bufferEnd = playbackPos + 0.5; // nearly empty
      logEvent('Network stall simulated! Buffer drained.', 'ev-warn');
    });

    document.getElementById('bufferResetBtn').addEventListener('click', () => {
      running = false;
      stalling = false;
      clearTimeout(timer);
      playbackPos = 0; bufferEnd = 0; rebuffers = 0;
      eventsEl.innerHTML = '';
      updateUI();
    });

    updateUI();
  })();

  // ==========================================================
  // ARCHITECTURE TABS
  // ==========================================================
  (function() {
    const tabs = document.querySelectorAll('.arch-tab');
    const panels = document.querySelectorAll('.arch-panel');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        document.querySelector(`.arch-panel[data-panel="${tab.dataset.tab}"]`).classList.add('active');
      });
    });
  })();

  // ==========================================================
  // DECISION CARDS (expand/collapse)
  // ==========================================================
  (function() {
    document.querySelectorAll('.decision-card').forEach(card => {
      card.addEventListener('click', () => {
        card.classList.toggle('expanded');
      });
    });
  })();
</script>
</BaseLayout>
