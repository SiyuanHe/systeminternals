---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Design a Video Streaming Service — Interactive Visualization"
  description="Understand video streaming architecture: CDN routing, adaptive bitrate, encoding pipeline, chunk delivery. Interactive simulation."
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "System Design", href: "/system-design/" },
    { label: "Video Streaming", href: "/system-design/video-streaming/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>📺 Design a Video Streaming Service</h1>
      <p class="subtitle">CDN routing, adaptive bitrate, encoding pipelines, and chunk delivery — all interactive</p>
    </header>

    <section class="overview-section">
      <div class="overview-card">
        <p>
          A video streaming service must deliver high-quality video to millions of concurrent users worldwide.
          The key challenges: <strong>how do you route users to the nearest server?</strong> How does the player
          adapt quality in real-time based on network conditions? How do you encode, segment, and distribute
          petabytes of video content efficiently? This page lets you explore each layer of the architecture interactively.
        </p>
        <div class="overview-stats">
          <div class="overview-stat">
            <span class="overview-stat-value">80%+</span>
            <span class="overview-stat-label">of internet traffic is video</span>
          </div>
          <div class="overview-stat">
            <span class="overview-stat-value">&lt;200ms</span>
            <span class="overview-stat-label">target startup latency</span>
          </div>
          <div class="overview-stat">
            <span class="overview-stat-value">5-20 Mbps</span>
            <span class="overview-stat-label">bandwidth for HD/4K</span>
          </div>
          <div class="overview-stat">
            <span class="overview-stat-value">4-10s</span>
            <span class="overview-stat-label">typical chunk/segment size</span>
          </div>
        </div>
      </div>
    </section>

    <!-- CDN Routing Visualization -->
    <section class="cdn-section">
      <h2>🌍 CDN Routing Visualization</h2>
      <p class="section-desc">Click on a user location to see how requests are routed to the nearest CDN edge server. Watch data packets flow from origin through edge to user.</p>
      <div class="cdn-controls">
        <button id="cdnResetBtn" class="action-btn reset-btn">🔄 Reset</button>
        <button id="cdnAutoBtn" class="action-btn primary-btn">▶️ Auto Demo</button>
        <span class="cdn-info" id="cdnInfo">Click a user icon to start routing</span>
      </div>
      <div class="cdn-map-container">
        <svg id="cdnMap" viewBox="0 0 900 460" class="cdn-map">
          <!-- Simplified world map background -->
          <rect x="0" y="0" width="900" height="460" fill="#0a1628" rx="8"/>
          <!-- Grid lines -->
          <line x1="0" y1="115" x2="900" y2="115" stroke="#1a2a4a" stroke-width="0.5" stroke-dasharray="4"/>
          <line x1="0" y1="230" x2="900" y2="230" stroke="#1a2a4a" stroke-width="0.5" stroke-dasharray="4"/>
          <line x1="0" y1="345" x2="900" y2="345" stroke="#1a2a4a" stroke-width="0.5" stroke-dasharray="4"/>
          <line x1="225" y1="0" x2="225" y2="460" stroke="#1a2a4a" stroke-width="0.5" stroke-dasharray="4"/>
          <line x1="450" y1="0" x2="450" y2="460" stroke="#1a2a4a" stroke-width="0.5" stroke-dasharray="4"/>
          <line x1="675" y1="0" x2="675" y2="460" stroke="#1a2a4a" stroke-width="0.5" stroke-dasharray="4"/>
          <!-- Continent outlines (simplified) -->
          <!-- North America -->
          <path d="M80,80 Q120,60 200,70 Q240,80 260,120 Q270,160 250,200 Q220,240 180,260 Q140,250 100,220 Q70,180 60,140 Q60,100 80,80Z" fill="#0d1f3c" stroke="#1e3a5f" stroke-width="1"/>
          <!-- South America -->
          <path d="M200,280 Q230,270 250,290 Q260,320 270,360 Q260,400 240,420 Q220,430 200,410 Q180,380 180,340 Q180,300 200,280Z" fill="#0d1f3c" stroke="#1e3a5f" stroke-width="1"/>
          <!-- Europe -->
          <path d="M380,70 Q420,60 460,70 Q480,90 490,120 Q480,150 460,160 Q430,170 400,160 Q380,140 370,110 Q370,90 380,70Z" fill="#0d1f3c" stroke="#1e3a5f" stroke-width="1"/>
          <!-- Africa -->
          <path d="M400,180 Q440,170 470,190 Q490,230 500,280 Q490,340 470,370 Q440,380 420,360 Q400,320 390,270 Q390,220 400,180Z" fill="#0d1f3c" stroke="#1e3a5f" stroke-width="1"/>
          <!-- Asia -->
          <path d="M520,60 Q600,50 700,70 Q760,100 780,150 Q770,200 740,220 Q680,240 620,230 Q560,210 530,170 Q510,130 510,90 Q510,70 520,60Z" fill="#0d1f3c" stroke="#1e3a5f" stroke-width="1"/>
          <!-- Australia -->
          <path d="M720,300 Q760,290 800,300 Q820,320 810,350 Q790,370 760,370 Q730,360 720,340 Q710,320 720,300Z" fill="#0d1f3c" stroke="#1e3a5f" stroke-width="1"/>

          <!-- Origin Server -->
          <g id="originServer" class="cdn-origin">
            <rect x="430" y="200" width="40" height="30" rx="4" fill="#ff6b35" stroke="#ff9a6c" stroke-width="1.5"/>
            <text x="450" y="220" text-anchor="middle" fill="#fff" font-size="10" font-weight="bold">SRC</text>
            <text x="450" y="248" text-anchor="middle" fill="#ff9a6c" font-size="9">Origin</text>
          </g>

          <!-- CDN Edge Servers -->
          <g class="cdn-edge" data-edge="us-east" data-x="180" data-y="140">
            <circle cx="180" cy="140" r="12" fill="#00c9a7" stroke="#4dffd4" stroke-width="1.5" opacity="0.9"/>
            <text x="180" y="144" text-anchor="middle" fill="#fff" font-size="8" font-weight="bold">E1</text>
            <text x="180" y="165" text-anchor="middle" fill="#4dffd4" font-size="8">US-East</text>
          </g>
          <g class="cdn-edge" data-edge="us-west" data-x="100" data-y="160">
            <circle cx="100" cy="160" r="12" fill="#00c9a7" stroke="#4dffd4" stroke-width="1.5" opacity="0.9"/>
            <text x="100" y="164" text-anchor="middle" fill="#fff" font-size="8" font-weight="bold">E2</text>
            <text x="100" y="185" text-anchor="middle" fill="#4dffd4" font-size="8">US-West</text>
          </g>
          <g class="cdn-edge" data-edge="eu-west" data-x="410" data-y="100">
            <circle cx="410" cy="100" r="12" fill="#00c9a7" stroke="#4dffd4" stroke-width="1.5" opacity="0.9"/>
            <text x="410" y="104" text-anchor="middle" fill="#fff" font-size="8" font-weight="bold">E3</text>
            <text x="410" y="125" text-anchor="middle" fill="#4dffd4" font-size="8">EU-West</text>
          </g>
          <g class="cdn-edge" data-edge="asia-east" data-x="720" data-y="130">
            <circle cx="720" cy="130" r="12" fill="#00c9a7" stroke="#4dffd4" stroke-width="1.5" opacity="0.9"/>
            <text x="720" y="134" text-anchor="middle" fill="#fff" font-size="8" font-weight="bold">E4</text>
            <text x="720" y="155" text-anchor="middle" fill="#4dffd4" font-size="8">Asia-East</text>
          </g>
          <g class="cdn-edge" data-edge="asia-south" data-x="620" data-y="200">
            <circle cx="620" cy="200" r="12" fill="#00c9a7" stroke="#4dffd4" stroke-width="1.5" opacity="0.9"/>
            <text x="620" y="204" text-anchor="middle" fill="#fff" font-size="8" font-weight="bold">E5</text>
            <text x="620" y="225" text-anchor="middle" fill="#4dffd4" font-size="8">Asia-S</text>
          </g>
          <g class="cdn-edge" data-edge="sa-east" data-x="230" data-y="340">
            <circle cx="230" cy="340" r="12" fill="#00c9a7" stroke="#4dffd4" stroke-width="1.5" opacity="0.9"/>
            <text x="230" y="344" text-anchor="middle" fill="#fff" font-size="8" font-weight="bold">E6</text>
            <text x="230" y="365" text-anchor="middle" fill="#4dffd4" font-size="8">SA-East</text>
          </g>
          <g class="cdn-edge" data-edge="au" data-x="770" data-y="330">
            <circle cx="770" cy="330" r="12" fill="#00c9a7" stroke="#4dffd4" stroke-width="1.5" opacity="0.9"/>
            <text x="770" y="334" text-anchor="middle" fill="#fff" font-size="8" font-weight="bold">E7</text>
            <text x="770" y="355" text-anchor="middle" fill="#4dffd4" font-size="8">AU</text>
          </g>

          <!-- User locations (clickable) -->
          <g class="cdn-user" data-user="ny" data-x="195" data-y="120" data-nearest="us-east" style="cursor:pointer">
            <circle cx="195" cy="120" r="8" fill="#6c5ce7" stroke="#a29bfe" stroke-width="1.5"/>
            <text x="195" y="124" text-anchor="middle" fill="#fff" font-size="7">U</text>
            <text x="195" y="110" text-anchor="middle" fill="#a29bfe" font-size="7">NYC</text>
          </g>
          <g class="cdn-user" data-user="la" data-x="80" data-y="170" data-nearest="us-west" style="cursor:pointer">
            <circle cx="80" cy="170" r="8" fill="#6c5ce7" stroke="#a29bfe" stroke-width="1.5"/>
            <text x="80" y="174" text-anchor="middle" fill="#fff" font-size="7">U</text>
            <text x="80" y="160" text-anchor="middle" fill="#a29bfe" font-size="7">LA</text>
          </g>
          <g class="cdn-user" data-user="london" data-x="400" data-y="82" data-nearest="eu-west" style="cursor:pointer">
            <circle cx="400" cy="82" r="8" fill="#6c5ce7" stroke="#a29bfe" stroke-width="1.5"/>
            <text x="400" y="86" text-anchor="middle" fill="#fff" font-size="7">U</text>
            <text x="400" y="72" text-anchor="middle" fill="#a29bfe" font-size="7">LDN</text>
          </g>
          <g class="cdn-user" data-user="tokyo" data-x="750" data-y="110" data-nearest="asia-east" style="cursor:pointer">
            <circle cx="750" cy="110" r="8" fill="#6c5ce7" stroke="#a29bfe" stroke-width="1.5"/>
            <text x="750" y="114" text-anchor="middle" fill="#fff" font-size="7">U</text>
            <text x="750" y="100" text-anchor="middle" fill="#a29bfe" font-size="7">TKY</text>
          </g>
          <g class="cdn-user" data-user="mumbai" data-x="600" data-y="210" data-nearest="asia-south" style="cursor:pointer">
            <circle cx="600" cy="210" r="8" fill="#6c5ce7" stroke="#a29bfe" stroke-width="1.5"/>
            <text x="600" y="214" text-anchor="middle" fill="#fff" font-size="7">U</text>
            <text x="600" y="200" text-anchor="middle" fill="#a29bfe" font-size="7">MUM</text>
          </g>
          <g class="cdn-user" data-user="saopaulo" data-x="220" data-y="360" data-nearest="sa-east" style="cursor:pointer">
            <circle cx="220" cy="360" r="8" fill="#6c5ce7" stroke="#a29bfe" stroke-width="1.5"/>
            <text x="220" y="364" text-anchor="middle" fill="#fff" font-size="7">U</text>
            <text x="220" y="350" text-anchor="middle" fill="#a29bfe" font-size="7">SAO</text>
          </g>
          <g class="cdn-user" data-user="sydney" data-x="800" data-y="340" data-nearest="au" style="cursor:pointer">
            <circle cx="800" cy="340" r="8" fill="#6c5ce7" stroke="#a29bfe" stroke-width="1.5"/>
            <text x="800" y="344" text-anchor="middle" fill="#fff" font-size="7">U</text>
            <text x="800" y="330" text-anchor="middle" fill="#a29bfe" font-size="7">SYD</text>
          </g>

          <!-- Animated elements group -->
          <g id="cdnAnimGroup"></g>

          <!-- Latency overlay -->
          <g id="cdnLatencyOverlay"></g>
        </svg>
        <div class="cdn-legend">
          <span class="cdn-legend-item"><span class="legend-dot origin-dot"></span> Origin Server</span>
          <span class="cdn-legend-item"><span class="legend-dot edge-dot"></span> CDN Edge Server</span>
          <span class="cdn-legend-item"><span class="legend-dot user-dot"></span> User Location</span>
        </div>
      </div>
      <div class="cdn-detail-panel" id="cdnDetailPanel">
        <div class="cdn-detail-row">
          <span class="cdn-detail-label">User</span>
          <span class="cdn-detail-value" id="cdnDetailUser">—</span>
        </div>
        <div class="cdn-detail-row">
          <span class="cdn-detail-label">Nearest Edge</span>
          <span class="cdn-detail-value" id="cdnDetailEdge">—</span>
        </div>
        <div class="cdn-detail-row">
          <span class="cdn-detail-label">Edge Latency</span>
          <span class="cdn-detail-value" id="cdnDetailEdgeLat">—</span>
        </div>
        <div class="cdn-detail-row">
          <span class="cdn-detail-label">Origin Latency</span>
          <span class="cdn-detail-value" id="cdnDetailOriginLat">—</span>
        </div>
        <div class="cdn-detail-row">
          <span class="cdn-detail-label">Savings</span>
          <span class="cdn-detail-value cdn-savings" id="cdnDetailSavings">—</span>
        </div>
      </div>
    </section>

    <!-- Adaptive Bitrate Switching -->
    <section class="abr-section">
      <h2>📊 Adaptive Bitrate Switching</h2>
      <p class="section-desc">Watch how ABR algorithms dynamically switch video quality based on available bandwidth. Simulate bandwidth changes to see quality adaptation in real-time.</p>
      <div class="abr-controls">
        <button id="abrStartBtn" class="action-btn primary-btn">▶️ Start Simulation</button>
        <button id="abrStopBtn" class="action-btn reset-btn">⏹️ Stop</button>
        <button id="abrDropBtn" class="action-btn warn-btn">📉 Bandwidth Drop</button>
        <button id="abrSpikeBtn" class="action-btn primary-btn-secondary">📈 Bandwidth Spike</button>
        <button id="abrResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>
      <div class="abr-layout">
        <div class="abr-chart-container">
          <canvas id="abrChart" width="700" height="300"></canvas>
          <div class="abr-chart-legend">
            <span class="abr-legend-item"><span class="abr-legend-line bw-line"></span> Bandwidth</span>
            <span class="abr-legend-item"><span class="abr-legend-line quality-line"></span> Selected Quality</span>
          </div>
        </div>
        <div class="abr-side-panel">
          <div class="abr-current-quality">
            <span class="abr-quality-label">Current Quality</span>
            <span class="abr-quality-value" id="abrCurrentQuality">—</span>
            <span class="abr-quality-bitrate" id="abrCurrentBitrate">— Mbps</span>
          </div>
          <div class="abr-buffer-indicator">
            <span class="abr-buffer-label">Buffer Level</span>
            <div class="abr-buffer-bar-container">
              <div class="abr-buffer-bar" id="abrBufferBar"></div>
            </div>
            <span class="abr-buffer-value" id="abrBufferValue">0.0s</span>
          </div>
          <div class="abr-quality-tiers">
            <h4>Quality Tiers</h4>
            <div class="abr-tier" data-tier="1080p">
              <span class="tier-label">1080p</span>
              <span class="tier-bitrate">5.0 Mbps</span>
              <div class="tier-indicator" id="tier1080"></div>
            </div>
            <div class="abr-tier" data-tier="720p">
              <span class="tier-label">720p</span>
              <span class="tier-bitrate">2.5 Mbps</span>
              <div class="tier-indicator" id="tier720"></div>
            </div>
            <div class="abr-tier" data-tier="480p">
              <span class="tier-label">480p</span>
              <span class="tier-bitrate">1.2 Mbps</span>
              <div class="tier-indicator" id="tier480"></div>
            </div>
            <div class="abr-tier" data-tier="360p">
              <span class="tier-label">360p</span>
              <span class="tier-bitrate">0.6 Mbps</span>
              <div class="tier-indicator" id="tier360"></div>
            </div>
            <div class="abr-tier" data-tier="240p">
              <span class="tier-label">240p</span>
              <span class="tier-bitrate">0.3 Mbps</span>
              <div class="tier-indicator" id="tier240"></div>
            </div>
          </div>
          <div class="abr-stats">
            <div class="abr-stat"><span>Quality Switches</span><strong id="abrSwitchCount">0</strong></div>
            <div class="abr-stat"><span>Rebuffer Events</span><strong id="abrRebufferCount">0</strong></div>
            <div class="abr-stat"><span>Avg Quality</span><strong id="abrAvgQuality">—</strong></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Encoding Pipeline -->
    <section class="encoding-section">
      <h2>🎬 Encoding Pipeline</h2>
      <p class="section-desc">See how raw video is processed into multiple quality levels and segmented for streaming. Click "Start Encoding" to animate the pipeline.</p>
      <div class="encoding-controls">
        <button id="encodeStartBtn" class="action-btn primary-btn">🚀 Start Encoding</button>
        <button id="encodeResetBtn" class="action-btn reset-btn">🔄 Reset</button>
        <div class="encode-input-info">
          <span>Input: <strong>1080p, 24fps, 10 min video</strong></span>
          <span>Raw size: <strong>~18 GB</strong></span>
        </div>
      </div>
      <div class="encoding-pipeline">
        <div class="pipeline-stage" id="pipeStage1">
          <div class="pipeline-stage-icon">📥</div>
          <div class="pipeline-stage-name">Raw Upload</div>
          <div class="pipeline-stage-detail">Ingest raw video file</div>
          <div class="pipeline-stage-bar"><div class="pipeline-stage-progress" id="pipeProgress1"></div></div>
          <div class="pipeline-stage-size">18 GB</div>
        </div>
        <div class="pipeline-arrow">→</div>
        <div class="pipeline-stage" id="pipeStage2">
          <div class="pipeline-stage-icon">🔧</div>
          <div class="pipeline-stage-name">Transcode</div>
          <div class="pipeline-stage-detail">H.264/H.265 encoding</div>
          <div class="pipeline-stage-bar"><div class="pipeline-stage-progress" id="pipeProgress2"></div></div>
          <div class="pipeline-stage-size">—</div>
        </div>
        <div class="pipeline-arrow">→</div>
        <div class="pipeline-stage" id="pipeStage3">
          <div class="pipeline-stage-icon">📐</div>
          <div class="pipeline-stage-name">Multi-Resolution</div>
          <div class="pipeline-stage-detail">Generate quality tiers</div>
          <div class="pipeline-stage-bar"><div class="pipeline-stage-progress" id="pipeProgress3"></div></div>
          <div class="pipeline-stage-size">—</div>
        </div>
        <div class="pipeline-arrow">→</div>
        <div class="pipeline-stage" id="pipeStage4">
          <div class="pipeline-stage-icon">🔪</div>
          <div class="pipeline-stage-name">Segmentation</div>
          <div class="pipeline-stage-detail">Split into 4s chunks</div>
          <div class="pipeline-stage-bar"><div class="pipeline-stage-progress" id="pipeProgress4"></div></div>
          <div class="pipeline-stage-size">—</div>
        </div>
        <div class="pipeline-arrow">→</div>
        <div class="pipeline-stage" id="pipeStage5">
          <div class="pipeline-stage-icon">☁️</div>
          <div class="pipeline-stage-name">Store & Distribute</div>
          <div class="pipeline-stage-detail">Push to CDN origins</div>
          <div class="pipeline-stage-bar"><div class="pipeline-stage-progress" id="pipeProgress5"></div></div>
          <div class="pipeline-stage-size">—</div>
        </div>
      </div>
      <div class="encoding-outputs" id="encodingOutputs">
        <h4>Generated Renditions</h4>
        <div class="rendition-grid" id="renditionGrid"></div>
      </div>
    </section>

    <!-- Chunk Delivery Simulation -->
    <section class="chunk-section">
      <h2>📦 Chunk Delivery Simulation</h2>
      <p class="section-desc">Watch video chunks being downloaded and played in sequence. Simulate network issues to see buffering behavior.</p>
      <div class="chunk-controls">
        <button id="chunkPlayBtn" class="action-btn primary-btn">▶️ Play</button>
        <button id="chunkPauseBtn" class="action-btn primary-btn-secondary">⏸️ Pause</button>
        <button id="chunkSlowBtn" class="action-btn warn-btn">🐢 Slow Network</button>
        <button id="chunkFastBtn" class="action-btn primary-btn-secondary">🐇 Fast Network</button>
        <button id="chunkResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>
      <div class="chunk-player">
        <div class="chunk-screen" id="chunkScreen">
          <div class="chunk-screen-text" id="chunkScreenText">Press Play</div>
          <div class="chunk-spinner" id="chunkSpinner" style="display:none">
            <div class="spinner-ring"></div>
            <span>Buffering...</span>
          </div>
          <div class="chunk-quality-badge" id="chunkQualityBadge">—</div>
        </div>
        <div class="chunk-timeline-container">
          <div class="chunk-timeline" id="chunkTimeline"></div>
          <div class="chunk-playhead" id="chunkPlayhead"></div>
          <div class="chunk-time-labels">
            <span>0:00</span>
            <span>0:20</span>
            <span>0:40</span>
            <span>1:00</span>
          </div>
        </div>
        <div class="chunk-stats-row">
          <div class="chunk-stat"><span>Downloaded</span><strong id="chunkDownloaded">0 / 15</strong></div>
          <div class="chunk-stat"><span>Playing</span><strong id="chunkPlaying">0 / 15</strong></div>
          <div class="chunk-stat"><span>Buffer Ahead</span><strong id="chunkBufferAhead">0 chunks</strong></div>
          <div class="chunk-stat"><span>Network</span><strong id="chunkNetworkSpeed">Fast</strong></div>
        </div>
      </div>
    </section>

    <!-- Video Player Buffer Visualization -->
    <section class="buffer-section">
      <h2>🎯 Video Player Buffer Visualization</h2>
      <p class="section-desc">Explore the internal buffer state of a video player. See how segments are fetched ahead of playback and what happens during network stalls.</p>
      <div class="buffer-controls">
        <button id="bufferStartBtn" class="action-btn primary-btn">▶️ Start Playback</button>
        <button id="bufferStallBtn" class="action-btn warn-btn">⚠️ Simulate Stall</button>
        <button id="bufferResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>
      <div class="buffer-viz">
        <div class="buffer-bar-outer">
          <div class="buffer-bar-labels">
            <span>Played</span>
            <span>Buffered</span>
            <span>Not Loaded</span>
          </div>
          <div class="buffer-bar-track" id="bufferBarTrack">
            <div class="buffer-played" id="bufferPlayed"></div>
            <div class="buffer-loaded" id="bufferLoaded"></div>
            <div class="buffer-playhead-marker" id="bufferPlayheadMarker"></div>
          </div>
          <div class="buffer-time-labels" id="bufferTimeLabels">
            <span>0:00</span><span>0:30</span><span>1:00</span><span>1:30</span><span>2:00</span>
          </div>
        </div>
        <div class="buffer-health-panel">
          <div class="buffer-health-gauge">
            <svg viewBox="0 0 120 70" class="health-gauge-svg">
              <path d="M10,60 A50,50 0 0,1 110,60" fill="none" stroke="#1a2a4a" stroke-width="10" stroke-linecap="round"/>
              <path d="M10,60 A50,50 0 0,1 110,60" fill="none" stroke="#00c9a7" stroke-width="10" stroke-linecap="round" id="healthArc" stroke-dasharray="0 157"/>
            </svg>
            <div class="health-label">Buffer Health</div>
