---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "Rate Limiter", description: "Token bucket, sliding window, fixed window — compare algorithms with live simulation", href: "/system-design/rate-limiter/", status: "live" },
  { title: "URL Shortener", description: "Base62 encoding, hash collisions, read/write paths, and capacity planning", href: "/system-design/url-shortener/", status: "live" },
  { title: "Chat System", description: "WebSocket lifecycle, message queues, fan-out strategies, and presence heartbeats", href: "/system-design/chat-system/", status: "live" },
  { title: "Payment System", description: "Payment flows, idempotency, retry logic, state machines, and distributed transaction patterns (saga vs 2PC)", href: "/system-design/payment-system/", status: "live" },
  { title: "Video Streaming", description: "CDN routing, adaptive bitrate switching, encoding pipeline, chunk delivery, and buffering simulation", href: "/system-design/video-streaming/", status: "live" },
  { title: "Web Crawler", description: "BFS/DFS crawl visualization, URL frontier, bloom filter dedup, politeness policies, and priority queues", href: "/system-design/web-crawler/", status: "live" },
  { title: "Ride Sharing", description: "Driver matching, geospatial indexing with quadtree/geohash, ETA calculation, and surge pricing", href: "/system-design/ride-sharing/", status: "live" },
  { title: "Distributed File System", description: "File chunking, replication across nodes, master/chunk server architecture, consistency, and fault tolerance", href: "/system-design/distributed-file-system/", status: "live" },
];
---

<BaseLayout 
  title="System Design" 
  description="Interactive system design interview visualizations — rate limiters, URL shorteners, chat systems, and more"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "System Design", href: "/system-design/" }]}
>
  <section class="section-header">
    <h1>🏗️ System Design</h1>
    <p>
      Classic system design interview topics brought to life with interactive visualizations.
      Explore how real-world systems handle scale, reliability, and performance trade-offs.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(96, 165, 250, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
