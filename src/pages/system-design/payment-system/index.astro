    .pci-item { background: #0f0f23; border: 1px solid #2a2a4a; border-radius: 6px; padding: 0.3rem 0.75rem; font-size: 0.8rem; color: #94a3b8; }

    /* ===== Design Decisions ===== */
    .decisions-section { margin: 2rem 0; }
    .decisions-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    @media (max-width: 800px) { .decisions-grid { grid-template-columns: 1fr; } }
    .decision-card { background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 12px; padding: 1.25rem; }
    .decision-card h4 { margin: 0 0 1rem; color: #667eea; font-size: 1rem; }
    .decision-tradeoff { display: flex; align-items: stretch; gap: 0.5rem; }
    .decision-option { flex: 1; background: #0f0f23; border: 1px solid #2a2a4a; border-radius: 8px; padding: 0.75rem; position: relative; }
    .decision-option strong { color: #e2e8f0; font-size: 0.9rem; display: block; margin-bottom: 0.4rem; }
    .decision-option p { color: #94a3b8; font-size: 0.8rem; margin: 0; line-height: 1.4; }
    .decision-chosen { border-color: #22c55e55; background: #14532d15; }
    .decision-badge { position: absolute; top: -8px; right: 8px; background: #22c55e; color: #0f0f23; font-size: 0.65rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 4px; text-transform: uppercase; }
    .decision-vs { display: flex; align-items: center; color: #64748b; font-weight: 700; font-size: 0.8rem; flex-shrink: 0; }

    /* ===== General/shared ===== */
    input[type="range"] { accent-color: #667eea; }
    @media (max-width: 600px) {
      .flow-diagram { min-width: 500px; }
      .state-row { gap: 0.25rem; }
      .tpc-arrow-set { gap: 1rem; }
      .decisions-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script type="module">{`
    // ===== Utility =====
    const $ = id => document.getElementById(id);
    const sleep = ms => new Promise(r => setTimeout(r, ms));

    // ===== 1. Payment Flow =====
    (function initFlow() {
      const nodes = ['fn-user','fn-gateway','fn-processor','fn-bank','fn-settlement'];
      const arrows = ['fa-1','fa-2','fa-3','fa-4'];
      const particles = ['fp-1','fp-2','fp-3','fp-4'];
      const labels = ['fal-1','fal-2','fal-3','fal-4'];
      const flowLog = $('flowLog');
      let flowRunning = false;

      $('flowAmountSlider').addEventListener('input', e => {
        $('flowAmountLabel').textContent = (e.target.value / 100).toFixed(2);
      });

      function logFlow(msg, cls) {
        const d = document.createElement('div');
        d.className = 'log-entry ' + (cls || '');
        const t = new Date().toLocaleTimeString();
        d.textContent = '[' + t + '] ' + msg;
        flowLog.prepend(d);
      }

      function resetFlow() {
        flowRunning = false;
        nodes.forEach(id => { $(id).classList.remove('active','done'); });
        particles.forEach(id => { $(id).classList.remove('animate'); $(id).style.left = '-10px'; });
        labels.forEach(id => { $(id).textContent = ''; });
        flowLog.innerHTML = '';
      }

      async function processPayment() {
        if (flowRunning) return;
        flowRunning = true;
        resetFlow();
        const amount = ($('flowAmountSlider').value / 100).toFixed(2);

        const steps = [
          { node: 0, msg: 'User initiates payment of $' + amount, label: null },
          { node: 0, msg: 'Sending to Payment Gateway...', arrow: 0, labelText: 'POST /pay' },
          { node: 1, msg: 'Gateway validates request, tokenizes card', label: null },
          { node: 1, msg: 'Forwarding to Processor...', arrow: 1, labelText: 'Auth $' + amount },
          { node: 2, msg: 'Processor contacts acquiring bank', label: null },
          { node: 2, msg: 'Sending to Bank network...', arrow: 2, labelText: 'ISO 8583' },
          { node: 3, msg: 'Bank checks balance, approves transaction', label: null },
          { node: 3, msg: 'Initiating settlement...', arrow: 3, labelText: 'Approved' },
          { node: 4, msg: 'Settlement complete. Funds transferred.', label: null },
        ];

        for (let i = 0; i < steps.length; i++) {
          if (!flowRunning) return;
          const s = steps[i];
          // activate node
          nodes.forEach((id, idx) => {
            $(id).classList.toggle('active', idx === s.node);
            if (idx < s.node) $(id).classList.add('done');
          });
          logFlow(s.msg, s.arrow !== undefined ? 'info' : '');

          if (s.arrow !== undefined) {
            labels[s.arrow] && ($(labels[s.arrow]).textContent = s.labelText || '');
            const p = $(particles[s.arrow]);
            p.classList.remove('animate');
            void p.offsetWidth; // reflow
            p.classList.add('animate');
            await sleep(700);
          } else {
            await sleep(600);
          }
        }

        $(nodes[4]).classList.add('done');
        $(nodes[4]).classList.remove('active');
        logFlow('Payment of $' + amount + ' completed successfully!', 'success');
        flowRunning = false;
      }

      $('processPaymentBtn').addEventListener('click', processPayment);
      $('resetFlowBtn').addEventListener('click', resetFlow);
    })();

    // ===== 2. State Machine =====
    (function initStateMachine() {
      const transitions = {
        created: ['pending'],
        pending: ['processing'],
        processing: ['success', 'failed'],
        success: ['refunded'],
        failed: [],
        refunded: []
      };
      const stateNames = { created:'Created', pending:'Pending', processing:'Processing', success:'Success', failed:'Failed', refunded:'Refunded' };
      let currentState = 'created';
      let history = [];

      function updateUI() {
        Object.keys(stateNames).forEach(s => {
          const el = $('state-' + s);
          const valid = transitions[currentState];
          el.classList.toggle('current', s === currentState);
          el.classList.toggle('disabled', s !== currentState && !valid.includes(s));
        });
        $('stateCurrentLabel').textContent = stateNames[currentState];
        const validT = transitions[currentState];
        $('stateTransitions').textContent = validT.length ? validT.map(s => stateNames[s]).join(', ') : 'None (terminal state)';
        $('stateHistory').textContent = history.length ? history.join(' -> ') : 'No transitions yet';
      }

      function transitionTo(state) {
        if (!transitions[currentState].includes(state)) return;
        history.push(stateNames[currentState]);
        currentState = state;
        history.push(stateNames[currentState]);
        // deduplicate consecutive
        const deduped = [history[0]];
        for (let i = 1; i < history.length; i++) {
          if (history[i] !== history[i-1]) deduped.push(history[i]);
        }
        history = deduped;
        updateUI();
      }

      Object.keys(stateNames).forEach(s => {
        $('state-' + s).addEventListener('click', () => transitionTo(s));
      });

      $('resetStateBtn').addEventListener('click', () => {
        currentState = 'created';
        history = [];
        updateUI();
      });

      $('autoStateBtn').addEventListener('click', async () => {
        currentState = 'created';
        history = [];
        updateUI();
        const path = ['pending', 'processing', 'success'];
        for (const s of path) {
          await sleep(800);
          transitionTo(s);
        }
      });

      updateUI();
    })();

    // ===== 3. Idempotency Demo =====
    (function initIdempotency() {
      let retryCount = 0;
      const amount = 49.99;

      function genKey() {
        return 'idem_' + Math.random().toString(36).substr(2, 12);
      }

      function resetIdemp() {
        retryCount = 0;
        ['idempBadRequests','idempBadCharges','idempGoodRequests','idempGoodCharges','idempBadArrows','idempGoodArrows'].forEach(id => $(id).innerHTML = '');
        $('idempBadTotal').textContent = '$0.00';
        $('idempGoodTotal').textContent = '$0.00';
        $('idempBadVerdict').textContent = '';
        $('idempBadVerdict').className = 'idemp-verdict';
        $('idempGoodVerdict').textContent = '';
        $('idempGoodVerdict').className = 'idemp-verdict';
        $('idempKeyValue').textContent = '\\u2014';
      }

      function addElement(parentId, cls, text) {
        const el = document.createElement('div');
        el.className = cls;
        el.textContent = text;
        $(parentId).appendChild(el);
      }

      async function simulateRetry() {
        retryCount++;
        const key = genKey();
        $('idempKeyValue').textContent = key;

        // Without idempotency - each retry creates a new charge
        await sleep(200);
        addElement('idempBadRequests', 'idemp-request-item', 'POST /pay $' + amount.toFixed(2));
        addElement('idempBadArrows', 'idemp-arrow-item', '\\u2192');
        addElement('idempBadCharges', 'idemp-charge-item' + (retryCount > 1 ? ' duplicate' : ''),
          (retryCount > 1 ? '\\u26a0 DUPLICATE ' : '') + 'Charge $' + amount.toFixed(2));
        $('idempBadTotal').textContent = '$' + (retryCount * amount).toFixed(2);

        if (retryCount > 1) {
          $('idempBadVerdict').textContent = '\\u274c Customer charged ' + retryCount + 'x! ($' + (retryCount * amount).toFixed(2) + ')';
          $('idempBadVerdict').className = 'idemp-verdict bad';
        }

        // With idempotency - duplicate detected, return cached response
        await sleep(100);
        addElement('idempGoodRequests', 'idemp-request-item', 'POST /pay key=' + key.slice(0,10) + '...');
        addElement('idempGoodArrows', 'idemp-arrow-item', '\\u2192');
        if (retryCount === 1) {
          addElement('idempGoodCharges', 'idemp-charge-item deduped', 'Charge $' + amount.toFixed(2));
        } else {
          addElement('idempGoodCharges', 'idemp-charge-item deduped', '\\u2713 Dedup: return cached');
        }
        $('idempGoodTotal').textContent = '$' + amount.toFixed(2);

        if (retryCount > 1) {
          $('idempGoodVerdict').textContent = '\\u2705 Correct! Only charged once ($' + amount.toFixed(2) + ')';
          $('idempGoodVerdict').className = 'idemp-verdict good';
        }
      }

      $('idempRetryBtn').addEventListener('click', simulateRetry);
      $('idempResetBtn').addEventListener('click', resetIdemp);
    })();

    // ===== 4. Retry Logic =====
    (function initRetry() {
      let running = false;
      let abortRetry = false;

      $('maxRetriesSlider').addEventListener('input', e => $('maxRetriesLabel').textContent = e.target.value);
      $('baseDelaySlider').addEventListener('input', e => $('baseDelayLabel').textContent = e.target.value);
      $('failProbSlider').addEventListener('input', e => $('failProbLabel').textContent = e.target.value);

      function calcDelay(attempt, base, jitter) {
        let delay = base * Math.pow(2, attempt);
        if (jitter) delay = delay * (0.5 + Math.random());
        return Math.round(delay);
      }

      function resetRetry() {
        abortRetry = true;
        running = false;
        $('retryTrack').innerHTML = '';
        $('retryAttempt').textContent = '0';
        $('retryTotalWait').textContent = '0ms';
        $('retryNextDelay').textContent = '\\u2014';
        $('retryResult').textContent = '\\u2014';
        $('retryResult').className = 'stat-v';
      }

      async function startRetry() {
        if (running) return;
        running = true;
        abortRetry = false;
        $('retryTrack').innerHTML = '';
        const maxRetries = parseInt($('maxRetriesSlider').value);
        const baseDelay = parseInt($('baseDelaySlider').value);
        const useJitter = $('jitterToggle').checked;
        const failProb = parseInt($('failProbSlider').value) / 100;
        let totalWait = 0;

        for (let attempt = 0; attempt <= maxRetries; attempt++) {
          if (abortRetry) return;

          // Add delay bar if not first attempt
          if (attempt > 0) {
            const delay = calcDelay(attempt - 1, baseDelay, useJitter);
            totalWait += delay;
            const barWidth = Math.min(delay / 10, 200);
            const bar = document.createElement('div');
            bar.className = 'retry-delay-bar';
            bar.style.width = barWidth + 'px';
            bar.innerHTML = '<div class="delay-label">' + delay + 'ms</div><div class="delay-fill"></div>';
            $('retryTrack').appendChild(bar);
            $('retryNextDelay').textContent = delay + 'ms';
            $('retryTotalWait').textContent = totalWait + 'ms';
            await sleep(Math.min(delay, 800)); // speed up viz
          }

          if (abortRetry) return;

          // Add attempt dot
          const dot = document.createElement('div');
          dot.className = 'retry-attempt';
          const succeeded = Math.random() > failProb || attempt === maxRetries;
          const isSuccess = Math.random() > failProb;
          const dotInner = document.createElement('div');

          // Show pending first
          dotInner.className = 'retry-dot pending';
          dotInner.textContent = (attempt + 1);
          dot.appendChild(dotInner);
          $('retryTrack').appendChild(dot);
          $('retryAttempt').textContent = (attempt + 1);

          await sleep(400);
          if (abortRetry) return;

          if (isSuccess) {
            dotInner.className = 'retry-dot success';
            $('retryResult').textContent = 'Success';
            $('retryResult').className = 'stat-v green';
            $('retryNextDelay').textContent = '\\u2014';
            running = false;
            return;
          } else {
            dotInner.className = 'retry-dot fail';
            if (attempt === maxRetries) {
              $('retryResult').textContent = 'Max retries exceeded';
              $('retryResult').className = 'stat-v red';
              $('retryNextDelay').textContent = '\\u2014';
              running = false;
              return;
            }
          }
        }
        running = false;
      }

      $('startRetryBtn').addEventListener('click', startRetry);
      $('resetRetryBtn').addEventListener('click', resetRetry);
    })();

    // ===== 5. Saga Pattern =====
    (function initSaga() {
      const stepNames = ['Create Order', 'Reserve Inventory', 'Process Payment', 'Confirm Shipping'];
      const compNames = ['Cancel Order', 'Release Inventory', 'Refund Payment', 'Cancel Shipment'];
      let currentStep = -1;
      let sagaState = 'idle'; // idle, forward, compensating, done
      let failAtStep = -1;

      function sagaLog(msg) {
        const log = $('sagaLog');
        const el = document.createElement('div');
        el.textContent = '> ' + msg;
        log.appendChild(el);
        log.scrollTop = log.scrollHeight;
      }

      function resetSaga() {
        currentStep = -1;
        sagaState = 'idle';
        failAtStep = -1;
        for (let i = 0; i < 4; i++) {
          const step = $('saga-step-' + i);
          step.className = 'saga-step';
          $('saga-status-' + i).textContent = '\\u23f3';
        }
        $('sagaLog').innerHTML = '';
      }

      function sagaNextStep() {
        if (sagaState === 'done' || sagaState === 'compensating') return;

        if (sagaState === 'idle') sagaState = 'forward';
        currentStep++;

        if (currentStep >= 4) {
          sagaState = 'done';
          sagaLog('\\u2705 Saga completed successfully!');
          return;
        }

        if (failAtStep === currentStep) {
          // Fail this step and start compensating
          $('saga-step-' + currentStep).className = 'saga-step failed';
          $('saga-status-' + currentStep).textContent = '\\u274c';
          sagaLog('\\u274c ' + stepNames[currentStep] + ' FAILED!');
          sagaState = 'compensating';
          compensateSaga(currentStep - 1);
          return;
        }

        // Mark active then done
        $('saga-step-' + currentStep).className = 'saga-step active';
        $('saga-status-' + currentStep).textContent = '\\u23f3';
        sagaLog('Executing: ' + stepNames[currentStep] + '...');

        setTimeout(() => {
          $('saga-step-' + currentStep).className = 'saga-step done';
          $('saga-status-' + currentStep).textContent = '\\u2705';
          sagaLog('\\u2705 ' + stepNames[currentStep] + ' succeeded');
        }, 300);
      }

      async function compensateSaga(fromStep) {
        sagaLog('\\u21a9\\ufe0f Starting compensating transactions...');
        for (let i = fromStep; i >= 0; i--) {
          await sleep(500);
          $('saga-step-' + i).className = 'saga-step compensating';
          $('saga-status-' + i).textContent = '\\u21a9\\ufe0f';
          sagaLog('Compensating: ' + compNames[i] + '...');
          await sleep(400);
          $('saga-step-' + i).className = 'saga-step compensated';
          $('saga-status-' + i).textContent = '\\u274c';
          sagaLog('\\u2705 ' + compNames[i] + ' done');
        }
        sagaState = 'done';
        sagaLog('\\u274c Saga rolled back completely.');
      }

      $('sagaStepBtn').addEventListener('click', () => {
        if (sagaState === 'compensating' || sagaState === 'done') return;
        sagaNextStep();
      });

      $('sagaFailBtn').addEventListener('click', () => {
        if (sagaState !== 'idle' && sagaState !== 'forward') return;
        failAtStep = currentStep + 1;
        sagaLog('\\u26a0 Next step will fail!');
        sagaNextStep();
      });

      $('sagaResetBtn').addEventListener('click', resetSaga);
    })();

    // ===== 6. Two-Phase Commit =====
    (function initTPC() {
      let phase = 'init'; // init, prepare, commit/abort
      let failParticipant = -1;

      function tpcLog(msg) {
        const log = $('tpcLog');
        const el = document.createElement('div');
        el.textContent = '> ' + msg;
        log.appendChild(el);
        log.scrollTop = log.scrollHeight;
      }

      function resetTPC() {
        phase = 'init';
        failParticipant = -1;
        $('tpc-coord').className = 'tpc-node';
        $('tpc-coord-state').textContent = 'INIT';
        for (let i = 0; i < 3; i++) {
          $('tpc-part-' + i).className = 'tpc-node';
          $('tpc-part-' + i + '-state').textContent = 'INIT';
          $('tpc-arrow-' + i).className = 'tpc-arrow-down';
          $('tpc-arrow-' + i).textContent = '\\u2193';
        }
        $('tpcPhaseLabel').textContent = 'Phase: Waiting';
        $('tpcLog').innerHTML = '';
      }

      function tpcNextPhase() {
        if (phase === 'init') {
          // Phase 1: Prepare
          phase = 'prepare';
          $('tpcPhaseLabel').textContent = 'Phase 1: PREPARE';
          $('tpc-coord-state').textContent = 'PREPARE';
          tpcLog('Coordinator sends PREPARE to all participants');
          for (let i = 0; i < 3; i++) {
            $('tpc-arrow-' + i).className = 'tpc-arrow-down prepare';
            $('tpc-arrow-' + i).textContent = '\\u2193 PREPARE';
            if (i === failParticipant) {
              $('tpc-part-' + i).className = 'tpc-node aborted';
              $('tpc-part-' + i + '-state').textContent = 'ABORT';
              tpcLog('\\u274c Participant ' + i + ' votes ABORT');
            } else {
              $('tpc-part-' + i).className = 'tpc-node prepared';
              $('tpc-part-' + i + '-state').textContent = 'PREPARED';
              tpcLog('\\u2705 Participant ' + i + ' votes YES');
            }
          }
        } else if (phase === 'prepare') {
          // Phase 2: Commit or Abort
          const shouldAbort = failParticipant >= 0;
          if (shouldAbort) {
            phase = 'abort';
            $('tpcPhaseLabel').textContent = 'Phase 2: ABORT';
            $('tpc-coord').className = 'tpc-node aborted';
            $('tpc-coord-state').textContent = 'ABORT';
            tpcLog('\\u274c Coordinator decides ABORT (participant voted no)');
            for (let i = 0; i < 3; i++) {
              $('tpc-arrow-' + i).className = 'tpc-arrow-down abort';
              $('tpc-arrow-' + i).textContent = '\\u2193 ABORT';
              $('tpc-part-' + i).className = 'tpc-node aborted';
              $('tpc-part-' + i + '-state').textContent = 'ABORTED';
            }
            tpcLog('All participants rolled back');
          } else {
            phase = 'commit';
            $('tpcPhaseLabel').textContent = 'Phase 2: COMMIT';
            $('tpc-coord').className = 'tpc-node committed';
            $('tpc-coord-state').textContent = 'COMMIT';
            tpcLog('\\u2705 Coordinator decides COMMIT (all voted yes)');
            for (let i = 0; i < 3; i++) {
              $('tpc-arrow-' + i).className = 'tpc-arrow-down commit';
              $('tpc-arrow-' + i).textContent = '\\u2193 COMMIT';
              $('tpc-part-' + i).className = 'tpc-node committed';
              $('tpc-part-' + i + '-state').textContent = 'COMMITTED';
            }
            tpcLog('All participants committed successfully');
          }
        }
      }

      $('tpcStepBtn').addEventListener('click', () => {
        if (phase === 'commit' || phase === 'abort') return;
        tpcNextPhase();
      });

      $('tpcFailBtn').addEventListener('click', () => {
        if (phase !== 'init') return;
        failParticipant = Math.floor(Math.random() * 3);
        tpcLog('\\u26a0 Participant ' + failParticipant + ' will fail during prepare');
        tpcNextPhase();
      });

      $('tpcResetBtn').addEventListener('click', resetTPC);
    })();

    // ===== 7. Architecture Tabs =====
    (function initArchTabs() {
      const tabs = document.querySelectorAll('.arch-tab');
      const panels = document.querySelectorAll('.arch-panel');
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          tabs.forEach(t => t.classList.remove('active'));
          panels.forEach(p => p.classList.remove('active'));
          tab.classList.add('active');
          $('panel-' + tab.dataset.tab).classList.add('active');
        });
      });
    })();
  `}</script>

</BaseLayout>
