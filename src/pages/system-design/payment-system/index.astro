---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Design a Payment System — Interactive Visualization"
  description="Explore payment system design with interactive visualizations: payment flows, state machines, idempotency, retry logic, saga patterns, and architecture deep dives."
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "System Design", href: "/system-design/" },
    { label: "Payment System", href: "/system-design/payment-system/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>💳 Design a Payment System</h1>
      <p class="subtitle">Payment flows, state machines, idempotency, retries, and distributed transactions — all interactive</p>
    </header>

    <section class="overview-section">
      <div class="overview-card">
        <p>
          A payment system handles the movement of money between parties. The key challenges:
          <strong>exactly-once processing</strong> (never double-charge a customer),
          <strong>consistency</strong> across distributed services,
          <strong>fault tolerance</strong> when banks and processors fail, and
          <strong>reconciliation</strong> to catch discrepancies. Explore each challenge below.
        </p>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- 1. Payment Flow Visualization                -->
    <!-- ============================================ -->
    <section class="flow-section">
      <h2>🔄 Payment Flow</h2>
      <p class="section-desc">Watch a payment travel from user to bank and back. Click "Process Payment" to animate the full lifecycle.</p>
      <div class="flow-controls">
        <button id="processPaymentBtn" class="action-btn primary-btn">▶️ Process Payment</button>
        <button id="resetFlowBtn" class="action-btn reset-btn">🔄 Reset</button>
        <label class="flow-amount-label">Amount: <span>$</span><strong id="flowAmountLabel">49.99</strong>
          <input type="range" id="flowAmountSlider" min="1" max="999" value="4999" step="1">
        </label>
      </div>
      <div class="flow-canvas-wrap">
        <div class="flow-diagram" id="flowDiagram">
          <!-- Nodes -->
          <div class="flow-node" id="fn-user" data-label="User">
            <div class="flow-node-icon">👤</div>
            <div class="flow-node-name">User</div>
          </div>
          <div class="flow-arrow" id="fa-1"><div class="flow-arrow-line"><div class="flow-particle" id="fp-1"></div></div><div class="flow-arrow-label" id="fal-1"></div></div>
          <div class="flow-node" id="fn-gateway" data-label="Payment Gateway">
            <div class="flow-node-icon">🌐</div>
            <div class="flow-node-name">Gateway</div>
          </div>
          <div class="flow-arrow" id="fa-2"><div class="flow-arrow-line"><div class="flow-particle" id="fp-2"></div></div><div class="flow-arrow-label" id="fal-2"></div></div>
          <div class="flow-node" id="fn-processor" data-label="Payment Processor">
            <div class="flow-node-icon">⚙️</div>
            <div class="flow-node-name">Processor</div>
          </div>
          <div class="flow-arrow" id="fa-3"><div class="flow-arrow-line"><div class="flow-particle" id="fp-3"></div></div><div class="flow-arrow-label" id="fal-3"></div></div>
          <div class="flow-node" id="fn-bank" data-label="Acquiring Bank">
            <div class="flow-node-icon">🏦</div>
            <div class="flow-node-name">Bank</div>
          </div>
          <div class="flow-arrow" id="fa-4"><div class="flow-arrow-line"><div class="flow-particle" id="fp-4"></div></div><div class="flow-arrow-label" id="fal-4"></div></div>
          <div class="flow-node" id="fn-settlement" data-label="Settlement">
            <div class="flow-node-icon">✅</div>
            <div class="flow-node-name">Settlement</div>
          </div>
        </div>
      </div>
      <div class="flow-log" id="flowLog"></div>
    </section>

    <!-- ============================================ -->
    <!-- 2. Payment State Machine                     -->
    <!-- ============================================ -->
    <section class="state-section">
      <h2>🔀 Payment State Machine</h2>
      <p class="section-desc">Click on valid next states to transition. The current state is highlighted. Observe valid and invalid transitions.</p>
      <div class="state-controls">
        <button id="resetStateBtn" class="action-btn reset-btn">🔄 Reset to Created</button>
        <button id="autoStateBtn" class="action-btn primary-btn">▶️ Auto-Play Happy Path</button>
      </div>
      <div class="state-machine" id="stateMachine">
        <div class="state-row">
          <div class="state-node state-created current" id="state-created" data-state="created">
            <div class="state-label">Created</div>
          </div>
          <div class="state-arrow-right">→</div>
          <div class="state-node state-pending" id="state-pending" data-state="pending">
            <div class="state-label">Pending</div>
          </div>
          <div class="state-arrow-right">→</div>
          <div class="state-node state-processing" id="state-processing" data-state="processing">
            <div class="state-label">Processing</div>
          </div>
        </div>
        <div class="state-branch">
          <div class="state-branch-line"></div>
          <div class="state-outcomes">
            <div class="state-node state-success" id="state-success" data-state="success">
              <div class="state-label">Success</div>
            </div>
            <div class="state-node state-failed" id="state-failed" data-state="failed">
              <div class="state-label">Failed</div>
            </div>
            <div class="state-node state-refunded" id="state-refunded" data-state="refunded">
              <div class="state-label">Refunded</div>
            </div>
          </div>
        </div>
      </div>
      <div class="state-info-panel" id="stateInfoPanel">
        <div class="state-info-current">Current: <strong id="stateCurrentLabel">Created</strong></div>
        <div class="state-info-transitions">Valid transitions: <span id="stateTransitions">Pending</span></div>
        <div class="state-history" id="stateHistory"></div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- 3. Idempotency Demo                          -->
    <!-- ============================================ -->
    <section class="idempotency-section">
      <h2>🔑 Idempotency Keys</h2>
      <p class="section-desc">Network retries can cause duplicate charges. Idempotency keys prevent this. Click "Simulate Retry" to see the difference.</p>
      <div class="idemp-controls">
        <button id="idempRetryBtn" class="action-btn primary-btn">🔁 Simulate Network Retry</button>
        <button id="idempResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>
      <div class="idemp-grid">
        <!-- Without Idempotency -->
        <div class="idemp-panel idemp-bad">
          <h3>❌ Without Idempotency</h3>
          <div class="idemp-scenario">
            <div class="idemp-client">
              <div class="idemp-label">Client</div>
              <div class="idemp-requests" id="idempBadRequests"></div>
            </div>
            <div class="idemp-arrow-col" id="idempBadArrows"></div>
            <div class="idemp-server">
              <div class="idemp-label">Server</div>
              <div class="idemp-charges" id="idempBadCharges"></div>
            </div>
          </div>
          <div class="idemp-total">
            Total charged: <strong class="red" id="idempBadTotal"><span>$</span>0.00</strong>
          </div>
          <div class="idemp-verdict" id="idempBadVerdict"></div>
        </div>
        <!-- With Idempotency -->
        <div class="idemp-panel idemp-good">
          <h3>✅ With Idempotency Key</h3>
          <div class="idemp-scenario">
            <div class="idemp-client">
              <div class="idemp-label">Client</div>
              <div class="idemp-requests" id="idempGoodRequests"></div>
            </div>
            <div class="idemp-arrow-col" id="idempGoodArrows"></div>
            <div class="idemp-server">
              <div class="idemp-label">Server</div>
              <div class="idemp-charges" id="idempGoodCharges"></div>
            </div>
          </div>
          <div class="idemp-total">
            Total charged: <strong class="green" id="idempGoodTotal"><span>$</span>0.00</strong>
          </div>
          <div class="idemp-verdict" id="idempGoodVerdict"></div>
        </div>
      </div>
      <div class="idemp-key-display" id="idempKeyDisplay">
        Idempotency Key: <code id="idempKeyValue">—</code>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- 4. Retry Logic Visualization                 -->
    <!-- ============================================ -->
    <section class="retry-section">
      <h2>🔁 Exponential Backoff & Retry</h2>
      <p class="section-desc">When a payment processor returns a transient error, we retry with exponential backoff. Watch the increasing delays between attempts.</p>
      <div class="retry-controls">
        <div class="retry-control-group">
          <label>Max Retries: <strong id="maxRetriesLabel">5</strong></label>
          <input type="range" id="maxRetriesSlider" min="1" max="8" value="5">
        </div>
        <div class="retry-control-group">
          <label>Base Delay: <strong id="baseDelayLabel">200</strong>ms</label>
          <input type="range" id="baseDelaySlider" min="100" max="2000" value="200" step="100">
        </div>
        <div class="retry-control-group">
          <label class="jitter-label">
            <input type="checkbox" id="jitterToggle" checked> Add Jitter
          </label>
        </div>
        <div class="retry-control-group">
          <label>Fail Probability: <strong id="failProbLabel">70</strong>%</label>
          <input type="range" id="failProbSlider" min="10" max="95" value="70">
        </div>
        <button id="startRetryBtn" class="action-btn primary-btn">▶️ Start Retry Sequence</button>
        <button id="resetRetryBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>
      <div class="retry-timeline" id="retryTimeline">
        <div class="retry-timeline-track" id="retryTrack"></div>
      </div>
      <div class="retry-stats">
        <div class="stat"><span class="stat-l">Attempt</span><span class="stat-v" id="retryAttempt">0</span></div>
        <div class="stat"><span class="stat-l">Total Wait</span><span class="stat-v" id="retryTotalWait">0ms</span></div>
        <div class="stat"><span class="stat-l">Next Delay</span><span class="stat-v" id="retryNextDelay">—</span></div>
        <div class="stat"><span class="stat-l">Result</span><span class="stat-v" id="retryResult">—</span></div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- 5. Distributed Transaction Patterns          -->
    <!-- ============================================ -->
    <section class="txn-section">
      <h2>🔗 Distributed Transaction Patterns</h2>
      <p class="section-desc">Compare Saga Pattern (choreography with compensating transactions) vs Two-Phase Commit (2PC). Step through each to see how failures are handled.</p>
      <div class="txn-grid">
        <!-- Saga Pattern -->
        <div class="txn-panel" id="sagaPanel">
          <h3>📜 Saga Pattern</h3>
          <p class="txn-desc">Each service performs its local transaction and publishes an event. On failure, compensating transactions undo previous steps.</p>
          <div class="txn-controls">
            <button id="sagaStepBtn" class="action-btn primary-btn">▶️ Next Step</button>
            <button id="sagaFailBtn" class="action-btn primary-btn-secondary">💥 Simulate Failure</button>
            <button id="sagaResetBtn" class="action-btn reset-btn">🔄 Reset</button>
          </div>
          <div class="saga-steps" id="sagaSteps">
            <div class="saga-step" id="saga-step-0" data-step="0">
              <div class="saga-step-num">1</div>
              <div class="saga-step-info">
                <div class="saga-step-name">Create Order</div>
                <div class="saga-step-comp">↩️ Cancel Order</div>
              </div>
              <div class="saga-step-status" id="saga-status-0">⏳</div>
            </div>
            <div class="saga-step" id="saga-step-1" data-step="1">
              <div class="saga-step-num">2</div>
              <div class="saga-step-info">
                <div class="saga-step-name">Reserve Inventory</div>
                <div class="saga-step-comp">↩️ Release Inventory</div>
              </div>
              <div class="saga-step-status" id="saga-status-1">⏳</div>
            </div>
            <div class="saga-step" id="saga-step-2" data-step="2">
              <div class="saga-step-num">3</div>
              <div class="saga-step-info">
                <div class="saga-step-name">Process Payment</div>
                <div class="saga-step-comp">↩️ Refund Payment</div>
              </div>
              <div class="saga-step-status" id="saga-status-2">⏳</div>
            </div>
            <div class="saga-step" id="saga-step-3" data-step="3">
              <div class="saga-step-num">4</div>
              <div class="saga-step-info">
                <div class="saga-step-name">Confirm Shipping</div>
                <div class="saga-step-comp">↩️ Cancel Shipment</div>
              </div>
              <div class="saga-step-status" id="saga-status-3">⏳</div>
            </div>
          </div>
          <div class="saga-log" id="sagaLog"></div>
        </div>

        <!-- Two-Phase Commit -->
        <div class="txn-panel" id="tpcPanel">
          <h3>🤝 Two-Phase Commit (2PC)</h3>
          <p class="txn-desc">A coordinator asks all participants to prepare, then commit. If any participant fails to prepare, all abort.</p>
          <div class="txn-controls">
            <button id="tpcStepBtn" class="action-btn primary-btn">▶️ Next Phase</button>
            <button id="tpcFailBtn" class="action-btn primary-btn-secondary">💥 Participant Fails</button>
            <button id="tpcResetBtn" class="action-btn reset-btn">🔄 Reset</button>
          </div>
          <div class="tpc-diagram" id="tpcDiagram">
            <div class="tpc-coordinator">
              <div class="tpc-node" id="tpc-coord">
                <div class="tpc-node-icon">👔</div>
                <div class="tpc-node-label">Coordinator</div>
                <div class="tpc-node-state" id="tpc-coord-state">INIT</div>
              </div>
            </div>
            <div class="tpc-arrows" id="tpcArrows">
              <div class="tpc-arrow-set">
                <div class="tpc-arrow-down" id="tpc-arrow-0">↓</div>
                <div class="tpc-arrow-down" id="tpc-arrow-1">↓</div>
                <div class="tpc-arrow-down" id="tpc-arrow-2">↓</div>
              </div>
            </div>
            <div class="tpc-participants">
              <div class="tpc-node" id="tpc-part-0">
                <div class="tpc-node-icon">🏦</div>
                <div class="tpc-node-label">Payment</div>
                <div class="tpc-node-state" id="tpc-part-0-state">INIT</div>
              </div>
              <div class="tpc-node" id="tpc-part-1">
                <div class="tpc-node-icon">📦</div>
                <div class="tpc-node-label">Inventory</div>
                <div class="tpc-node-state" id="tpc-part-1-state">INIT</div>
              </div>
              <div class="tpc-node" id="tpc-part-2">
                <div class="tpc-node-icon">📧</div>
                <div class="tpc-node-label">Notification</div>
                <div class="tpc-node-state" id="tpc-part-2-state">INIT</div>
              </div>
            </div>
          </div>
          <div class="tpc-phase-label" id="tpcPhaseLabel">Phase: Waiting</div>
          <div class="tpc-log" id="tpcLog"></div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- 6. Architecture Deep Dive                    -->
    <!-- ============================================ -->
    <section class="arch-section">
      <h2>🏗️ Architecture Deep Dive</h2>
      <div class="arch-tabs">
        <button class="arch-tab active" data-tab="api">API Design</button>
        <button class="arch-tab" data-tab="schema">Database Schema</button>
        <button class="arch-tab" data-tab="recon">Reconciliation</button>
        <button class="arch-tab" data-tab="fraud">Fraud Detection</button>
        <button class="arch-tab" data-tab="pci">PCI Compliance</button>
      </div>
      <div class="arch-panels">
        <!-- API Design -->
        <div class="arch-panel active" id="panel-api">
          <h3>RESTful Payment API</h3>
          <div class="code-block">
            <pre><code set:html={`POST /v1/payments
{
  "idempotency_key": "uuid-v4-unique-per-request",
  "amount": 4999,          // cents to avoid float issues
  "currency": "USD",
  "payment_method": {
    "type": "card",
    "token": "tok_visa_4242"  // tokenized, never raw card
  },
  "description": "Order #12345",
  "metadata": { "order_id": "12345" }
}

Response 201:
{
  "id": "pay_abc123",
  "status": "pending",
  "amount": 4999,
  "currency": "USD",
  "created_at": "2025-01-15T10:30:00Z"
}

GET /v1/payments/:id          // check status
POST /v1/payments/:id/capture // capture authorized payment
POST /v1/payments/:id/refund  // initiate refund
GET /v1/payments?limit=20     // list with pagination`} /></pre>
          </div>
          <div class="arch-notes">
            <p><strong>Key decisions:</strong></p>
            <ul>
              <li>Amounts in <strong>smallest currency unit</strong> (cents) to avoid floating-point errors</li>
              <li><strong>Idempotency key</strong> is required on all mutating endpoints</li>
              <li>Card data is <strong>tokenized</strong> before reaching our servers (PCI compliance)</li>
              <li>Separate <strong>authorize/capture</strong> flow for pre-auth scenarios</li>
              <li>All responses include <strong>status</strong> for async polling</li>
            </ul>
          </div>
        </div>

        <!-- Database Schema -->
        <div class="arch-panel" id="panel-schema">
          <h3>Core Tables</h3>
          <div class="code-block">
            <pre><code set:html={`-- Payments table (source of truth)
CREATE TABLE payments (
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  idempotency_key VARCHAR(255) UNIQUE NOT NULL,
  amount          BIGINT NOT NULL,        -- cents
  currency        VARCHAR(3) NOT NULL,
  status          VARCHAR(20) NOT NULL DEFAULT 'created',
  payment_method  JSONB NOT NULL,
  merchant_id     UUID NOT NULL REFERENCES merchants(id),
  description     TEXT,
  metadata        JSONB DEFAULT '{}',
  processor_ref   VARCHAR(255),           -- external ref
  failure_reason  TEXT,
  created_at      TIMESTAMPTZ DEFAULT NOW(),
  updated_at      TIMESTAMPTZ DEFAULT NOW()
);

-- State transition ledger (immutable audit log)
CREATE TABLE payment_events (
  id          BIGSERIAL PRIMARY KEY,
  payment_id  UUID NOT NULL REFERENCES payments(id),
  from_status VARCHAR(20),
  to_status   VARCHAR(20) NOT NULL,
  reason      TEXT,
  actor       VARCHAR(50),   -- 'system', 'user', 'webhook'
  created_at  TIMESTAMPTZ DEFAULT NOW()
);

-- Idempotency store (dedup layer)
CREATE TABLE idempotency_keys (
  key         VARCHAR(255) PRIMARY KEY,
  payment_id  UUID REFERENCES payments(id),
  response    JSONB,
  created_at  TIMESTAMPTZ DEFAULT NOW(),
  expires_at  TIMESTAMPTZ DEFAULT NOW() + INTERVAL '24 hours'
);`} /></pre>
          </div>
          <div class="arch-notes">
            <p><strong>Design rationale:</strong></p>
            <ul>
              <li><strong>Immutable event log</strong> tracks every state transition for auditability</li>
              <li><strong>UNIQUE constraint</strong> on idempotency_key provides database-level dedup</li>
              <li>Idempotency keys <strong>expire after 24h</strong> to bound storage growth</li>
              <li><strong>JSONB metadata</strong> allows flexible merchant-specific data</li>
              <li>Processor reference stored for <strong>reconciliation</strong> with external systems</li>
            </ul>
          </div>
        </div>

        <!-- Reconciliation -->
        <div class="arch-panel" id="panel-recon">
          <h3>Payment Reconciliation</h3>
          <div class="arch-diagram-text">
            <div class="recon-flow">
              <div class="recon-step">
                <div class="recon-icon">📥</div>
                <div class="recon-text"><strong>1. Ingest:</strong> Pull settlement files from processor (daily CSV/SFTP)</div>
              </div>
              <div class="recon-step">
                <div class="recon-icon">🔍</div>
                <div class="recon-text"><strong>2. Match:</strong> Join on processor_ref with our payments table</div>
              </div>
              <div class="recon-step">
                <div class="recon-icon">⚖️</div>
                <div class="recon-text"><strong>3. Compare:</strong> Verify amounts, currencies, statuses match</div>
              </div>
              <div class="recon-step">
                <div class="recon-icon">🚨</div>
                <div class="recon-text"><strong>4. Flag:</strong> Mismatches trigger alerts for manual review</div>
              </div>
              <div class="recon-step">
                <div class="recon-icon">✅</div>
                <div class="recon-text"><strong>5. Resolve:</strong> Adjust ledger entries or initiate corrections</div>
              </div>
            </div>
          </div>
          <div class="arch-notes">
            <p><strong>Common discrepancies:</strong></p>
            <ul>
              <li><strong>Missing payments:</strong> We recorded success but processor has no record (network issue)</li>
              <li><strong>Amount mismatch:</strong> Currency conversion differences or partial captures</li>
              <li><strong>Status mismatch:</strong> Webhook missed, payment actually declined at bank</li>
              <li><strong>Orphaned transactions:</strong> Processor charged but we crashed before recording</li>
            </ul>
          </div>
        </div>

        <!-- Fraud Detection -->
        <div class="arch-panel" id="panel-fraud">
          <h3>Fraud Detection Pipeline</h3>
          <div class="arch-diagram-text">
            <div class="fraud-layers">
              <div class="fraud-layer" data-risk="low">
                <div class="fraud-layer-label">Layer 1: Rules Engine</div>
                <div class="fraud-layer-desc">Velocity checks, amount thresholds, blocked lists, geo-IP</div>
              </div>
              <div class="fraud-layer" data-risk="medium">
                <div class="fraud-layer-label">Layer 2: ML Scoring</div>
                <div class="fraud-layer-desc">Real-time risk score (0-100) from behavioral features</div>
              </div>
              <div class="fraud-layer" data-risk="high">
                <div class="fraud-layer-label">Layer 3: 3D Secure</div>
                <div class="fraud-layer-desc">Challenge high-risk with bank-issued OTP verification</div>
              </div>
              <div class="fraud-layer" data-risk="review">
                <div class="fraud-layer-label">Layer 4: Manual Review</div>
                <div class="fraud-layer-desc">Suspicious transactions queued for human analysts</div>
              </div>
            </div>
          </div>
          <div class="arch-notes">
            <p><strong>Key signals:</strong></p>
            <ul>
              <li>Card testing patterns (many small charges in rapid succession)</li>
              <li>Shipping/billing address mismatch</li>
              <li>Device fingerprint anomalies</li>
              <li>Unusual purchase velocity or amount for the merchant category</li>
            </ul>
          </div>
        </div>

        <!-- PCI Compliance -->
        <div class="arch-panel" id="panel-pci">
          <h3>PCI DSS Compliance</h3>
          <div class="arch-diagram-text">
            <div class="pci-zones">
              <div class="pci-zone pci-zone-outside">
                <div class="pci-zone-label">Outside PCI Scope</div>
                <div class="pci-zone-items">
                  <span class="pci-item">Application Server</span>
                  <span class="pci-item">User Dashboard</span>
                  <span class="pci-item">Analytics</span>
                </div>
              </div>
              <div class="pci-zone pci-zone-boundary">
                <div class="pci-zone-label">PCI Boundary</div>
                <div class="pci-zone-items">
                  <span class="pci-item">Tokenization Service</span>
                  <span class="pci-item">Card Vault (HSM)</span>
                </div>
              </div>
              <div class="pci-zone pci-zone-external">
                <div class="pci-zone-label">External (PSP)</div>
                <div class="pci-zone-items">
                  <span class="pci-item">Stripe / Adyen</span>
                  <span class="pci-item">Card Networks</span>
                </div>
              </div>
            </div>
          </div>
          <div class="arch-notes">
            <p><strong>Minimizing PCI scope:</strong></p>
            <ul>
              <li>Use a <strong>PSP's hosted payment form</strong> (Stripe Elements) so raw card data never hits our servers</li>
              <li>If we must handle cards: <strong>tokenize immediately</strong> at the edge and store tokens, not PANs</li>
              <li><strong>Network segmentation</strong> isolates card data environment from general infrastructure</li>
              <li><strong>Encryption at rest and in transit</strong> (TLS 1.2+, AES-256 for stored tokens)</li>
              <li>Regular <strong>penetration testing</strong> and <strong>vulnerability scanning</strong> required</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- 7. Key Design Decisions                      -->
    <!-- ============================================ -->
    <section class="decisions-section">
      <h2>⚖️ Key Design Decisions</h2>
      <div class="decisions-grid">
        <div class="decision-card">
          <h4>Consistency vs Availability</h4>
          <div class="decision-tradeoff">
            <div class="decision-option decision-chosen">
              <span class="decision-badge">Chosen</span>
              <strong>Strong Consistency</strong>
              <p>Payment status must be accurate. We accept higher latency and use synchronous writes with ACID guarantees.</p>
            </div>
            <div class="decision-vs">vs</div>
            <div class="decision-option">
              <strong>High Availability</strong>
              <p>Eventual consistency risks showing stale payment states, leading to double-charges or lost payments.</p>
            </div>
          </div>
        </div>
        <div class="decision-card">
          <h4>Sync vs Async Processing</h4>
          <div class="decision-tradeoff">
            <div class="decision-option">
              <strong>Fully Synchronous</strong>
              <p>Simple but blocks user while waiting for bank response (can be 5-30 seconds).</p>
            </div>
            <div class="decision-vs">vs</div>
            <div class="decision-option decision-chosen">
              <span class="decision-badge">Chosen</span>
              <strong>Async with Webhooks</strong>
              <p>Return "pending" immediately. Notify via webhook when bank responds. Better UX and throughput.</p>
            </div>
          </div>
        </div>
        <div class="decision-card">
          <h4>Single DB vs Event Sourcing</h4>
          <div class="decision-tradeoff">
            <div class="decision-option">
              <strong>Single Mutable Row</strong>
              <p>Simpler queries but loses history of state transitions. Hard to debug payment issues.</p>
            </div>
            <div class="decision-vs">vs</div>
            <div class="decision-option decision-chosen">
              <span class="decision-badge">Chosen</span>
              <strong>Event Sourced Ledger</strong>
              <p>Append-only event log. Current state is derived. Full auditability for financial compliance.</p>
            </div>
          </div>
        </div>
        <div class="decision-card">
          <h4>Build vs Buy PSP</h4>
          <div class="decision-tradeoff">
            <div class="decision-option">
              <strong>Build In-House</strong>
              <p>Full control but massive PCI scope, card network agreements, and compliance burden.</p>
            </div>
            <div class="decision-vs">vs</div>
            <div class="decision-option decision-chosen">
              <span class="decision-badge">Chosen</span>
              <strong>Use PSP (Stripe/Adyen)</strong>
              <p>Outsource PCI scope. Focus on business logic. Multi-PSP for redundancy.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

