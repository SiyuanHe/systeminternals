---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Design a Distributed File System — Interactive Visualization"
  description="Understand distributed file system architecture: chunk splitting, replication, master/chunk servers, consistency, fault tolerance. Interactive simulation."
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "System Design", href: "/system-design/" },
    { label: "Distributed File System", href: "/system-design/distributed-file-system/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>📁💾 Design a Distributed File System</h1>
      <p class="subtitle">Chunk splitting, replication, master/chunk architecture, consistency, and fault tolerance — all interactive</p>
    </header>

    <section class="overview-section">
      <div class="overview-card">
        <p>
          A distributed file system stores large files across multiple machines by splitting them into
          fixed-size <strong>chunks</strong> (typically 64MB) and replicating each chunk across several
          <strong>chunk servers</strong>. A <strong>master server</strong> maintains metadata: the file
          namespace, chunk-to-server mappings, and lease management. The key challenges are
          <em>consistency</em>, <em>fault tolerance</em>, and <em>efficient data flow</em>. This design
          is inspired by the Google File System (GFS) and HDFS.
        </p>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- Section 1: File Chunking Visualization                       -->
    <!-- ============================================================ -->
    <section class="chunking-section">
      <h2>🔪 File Chunking</h2>
      <p class="section-desc">Enter a file name and size to see it split into fixed-size chunks. Each chunk gets a unique ID and is tracked by the master's metadata table.</p>

      <div class="chunking-controls">
        <div class="input-group">
          <label for="fileName">File Name</label>
          <input type="text" id="fileName" value="research_data.tar" placeholder="e.g. backup.tar">
        </div>
        <div class="input-group">
          <label for="fileSize">File Size (MB)</label>
          <input type="number" id="fileSize" value="400" min="1" max="2048">
        </div>
        <div class="input-group">
          <label for="chunkSize">Chunk Size (MB)</label>
          <select id="chunkSize">
            <option value="16">16 MB</option>
            <option value="32">32 MB</option>
            <option value="64" selected>64 MB</option>
            <option value="128">128 MB</option>
          </select>
        </div>
        <button id="splitFileBtn" class="action-btn primary-btn">Split File</button>
        <button id="resetChunkBtn" class="action-btn reset-btn">Reset</button>
      </div>

      <div class="chunking-layout">
        <div class="file-visual">
          <div class="file-icon" id="fileIcon">
            <div class="file-icon-inner">
              <span class="file-emoji">📄</span>
              <span class="file-label" id="fileLabel">research_data.tar</span>
              <span class="file-size-label" id="fileSizeLabel">400 MB</span>
            </div>
          </div>
          <div class="split-arrow" id="splitArrow">
            <svg width="60" height="30"><path d="M5,15 L50,15" stroke="#4fc3f7" stroke-width="2" stroke-dasharray="6,3" fill="none"/><polygon points="50,10 60,15 50,20" fill="#4fc3f7"/></svg>
          </div>
          <div class="chunks-container" id="chunksContainer"></div>
        </div>
        <div class="metadata-table-wrap">
          <h4>Master Metadata Table</h4>
          <table class="metadata-table" id="metadataTable">
            <thead>
              <tr><th>Chunk ID</th><th>File</th><th>Offset</th><th>Size</th><th>Checksum</th></tr>
            </thead>
            <tbody id="metadataBody"></tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- Section 2: Replication Across Nodes                          -->
    <!-- ============================================================ -->
    <section class="replication-section">
      <h2>🔄 Replication Across Nodes</h2>
      <p class="section-desc">Watch chunks replicated across chunk servers. Adjust the replication factor. Click a node to simulate failure and observe re-replication.</p>

      <div class="replication-controls">
        <label>Replication Factor: <strong id="repFactorLabel">3</strong>
          <input type="range" id="repFactorSlider" min="1" max="5" value="3">
        </label>
        <button id="replicateBtn" class="action-btn primary-btn">Replicate Chunks</button>
        <button id="resetRepBtn" class="action-btn reset-btn">Reset</button>
      </div>

      <div class="cluster-layout">
        <div class="cluster-ring" id="clusterRing"></div>
        <div class="replication-info">
          <div class="rep-legend">
            <span class="legend-item"><span class="legend-dot primary-dot"></span> Primary</span>
            <span class="legend-item"><span class="legend-dot replica1-dot"></span> Replica 1</span>
            <span class="legend-item"><span class="legend-dot replica2-dot"></span> Replica 2</span>
            <span class="legend-item"><span class="legend-dot dead-dot"></span> Dead Node</span>
          </div>
          <div class="rep-stats">
            <div class="stat"><span class="stat-l">Total Nodes</span><span class="stat-v" id="totalNodes">8</span></div>
            <div class="stat"><span class="stat-l">Healthy Nodes</span><span class="stat-v" id="healthyNodes">8</span></div>
            <div class="stat"><span class="stat-l">Chunks Stored</span><span class="stat-v" id="chunksStored">0</span></div>
            <div class="stat"><span class="stat-l">Under-Replicated</span><span class="stat-v" id="underReplicated">0</span></div>
          </div>
          <div class="rep-log" id="repLog"></div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- Section 3: Master / Chunk Server Architecture                -->
    <!-- ============================================================ -->
    <section class="architecture-section">
      <h2>🏗️ Master / Chunk Server Architecture</h2>
      <p class="section-desc">Toggle between read and write flows to see how clients interact with the master and chunk servers.</p>

      <div class="arch-controls">
        <button id="writeFlowBtn" class="action-btn primary-btn active-flow">Write Flow</button>
        <button id="readFlowBtn" class="action-btn primary-btn-secondary">Read Flow</button>
        <button id="replayFlowBtn" class="action-btn reset-btn">Replay</button>
      </div>

      <div class="arch-diagram" id="archDiagram">
        <canvas id="archCanvas" width="800" height="450"></canvas>
      </div>

      <div class="flow-steps" id="flowSteps"></div>
    </section>

    <!-- ============================================================ -->
    <!-- Section 4: Consistency Model                                 -->
    <!-- ============================================================ -->
    <section class="consistency-section">
      <h2>🔒 Consistency Model</h2>
      <p class="section-desc">Compare strong vs. eventual consistency. Watch how write acknowledgements differ and how replicas converge.</p>

      <div class="consistency-controls">
        <button id="strongConsBtn" class="action-btn primary-btn active-cons">Strong Consistency</button>
        <button id="eventualConsBtn" class="action-btn primary-btn-secondary">Eventual Consistency</button>
        <button id="triggerWriteBtn" class="action-btn primary-btn">Trigger Write</button>
        <button id="resetConsBtn" class="action-btn reset-btn">Reset</button>
      </div>

      <div class="consistency-layout">
        <div class="cons-timeline" id="consTimeline">
          <canvas id="consCanvas" width="750" height="350"></canvas>
        </div>
        <div class="cons-info">
          <div class="cons-status" id="consStatus">
            <div class="stat"><span class="stat-l">Model</span><span class="stat-v" id="consModelLabel">Strong</span></div>
            <div class="stat"><span class="stat-l">Write Latency</span><span class="stat-v" id="writeLatency">—</span></div>
            <div class="stat"><span class="stat-l">Replicas Synced</span><span class="stat-v" id="replicasSynced">0 / 3</span></div>
            <div class="stat"><span class="stat-l">ACK Sent</span><span class="stat-v" id="ackSent">No</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- Section 5: Fault Tolerance                                   -->
    <!-- ============================================================ -->
    <section class="fault-section">
      <h2>💥 Fault Tolerance Simulation</h2>
      <p class="section-desc">Click on chunk servers to kill them. Watch the system detect the failure via heartbeat timeout and trigger re-replication on surviving nodes.</p>

      <div class="fault-controls">
        <button id="startHeartbeatBtn" class="action-btn primary-btn">Start Heartbeat Monitor</button>
        <button id="resetFaultBtn" class="action-btn reset-btn">Reset All Nodes</button>
      </div>

      <div class="fault-layout">
        <div class="fault-cluster" id="faultCluster"></div>
        <div class="fault-info">
          <div class="fault-stats">
            <div class="stat"><span class="stat-l">Alive</span><span class="stat-v green" id="aliveCount">8</span></div>
            <div class="stat"><span class="stat-l">Dead</span><span class="stat-v red" id="deadCount">0</span></div>
            <div class="stat"><span class="stat-l">Re-replications</span><span class="stat-v" id="reRepCount">0</span></div>
            <div class="stat"><span class="stat-l">Recovery Time</span><span class="stat-v" id="recoveryTime">— ms</span></div>
          </div>
          <div class="heartbeat-monitor" id="heartbeatMonitor">
            <h4>Heartbeat Log</h4>
            <div class="hb-log" id="hbLog"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- Section 6: Architecture Deep Dive                            -->
    <!-- ============================================================ -->
    <section class="deepdive-section">
      <h2>📚 Architecture Deep Dive</h2>
      <p class="section-desc">Detailed internals of a production distributed file system.</p>

      <div class="deepdive-grid">
        <div class="deepdive-card">
          <h3>Namespace Management</h3>
          <p>The master manages the full file namespace as a flat lookup table mapping pathnames to metadata. Each path has a read-write lock. Creating <code>/d1/d2/leaf</code> acquires read locks on <code>/d1</code> and <code>/d1/d2</code> and a write lock on <code>/d1/d2/leaf</code>. This allows concurrent mutations in the same directory — unlike a traditional inode tree.</p>
          <div class="dd-detail">
            <strong>Key Insight:</strong> No per-directory data structures means no risk of directory-level hot spots.
          </div>
        </div>

        <div class="deepdive-card">
          <h3>Chunk Lease Mechanism</h3>
          <p>The master grants a 60-second lease to one replica (the <strong>primary</strong>) for each chunk. The primary picks the mutation order and all replicas follow it. This ensures a consistent serial order without the master being on the data path.</p>
          <div class="dd-detail">
            <strong>Lease Renewal:</strong> The primary requests extensions via heartbeat messages. If the master loses contact, it waits for the lease to expire before granting a new one — preventing split-brain.
          </div>
        </div>

        <div class="deepdive-card">
          <h3>Garbage Collection</h3>
          <p>Deleted files are renamed to a hidden name with a deletion timestamp. A background scan reclaims files hidden for more than 3 days. Orphaned chunks (no file reference) are identified during chunk-namespace comparison and removed.</p>
          <div class="dd-detail">
            <strong>Advantage:</strong> Lazy deletion provides a safety net against accidental deletes and simplifies failure handling during complex operations.
          </div>
        </div>

        <div class="deepdive-card">
          <h3>Snapshots</h3>
          <p>Snapshot is implemented via <strong>copy-on-write</strong>. When a snapshot is requested, the master revokes all leases on affected chunks, logs the operation, and duplicates the metadata. Actual data is only copied when a chunk is next mutated.</p>
          <div class="dd-detail">
            <strong>Efficiency:</strong> Snapshot is nearly instantaneous regardless of dataset size since no data is copied upfront.
          </div>
        </div>

        <div class="deepdive-card">
          <h3>Data Integrity</h3>
          <p>Each chunk is divided into 64KB blocks, each with a 32-bit checksum. On reads, the chunk server verifies the checksum before returning data. Corruption is detected immediately, and the client retries from another replica. The master then re-replicates the valid copy.</p>
          <div class="dd-detail">
            <strong>Idle Verification:</strong> Chunk servers scan inactive chunks periodically to detect bit-rot before it affects reads.
          </div>
        </div>

        <div class="deepdive-card">
          <h3>Scaling Strategies</h3>
          <p>Scale horizontally by adding chunk servers — the master rebalances chunks. For metadata scaling, use a shadow master for read-only redundancy, or partition the namespace across multiple masters (federated model as in HDFS Federation).</p>
          <div class="dd-detail">
            <strong>Bottleneck:</strong> The single-master model limits namespace operations. HDFS Federation addresses this with independent namespace volumes.
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- Section 7: Key Design Decisions                              -->
    <!-- ============================================================ -->
    <section class="tradeoffs-section">
      <h2>⚖️ Key Design Decisions</h2>
      <p class="section-desc">Every design choice involves tradeoffs. Understand both sides.</p>

      <div class="tradeoff-grid">
        <div class="tradeoff-card">
          <h3>Chunk Size: Small vs. Large</h3>
          <div class="tradeoff-sides">
            <div class="tradeoff-pro">
              <h4>Large Chunks (64–128 MB)</h4>
              <ul>
                <li>Fewer metadata entries on master</li>
                <li>Fewer TCP connections per file read</li>
                <li>Good for large sequential reads</li>
              </ul>
            </div>
            <div class="tradeoff-con">
              <h4>Small Chunks (4–16 MB)</h4>
              <ul>
                <li>Better parallelism for small files</li>
                <li>Less internal fragmentation</li>
                <li>More metadata overhead on master</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="tradeoff-card">
          <h3>Replication vs. Erasure Coding</h3>
          <div class="tradeoff-sides">
            <div class="tradeoff-pro">
              <h4>Replication (3x)</h4>
              <ul>
                <li>Simple implementation</li>
                <li>Fast reads (any replica)</li>
                <li>3x storage overhead</li>
              </ul>
            </div>
            <div class="tradeoff-con">
              <h4>Erasure Coding (e.g. RS 6+3)</h4>
              <ul>
                <li>1.5x storage overhead</li>
                <li>CPU cost for encoding/decoding</li>
                <li>Good for cold/warm data</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="tradeoff-card">
          <h3>Strong vs. Eventual Consistency</h3>
          <div class="tradeoff-sides">
            <div class="tradeoff-pro">
              <h4>Strong Consistency</h4>
              <ul>
                <li>All readers see the latest write</li>
                <li>Simpler application logic</li>
                <li>Higher write latency</li>
              </ul>
            </div>
            <div class="tradeoff-con">
              <h4>Eventual Consistency</h4>
              <ul>
                <li>Lower write latency</li>
                <li>Better availability</li>
                <li>Risk of stale reads</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="tradeoff-card">
          <h3>Single vs. Distributed Metadata</h3>
          <div class="tradeoff-sides">
            <div class="tradeoff-pro">
              <h4>Single Master</h4>
              <ul>
                <li>Simple consistency for metadata</li>
                <li>Global view for placement</li>
                <li>Single point of failure risk</li>
              </ul>
            </div>
            <div class="tradeoff-con">
              <h4>Distributed Metadata</h4>
              <ul>
                <li>No single bottleneck</li>
                <li>Higher availability</li>
                <li>Complex consistency (Paxos/Raft)</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* =========== Global =========== */
  .viz-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.25rem 3rem;
    color: #e0e0e0;
  }
  .viz-header {
    text-align: center;
    padding: 2.5rem 0 1rem;
  }
  .viz-header h1 {
    font-size: 2.2rem;
    margin: 0 0 0.5rem;
    color: #fff;
  }
  .subtitle {
    color: #90a4ae;
    font-size: 1.05rem;
    margin: 0;
  }

  /* Overview */
  .overview-section { margin-bottom: 2rem; }
  .overview-card {
    background: #1a2332;
    border: 1px solid #263248;
    border-radius: 12px;
    padding: 1.5rem;
    line-height: 1.7;
    font-size: 1rem;
  }
  .overview-card strong { color: #4fc3f7; }
  .overview-card em { color: #81c784; }

  /* Shared section styling */
  section {
    margin-bottom: 3rem;
  }
  section h2 {
    font-size: 1.55rem;
    color: #fff;
    margin: 0 0 0.4rem;
  }
  .section-desc {
    color: #90a4ae;
    margin: 0 0 1.25rem;
    font-size: 0.95rem;
  }

  /* Buttons */
  .action-btn {
    padding: 0.5rem 1.1rem;
    border: none;
    border-radius: 8px;
    font-size: 0.9rem;
    cursor: pointer;
    font-weight: 600;
    transition: background 0.2s, transform 0.1s;
  }
  .action-btn:active { transform: scale(0.97); }
  .primary-btn { background: #1976d2; color: #fff; }
  .primary-btn:hover { background: #1e88e5; }
  .primary-btn-secondary { background: #2e3d52; color: #90caf9; border: 1px solid #37474f; }
  .primary-btn-secondary:hover { background: #37474f; }
  .reset-btn { background: #37474f; color: #b0bec5; }
  .reset-btn:hover { background: #455a64; }
  .active-flow, .active-cons { background: #0d47a1; box-shadow: 0 0 8px rgba(25,118,210,0.5); }

  /* Stat blocks */
  .stat { display: flex; justify-content: space-between; padding: 0.35rem 0; border-bottom: 1px solid #1e2d3d; font-size: 0.9rem; }
  .stat-l { color: #78909c; }
  .stat-v { color: #4fc3f7; font-weight: 700; }
  .green { color: #66bb6a !important; }
  .red { color: #ef5350 !important; }

  /* =========== Section 1: Chunking =========== */
  .chunking-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: flex-end;
    margin-bottom: 1.25rem;
  }
  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .input-group label {
    font-size: 0.8rem;
    color: #78909c;
  }
  .input-group input, .input-group select {
    padding: 0.45rem 0.7rem;
    border-radius: 6px;
    border: 1px solid #37474f;
    background: #0d1b2a;
    color: #e0e0e0;
    font-size: 0.9rem;
    width: 150px;
  }
  .chunking-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .file-visual {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .file-icon {
    flex-shrink: 0;
  }
  .file-icon-inner {
    background: #1a2332;
    border: 2px solid #1976d2;
    border-radius: 10px;
    padding: 1rem;
    text-align: center;
    width: 120px;
    transition: border-color 0.3s;
  }
  .file-emoji { font-size: 2rem; display: block; margin-bottom: 0.3rem; }
  .file-label { display: block; font-size: 0.8rem; color: #90caf9; word-break: break-all; }
  .file-size-label { display: block; font-size: 0.75rem; color: #78909c; margin-top: 0.2rem; }
  .split-arrow { flex-shrink: 0; display: flex; align-items: center; padding-top: 1.5rem; }
  .chunks-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
  }
  .chunk-block {
    background: #0d2137;
    border: 1px solid #1565c0;
    border-radius: 6px;
    padding: 0.4rem 0.6rem;
    font-size: 0.72rem;
    text-align: center;
    min-width: 70px;
    opacity: 0;
    transform: translateY(10px);
    animation: chunkAppear 0.35s forwards;
  }
  .chunk-block .chunk-id { color: #4fc3f7; display: block; font-weight: 700; }
  .chunk-block .chunk-sz { color: #78909c; display: block; }
  @keyframes chunkAppear {
    to { opacity: 1; transform: translateY(0); }
  }

  .metadata-table-wrap {
    overflow-x: auto;
  }
  .metadata-table-wrap h4 { color: #b0bec5; margin: 0 0 0.5rem; font-size: 0.95rem; }
  .metadata-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }
  .metadata-table th {
    background: #0d1b2a;
    color: #4fc3f7;
    padding: 0.4rem 0.5rem;
    text-align: left;
    border-bottom: 1px solid #1e2d3d;
    white-space: nowrap;
  }
  .metadata-table td {
    padding: 0.35rem 0.5rem;
    border-bottom: 1px solid #131f2e;
    color: #b0bec5;
    white-space: nowrap;
  }
  .metadata-table tbody tr { opacity: 0; animation: rowAppear 0.3s forwards; }
  @keyframes rowAppear { to { opacity: 1; } }

  /* =========== Section 2: Replication =========== */
  .replication-controls {
    display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; margin-bottom: 1.25rem;
  }
  .replication-controls label { color: #b0bec5; font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem; }
  .replication-controls input[type="range"] { width: 100px; }
  .cluster-layout {
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: 1.5rem;
  }
  .cluster-ring {
    position: relative;
    width: 400px;
    height: 400px;
    border: 2px dashed #1e2d3d;
    border-radius: 50%;
    margin: 0 auto;
  }
  .node-circle {
    position: absolute;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #1a2332;
    border: 3px solid #37474f;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: #b0bec5;
    cursor: pointer;
    transition: border-color 0.3s, background 0.3s, box-shadow 0.3s, transform 0.2s;
    z-index: 2;
  }
  .node-circle:hover { transform: scale(1.1); }
  .node-circle .node-label { font-weight: 700; font-size: 0.75rem; }
  .node-circle .node-chunks { font-size: 0.65rem; color: #78909c; }
  .node-circle.node-dead {
    border-color: #c62828;
    background: #3e1111;
    opacity: 0.6;
  }
  .node-circle.node-dead .node-label { color: #ef5350; text-decoration: line-through; }
  .chunk-dot {
    position: absolute;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0;
    animation: dotAppear 0.5s forwards;
  }
  @keyframes dotAppear { to { opacity: 1; } }
  .chunk-dot.primary-chunk { background: #1976d2; }
  .chunk-dot.replica1-chunk { background: #43a047; }
  .chunk-dot.replica2-chunk { background: #f9a825; }

  .replication-info { display: flex; flex-direction: column; gap: 1rem; }
  .rep-legend { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 0.5rem; }
  .legend-item { display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; color: #b0bec5; }
  .legend-dot { width: 12px; height: 12px; border-radius: 50%; display: inline-block; }
  .primary-dot { background: #1976d2; }
  .replica1-dot { background: #43a047; }
  .replica2-dot { background: #f9a825; }
  .dead-dot { background: #c62828; }

  .rep-log {
    background: #0d1b2a;
    border: 1px solid #1e2d3d;
    border-radius: 8px;
    padding: 0.75rem;
    max-height: 180px;
    overflow-y: auto;
    font-size: 0.78rem;
    font-family: 'Courier New', monospace;
    color: #78909c;
  }
  .rep-log .log-entry { margin-bottom: 0.25rem; }
  .rep-log .log-entry.info { color: #4fc3f7; }
  .rep-log .log-entry.warn { color: #ffa726; }
  .rep-log .log-entry.error { color: #ef5350; }
  .rep-log .log-entry.success { color: #66bb6a; }

  /* =========== Section 3: Architecture =========== */
  .arch-controls {
    display: flex; gap: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap;
  }
  .arch-diagram {
    background: #0d1b2a;
    border: 1px solid #1e2d3d;
    border-radius: 12px;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }
  .arch-diagram canvas { display: block; margin: 0 auto; }
  .flow-steps {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .flow-step {
    background: #1a2332;
    border: 1px solid #263248;
    border-radius: 8px;
    padding: 0.6rem 0.9rem;
    font-size: 0.85rem;
    color: #78909c;
    flex: 1;
    min-width: 160px;
    opacity: 0.4;
    transition: opacity 0.4s, border-color 0.4s;
  }
  .flow-step.active-step {
    opacity: 1;
