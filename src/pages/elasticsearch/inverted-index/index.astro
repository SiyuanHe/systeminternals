</style>

<script is:inline>
  // ========== STOP WORDS & STEMMING ==========
  var STOP_WORDS = new Set(['the', 'a', 'an', 'is', 'are', 'was', 'were', 'be', 'been', 'being',
    'have', 'has', 'had', 'do', 'does', 'did', 'will', 'would', 'could', 'should', 'may', 'might',
    'shall', 'can', 'to', 'of', 'in', 'for', 'on', 'with', 'at', 'by', 'from', 'as', 'into',
    'through', 'during', 'before', 'after', 'above', 'below', 'between', 'out', 'off', 'over',
    'under', 'again', 'further', 'then', 'once', 'and', 'but', 'or', 'nor', 'not', 'so', 'yet',
    'both', 'either', 'neither', 'each', 'every', 'all', 'any', 'few', 'more', 'most', 'other',
    'some', 'such', 'no', 'only', 'own', 'same', 'than', 'too', 'very', 'just', 'it', 'its',
    'this', 'that', 'these', 'those', 'i', 'me', 'my', 'we', 'our', 'you', 'your', 'he', 'him',
    'his', 'she', 'her', 'they', 'them', 'their', 'what', 'which', 'who', 'whom']);

  function simpleStem(word) {
    if (word.length < 4) return word;
    // Simple suffix stripping
    if (word.endsWith('ies') && word.length > 4) return word.slice(0, -3) + 'y';
    if (word.endsWith('sses')) return word.slice(0, -2);
    if (word.endsWith('ness')) return word.slice(0, -4);
    if (word.endsWith('ment')) return word.slice(0, -4) || word;
    if (word.endsWith('ting') && word.length > 5) return word.slice(0, -3);
    if (word.endsWith('ing') && word.length > 5) return word.slice(0, -3);
    if (word.endsWith('tion')) return word.slice(0, -4) + 't';
    if (word.endsWith('ous')) return word.slice(0, -3);
    if (word.endsWith('ive')) return word.slice(0, -3);
    if (word.endsWith('ful')) return word.slice(0, -3);
    if (word.endsWith('ly') && word.length > 4) return word.slice(0, -2);
    if (word.endsWith('ed') && word.length > 4) return word.slice(0, -2);
    if (word.endsWith('er') && word.length > 4) return word.slice(0, -2);
    if (word.endsWith('es') && word.length > 4) return word.slice(0, -2);
    if (word.endsWith('s') && !word.endsWith('ss') && word.length > 3) return word.slice(0, -1);
    return word;
  }

  function analyze(text) {
    // Step 1: Character filters (strip HTML, normalize)
    var charFiltered = text.replace(/<[^>]+>/g, '').replace(/&amp;/g, 'and').replace(/&/g, 'and');

    // Step 2: Tokenize (split on non-alphanumeric)
    var rawTokens = charFiltered.split(/[^a-zA-Z0-9]+/).filter(function(t) { return t.length > 0; });

    // Step 3: Lowercase
    var lowered = rawTokens.map(function(t) { return t.toLowerCase(); });

    // Step 4: Stop word removal
    var stopped = lowered.map(function(t) {
      return { token: t, removed: STOP_WORDS.has(t) };
    });

    // Step 5: Stemming on non-stopped tokens
    var final = [];
    var stemmed = [];
    for (var i = 0; i < stopped.length; i++) {
      if (!stopped[i].removed) {
        var s = simpleStem(stopped[i].token);
        stemmed.push({ original: stopped[i].token, stemmed: s, changed: s !== stopped[i].token });
        final.push(s);
      }
    }

    return {
      original: text,
      charFiltered: charFiltered,
      rawTokens: rawTokens,
      lowered: lowered,
      stopped: stopped,
      stemmed: stemmed,
      final: final
    };
  }

  // ========== ANALYZER PIPELINE VIZ ==========
  function renderPipeline() {
    var input = document.getElementById('analyzerInput');
    var container = document.getElementById('pipelineStages');
    var text = input.value.trim();
    if (!text) { container.innerHTML = ''; return; }

    var result = analyze(text);
    var html = '';

    // Stage 1: Original
    html += '<div class="stage"><div class="stage-header" style="color:#888;">📝 Original Input</div>';
    html += '<div class="token-list"><span class="token-chip original">' + escapeHtml(result.original) + '</span></div></div>';
    html += '<div class="stage-arrow">▼</div>';

    // Stage 2: Char filtered
    html += '<div class="stage"><div class="stage-header" style="color:#60a5fa;">🔤 Character Filters</div>';
    html += '<div class="token-list"><span class="token-chip filtered">' + escapeHtml(result.charFiltered) + '</span></div></div>';
    html += '<div class="stage-arrow">▼</div>';

    // Stage 3: Tokenized
    html += '<div class="stage"><div class="stage-header" style="color:#a855f7;">✂️ Tokenizer (standard)</div>';
    html += '<div class="token-list">';
    for (var i = 0; i < result.rawTokens.length; i++) {
      html += '<span class="token-chip filtered">' + escapeHtml(result.rawTokens[i]) + '</span>';
    }
    html += '</div></div>';
    html += '<div class="stage-arrow">▼</div>';

    // Stage 4: Lowercase
    html += '<div class="stage"><div class="stage-header" style="color:#eab308;">🔡 Lowercase</div>';
    html += '<div class="token-list">';
    for (var i = 0; i < result.lowered.length; i++) {
      html += '<span class="token-chip filtered">' + escapeHtml(result.lowered[i]) + '</span>';
    }
    html += '</div></div>';
    html += '<div class="stage-arrow">▼</div>';

    // Stage 5: Stop word removal
    html += '<div class="stage"><div class="stage-header" style="color:#ef4444;">🚫 Stop Words Removal</div>';
    html += '<div class="token-list">';
    for (var i = 0; i < result.stopped.length; i++) {
      var cls = result.stopped[i].removed ? 'removed' : 'filtered';
      html += '<span class="token-chip ' + cls + '">' + escapeHtml(result.stopped[i].token) + '</span>';
    }
    html += '</div></div>';
    html += '<div class="stage-arrow">▼</div>';

    // Stage 6: Stemming
    html += '<div class="stage"><div class="stage-header" style="color:#22c55e;">🌱 Stemming</div>';
    html += '<div class="token-list">';
    for (var i = 0; i < result.stemmed.length; i++) {
      var cls = result.stemmed[i].changed ? 'stemmed' : 'filtered';
      var label = result.stemmed[i].changed
        ? escapeHtml(result.stemmed[i].original) + ' → ' + escapeHtml(result.stemmed[i].stemmed)
        : escapeHtml(result.stemmed[i].stemmed);
      html += '<span class="token-chip ' + cls + '">' + label + '</span>';
    }
    html += '</div></div>';

    // Final tokens
    html += '<div class="stage" style="border-color:rgba(0,212,255,0.3);background:rgba(0,212,255,0.05);"><div class="stage-header" style="color:#00d4ff;">✅ Final Tokens (indexed)</div>';
    html += '<div class="token-list">';
    for (var i = 0; i < result.final.length; i++) {
      html += '<span class="token-chip filtered" style="background:rgba(0,212,255,0.15);color:#00d4ff;border-color:rgba(0,212,255,0.4);">' + escapeHtml(result.final[i]) + '</span>';
    }
    html += '</div></div>';

    container.innerHTML = html;
  }

  function escapeHtml(text) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(text));
    return div.innerHTML;
  }

  document.getElementById('analyzeBtn').addEventListener('click', renderPipeline);
  document.getElementById('analyzerInput').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') renderPipeline();
  });

  // ========== INVERTED INDEX ==========
  var documents = [];
  var invertedIdx = {};

  function addDocument(text) {
    var docId = documents.length + 1;
    documents.push({ id: docId, text: text });
    var result = analyze(text);
    for (var i = 0; i < result.final.length; i++) {
      var term = result.final[i];
      if (!invertedIdx[term]) invertedIdx[term] = [];
      if (invertedIdx[term].indexOf(docId) === -1) {
        invertedIdx[term].push(docId);
      }
    }
    renderIndex();
  }

  function renderIndex() {
    var docsList = document.getElementById('docsList');
    var indexDiv = document.getElementById('invertedIndex');

    // Render documents
    var docsHtml = '';
    for (var i = 0; i < documents.length; i++) {
      docsHtml += '<div class="doc-item" data-doc-id="' + documents[i].id + '">';
      docsHtml += '<span class="doc-id">DOC ' + documents[i].id + '</span>';
      docsHtml += escapeHtml(documents[i].text);
      docsHtml += '</div>';
    }
    if (documents.length === 0) {
      docsHtml = '<div style="color:#555;text-align:center;padding:20px;">No documents indexed yet</div>';
    }
    docsList.innerHTML = docsHtml;

    // Render inverted index sorted by term
    var terms = Object.keys(invertedIdx).sort();
    var indexHtml = '';
    for (var i = 0; i < terms.length; i++) {
      var term = terms[i];
      var postings = invertedIdx[term];
      indexHtml += '<div class="index-row" data-term="' + escapeHtml(term) + '">';
      indexHtml += '<span class="term-name">' + escapeHtml(term) + '</span>';
      indexHtml += '<span class="term-arrow">→</span>';
      indexHtml += '<span class="posting-list">';
      for (var j = 0; j < postings.length; j++) {
        indexHtml += '<span class="posting-id">' + postings[j] + '</span>';
      }
      indexHtml += '</span>';
      indexHtml += '<span class="term-freq">df=' + postings.length + '</span>';
      indexHtml += '</div>';
    }
    if (terms.length === 0) {
      indexHtml = '<div style="color:#555;text-align:center;padding:20px;">Index is empty</div>';
    }
    indexDiv.innerHTML = indexHtml;

    // Add hover interaction
    var rows = indexDiv.querySelectorAll('.index-row');
    for (var i = 0; i < rows.length; i++) {
      rows[i].addEventListener('mouseenter', function() {
        var term = this.getAttribute('data-term');
        var postings = invertedIdx[term] || [];
        this.classList.add('highlight');
        var items = docsList.querySelectorAll('.doc-item');
        for (var j = 0; j < items.length; j++) {
          var did = parseInt(items[j].getAttribute('data-doc-id'));
          if (postings.indexOf(did) !== -1) {
            items[j].classList.add('highlight');
          }
        }
      });
      rows[i].addEventListener('mouseleave', function() {
        this.classList.remove('highlight');
        var items = docsList.querySelectorAll('.doc-item');
        for (var j = 0; j < items.length; j++) {
          items[j].classList.remove('highlight');
        }
      });
    }
  }

  document.getElementById('addDocBtn').addEventListener('click', function() {
    var input = document.getElementById('docInput');
    var text = input.value.trim();
    if (text) {
      addDocument(text);
      input.value = '';
    }
  });

  document.getElementById('docInput').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      var text = this.value.trim();
      if (text) { addDocument(text); this.value = ''; }
    }
  });

  document.getElementById('resetIndexBtn').addEventListener('click', function() {
    documents = [];
    invertedIdx = {};
    renderIndex();
    document.getElementById('searchResults').innerHTML = '';
  });

  // Preset buttons
  var presetBtns = document.querySelectorAll('.preset-btn');
  for (var i = 0; i < presetBtns.length; i++) {
    presetBtns[i].addEventListener('click', function() {
      addDocument(this.getAttribute('data-text'));
    });
  }

  // ========== SEARCH ==========
  function bm25Score(tf, df, dl, avgdl, N, k1, b) {
    var idf = Math.log(1 + (N - df + 0.5) / (df + 0.5));
    var tfNorm = (tf * (k1 + 1)) / (tf + k1 * (1 - b + b * (dl / avgdl)));
    return idf * tfNorm;
  }

  function searchDocuments(query) {
    var container = document.getElementById('searchResults');
    if (documents.length === 0) {
      container.innerHTML = '<div class="no-results">Index some documents first, then search.</div>';
      return;
    }

    var queryResult = analyze(query);
    var queryTerms = queryResult.final;
    if (queryTerms.length === 0) {
      container.innerHTML = '<div class="no-results">No searchable terms in query after analysis.</div>';
      return;
    }

    // Calculate BM25 for each document
    var N = documents.length;
    var totalLen = 0;
    var docTokens = [];
    for (var i = 0; i < documents.length; i++) {
      var tokens = analyze(documents[i].text).final;
      docTokens.push(tokens);
      totalLen += tokens.length;
    }
    var avgdl = totalLen / N;
    var k1 = 1.2;
    var b = 0.75;

    var scores = [];
    for (var d = 0; d < documents.length; d++) {
      var score = 0;
      var explanation = [];
      var matchedTerms = [];

      for (var t = 0; t < queryTerms.length; t++) {
        var term = queryTerms[t];
        var df = invertedIdx[term] ? invertedIdx[term].length : 0;
        if (df === 0) continue;

        // Count term frequency in this doc
        var tf = 0;
        for (var k = 0; k < docTokens[d].length; k++) {
          if (docTokens[d][k] === term) tf++;
        }
        if (tf === 0) continue;

        var s = bm25Score(tf, df, docTokens[d].length, avgdl, N, k1, b);
        score += s;
        matchedTerms.push(term);
        explanation.push(term + ': tf=' + tf + ', df=' + df + ', score=' + s.toFixed(3));
      }

      if (score > 0) {
        scores.push({ docId: documents[d].id, text: documents[d].text, score: score, explanation: explanation, matchedTerms: matchedTerms });
      }
    }

    scores.sort(function(a, b) { return b.score - a.score; });

    if (scores.length === 0) {
      container.innerHTML = '<div class="no-results">No documents matched the query "' + escapeHtml(query) + '"</div>';
      return;
    }

    var html = '';
    for (var i = 0; i < scores.length; i++) {
      var hit = scores[i];
      html += '<div class="search-hit">';
      html += '<div class="hit-header">';
      html += '<span><span class="doc-id">DOC ' + hit.docId + '</span></span>';
      html += '<span class="hit-score">BM25: ' + hit.score.toFixed(4) + '</span>';
      html += '</div>';

      // Highlight matched terms in text
      var highlighted = escapeHtml(hit.text);
      // We need to highlight original words that stem to matched terms
      var words = hit.text.split(/(\s+|[^a-zA-Z0-9]+)/);
      var highlightedParts = '';
      for (var w = 0; w < words.length; w++) {
        var clean = words[w].replace(/[^a-zA-Z0-9]/g, '').toLowerCase();
        var stem = clean ? simpleStem(clean) : '';
        if (stem && hit.matchedTerms.indexOf(stem) !== -1) {
          highlightedParts += '<mark>' + escapeHtml(words[w]) + '</mark>';
        } else {
          highlightedParts += escapeHtml(words[w]);
        }
      }

      html += '<div class="hit-text">' + highlightedParts + '</div>';
      html += '<div class="hit-explain">' + hit.explanation.join(' | ') + '</div>';
      html += '</div>';
    }
    container.innerHTML = html;

    // Highlight matching terms in inverted index
    var indexRows = document.querySelectorAll('.index-row');
    for (var i = 0; i < indexRows.length; i++) {
      var term = indexRows[i].getAttribute('data-term');
      if (queryTerms.indexOf(term) !== -1) {
        indexRows[i].classList.add('highlight');
        var postingIds = indexRows[i].querySelectorAll('.posting-id');
        var matchDocIds = scores.map(function(s) { return s.docId; });
        for (var j = 0; j < postingIds.length; j++) {
          var pid = parseInt(postingIds[j].textContent);
          if (matchDocIds.indexOf(pid) !== -1) {
            postingIds[j].classList.add('match');
          }
        }
      } else {
        indexRows[i].classList.remove('highlight');
      }
    }
  }

  document.getElementById('searchBtn').addEventListener('click', function() {
    var q = document.getElementById('searchInput').value.trim();
    if (q) searchDocuments(q);
  });
  document.getElementById('searchInput').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      var q = this.value.trim();
      if (q) searchDocuments(q);
    }
  });

  // ========== BM25 INTERACTIVE ==========
  var k1Slider = document.getElementById('k1Slider');
  var bSlider = document.getElementById('bSlider');
  var tfSlider = document.getElementById('tfSlider');
  var dlSlider = document.getElementById('dlSlider');
  var avgdlSlider = document.getElementById('avgdlSlider');
  var nSlider = document.getElementById('nSlider');
  var dfSlider = document.getElementById('dfSlider');

  function updateBM25() {
    var k1 = parseInt(k1Slider.value) / 10;
    var b = parseInt(bSlider.value) / 100;
    var tf = parseInt(tfSlider.value);
    var dl = parseInt(dlSlider.value);
    var avgdl = parseInt(avgdlSlider.value);
    var N = parseInt(nSlider.value);
    var df = Math.min(parseInt(dfSlider.value), N);

    document.getElementById('k1Label').textContent = k1.toFixed(1);
    document.getElementById('bLabel').textContent = b.toFixed(2);
    document.getElementById('tfLabel').textContent = tf;
    document.getElementById('dlLabel').textContent = dl;
    document.getElementById('avgdlLabel').textContent = avgdl;
    document.getElementById('nLabel').textContent = N;
    document.getElementById('dfLabel').textContent = df;

    var idf = Math.log(1 + (N - df + 0.5) / (df + 0.5));
    var tfNorm = (tf * (k1 + 1)) / (tf + k1 * (1 - b + b * (dl / avgdl)));
    var score = idf * tfNorm;

    var output = document.getElementById('bm25Output');
    var html = '<div class="bm25-formula">';
    html += '<span class="bm25-component">IDF</span> = ln(1 + (N - df + 0.5) / (df + 0.5))<br>';
    html += '&nbsp;&nbsp;&nbsp;&nbsp;= ln(1 + (' + N + ' - ' + df + ' + 0.5) / (' + df + ' + 0.5)) = <span class="bm25-value">' + idf.toFixed(4) + '</span><br><br>';
    html += '<span class="bm25-component">TF_norm</span> = (tf × (k1 + 1)) / (tf + k1 × (1 - b + b × (dl / avgdl)))<br>';
    html += '&nbsp;&nbsp;&nbsp;&nbsp;= (' + tf + ' × ' + (k1 + 1).toFixed(1) + ') / (' + tf + ' + ' + k1.toFixed(1) + ' × (1 - ' + b.toFixed(2) + ' + ' + b.toFixed(2) + ' × (' + dl + ' / ' + avgdl + ')))<br>';
    html += '&nbsp;&nbsp;&nbsp;&nbsp;= <span class="bm25-value">' + tfNorm.toFixed(4) + '</span><br><br>';
    html += '<span class="bm25-component">Score</span> = IDF × TF_norm = ' + idf.toFixed(4) + ' × ' + tfNorm.toFixed(4) + ' = <span class="bm25-value">' + score.toFixed(4) + '</span>';
    html += '</div>';
    html += '<div class="bm25-score">' + score.toFixed(4) + '</div>';
    output.innerHTML = html;
  }

  var bm25Sliders = [k1Slider, bSlider, tfSlider, dlSlider, avgdlSlider, nSlider, dfSlider];
  for (var i = 0; i < bm25Sliders.length; i++) {
    bm25Sliders[i].addEventListener('input', updateBM25);
  }

  // ========== LUCENE SEGMENTS ==========
  var segments = [];
  var segmentId = 0;
  var segmentCanvas = document.getElementById('segmentCanvas');
  var segmentCtx = segmentCanvas.getContext('2d');

  function drawSegments() {
    var ctx = segmentCtx;
    var w = segmentCanvas.width;
    var h = segmentCanvas.height;
    ctx.clearRect(0, 0, w, h);

    if (segments.length === 0) {
      ctx.fillStyle = '#555';
      ctx.font = '14px Inter, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('Click "+ Write Segment" to create Lucene segments', w / 2, h / 2);
      return;
    }

    var padding = 30;
    var gap = 12;
    var maxBarWidth = (w - padding * 2 - gap * (segments.length - 1)) / segments.length;
    var barWidth = Math.min(maxBarWidth, 80);
    var totalWidth = segments.length * barWidth + (segments.length - 1) * gap;
    var startX = (w - totalWidth) / 2;

    var maxDocs = 1;
    for (var i = 0; i < segments.length; i++) {
      if (segments[i].docs > maxDocs) maxDocs = segments[i].docs;
    }

    var colors = ['#00d4ff', '#60a5fa', '#a855f7', '#22c55e', '#eab308', '#ef4444', '#ec4899', '#14b8a6'];

    for (var i = 0; i < segments.length; i++) {
      var seg = segments[i];
      var x = startX + i * (barWidth + gap);
      var barMaxH = h - 100;
      var barH = Math.max(30, (seg.docs / maxDocs) * barMaxH);
      var y = h - 50 - barH;
      var color = colors[i % colors.length];

      // Bar
      ctx.fillStyle = color + '30';
      ctx.strokeStyle = color;
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.roundRect(x, y, barWidth, barH, 6);
      ctx.fill();
      ctx.stroke();

      // Segment label
      ctx.fillStyle = '#fff';
      ctx.font = 'bold 11px Inter, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('Seg ' + seg.id, x + barWidth / 2, y + 20);

      // Doc count
      ctx.fillStyle = color;
      ctx.font = '10px Monaco, monospace';
      ctx.fillText(seg.docs + ' docs', x + barWidth / 2, y + 36);

      // Size indicator
      ctx.fillStyle = '#888';
      ctx.font = '9px Inter, sans-serif';
      ctx.fillText(seg.size + ' KB', x + barWidth / 2, h - 36);

      // Status
      if (seg.merging) {
        ctx.fillStyle = '#eab308';
        ctx.font = '10px Inter, sans-serif';
        ctx.fillText('MERGING', x + barWidth / 2, y - 8);
      }
    }

    // Title
    ctx.fillStyle = 'rgba(255,255,255,0.2)';
    ctx.font = '11px Inter, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(segments.length + ' segment' + (segments.length !== 1 ? 's' : '') + ' in index', w / 2, 20);
  }

  function addTimelineEntry(container, text, cls) {
    var el = document.createElement('div');
    el.className = 'failover-step ' + cls;
    el.textContent = text;
    container.appendChild(el);
    container.scrollTop = container.scrollHeight;
  }

  document.getElementById('addSegmentBtn').addEventListener('click', function() {
    segmentId++;
    var docs = 5 + Math.floor(Math.random() * 20);
    var size = docs * (10 + Math.floor(Math.random() * 5));
    segments.push({ id: segmentId, docs: docs, size: size, merging: false });

    var badge = document.getElementById('segmentBadge');
    var statusText = document.getElementById('segmentStatusText');
    badge.className = 'status-badge writing';
    badge.textContent = 'WRITING';
    statusText.textContent = 'Segment ' + segmentId + ' created with ' + docs + ' documents';

    addTimelineEntry(document.getElementById('segmentTimeline'),
      '📝 Segment ' + segmentId + ' flushed from in-memory buffer (' + docs + ' docs, ' + size + ' KB)', 'write-step');

    if (segments.length >= 3) {
      document.getElementById('mergeSegmentsBtn').disabled = false;
    }

    drawSegments();
  });

  document.getElementById('mergeSegmentsBtn').addEventListener('click', async function() {
    if (segments.length < 2) return;
    this.disabled = true;

    var badge = document.getElementById('segmentBadge');
    var statusText = document.getElementById('segmentStatusText');
    badge.className = 'status-badge merging';
    badge.textContent = 'MERGING';

    // Mark all for merge
    for (var i = 0; i < segments.length; i++) segments[i].merging = true;
    drawSegments();

    var names = segments.map(function(s) { return 'Seg ' + s.id; }).join(', ');
    addTimelineEntry(document.getElementById('segmentTimeline'),
      '🔀 Merge started: ' + names, 'merge-step');

    await new Promise(function(r) { setTimeout(r, 1500); });

    // Create merged segment
    var totalDocs = 0;
    var totalSize = 0;
    for (var i = 0; i < segments.length; i++) {
      totalDocs += segments[i].docs;
      totalSize += segments[i].size;
    }

    segmentId++;
    segments = [{ id: segmentId, docs: totalDocs, size: Math.floor(totalSize * 0.7), merging: false }];

    statusText.textContent = 'Merged into Segment ' + segmentId + ' (' + totalDocs + ' docs)';
    badge.className = 'status-badge done';
    badge.textContent = 'MERGED';

    addTimelineEntry(document.getElementById('segmentTimeline'),
      '✅ Merged into Segment ' + segmentId + ': ' + totalDocs + ' docs, ' + Math.floor(totalSize * 0.7) + ' KB (30% compaction)', 'result-step');

    drawSegments();
  });

  document.getElementById('resetSegmentsBtn').addEventListener('click', function() {
    segments = [];
    segmentId = 0;
    document.getElementById('segmentTimeline').innerHTML = '';
    document.getElementById('segmentBadge').className = 'status-badge idle';
    document.getElementById('segmentBadge').textContent = 'Ready';
    document.getElementById('segmentStatusText').textContent = 'Add segments to see how Lucene manages immutable data';
    document.getElementById('mergeSegmentsBtn').disabled = true;
    drawSegments();
  });

  // ========== SHARDS & REPLICAS ==========
  var shardCanvas = document.getElementById('shardCanvas');
  var shardCtx = shardCanvas.getContext('2d');
  var shardSlider = document.getElementById('shardSlider');
  var replicaSlider = document.getElementById('replicaSlider');

  shardSlider.addEventListener('input', function() {
    document.getElementById('shardCountLabel').textContent = this.value;
    drawShardTopology();
  });
  replicaSlider.addEventListener('input', function() {
    document.getElementById('replicaCountLabel').textContent = this.value;
    drawShardTopology();
  });

  function drawShardTopology(activeShards, phase) {
    var ctx = shardCtx;
    var w = shardCanvas.width;
    var h = shardCanvas.height;
    ctx.clearRect(0, 0, w, h);

    var numShards = parseInt(shardSlider.value);
    var numReplicas = parseInt(replicaSlider.value);
    var totalCopies = 1 + numReplicas;

    // Draw coordinating node
    var coordX = w / 2;
    var coordY = 50;
    ctx.fillStyle = 'rgba(234, 179, 8, 0.2)';
    ctx.strokeStyle = '#eab308';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.arc(coordX, coordY, 25, 0, Math.PI * 2);
    ctx.fill();
    ctx.stroke();
    ctx.fillStyle = '#fff';
    ctx.font = 'bold 10px Inter, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('COORD', coordX, coordY + 3);

    // Draw shard groups
    var groupWidth = (w - 80) / numShards;
    var shardY = 180;

    for (var s = 0; s < numShards; s++) {
      var groupX = 40 + s * groupWidth + groupWidth / 2;

      // Line from coordinator
      var isActive = activeShards ? activeShards.indexOf(s) !== -1 : false;
      ctx.strokeStyle = isActive ? '#00d4ff' : 'rgba(255,255,255,0.1)';
      ctx.lineWidth = isActive ? 2 : 1;
      ctx.setLineDash(isActive ? [] : [4, 4]);
      ctx.beginPath();
      ctx.moveTo(coordX, coordY + 25);
      ctx.lineTo(groupX, shardY - 30);
      ctx.stroke();
      ctx.setLineDash([]);

      for (var r = 0; r < totalCopies; r++) {
        var isPrimary = r === 0;
        var sy = shardY + r * 70;
        var color = isPrimary ? '#00d4ff' : '#60a5fa';

        // Shard box
        var boxW = Math.min(groupWidth - 20, 100);
        var boxH = 50;
        var bx = groupX - boxW / 2;

        ctx.fillStyle = isActive ? color + '25' : color + '10';
        ctx.strokeStyle = isActive ? color : color + '60';
        ctx.lineWidth = isActive ? 2 : 1;
        ctx.beginPath();
        ctx.roundRect(bx, sy, boxW, boxH, 8);
        ctx.fill();
        ctx.stroke();

        // Label
        ctx.fillStyle = '#fff';
        ctx.font = 'bold 10px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText((isPrimary ? 'P' : 'R' + r) + s, groupX, sy + 22);

        ctx.fillStyle = '#888';
        ctx.font = '9px Inter, sans-serif';
        ctx.fillText(isPrimary ? 'PRIMARY' : 'REPLICA', groupX, sy + 38);

        if (isActive && phase === 'gather' && isPrimary) {
          ctx.fillStyle = '#22c55e';
          ctx.font = 'bold 9px Inter, sans-serif';
          ctx.fillText('✓ RESULTS', groupX, sy + boxH + 14);
        }
      }
    }

    // Phase label
    if (phase) {
      ctx.fillStyle = 'rgba(255,255,255,0.15)';
      ctx.font = '11px Inter, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText(phase === 'scatter' ? 'QUERY PHASE (scatter)' : 'FETCH PHASE (gather)', w / 2, h - 15);
    }
  }

  document.getElementById('runQueryBtn').addEventListener('click', async function() {
    var numShards = parseInt(shardSlider.value);
    var timeline = document.getElementById('shardTimeline');
    var badge = document.getElementById('shardBadge');
    var statusText = document.getElementById('shardStatusText');
    timeline.innerHTML = '';

    // Step 1: Client sends query
    badge.className = 'status-badge searching';
    badge.textContent = 'QUERY';
    statusText.textContent = 'Client sends search request to coordinating node';
    addTimelineEntry(timeline, '📨 Client sends query to coordinating node', 'info-step');
    drawShardTopology([], null);
    await new Promise(function(r) { setTimeout(r, 800); });

    // Step 2: Scatter - query all shards
    badge.className = 'status-badge scatter';
    badge.textContent = 'SCATTER';
    statusText.textContent = 'Coordinator fans out query to one copy of each shard';
    var allShards = [];
    for (var i = 0; i < numShards; i++) allShards.push(i);
    drawShardTopology(allShards, 'scatter');
    addTimelineEntry(timeline, '🔍 Query Phase: coordinator sends query to ' + numShards + ' shards in parallel', 'scatter-step');
    await new Promise(function(r) { setTimeout(r, 1000); });

    // Step 3: Each shard returns top results
    for (var s = 0; s < numShards; s++) {
      var hits = 2 + Math.floor(Math.random() * 8);
      addTimelineEntry(timeline, '  ↳ Shard P' + s + ' returns top-' + hits + ' (doc_id, score) pairs', 'scatter-step');
      await new Promise(function(r) { setTimeout(r, 300); });
    }

    // Step 4: Gather - merge results
    badge.className = 'status-badge gather';
    badge.textContent = 'GATHER';
    statusText.textContent = 'Coordinator merges results from all shards';
    drawShardTopology(allShards, 'gather');
    addTimelineEntry(timeline, '📋 Fetch Phase: coordinator merges scores, picks global top-10', 'gather-step');
    await new Promise(function(r) { setTimeout(r, 800); });

    addTimelineEntry(timeline, '📦 Fetching full documents from relevant shards...', 'gather-step');
    await new Promise(function(r) { setTimeout(r, 600); });

    badge.className = 'status-badge done';
    badge.textContent = 'COMPLETE';
    statusText.textContent = 'Search completed — results merged from ' + numShards + ' shards';
    addTimelineEntry(timeline, '✅ Results returned to client: 10 documents, sorted by relevance', 'result-step');
  });

  document.getElementById('resetShardsBtn').addEventListener('click', function() {
    document.getElementById('shardTimeline').innerHTML = '';
    document.getElementById('shardBadge').className = 'status-badge idle';
    document.getElementById('shardBadge').textContent = 'Ready';
    document.getElementById('shardStatusText').textContent = 'Configure shards and run a distributed query';
    drawShardTopology();
  });

  // ========== INITIAL RENDER ==========
  renderPipeline();
  renderIndex();
  updateBM25();
  drawSegments();
  drawShardTopology();
</script>
</BaseLayout>
