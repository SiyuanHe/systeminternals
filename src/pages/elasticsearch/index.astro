---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "Inverted Index & Search", description: "How Elasticsearch indexes documents and finds matches using inverted indexes, analyzers, and BM25 scoring", href: "/elasticsearch/inverted-index/", status: "live" },
  { title: "Cluster & Shard Routing", description: "How documents are routed to shards and queries fan out across the cluster", href: "/elasticsearch/cluster-shard-routing/", status: "live" },
  { title: "Near Real-Time Search", description: "Refresh intervals, translog, and the journey from index to searchable", href: "#", status: "coming" },
  { title: "Aggregations Pipeline", description: "Bucket, metric, and pipeline aggregations — how they distribute and merge", href: "#", status: "coming" },
  { title: "Relevance Tuning", description: "Function score, boosting, decay functions, and multi-match strategies", href: "#", status: "coming" },
  { title: "Index Lifecycle Management", description: "Hot-warm-cold-frozen architecture and rollover policies", href: "#", status: "coming" },
  { title: "Mapping & Dynamic Templates", description: "Field types, multi-fields, and how mappings affect search and storage", href: "#", status: "coming" },
  { title: "Distributed Writes", description: "Primary/replica shard write path, consistency, and failure handling", href: "#", status: "coming" },
];
---

<BaseLayout 
  title="Elasticsearch Internals" 
  description="Interactive visualizations for understanding Elasticsearch architecture, inverted indexes, scoring, and distributed search"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Elasticsearch", href: "/elasticsearch/" }]}
>
  <section class="section-header">
    <h1>🔍 Elasticsearch Internals</h1>
    <p>
      Elasticsearch is a distributed search and analytics engine built on Apache Lucene. These interactive 
      visualizations help you understand how it indexes documents, executes searches across shards, and 
      scores results for relevance.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(0, 212, 255, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
