---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "Proxy Internals", description: "Request flow, load balancing, circuit breaking, xDS, and health checking", href: "/envoy/proxy-internals/", status: "live" },
  { title: "TLS & mTLS", description: "Certificate management, SDS, and mutual TLS in service mesh", href: "#", status: "coming" },
  { title: "HTTP Filters", description: "Router, RBAC, Lua, ext_authz, and custom filter chains", href: "#", status: "coming" },
  { title: "Observability", description: "Stats, tracing, access logging, and admin interface", href: "#", status: "coming" },
  { title: "Wasm Extensions", description: "Writing proxy filters in WebAssembly with proxy-wasm SDK", href: "#", status: "coming" },
  { title: "Service Mesh (Istio)", description: "Sidecar injection, VirtualService, DestinationRule, and traffic management", href: "#", status: "coming" },
];
---

<BaseLayout 
  title="Envoy Proxy Internals" 
  description="Interactive visualizations for understanding Envoy Proxy architecture, load balancing, circuit breaking, and xDS configuration"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Envoy", href: "/envoy/" }]}
>
  <section class="section-header">
    <h1>🛡️ Envoy Proxy Internals</h1>
    <p>
      Envoy is a high-performance L4/L7 proxy designed for modern service mesh architectures.
      Originally built at Lyft, it powers Istio, AWS App Mesh, and countless production deployments.
      These visualizations help you understand how requests flow through Envoy and how to tune it.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(139, 92, 246, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
