  /* Retry */
  .retry-section { margin-bottom: 50px; }
  .retry-controls { display: flex; gap: 16px; align-items: flex-end; flex-wrap: wrap; margin-bottom: 24px; }
  .retry-viz { background: rgba(0,0,0,0.2); border-radius: 14px; padding: 24px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 16px; min-height: 80px; display: flex; flex-direction: column; gap: 8px; }
