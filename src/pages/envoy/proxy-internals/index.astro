  .rl-bucket-fill { width: 80px; height: 120px; border: 2px solid rgba(245,158,11,0.4); border-radius: 0 0 8px 8px; margin: 0 auto 8px; position: relative; overflow: hidden; background: rgba(0,0,0,0.2); }
  .rl-bucket-fill::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 100%; background: linear-gradient(0deg, rgba(245,158,11,0.6), rgba(245,158,11,0.2)); transition: height 0.3s; }
  .rl-bucket-val { font-size: 0.85rem; color: #f59e0b; font-family: monospace; }
  .rl-results { flex: 1; display: flex; flex-wrap: wrap; gap: 8px; align-content: flex-start; }
  .rl-req { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 700; animation: fadeIn 0.2s; }
  .rl-req.allowed { background: rgba(16,185,129,0.2); border: 1px solid rgba(16,185,129,0.4); color: #10b981; }
  .rl-req.denied { background: rgba(239,68,68,0.2); border: 1px solid rgba(239,68,68,0.4); color: #ef4444; }

  /* Explain */
  .explain-section { margin-bottom: 50px; }
