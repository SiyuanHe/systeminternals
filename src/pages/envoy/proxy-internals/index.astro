  .rl-viz { background: rgba(0,0,0,0.2); border-radius: 14px; padding: 24px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 16px; display: flex; gap: 24px; align-items: flex-start; min-height: 150px; }
  .rl-bucket { text-align: center; min-width: 100px; }
