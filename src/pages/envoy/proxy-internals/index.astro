---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Envoy Proxy Internals: Architecture, Load Balancing & xDS" 
  description="Interactive visualization of Envoy proxy internals — request flow, load balancing algorithms, circuit breaking, xDS API, and health checking"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "Envoy", href: "/envoy/" },
    { label: "Proxy Internals", href: "/envoy/proxy-internals/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🛡️ Envoy Proxy Internals</h1>
      <p class="subtitle">Request Flow · Load Balancing · Circuit Breaking · xDS · Health Checking</p>
    </header>

    <section class="overview-section">
      <div class="overview-card">
        <p>
          Envoy is a <strong>L4/L7 proxy</strong> designed for cloud-native applications. Requests flow through
          <strong>listeners</strong> into <strong>filter chains</strong>, are matched to <strong>routes</strong>,
          then forwarded to <strong>clusters</strong> of upstream <strong>endpoints</strong>. All configuration
          is dynamic via the <em>xDS API</em> — the same mechanism Istio uses to program thousands of sidecars.
        </p>
      </div>
    </section>

    <!-- Request Flow -->
    <section class="flow-section">
      <h2>🔀 Request Flow: Listener → Endpoint</h2>
      <p class="section-desc">A request enters a listener, traverses filter chains (L4 + L7), matches a route, selects a cluster, and reaches an endpoint. Click "Send Request" to trace the path.</p>

      <div class="flow-controls">
        <div class="flow-toggle">
          <button class="flow-btn active" data-layer="l7">L7 (HTTP)</button>
          <button class="flow-btn" data-layer="l4">L4 (TCP)</button>
        </div>
        <button id="sendFlowBtn" class="action-btn primary-btn">▶ Send Request</button>
        <button id="resetFlowBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="flow-viz" id="flowViz">
        <div class="flow-stage" id="flowStage0">
          <div class="flow-icon">🌐</div>
          <div class="flow-label">Client</div>
        </div>
        <div class="flow-arrow" id="flowArrow0">→</div>
        <div class="flow-stage" id="flowStage1">
          <div class="flow-icon">👂</div>
          <div class="flow-label">Listener<br><span class="flow-detail">:8080</span></div>
        </div>
        <div class="flow-arrow" id="flowArrow1">→</div>
        <div class="flow-stage" id="flowStage2">
          <div class="flow-icon">⛓️</div>
          <div class="flow-label">Filter Chain<br><span class="flow-detail" id="filterDetail">HTTP conn mgr</span></div>
        </div>
        <div class="flow-arrow" id="flowArrow2">→</div>
        <div class="flow-stage" id="flowStage3">
          <div class="flow-icon">🗺️</div>
          <div class="flow-label">Route<br><span class="flow-detail" id="routeDetail">/api/* → svc</span></div>
        </div>
        <div class="flow-arrow" id="flowArrow3">→</div>
        <div class="flow-stage" id="flowStage4">
          <div class="flow-icon">📦</div>
          <div class="flow-label">Cluster<br><span class="flow-detail">my-service</span></div>
        </div>
        <div class="flow-arrow" id="flowArrow4">→</div>
        <div class="flow-stage" id="flowStage5">
          <div class="flow-icon">🖥️</div>
          <div class="flow-label">Endpoint<br><span class="flow-detail">10.0.0.3:8080</span></div>
        </div>
      </div>

      <div class="flow-log" id="flowLog"></div>
    </section>

    <!-- Load Balancing -->
    <section class="lb-section">
      <h2>⚖️ Load Balancing Algorithms</h2>
      <p class="section-desc">Envoy supports multiple load balancing policies. Watch how each distributes requests across endpoints.</p>

      <div class="lb-controls">
        <div class="lb-tabs">
          <button class="lb-tab active" data-algo="round_robin">Round Robin</button>
          <button class="lb-tab" data-algo="least_request">Least Request</button>
          <button class="lb-tab" data-algo="ring_hash">Ring Hash</button>
          <button class="lb-tab" data-algo="maglev">Maglev</button>
        </div>
        <div class="slider-group">
          <label>Endpoints: <strong id="epCountLabel">4</strong></label>
          <input type="range" id="epCountSlider" min="2" max="8" value="4">
        </div>
        <button id="sendLbBtn" class="action-btn primary-btn">📤 Send 20 Requests</button>
        <button id="resetLbBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="lb-viz" id="lbViz">
        <div class="lb-proxy-col">
          <div class="lb-proxy-box">
            <div class="lb-proxy-label">Envoy</div>
            <div class="lb-algo-label" id="lbAlgoLabel">round_robin</div>
          </div>
          <div class="lb-queue" id="lbQueue"></div>
        </div>
        <div class="lb-endpoints-col" id="lbEndpoints"></div>
      </div>

      <div class="lb-desc" id="lbDesc">
        <strong>Round Robin:</strong> Requests are distributed sequentially across all endpoints. Simple and fair, but doesn't account for varying response times.
      </div>
    </section>

    <!-- Circuit Breaking -->
    <section class="cb-section">
      <h2>🔌 Circuit Breaking</h2>
      <p class="section-desc">Circuit breakers prevent cascading failures by limiting connections, pending requests, and retries. Watch the circuit trip when thresholds are exceeded.</p>

      <div class="cb-controls">
        <div class="slider-group">
          <label>Max connections: <strong id="cbMaxConnLabel">5</strong></label>
          <input type="range" id="cbMaxConnSlider" min="1" max="10" value="5">
        </div>
        <div class="slider-group">
          <label>Request rate (req/s): <strong id="cbRateLabel">3</strong></label>
          <input type="range" id="cbRateSlider" min="1" max="15" value="3">
        </div>
        <button id="startCbBtn" class="action-btn primary-btn">▶ Start Traffic</button>
        <button id="stopCbBtn" class="action-btn danger-btn" disabled>⏹ Stop</button>
        <button id="resetCbBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="cb-viz" id="cbViz">
        <div class="cb-meter-group">
          <div class="cb-meter">
            <div class="cb-meter-label">Active Connections</div>
            <div class="cb-meter-bar-wrap">
              <div class="cb-meter-bar" id="cbConnBar" style="width:0%"></div>
              <div class="cb-meter-threshold" id="cbConnThreshold"></div>
            </div>
            <div class="cb-meter-val"><span id="cbConnVal">0</span> / <span id="cbConnMax">5</span></div>
          </div>
          <div class="cb-meter">
            <div class="cb-meter-label">Pending Requests</div>
            <div class="cb-meter-bar-wrap">
              <div class="cb-meter-bar pending-bar" id="cbPendBar" style="width:0%"></div>
              <div class="cb-meter-threshold" id="cbPendThreshold"></div>
            </div>
            <div class="cb-meter-val"><span id="cbPendVal">0</span> / <span id="cbPendMax">10</span></div>
          </div>
          <div class="cb-meter">
            <div class="cb-meter-label">Retries</div>
            <div class="cb-meter-bar-wrap">
              <div class="cb-meter-bar retry-bar" id="cbRetryBar" style="width:0%"></div>
              <div class="cb-meter-threshold" id="cbRetryThreshold"></div>
            </div>
            <div class="cb-meter-val"><span id="cbRetryVal">0</span> / <span id="cbRetryMax">3</span></div>
          </div>
        </div>
        <div class="cb-state-display">
          <div class="cb-state-icon" id="cbStateIcon">✅</div>
          <div class="cb-state-text" id="cbStateText">CLOSED (healthy)</div>
        </div>
      </div>

      <div class="cb-log" id="cbLog"></div>
    </section>

    <!-- xDS API -->
    <section class="xds-section">
      <h2>📡 xDS Dynamic Configuration</h2>
      <p class="section-desc">Envoy discovers configuration from a control plane (like Istio's istiod) via the xDS protocol. Click a resource type to see how config is pushed.</p>

      <div class="xds-controls">
        <div class="xds-tabs">
          <button class="xds-tab active" data-xds="LDS">LDS</button>
          <button class="xds-tab" data-xds="RDS">RDS</button>
          <button class="xds-tab" data-xds="CDS">CDS</button>
          <button class="xds-tab" data-xds="EDS">EDS</button>
          <button class="xds-tab" data-xds="SDS">SDS</button>
        </div>
        <button id="pushXdsBtn" class="action-btn primary-btn">📤 Push Config</button>
        <button id="pushAllXdsBtn" class="action-btn secondary-btn">🔄 Full Sync</button>
      </div>

      <div class="xds-viz" id="xdsViz">
        <div class="xds-cp">
          <div class="xds-cp-label">Control Plane</div>
          <div class="xds-cp-sub">(istiod / go-control-plane)</div>
          <div class="xds-cp-config" id="xdsCpConfig"></div>
        </div>
        <div class="xds-stream" id="xdsStream">
          <div class="xds-stream-label">gRPC bi-directional stream</div>
          <div class="xds-msgs" id="xdsMsgs"></div>
        </div>
        <div class="xds-envoy">
          <div class="xds-envoy-label">Envoy Proxy</div>
          <div class="xds-envoy-config" id="xdsEnvoyConfig">
            <div class="xds-config-slot" id="xdsSlotLDS">LDS: —</div>
            <div class="xds-config-slot" id="xdsSlotRDS">RDS: —</div>
            <div class="xds-config-slot" id="xdsSlotCDS">CDS: —</div>
            <div class="xds-config-slot" id="xdsSlotEDS">EDS: —</div>
            <div class="xds-config-slot" id="xdsSlotSDS">SDS: —</div>
          </div>
        </div>
      </div>

      <div class="xds-desc" id="xdsDesc">
        <strong>LDS (Listener Discovery Service):</strong> Discovers listener configurations — which ports to bind, what filter chains to attach. When Istio creates a VirtualService, it updates LDS.
      </div>
    </section>

    <!-- Health Checking -->
    <section class="hc-section">
      <h2>🏥 Health Checking</h2>
      <p class="section-desc">Envoy uses active health checks (HTTP/TCP/gRPC probes) and passive outlier detection to remove unhealthy endpoints.</p>

      <div class="hc-controls">
        <div class="hc-toggle">
          <button class="hc-btn active" data-mode="active">Active (HTTP)</button>
          <button class="hc-btn" data-mode="passive">Passive (Outlier)</button>
        </div>
        <button id="startHcBtn" class="action-btn primary-btn">▶ Start Checking</button>
        <button id="failEndpointBtn" class="action-btn danger-btn">💀 Fail Endpoint</button>
        <button id="resetHcBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="hc-viz" id="hcViz"></div>
      <div class="hc-log" id="hcLog"></div>
    </section>

    <!-- Retry Policies -->
    <section class="retry-section">
      <h2>🔁 Retry Policies</h2>
      <p class="section-desc">Envoy retries failed requests with configurable back-off, jitter, and retry budgets to prevent thundering herds.</p>

      <div class="retry-controls">
        <div class="slider-group">
          <label>Max retries: <strong id="retryMaxLabel">3</strong></label>
          <input type="range" id="retryMaxSlider" min="1" max="5" value="3">
        </div>
        <div class="slider-group">
          <label>Failure rate: <strong id="retryFailLabel">60</strong>%</label>
          <input type="range" id="retryFailSlider" min="10" max="90" value="60">
        </div>
        <button id="sendRetryBtn" class="action-btn primary-btn">▶ Send Request</button>
        <button id="resetRetryBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="retry-viz" id="retryViz"></div>
      <div class="retry-desc">
        <strong>Retry budget:</strong> Limits total retry ratio to 20% of active requests, preventing retry storms. Combined with <em>jitter</em> (randomized delay), retries don't thundering-herd the upstream.
      </div>
    </section>

    <!-- Rate Limiting -->
    <section class="rl-section">
      <h2>🚦 Rate Limiting</h2>
      <p class="section-desc">Envoy supports local rate limiting (per-proxy token bucket) and global rate limiting (centralized service). Watch requests get throttled.</p>

      <div class="rl-controls">
        <div class="rl-toggle">
          <button class="rl-btn active" data-mode="local">Local</button>
          <button class="rl-btn" data-mode="global">Global</button>
        </div>
        <div class="slider-group">
          <label>Rate limit: <strong id="rlLimitLabel">5</strong> req/s</label>
          <input type="range" id="rlLimitSlider" min="1" max="15" value="5">
        </div>
        <button id="sendRlBtn" class="action-btn primary-btn">📤 Burst 10 Requests</button>
        <button id="resetRlBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="rl-viz" id="rlViz">
        <div class="rl-bucket">
          <div class="rl-bucket-label">Token Bucket</div>
          <div class="rl-bucket-fill" id="rlBucketFill"></div>
          <div class="rl-bucket-val" id="rlBucketVal">5 / 5</div>
        </div>
        <div class="rl-results" id="rlResults"></div>
      </div>
    </section>

    <!-- Explanations -->
    <section class="explain-section">
      <div class="explain-grid">
        <div class="explain-card highlight-card">
          <h3>💡 L4 vs L7</h3>
          <p>
            <strong>L4 (TCP proxy)</strong> operates on connections — Envoy sees bytes, not HTTP semantics.
            <strong>L7 (HTTP)</strong> understands headers, paths, and methods, enabling content-based routing,
            header manipulation, and per-route policies. Most service mesh traffic uses L7.
          </p>
        </div>
        <div class="explain-card">
          <h3>🔄 xDS Ordering</h3>
          <p>
            Config must be applied in order: <code>CDS/EDS</code> first (so clusters exist),
            then <code>LDS/RDS</code> (so routes can reference clusters).
            Istio's istiod handles this via <em>Aggregated Discovery Service (ADS)</em> —
            a single gRPC stream that serializes updates.
          </p>
        </div>
        <div class="explain-card">
          <h3>🏥 Outlier Detection</h3>
          <p>
            Passive health checking counts <strong>consecutive 5xx errors</strong> per endpoint.
            After a threshold (e.g., 5 errors), the endpoint is ejected for a base interval.
            Each subsequent ejection doubles the time. This is <em>complementary</em> to active checks.
          </p>
        </div>
        <div class="explain-card">
          <h3>⚖️ Maglev vs Ring Hash</h3>
          <p>
            Both provide <strong>consistent hashing</strong> — great for caching proxies.
            Maglev builds a 65537-entry lookup table for O(1) lookups and more uniform distribution.
            Ring hash is simpler but can have hotspots with fewer endpoints.
          </p>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://www.envoyproxy.io/docs/envoy/latest/" target="_blank">Envoy Documentation</a> and <a href="https://istio.io/latest/docs/ops/deployment/architecture/" target="_blank">Istio Architecture</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20Envoy%20Proxy%20Internals%20Visualizer&url=https://systeminternals.dev/envoy/proxy-internals/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/envoy/proxy-internals/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/envoy/proxy-internals/&t=Interactive%20Envoy%20Proxy%20Internals%20Visualizer" target="_blank" class="share-btn">🟧 HN</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container { max-width: 1100px; margin: 0 auto; }
  .viz-header { text-align: center; margin-bottom: 40px; }
  .viz-header h1 { font-size: 2.5rem; margin-bottom: 10px; background: linear-gradient(90deg, #8b5cf6, #06b6d4, #10b981); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .subtitle { color: #888; font-size: 1.1rem; }
  h2 { font-size: 1.5rem; color: #fff; margin-bottom: 12px; }
  .section-desc { color: #888; margin-bottom: 24px; }

  .overview-section { margin-bottom: 50px; }
  .overview-card { background: linear-gradient(135deg, rgba(139,92,246,0.1), rgba(6,182,212,0.05)); border: 1px solid rgba(139,92,246,0.3); border-radius: 16px; padding: 24px 28px; font-size: 1.05rem; line-height: 1.8; color: #ccc; }
  .overview-card strong { color: #fff; }
  .overview-card em { color: #8b5cf6; font-style: normal; font-weight: 500; }

  .action-btn { padding: 10px 20px; border: none; border-radius: 10px; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .action-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .primary-btn { background: linear-gradient(135deg, #8b5cf6, #7c3aed); color: white; }
  .primary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(139,92,246,0.4); }
  .secondary-btn { background: linear-gradient(135deg, #06b6d4, #0891b2); color: white; }
  .secondary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(6,182,212,0.4); }
  .danger-btn { background: linear-gradient(135deg, #f87171, #ef4444); color: white; }
  .danger-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(239,68,68,0.4); }
  .reset-btn { background: rgba(255,255,255,0.1); color: #aaa; }
  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  input[type="range"] { -webkit-appearance: none; height: 8px; background: rgba(255,255,255,0.15); border-radius: 4px; cursor: pointer; width: 100%; }
  input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 20px; height: 20px; border-radius: 50%; background: #8b5cf6; cursor: pointer; }
  .slider-group { margin-bottom: 16px; }
  .slider-group label { color: #ccc; font-size: 0.95rem; display: block; margin-bottom: 8px; }
  .slider-group strong { color: #8b5cf6; }
  .slider-group input[type="range"] { max-width: 400px; }

  /* Request Flow */
  .flow-section { margin-bottom: 50px; }
  .flow-controls { display: flex; gap: 16px; align-items: flex-end; flex-wrap: wrap; margin-bottom: 24px; }
  .flow-toggle { display: flex; gap: 8px; }
  .flow-btn { padding: 8px 16px; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; background: rgba(255,255,255,0.03); color: #ccc; font-size: 0.85rem; cursor: pointer; transition: all 0.2s; }
  .flow-btn.active { border-color: #8b5cf6; background: rgba(139,92,246,0.15); color: #a78bfa; font-weight: 600; }
  .flow-viz { display: flex; align-items: center; gap: 0; background: rgba(0,0,0,0.2); border-radius: 14px; padding: 24px 16px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 12px; overflow-x: auto; }
  .flow-stage { text-align: center; min-width: 80px; padding: 12px 8px; border-radius: 12px; border: 2px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.03); transition: all 0.4s; flex-shrink: 0; }
  .flow-stage.active { border-color: #8b5cf6; background: rgba(139,92,246,0.15); box-shadow: 0 0 20px rgba(139,92,246,0.3); }
  .flow-stage.done { border-color: #10b981; background: rgba(16,185,129,0.1); }
  .flow-icon { font-size: 1.5rem; margin-bottom: 6px; }
  .flow-label { font-size: 0.75rem; color: #ccc; line-height: 1.4; }
  .flow-detail { color: #888; font-size: 0.65rem; }
  .flow-arrow { color: #555; font-size: 1.2rem; padding: 0 4px; flex-shrink: 0; transition: color 0.4s; }
  .flow-arrow.active { color: #8b5cf6; }
  .flow-arrow.done { color: #10b981; }
  .flow-log { background: rgba(0,0,0,0.2); border-radius: 12px; padding: 16px; border: 1px solid rgba(255,255,255,0.1); min-height: 40px; max-height: 200px; overflow-y: auto; font-size: 0.85rem; font-family: monospace; color: #aaa; }

  /* Load Balancing */
  .lb-section { margin-bottom: 50px; }
  .lb-controls { display: flex; gap: 16px; align-items: flex-end; flex-wrap: wrap; margin-bottom: 24px; }
  .lb-tabs { display: flex; gap: 8px; flex-wrap: wrap; }
  .lb-tab { padding: 8px 16px; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; background: rgba(255,255,255,0.03); color: #ccc; font-size: 0.85rem; cursor: pointer; transition: all 0.2s; font-family: monospace; }
  .lb-tab.active { border-color: #06b6d4; background: rgba(6,182,212,0.15); color: #06b6d4; font-weight: 600; }
  .lb-viz { display: flex; gap: 32px; background: rgba(0,0,0,0.2); border-radius: 14px; padding: 24px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 16px; min-height: 200px; }
  .lb-proxy-col { display: flex; flex-direction: column; align-items: center; min-width: 100px; }
  .lb-proxy-box { background: rgba(139,92,246,0.15); border: 2px solid rgba(139,92,246,0.4); border-radius: 12px; padding: 16px; text-align: center; margin-bottom: 12px; }
  .lb-proxy-label { font-size: 0.8rem; color: #888; text-transform: uppercase; font-weight: 600; }
  .lb-algo-label { font-size: 0.85rem; color: #a78bfa; font-family: monospace; margin-top: 4px; }
  .lb-queue { display: flex; flex-direction: column; gap: 4px; align-items: center; }
  .lb-endpoints-col { flex: 1; display: flex; flex-direction: column; gap: 12px; }
  .lb-endpoint { display: flex; align-items: center; gap: 12px; padding: 10px 14px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; transition: all 0.3s; }
  .lb-endpoint.hit { background: rgba(6,182,212,0.15); border-color: rgba(6,182,212,0.4); }
  .lb-ep-name { font-size: 0.85rem; color: #ccc; font-family: monospace; min-width: 100px; }
  .lb-ep-bar-wrap { flex: 1; height: 20px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; }
  .lb-ep-bar { height: 100%; background: linear-gradient(90deg, #06b6d4, #8b5cf6); border-radius: 4px; transition: width 0.3s; width: 0%; }
  .lb-ep-count { font-size: 0.85rem; color: #06b6d4; font-weight: 600; min-width: 30px; text-align: right; }
  .lb-desc { background: rgba(0,0,0,0.15); border-radius: 10px; padding: 14px 18px; font-size: 0.9rem; color: #aaa; line-height: 1.6; }
  .lb-desc strong { color: #06b6d4; }

  /* Circuit Breaking */
  .cb-section { margin-bottom: 50px; }
  .cb-controls { display: flex; gap: 16px; align-items: flex-end; flex-wrap: wrap; margin-bottom: 24px; }
  .cb-viz { background: rgba(0,0,0,0.2); border-radius: 14px; padding: 24px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 12px; }
  .cb-meter-group { display: flex; flex-direction: column; gap: 16px; margin-bottom: 20px; }
