    .lb-viz { flex-direction: column; }
    .xds-viz { flex-direction: column; }
    .xds-cp { border-radius: 12px 12px 0 0; }
    .xds-envoy { border-radius: 0 0 12px 12px; }
    .rl-viz { flex-direction: column; align-items: center; }
  }
</style>

<script is:inline>
  // ========== COLORS ==========
  var COLORS = ['#8b5cf6', '#06b6d4', '#10b981', '#f59e0b', '#ec4899', '#f43f5e', '#3b82f6', '#84cc16'];

  // ========== REQUEST FLOW ==========
  var flowLayer = 'l7';
  var flowRunning = false;

  document.querySelectorAll('.flow-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.flow-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      flowLayer = btn.getAttribute('data-layer');
      var fd = document.getElementById('filterDetail');
      var rd = document.getElementById('routeDetail');
      if (flowLayer === 'l4') {
        fd.textContent = 'TCP proxy filter';
        rd.textContent = 'TCP match';
      } else {
        fd.textContent = 'HTTP conn mgr';
        rd.textContent = '/api/* → svc';
      }
    });
  });

  document.getElementById('sendFlowBtn').addEventListener('click', function() {
    if (flowRunning) return;
    flowRunning = true;
    var log = document.getElementById('flowLog');
    log.innerHTML = '';
    var stages = 6;
    var stageNames = ['Client', 'Listener :8080', 'Filter Chain', 'Route Match', 'Cluster Selection', 'Endpoint 10.0.0.3:8080'];
    var l7Logs = [
      'Client sends GET /api/users HTTP/1.1',
      'Listener 0.0.0.0:8080 accepts connection',
      'HTTP Connection Manager → Router filter → RBAC filter',
      'Route match: prefix /api/* → cluster "my-service"',
      'Cluster "my-service" selects endpoint via round_robin',
      'Request forwarded to 10.0.0.3:8080 — 200 OK (12ms)'
    ];
    var l4Logs = [
      'Client opens TCP connection',
      'Listener 0.0.0.0:8080 accepts connection',
      'TCP proxy filter matches destination CIDR',
      'Route to cluster "my-service-tcp"',
      'Cluster selects endpoint via round_robin',
      'TCP bytes proxied to 10.0.0.3:8080'
    ];
    var logs = flowLayer === 'l7' ? l7Logs : l4Logs;

    // Reset
    for (var i = 0; i < stages; i++) {
      document.getElementById('flowStage' + i).classList.remove('active', 'done');
      if (i < stages - 1) {
        document.getElementById('flowArrow' + i).classList.remove('active', 'done');
      }
    }

    function animateStage(idx) {
      if (idx >= stages) {
        flowRunning = false;
        return;
      }
      if (idx > 0) {
        document.getElementById('flowStage' + (idx - 1)).classList.remove('active');
        document.getElementById('flowStage' + (idx - 1)).classList.add('done');
        document.getElementById('flowArrow' + (idx - 1)).classList.remove('active');
        document.getElementById('flowArrow' + (idx - 1)).classList.add('done');
      }
      document.getElementById('flowStage' + idx).classList.add('active');
      if (idx < stages - 1) {
        document.getElementById('flowArrow' + idx).classList.add('active');
      }
      var entry = document.createElement('div');
      entry.style.cssText = 'color:#a78bfa;animation:fadeIn 0.3s';
      entry.textContent = '[' + (idx + 1) + '/' + stages + '] ' + logs[idx];
      log.appendChild(entry);
      log.scrollTop = log.scrollHeight;
      setTimeout(function() { animateStage(idx + 1); }, 700);
    }
    animateStage(0);
  });

  document.getElementById('resetFlowBtn').addEventListener('click', function() {
    flowRunning = false;
    for (var i = 0; i < 6; i++) {
      document.getElementById('flowStage' + i).classList.remove('active', 'done');
      if (i < 5) document.getElementById('flowArrow' + i).classList.remove('active', 'done');
    }
    document.getElementById('flowLog').innerHTML = '';
  });

  // ========== LOAD BALANCING ==========
  var lbAlgo = 'round_robin';
  var epCount = 4;
  var lbCounts = [];
  var lbRRIndex = 0;
  var lbAnimating = false;

  var lbDescs = {
    round_robin: '<strong>Round Robin:</strong> Requests are distributed sequentially across all endpoints. Simple and fair, but doesn\'t account for varying response times.',
    least_request: '<strong>Least Request:</strong> Picks 2 random endpoints and sends to the one with fewer active requests. Adapts to heterogeneous latency without global state.',
    ring_hash: '<strong>Ring Hash:</strong> Consistent hashing maps requests to endpoints on a virtual ring. Adding/removing endpoints only remaps nearby keys — ideal for caching.',
    maglev: '<strong>Maglev:</strong> Google\'s consistent hashing builds a 65537-entry lookup table. More uniform than ring hash with O(1) lookups. Used in production at massive scale.'
  };

  function buildLbEndpoints() {
    var container = document.getElementById('lbEndpoints');
    container.innerHTML = '';
    lbCounts = [];
    for (var i = 0; i < epCount; i++) {
      lbCounts.push(0);
      var ep = document.createElement('div');
      ep.className = 'lb-endpoint';
      ep.id = 'lbEp' + i;
      ep.innerHTML = '<div class="lb-ep-name">10.0.0.' + (i + 1) + ':8080</div>' +
        '<div class="lb-ep-bar-wrap"><div class="lb-ep-bar" id="lbBar' + i + '"></div></div>' +
        '<div class="lb-ep-count" id="lbCount' + i + '">0</div>';
      container.appendChild(ep);
    }
  }
  buildLbEndpoints();

  document.getElementById('epCountSlider').addEventListener('input', function(e) {
    epCount = parseInt(e.target.value);
    document.getElementById('epCountLabel').textContent = epCount;
    buildLbEndpoints();
  });

  document.querySelectorAll('.lb-tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.lb-tab').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      lbAlgo = btn.getAttribute('data-algo');
      document.getElementById('lbAlgoLabel').textContent = lbAlgo;
      document.getElementById('lbDesc').innerHTML = lbDescs[lbAlgo];
      buildLbEndpoints();
    });
  });

  function pickEndpoint(reqIdx) {
    if (lbAlgo === 'round_robin') {
      var idx = lbRRIndex % epCount;
      lbRRIndex++;
      return idx;
    } else if (lbAlgo === 'least_request') {
      var a = Math.floor(Math.random() * epCount);
      var b = Math.floor(Math.random() * epCount);
      return lbCounts[a] <= lbCounts[b] ? a : b;
    } else if (lbAlgo === 'ring_hash') {
      var hash = 0;
      var key = 'req-' + reqIdx;
      for (var c = 0; c < key.length; c++) { hash = ((hash << 5) - hash) + key.charCodeAt(c); hash |= 0; }
      return Math.abs(hash) % epCount;
    } else {
      // maglev-like
      var hash2 = 0;
      var key2 = 'req-' + reqIdx;
      for (var c2 = 0; c2 < key2.length; c2++) { hash2 = ((hash2 << 7) ^ (hash2 >> 3)) + key2.charCodeAt(c2); hash2 |= 0; }
      return Math.abs(hash2) % epCount;
    }
  }

  document.getElementById('sendLbBtn').addEventListener('click', function() {
    if (lbAnimating) return;
    lbAnimating = true;
    lbRRIndex = 0;
    buildLbEndpoints();
    var totalReqs = 20;
    var sent = 0;

    function sendOne() {
      if (sent >= totalReqs) { lbAnimating = false; return; }
      var idx = pickEndpoint(sent);
      lbCounts[idx]++;
      var maxCount = Math.max.apply(null, lbCounts);

      // Update bars
      for (var i = 0; i < epCount; i++) {
        var pct = maxCount > 0 ? (lbCounts[i] / totalReqs) * 100 : 0;
        document.getElementById('lbBar' + i).style.width = pct + '%';
        document.getElementById('lbCount' + i).textContent = lbCounts[i];
        document.getElementById('lbEp' + i).classList.remove('hit');
      }
      document.getElementById('lbEp' + idx).classList.add('hit');
      sent++;
      setTimeout(sendOne, 120);
    }
    sendOne();
  });

  document.getElementById('resetLbBtn').addEventListener('click', function() {
    lbAnimating = false;
    lbRRIndex = 0;
    buildLbEndpoints();
  });

  // ========== CIRCUIT BREAKING ==========
  var cbMaxConn = 5;
  var cbRate = 3;
  var cbInterval = null;
  var cbConns = 0;
  var cbPending = 0;
  var cbRetries = 0;
  var cbState = 'closed';
  var cbMaxPend = 10;
  var cbMaxRetry = 3;

  document.getElementById('cbMaxConnSlider').addEventListener('input', function(e) {
    cbMaxConn = parseInt(e.target.value);
    document.getElementById('cbMaxConnLabel').textContent = cbMaxConn;
    document.getElementById('cbConnMax').textContent = cbMaxConn;
    document.getElementById('cbConnThreshold').style.left = '100%';
  });

  document.getElementById('cbRateSlider').addEventListener('input', function(e) {
    cbRate = parseInt(e.target.value);
    document.getElementById('cbRateLabel').textContent = cbRate;
  });

  function updateCbDisplay() {
    var connPct = Math.min((cbConns / cbMaxConn) * 100, 100);
    var pendPct = Math.min((cbPending / cbMaxPend) * 100, 100);
    var retryPct = Math.min((cbRetries / cbMaxRetry) * 100, 100);

    var connBar = document.getElementById('cbConnBar');
    connBar.style.width = connPct + '%';
    connBar.className = 'cb-meter-bar' + (connPct >= 80 ? ' warning' : '') + (connPct >= 100 ? ' tripped' : '');

    document.getElementById('cbPendBar').style.width = pendPct + '%';
    document.getElementById('cbRetryBar').style.width = retryPct + '%';

    document.getElementById('cbConnVal').textContent = cbConns;
    document.getElementById('cbPendVal').textContent = cbPending;
    document.getElementById('cbRetryVal').textContent = cbRetries;

    var stateIcon = document.getElementById('cbStateIcon');
    var stateText = document.getElementById('cbStateText');

    if (cbConns >= cbMaxConn || cbRetries >= cbMaxRetry) {
      cbState = 'open';
      stateIcon.textContent = '🔴';
      stateText.textContent = 'OPEN (tripped!)';
      stateText.className = 'cb-state-text open';
    } else if (cbConns >= cbMaxConn * 0.8) {
      cbState = 'half';
      stateIcon.textContent = '🟡';
      stateText.textContent = 'HALF-OPEN (near limit)';
      stateText.className = 'cb-state-text half';
    } else {
      cbState = 'closed';
      stateIcon.textContent = '✅';
      stateText.textContent = 'CLOSED (healthy)';
      stateText.className = 'cb-state-text';
    }
  }

  function cbLog(msg, color) {
    var log = document.getElementById('cbLog');
    var entry = document.createElement('div');
    entry.style.cssText = 'color:' + (color || '#aaa') + ';animation:fadeIn 0.2s';
    entry.textContent = '[' + new Date().toLocaleTimeString() + '] ' + msg;
    log.appendChild(entry);
    log.scrollTop = log.scrollHeight;
  }

  document.getElementById('startCbBtn').addEventListener('click', function() {
    if (cbInterval) return;
    document.getElementById('startCbBtn').disabled = true;
    document.getElementById('stopCbBtn').disabled = false;
    cbLog('Traffic started at ' + cbRate + ' req/s', '#10b981');

    cbInterval = setInterval(function() {
      if (cbState === 'open') {
        cbPending++;
        if (cbPending > cbMaxPend) cbPending = cbMaxPend;
        cbLog('Request REJECTED — circuit OPEN', '#ef4444');
        // Slowly recover
        if (Math.random() < 0.15) {
          cbConns = Math.max(0, cbConns - 1);
          cbRetries = Math.max(0, cbRetries - 1);
          cbLog('Connection released (recovery)', '#f59e0b');
        }
      } else {
        cbConns++;
        if (Math.random() < 0.3) {
          cbRetries = Math.min(cbRetries + 1, cbMaxRetry);
          cbLog('Request failed → retry #' + cbRetries, '#f59e0b');
        } else {
          cbLog('Request accepted (conn: ' + cbConns + '/' + cbMaxConn + ')', '#06b6d4');
        }
        // Connections complete after delay
        setTimeout(function() {
          cbConns = Math.max(0, cbConns - 1);
          cbPending = Math.max(0, cbPending - 1);
          updateCbDisplay();
        }, 1500 + Math.random() * 1500);
      }
      updateCbDisplay();
    }, 1000 / cbRate);
  });

  document.getElementById('stopCbBtn').addEventListener('click', function() {
    clearInterval(cbInterval);
    cbInterval = null;
    document.getElementById('startCbBtn').disabled = false;
    document.getElementById('stopCbBtn').disabled = true;
    cbLog('Traffic stopped', '#888');
  });

  document.getElementById('resetCbBtn').addEventListener('click', function() {
    clearInterval(cbInterval);
    cbInterval = null;
    cbConns = 0; cbPending = 0; cbRetries = 0; cbState = 'closed';
    document.getElementById('startCbBtn').disabled = false;
    document.getElementById('stopCbBtn').disabled = true;
    updateCbDisplay();
    document.getElementById('cbLog').innerHTML = '';
  });

  // ========== xDS ==========
  var currentXds = 'LDS';
  var xdsVersions = { LDS: 0, RDS: 0, CDS: 0, EDS: 0, SDS: 0 };

  var xdsInfo = {
    LDS: { desc: '<strong>LDS (Listener Discovery Service):</strong> Discovers listener configurations — which ports to bind, what filter chains to attach. When Istio creates a VirtualService, it updates LDS.', config: 'listeners:\n- name: http_listener\n  address: 0.0.0.0:8080\n  filter_chains:\n  - filters:\n    - http_connection_manager' },
    RDS: { desc: '<strong>RDS (Route Discovery Service):</strong> Discovers route tables — maps virtual hosts and URL paths to clusters. Changed when you update VirtualService routing rules.', config: 'routes:\n- match: { prefix: /api }\n  route: { cluster: my-svc }\n- match: { prefix: /web }\n  route: { cluster: frontend }' },
    CDS: { desc: '<strong>CDS (Cluster Discovery Service):</strong> Discovers upstream clusters — their LB policy, circuit breaker settings, and TLS context. Maps to Istio DestinationRules.', config: 'clusters:\n- name: my-svc\n  type: EDS\n  lb_policy: ROUND_ROBIN\n  circuit_breakers:\n    max_connections: 1024' },
    EDS: { desc: '<strong>EDS (Endpoint Discovery Service):</strong> Discovers the actual IP:port endpoints for each cluster. Updated as pods scale up/down in Kubernetes.', config: 'endpoints:\n- cluster: my-svc\n  endpoints:\n  - 10.0.0.1:8080 (healthy)\n  - 10.0.0.2:8080 (healthy)\n  - 10.0.0.3:8080 (draining)' },
    SDS: { desc: '<strong>SDS (Secret Discovery Service):</strong> Delivers TLS certificates and keys. Istio\'s Citadel/istiod rotates mTLS certs via SDS — no restart needed.', config: 'secrets:\n- name: default\n  tls_certificate:\n    certificate_chain: [PEM]\n    private_key: [PEM]\n  validation_context:\n    trusted_ca: [PEM]' }
  };

  function updateXdsDisplay() {
    document.getElementById('xdsCpConfig').textContent = xdsInfo[currentXds].config;
    document.getElementById('xdsDesc').innerHTML = xdsInfo[currentXds].desc;
  }
  updateXdsDisplay();

  document.querySelectorAll('.xds-tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.xds-tab').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentXds = btn.getAttribute('data-xds');
      updateXdsDisplay();
    });
  });

  function pushXds(type) {
    xdsVersions[type]++;
    var ver = xdsVersions[type];
    var msgs = document.getElementById('xdsMsgs');

    // DiscoveryRequest
    var req = document.createElement('div');
    req.style.cssText = 'background:rgba(139,92,246,0.2);border:1px solid rgba(139,92,246,0.4);border-radius:6px;padding:6px 10px;font-size:0.75rem;color:#a78bfa;font-family:monospace;animation:slideDown 0.3s;white-space:nowrap;';
    req.textContent = '← DiscoveryRequest{type:' + type + ', v:' + (ver - 1) + '}';
    msgs.appendChild(req);

    setTimeout(function() {
      var resp = document.createElement('div');
      resp.style.cssText = 'background:rgba(16,185,129,0.2);border:1px solid rgba(16,185,129,0.4);border-radius:6px;padding:6px 10px;font-size:0.75rem;color:#10b981;font-family:monospace;animation:slideDown 0.3s;white-space:nowrap;';
      resp.textContent = '→ DiscoveryResponse{type:' + type + ', v:' + ver + ', nonce:' + Math.random().toString(36).slice(2, 8) + '}';
      msgs.appendChild(resp);

      // Update slot
      var slot = document.getElementById('xdsSlot' + type);
      slot.textContent = type + ': v' + ver + ' ✓';
      slot.classList.add('updated');
      setTimeout(function() { slot.classList.remove('updated'); }, 2000);

      // ACK
      setTimeout(function() {
        var ack = document.createElement('div');
        ack.style.cssText = 'background:rgba(139,92,246,0.1);border:1px solid rgba(139,92,246,0.2);border-radius:6px;padding:6px 10px;font-size:0.75rem;color:#888;font-family:monospace;animation:slideDown 0.3s;white-space:nowrap;';
        ack.textContent = '← ACK{type:' + type + ', v:' + ver + '}';
        msgs.appendChild(ack);
      }, 400);
    }, 500);
  }

  document.getElementById('pushXdsBtn').addEventListener('click', function() {
    document.getElementById('xdsMsgs').innerHTML = '';
    pushXds(currentXds);
  });

  document.getElementById('pushAllXdsBtn').addEventListener('click', function() {
    document.getElementById('xdsMsgs').innerHTML = '';
    var order = ['CDS', 'EDS', 'LDS', 'RDS', 'SDS'];
    order.forEach(function(type, i) {
      setTimeout(function() { pushXds(type); }, i * 1200);
    });
  });

  // ========== HEALTH CHECKING ==========
  var hcMode = 'active';
  var hcEndpoints = [
    { name: '10.0.0.1', healthy: true, failures: 0 },
    { name: '10.0.0.2', healthy: true, failures: 0 },
    { name: '10.0.0.3', healthy: true, failures: 0 },
    { name: '10.0.0.4', healthy: true, failures: 0 }
  ];
  var hcInterval = null;
  var hcFailTarget = -1;

  document.querySelectorAll('.hc-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.hc-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      hcMode = btn.getAttribute('data-mode');
    });
  });

  function buildHcViz() {
    var container = document.getElementById('hcViz');
    container.innerHTML = '';
    hcEndpoints.forEach(function(ep, i) {
      var div = document.createElement('div');
      div.className = 'hc-endpoint' + (ep.healthy ? '' : ' unhealthy') + (ep.failures >= 5 ? ' ejected' : '');
      div.id = 'hcEp' + i;
      div.innerHTML = '<div class="hc-ep-icon">' + (ep.healthy ? '🖥️' : '💀') + '</div>' +
        '<div class="hc-ep-name">' + ep.name + '</div>' +
        '<div class="hc-ep-status' + (ep.healthy ? '' : ' fail') + '">' +
        (ep.failures >= 5 ? 'EJECTED' : (ep.healthy ? 'HEALTHY' : 'FAILING (' + ep.failures + ')')) + '</div>';
      container.appendChild(div);
    });
  }
  buildHcViz();

  function hcLog(msg, color) {
    var log = document.getElementById('hcLog');
    var entry = document.createElement('div');
    entry.style.cssText = 'color:' + (color || '#aaa') + ';animation:fadeIn 0.2s';
    entry.textContent = msg;
    log.appendChild(entry);
    log.scrollTop = log.scrollHeight;
  }

  document.getElementById('startHcBtn').addEventListener('click', function() {
    if (hcInterval) return;
    hcLog('Health checking started (' + hcMode + ' mode)', '#10b981');

    hcInterval = setInterval(function() {
      hcEndpoints.forEach(function(ep, i) {
        if (i === hcFailTarget) {
          ep.failures++;
          if (ep.failures >= 3) ep.healthy = false;
          if (hcMode === 'active') {
            hcLog('Active probe to ' + ep.name + ' → ' + (ep.healthy ? '200 OK' : 'TIMEOUT'), ep.healthy ? '#10b981' : '#ef4444');
          } else {
            hcLog('Outlier: ' + ep.name + ' consecutive 5xx count: ' + ep.failures, '#f59e0b');
          }
          if (ep.failures >= 5) {
            hcLog('⚠ ' + ep.name + ' EJECTED (threshold exceeded)', '#ef4444');
          }
        } else {
          if (hcMode === 'active') {
            hcLog('Active probe to ' + ep.name + ' → 200 OK', '#10b981');
          }
        }
      });
      buildHcViz();
    }, 1500);
  });

  document.getElementById('failEndpointBtn').addEventListener('click', function() {
    hcFailTarget = Math.floor(Math.random() * hcEndpoints.length);
    hcLog('Endpoint ' + hcEndpoints[hcFailTarget].name + ' is now failing!', '#ef4444');
  });

  document.getElementById('resetHcBtn').addEventListener('click', function() {
    clearInterval(hcInterval);
    hcInterval = null;
    hcFailTarget = -1;
    hcEndpoints.forEach(function(ep) { ep.healthy = true; ep.failures = 0; });
    buildHcViz();
    document.getElementById('hcLog').innerHTML = '';
  });

  // ========== RETRY POLICIES ==========
  var retryMax = 3;
  var retryFailRate = 60;

  document.getElementById('retryMaxSlider').addEventListener('input', function(e) {
    retryMax = parseInt(e.target.value);
    document.getElementById('retryMaxLabel').textContent = retryMax;
  });

  document.getElementById('retryFailSlider').addEventListener('input', function(e) {
    retryFailRate = parseInt(e.target.value);
    document.getElementById('retryFailLabel').textContent = retryFailRate;
  });

  document.getElementById('sendRetryBtn').addEventListener('click', function() {
    var viz = document.getElementById('retryViz');
    viz.innerHTML = '';
    var attempt = 0;
    var baseDelay = 100;

    function tryOnce() {
      if (attempt > retryMax) {
        var final = document.createElement('div');
        final.className = 'retry-attempt failure';
        final.innerHTML = '<span class="retry-num">EXHAUSTED</span><span class="retry-result" style="color:#ef4444">All retries failed — 503 returned to client</span>';
        viz.appendChild(final);
        return;
      }

      var fail = Math.random() * 100 < retryFailRate;
      var delay = attempt === 0 ? 0 : Math.floor(baseDelay * Math.pow(2, attempt - 1) * (0.5 + Math.random()));
      var div = document.createElement('div');
      div.className = 'retry-attempt ' + (fail ? 'failure' : 'success');
      div.innerHTML = '<span class="retry-num">' + (attempt === 0 ? 'Initial' : 'Retry #' + attempt) + '</span>' +
        '<span class="retry-result" style="color:' + (fail ? '#ef4444' : '#10b981') + '">' + (fail ? '503 Service Unavailable' : '200 OK ✓') + '</span>' +
        (delay > 0 ? '<span class="retry-delay">+' + delay + 'ms jitter</span>' : '');
      viz.appendChild(div);

      if (fail) {
        attempt++;
        setTimeout(tryOnce, 500);
      }
    }
    tryOnce();
  });

  document.getElementById('resetRetryBtn').addEventListener('click', function() {
    document.getElementById('retryViz').innerHTML = '';
  });

  // ========== RATE LIMITING ==========
  var rlLimit = 5;
  var rlMode = 'local';
  var rlTokens = 5;

  document.querySelectorAll('.rl-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.rl-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      rlMode = btn.getAttribute('data-mode');
    });
  });

  document.getElementById('rlLimitSlider').addEventListener('input', function(e) {
    rlLimit = parseInt(e.target.value);
    rlTokens = rlLimit;
    document.getElementById('rlLimitLabel').textContent = rlLimit;
    updateRlBucket();
  });

  function updateRlBucket() {
    var pct = (rlTokens / rlLimit) * 100;
    var fill = document.getElementById('rlBucketFill');
    fill.style.setProperty('--fill', pct + '%');
    fill.setAttribute('style', '');
    // Set the fill via the after pseudo-element height
    fill.innerHTML = '<div style="position:absolute;bottom:0;left:0;right:0;height:' + pct + '%;background:linear-gradient(0deg,rgba(245,158,11,0.6),rgba(245,158,11,0.2));transition:height 0.3s;border-radius:0 0 6px 6px;"></div>';
    document.getElementById('rlBucketVal').textContent = rlTokens + ' / ' + rlLimit;
  }
  updateRlBucket();

  document.getElementById('sendRlBtn').addEventListener('click', function() {
    var results = document.getElementById('rlResults');
    results.innerHTML = '';
    rlTokens = rlLimit;
    updateRlBucket();

    var totalReqs = 10;
    var sent = 0;

    function sendOne() {
      if (sent >= totalReqs) return;
      sent++;
      var allowed = rlTokens > 0;
      if (allowed) rlTokens--;
      updateRlBucket();

      var req = document.createElement('div');
      req.className = 'rl-req ' + (allowed ? 'allowed' : 'denied');
      req.textContent = allowed ? '✓' : '✗';
      req.title = (allowed ? '200 OK' : '429 Too Many Requests') + (rlMode === 'global' ? ' (global RLS)' : ' (local)');
      results.appendChild(req);

      setTimeout(sendOne, 200);
    }
    sendOne();

    // Token refill
    setTimeout(function() {
      if (rlTokens < rlLimit) {
        rlTokens = Math.min(rlTokens + Math.floor(rlLimit / 2), rlLimit);
        updateRlBucket();
      }
    }, 2500);
  });

  document.getElementById('resetRlBtn').addEventListener('click', function() {
    rlTokens = rlLimit;
    updateRlBucket();
    document.getElementById('rlResults').innerHTML = '';
  });
</script>
