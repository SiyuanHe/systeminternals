constphiCanvas=document.getElementById('phiCanvas');
constphiCtx=phiCanvas.getContext('2d');
constphiInfo=document.getElementById('phiInfo');
letphiAnimating=false;

functiondrawPhiChart(values){
constctx=phiCtx;
constw=phiCanvas.width;
consth=phiCanvas.height;
constpad={top:30,right:30,bottom:40,left:60};
constchartW=w-pad.left-pad.right;
constchartH=h-pad.top-pad.bottom;

ctx.clearRect(0,0,w,h);

constmaxTime=values.length>0?values[values.length-1].time:20;
constmaxPhi=12;

//Grid
ctx.strokeStyle='rgba(255,255,255,0.05)';
ctx.lineWidth=1;
for(letp=0;p<=maxPhi;p+=2){
consty=pad.top+chartH-(p/maxPhi)*chartH;
ctx.beginPath();
ctx.moveTo(pad.left,y);
ctx.lineTo(pad.left+chartW,y);
ctx.stroke();

ctx.fillStyle='#666';
ctx.font='10pxMonaco,monospace';
ctx.textAlign='right';
ctx.fillText(`φ=${p}`,pad.left-8,y+3);
}

//Thresholdlineatφ=8
constthreshY=pad.top+chartH-(8/maxPhi)*chartH;
ctx.strokeStyle='#ef4444';
ctx.lineWidth=1;
ctx.setLineDash([6,4]);
ctx.beginPath();
ctx.moveTo(pad.left,threshY);
ctx.lineTo(pad.left+chartW,threshY);
ctx.stroke();
ctx.setLineDash([]);
ctx.fillStyle='#ef4444';
ctx.font='bold10pxInter,sans-serif';
ctx.textAlign='left';
ctx.fillText('THRESHOLD(φ=8)',pad.left+chartW-110,threshY-6);

//Philine
if(values.length>1){
ctx.strokeStyle='#f97316';
ctx.lineWidth=2;
ctx.beginPath();
for(leti=0;i<values.length;i++){
constx=pad.left+(values[i].time/maxTime)*chartW;
consty=pad.top+chartH-(Math.min(values[i].phi,maxPhi)/maxPhi)*chartH;
if(i===0)ctx.moveTo(x,y);
elsectx.lineTo(x,y);
}
ctx.stroke();

//Fillundercurve
ctx.lineTo(pad.left+(values[values.length-1].time/maxTime)*chartW,pad.top+chartH);
ctx.lineTo(pad.left+(values[0].time/maxTime)*chartW,pad.top+chartH);
ctx.closePath();
ctx.fillStyle='rgba(249,115,22,0.1)';
ctx.fill();
}

//Heartbeatmarkers
for(constvofvalues){
if(v.heartbeat){
constx=pad.left+(v.time/maxTime)*chartW;
ctx.fillStyle='#22c55e';
ctx.beginPath();
ctx.arc(x,pad.top+chartH+15,4,0,Math.PI*2);
ctx.fill();
}
}

//Axislabels
ctx.fillStyle='#888';
ctx.font='11pxInter,sans-serif';
ctx.textAlign='center';
ctx.fillText('Time(seconds)',pad.left+chartW/2,h-5);
ctx.fillStyle='#22c55e';
ctx.fillText('●=heartbeatreceived',pad.left+chartW/2,h-18);

//Title
ctx.fillStyle='#fff';
ctx.font='bold12pxInter,sans-serif';
ctx.textAlign='left';
ctx.fillText('SuspicionLevel(φ)',pad.left,pad.top-10);
}

document.getElementById('startPhiBtn')?.addEventListener('click',async()=>{
if(phiAnimating)return;
phiAnimating=true;
(document.getElementById('startPhiBtn')).disabled=true;

constvalues=[];
letphi=0;
consttotalTime=20;
conststeps=100;
constheartbeatInterval=1;//1second
letlastHeartbeat=0;
constfailTime=8;//Nodestopssendingheartbeatsatt=8

for(leti=0;i<=steps;i++){
constt=(i/steps)*totalTime;
constheartbeat=t<failTime&&t-lastHeartbeat>=heartbeatInterval;
if(heartbeat)lastHeartbeat=t;

if(t<failTime){
//Normal:phistayslow,resetsonheartbeat
phi=Math.max(0,(t-lastHeartbeat)*0.5);
}else{
//Afterfailure:phiincreasesbasedontimesincelastheartbeat
consttimeSinceHB=t-lastHeartbeat;
phi=Math.min(12,timeSinceHB*1.2);
}

values.push({time:t,phi,heartbeat});
drawPhiChart(values);

constcurrentPhi=phi;
if(t>=failTime&&currentPhi>=8&&values.filter(v=>v.phi>=8).length===1){
phiInfo.innerHTML=`⏱t=${t.toFixed(1)}s—<span style="color:#ef4444;font-weight:600;">φ=${currentPhi.toFixed(1)}≥8→NODEMARKEDDOWN</span>.Probabilityofbeingalive:<strong>${(Math.pow(10,-currentPhi)*100).toFixed(6)}%</strong>`;
}elseif(t<failTime){
phiInfo.innerHTML=`⏱t=${t.toFixed(1)}s—<span style="color:#22c55e;">φ=${currentPhi.toFixed(2)}</span>—heartbeatsnormal,nodeishealthy`;
}else{
constprob=Math.pow(10,-currentPhi)*100;
phiInfo.innerHTML=`⏱t=${t.toFixed(1)}s—<span style="color:#f97316;">φ=${currentPhi.toFixed(2)}</span>—noheartbeatfor${(t-lastHeartbeat).toFixed(1)}s.Probalive:${prob<0.001?prob.toExponential(2):prob.toFixed(4)}%`;
}

awaitnewPromise(r=>setTimeout(r,50));
}

phiAnimating=false;
(document.getElementById('startPhiBtn')).disabled=false;
});

document.getElementById('resetPhiBtn')?.addEventListener('click',()=>{
phiAnimating=false;
phiCtx.clearRect(0,0,phiCanvas.width,phiCanvas.height);
phiInfo.innerHTML='Click"Simulate"towatchthePhiAccrualFailureDetectorinaction';
drawPhiChart([]);
(document.getElementById('startPhiBtn')).disabled=false;
});

//==========READ/WRITEPATH==========
constrwCanvas=document.getElementById('rwCanvas');
constrwCtx=rwCanvas.getContext('2d');
constrwTimeline=document.getElementById('rwTimeline');
constrwBadge=document.getElementById('rwBadge');
constrwStatusText=document.getElementById('rwStatusText');
constclSelect=document.getElementById('clSelect');

functiongetRequiredAcks(cl,rfVal){
switch(cl){
case'ONE':return1;
case'QUORUM':
case'LOCAL_QUORUM':returnMath.floor(rfVal/2)+1;
case'ALL':returnrfVal;
default:return1;
}
}

functiondrawRwViz(coordinator,replicas,acked,op,cl){
constctx=rwCtx;
constcanvas=rwCanvas;
ctx.clearRect(0,0,canvas.width,canvas.height);

constcx=canvas.width/2;
constcy=canvas.height/2;
constradius=Math.min(cx,cy)-80;

//Drawring
ctx.strokeStyle='rgba(255,255,255,0.08)';
ctx.lineWidth=2;
ctx.beginPath();
ctx.arc(cx,cy,radius,0,Math.PI*2);
ctx.stroke();

//Drawallnodesonring
for(leti=0;i<nodeCount;i++){
constangle=(Math.PI*2*i/nodeCount)-Math.PI/2;
constnx=cx+Math.cos(angle)*radius;
constny=cy+Math.sin(angle)*radius;

constisCoord=i===coordinator;
constisReplica=replicas.includes(i);
constisAcked=acked.includes(i);

letcolor=NODE_COLORS[i];
letr=22;

if(isCoord){
r=28;
ctx.shadowColor='#eab308';
ctx.shadowBlur=15;
}elseif(isReplica){
ctx.shadowColor=isAcked?'#22c55e':color;
ctx.shadowBlur=10;
}else{
ctx.shadowBlur=0;
}

ctx.fillStyle=color+(isReplica?'40':'15');
ctx.beginPath();
ctx.arc(nx,ny,r,0,Math.PI*2);
ctx.fill();

ctx.strokeStyle=isCoord?'#eab308':(isAcked?'#22c55e':color);
ctx.lineWidth=isCoord||isReplica?2:1;
ctx.beginPath();
ctx.arc(nx,ny,r,0,Math.PI*2);
ctx.stroke();
ctx.shadowBlur=0;

//Linesfromcoordinatortoreplicas
if(isReplica&&!isCoord){
constcoordAngle=(Math.PI*2*coordinator/nodeCount)-Math.PI/2;
constcx2=cx+Math.cos(coordAngle)*radius;
constcy2=cy+Math.sin(coordAngle)*radius;

ctx.strokeStyle=isAcked?'#22c55e50':(op==='write'?'#f9731640':'#60a5fa40');
ctx.lineWidth=2;
ctx.setLineDash([4,4]);
ctx.beginPath();
ctx.moveTo(cx2,cy2);
ctx.lineTo(nx,ny);
ctx.stroke();
ctx.setLineDash([]);
}

//Labels
ctx.fillStyle='#fff';
ctx.font='bold10pxInter,sans-serif';
ctx.textAlign='center';
ctx.textBaseline='middle';
ctx.fillText(NODE_NAMES[i],nx,ny);

if(isCoord){
ctx.fillStyle='#eab308';
ctx.font='9pxInter,sans-serif';
ctx.fillText('COORDINATOR',nx,ny+r+12);
}

if(isReplica&&!isCoord){
ctx.fillStyle=isAcked?'#22c55e':'#888';
ctx.font='9pxInter,sans-serif';
ctx.fillText(isAcked?'✓ACK':'REPLICA',nx,ny+r+12);
}
}

//Centerinfo
ctx.fillStyle='rgba(255,255,255,0.2)';
ctx.font='11pxInter,sans-serif';
ctx.textAlign='center';
ctx.fillText(`${op.toUpperCase()}•CL=${cl}`,cx,cy-8);
ctx.fillText(`Need${getRequiredAcks(cl,replicas.length)}/${replicas.length}ACKs`,cx,cy+8);
}

asyncfunctionrunRwOp(op){
constcl=clSelect.value;
consttoken=keyToToken('example_key');
constreplicas=findReplicas(token,Math.min(rf,nodeCount));
constcoordinator=replicas[0];
constrequired=getRequiredAcks(cl,replicas.length);

rwTimeline.innerHTML='';
constaddEntry=(text,cls)=>{
constel=document.createElement('div');
el.className=`failover-step${cls}`;
el.textContent=text;
rwTimeline.appendChild(el);
rwTimeline.scrollTop=rwTimeline.scrollHeight;
};

//Step1:Coordinatorreceivesrequest
rwBadge.className=`status-badge${op==='write'?'writing':'reading'}`;
rwBadge.textContent=op.toUpperCase();
rwStatusText.textContent=`${NODE_NAMES[coordinator]}iscoordinatorforthis${op}`;
drawRwViz(coordinator,replicas,[],op,cl);
addEntry(`📨Clientsends${op.toUpperCase()}tocoordinator${NODE_NAMES[coordinator]}`,'info-step');
awaitnewPromise(r=>setTimeout(r,800));

//Step2:Sendtoreplicas
if(op==='write'){
addEntry(`✍CoordinatorsendswritetoALL${replicas.length}replicas:${replicas.map(id=>NODE_NAMES[id]).join(',')}`,'detect-step');
}else{
addEntry(`📖Coordinatorsendsfullreadto${NODE_NAMES[replicas[0]]},digestreadtoothers`,'detect-step');
}
awaitnewPromise(r=>setTimeout(r,800));

//Step3:ACKscomeinonebyone
constacked=[];
for(leti=0;i<replicas.length;i++){
acked.push(replicas[i]);
drawRwViz(coordinator,replicas,[...acked],op,cl);

if(op==='write'){
addEntry(`✅${NODE_NAMES[replicas[i]]}wrotetocommitlog+memtable→ACK(${acked.length}/${required}needed)`,'promote-step');
}else{
addEntry(`✅${NODE_NAMES[replicas[i]]}respondedwith${i===0?'fulldata':'digest'}→ACK(${acked.length}/${required}needed)`,'promote-step');
}

if(acked.length>=required){
awaitnewPromise(r=>setTimeout(r,500));
rwBadge.className='status-badgedone';
rwBadge.textContent='SUCCESS';
rwStatusText.textContent=`${op.toUpperCase()}succeededwithCL=${cl}(${required}/${replicas.length}acks)`;
addEntry(`🎉CL=${cl}satisfied!CoordinatorrespondsSUCCESStoclient`,'promote-step');

if(op==='read'&&replicas.length>required){
awaitnewPromise(r=>setTimeout(r,600));
addEntry(`🔧Background:read-repairchecksremainingreplicasforconsistency`,'gossip-step');
}
break;
}
awaitnewPromise(r=>setTimeout(r,600));
}
}

document.getElementById('writeBtn')?.addEventListener('click',()=>runRwOp('write'));
document.getElementById('readBtn')?.addEventListener('click',()=>runRwOp('read'));

functionresetRw(){
rwTimeline.innerHTML='';
rwBadge.className='status-badgeidle';
rwBadge.textContent='Ready';
rwStatusText.textContent='PickaconsistencylevelandclickWriteorRead';
rwCtx.clearRect(0,0,rwCanvas.width,rwCanvas.height);
}

document.getElementById('resetRwBtn')?.addEventListener('click',resetRw);

//==========ADD/REMOVENODES==========
constnodeOpCanvas=document.getElementById('nodeOpCanvas');
constnodeOpCtx=nodeOpCanvas.getContext('2d');
constnodeOpTimeline=document.getElementById('nodeOpTimeline');
constnodeOpBadge=document.getElementById('nodeOpBadge');
constnodeOpStatusText=document.getElementById('nodeOpStatusText');

letopNodeCount=6;

functionrenderNodeOpRing(){
consttempNodes=[];
consttempTokens=[];

for(leti=0;i<opNodeCount;i++){
consttoken=TOKEN_MIN+(TOKEN_RANGE*BigInt(i))/BigInt(opNodeCount);
tempNodes.push({
id:i,name:NODE_NAMES[i],color:NODE_COLORS[i],
tokens:[token],x:0,y:0
});
tempTokens.push({token,nodeId:i});
}
tempTokens.sort((a,b)=>(a.token<b.token?-1:a.token>b.token?1:0));

drawRing(nodeOpCtx,nodeOpCanvas,tempNodes,tempTokens,{
label:`${opNodeCount}nodes`
});
}

document.getElementById('addNodeBtn')?.addEventListener('click',async()=>{
if(opNodeCount>=12)return;
constnewId=opNodeCount;
opNodeCount++;

nodeOpBadge.className='status-badgestreaming';
nodeOpBadge.textContent='JOINING';
nodeOpStatusText.textContent=`${NODE_NAMES[newId]}isjoiningthecluster...`;

constaddEntry=(text,cls)=>{
constel=document.createElement('div');
el.className=`failover-step${cls}`;
el.textContent=text;
nodeOpTimeline.appendChild(el);
nodeOpTimeline.scrollTop=nodeOpTimeline.scrollHeight;
};

addEntry(`📡${NODE_NAMES[newId]}contactsseednodesandjoinsthering`,'info-step');
awaitnewPromise(r=>setTimeout(r,800));
addEntry(`💍${NODE_NAMES[newId]}claimstokenranges—ringisrebalancing`,'detect-step');
awaitnewPromise(r=>setTimeout(r,800));
addEntry(`📦Streamingdatafromneighborsto${NODE_NAMES[newId]}...`,'stream-step');
awaitnewPromise(r=>setTimeout(r,1000));

renderNodeOpRing();

addEntry(`✅${NODE_NAMES[newId]}isnowafullmember.${opNodeCount}nodesincluster.`,'promote-step');
nodeOpBadge.className='status-badgedone';
nodeOpBadge.textContent='JOINED';
nodeOpStatusText.textContent=`${NODE_NAMES[newId]}successfullyjoined.Clusterhas${opNodeCount}nodes.`;
});

document.getElementById('removeNodeBtn')?.addEventListener('click',async()=>{
if(opNodeCount<=3)return;
constremovedId=opNodeCount-1;

nodeOpBadge.className='status-badgefailed';
nodeOpBadge.textContent='DECOMMISSION';
nodeOpStatusText.textContent=`${NODE_NAMES[removedId]}isbeingdecommissioned...`;

constaddEntry=(text,cls)=>{
constel=document.createElement('div');
el.className=`failover-step${cls}`;
el.textContent=text;
nodeOpTimeline.appendChild(el);
nodeOpTimeline.scrollTop=nodeOpTimeline.scrollHeight;
};

addEntry(`🔧nodetooldecommissionon${NODE_NAMES[removedId]}`,'detect-step');
awaitnewPromise(r=>setTimeout(r,800));
addEntry(`📦${NODE_NAMES[removedId]}streamingalldatatoremainingnodes...`,'stream-step');
awaitnewPromise(r=>setTimeout(r,1000));

opNodeCount--;
renderNodeOpRing();

addEntry(`✅${NODE_NAMES[removedId]}removed.Clusterrebalancedto${opNodeCount}nodes.`,'promote-step');
nodeOpBadge.className='status-badgedone';
nodeOpBadge.textContent='REMOVED';
nodeOpStatusText.textContent=`${NODE_NAMES[removedId]}decommissioned.Clusterhas${opNodeCount}nodes.`;
});

functionresetNodeOps(){
opNodeCount=nodeCount;
nodeOpTimeline.innerHTML='';
nodeOpBadge.className='status-badgeidle';
nodeOpBadge.textContent='Ready';
nodeOpStatusText.textContent='Addorremovenodestoseedatastreaming';
renderNodeOpRing();
}

document.getElementById('resetNodesBtn')?.addEventListener('click',resetNodeOps);

//==========INITIALRENDER==========
renderMainRing();
renderLegend();
renderReplicationRing();
renderGossipCanvas();
drawPhiChart([]);
renderNodeOpRing();
</script>
