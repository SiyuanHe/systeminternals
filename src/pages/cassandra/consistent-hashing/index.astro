<script is:inline>
//==========CONSTANTS==========
constNODE_COLORS=[
'#ef4444','#3b82f6','#22c55e','#f59e0b','#8b5cf6','#ec4899',
'#14b8a6','#f43f5e','#6366f1','#84cc16','#06b6d4','#e11d48'
;
constNODE_NAMES=['N1','N2','N3','N4','N5','N6','N7','N8','N9','N10','N11','N12'];
constTOKEN_MIN=BigInt('-9223372036854775808');
constTOKEN_MAX=BigInt('9223372036854775807');
constTOKEN_RANGE=TOKEN_MAX-TOKEN_MIN+1n;

//==========Murmur3(simplified32-bitfordemo,scaledto64-bitrange)==========
functionmurmur3_32(key,seed=0){
leth=seed>>>0;
constlen=key.length;
constnblocks=len>>2;
for(leti=0;i<nblocks;i++){
letk=(key.charCodeAt(i*4)&0xff)|
((key.charCodeAt(i*4+1)&0xff)<<8)|
((key.charCodeAt(i*4+2)&0xff)<<16)|
((key.charCodeAt(i*4+3)&0xff)<<24);
k=Math.imul(k,0xcc9e2d51);
k=(k<<15)|(k>>>17);
k=Math.imul(k,0x1b873593);
h^=k;
h=(h<<13)|(h>>>19);
h=Math.imul(h,5)+0xe6546b64;
}
letk=0;
consttail=nblocks*4;
switch(len&3){
case3:k^=(key.charCodeAt(tail+2)&0xff)<<16;
case2:k^=(key.charCodeAt(tail+1)&0xff)<<8;
case1:k^=(key.charCodeAt(tail)&0xff);
k=Math.imul(k,0xcc9e2d51);
k=(k<<15)|(k>>>17);
k=Math.imul(k,0x1b873593);
h^=k;
}
h^=len;
h^=h>>>16;
h=Math.imul(h,0x85ebca6b);
h^=h>>>13;
h=Math.imul(h,0xc2b2ae35);
h^=h>>>16;
returnh>>>0;
}

functionkeyToToken(key){
consth=murmur3_32(key);
//Scaletofull64-bitrange
constscaled=TOKEN_MIN+BigInt(h)*TOKEN_RANGE/BigInt(0x100000000);
returnscaled;
}

functiontokenToAngle(token){
constnormalized=Number(token-TOKEN_MIN)/Number(TOKEN_RANGE);
returnnormalized*Math.PI*2-Math.PI/2;
}

//==========STATE==========
letnodeCount=6;
letvnodesEnabled=false;
letrf=3;
letstrategy='simple';


letringNodes=[];
letallTokens=[];

functionbuildRing(){
ringNodes=[];
allTokens=[];

for(leti=0;i<nodeCount;i++){
constnode={
id:i,
name:NODE_NAMES[i],
color:NODE_COLORS[i],
tokens:[],
x:0,y:0
};

if(vnodesEnabled){
//256vnodespernode(show16forvisualclarity)
constvnodeCount=16;
for(letv=0;v<vnodeCount;v++){
consthash=murmur3_32(`${NODE_NAMES[i]}-vnode-${v}`,42);
consttoken=TOKEN_MIN+BigInt(hash)*TOKEN_RANGE/BigInt(0x100000000);
node.tokens.push(token);
allTokens.push({token,nodeId:i});
}
}else{
//Evendistribution
consttoken=TOKEN_MIN+(TOKEN_RANGE*BigInt(i))/BigInt(nodeCount);
node.tokens.push(token);
allTokens.push({token,nodeId:i});
}

ringNodes.push(node);
}

allTokens.sort((a,b)=>(a.token<b.token?-1:a.token>b.token?1:0));
}

functionfindOwner(token){
//Walkclockwise:findfirsttoken>=giventoken
for(consttofallTokens){
if(t.token>=token)returnt.nodeId;
}
returnallTokens[0].nodeId;//Wraparound
}

functionfindReplicas(token,count){
constreplicas=[];
conststartIdx=allTokens.findIndex(t=>t.token>=token);
conststart=startIdx===-1?0:startIdx;

for(leti=0;i<allTokens.length&&replicas.length<count;i++){
constidx=(start+i)%allTokens.length;
constnodeId=allTokens[idx].nodeId;
if(!replicas.includes(nodeId)){
replicas.push(nodeId);
}
}
returnreplicas;
}

