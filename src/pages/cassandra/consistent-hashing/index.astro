ctx.setLineDash([4,4]);
ctx.beginPath();
ctx.moveTo(cx,cy);
ctx.lineTo(hx,hy);
ctx.stroke();
ctx.setLineDash([]);

//Arrowtoowner
if(opts.highlightOwner!==undefined&&opts.highlightOwner>=0){
constownerNode=nodes[opts.highlightOwner];
if(ownerNode){
ctx.strokeStyle=ownerNode.color;
ctx.lineWidth=2;
ctx.setLineDash([6,4]);
ctx.beginPath();
ctx.moveTo(hx,hy);
constownerAngle=tokenToAngle(ownerNode.tokens[0]);
constox=cx+Math.cos(ownerAngle)*radius;
constoy=cy+Math.sin(ownerAngle)*radius;
ctx.lineTo(ox,oy);
ctx.stroke();
ctx.setLineDash([]);
}
}
}

//Highlightreplicanodes
if(opts?.replicaNodes&&opts.replicaNodes.length>0){
for(letri=0;ri<opts.replicaNodes.length;ri++){
constrNode=nodes[opts.replicaNodes[ri]];
if(!rNode)continue;
ctx.strokeStyle='#fff';
