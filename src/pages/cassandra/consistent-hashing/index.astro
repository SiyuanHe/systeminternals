//Streaminganimation
if(opts?.streamingFrom!==undefined&&opts?.streamingTo!==undefined&&opts?.streamProgress!==undefined){
constfromNode=nodes[opts.streamingFrom];
consttoNode=nodes[opts.streamingTo];
if(fromNode&&toNode){
constprogress=opts.streamProgress;
constsx=fromNode.x,sy=fromNode.y;
constex=toNode.x,ey=toNode.y;
constpx=sx+(ex-sx)*progress;
constpy=sy+(ey-sy)*progress;

ctx.strokeStyle='#eab308';
