functiongossipStep(){
if(gossipDeadNode<0)return;
gossipRound++;
constnewKnowers=[];

//Eachknowingnodegossipsto1-3randompeers
constcurrentKnowers=[...gossipKnows];
for(constknowerofcurrentKnowers){
constpeers=ringNodes.filter(n=>n.id!==knower&&n.id!==gossipDeadNode);
constnumPeers=Math.min(1+Math.floor(Math.random()*3),peers.length);
constshuffled=peers.sort(()=>Math.random()-0.5).slice(0,numPeers);
for(constpeerofshuffled){
if(!gossipKnows.has(peer.id)){
gossipKnows.add(peer.id);
newKnowers.push(peer.id);
}
}
}

constaddEntry=(text,cls)=>{
constel=document.createElement('div');
el.className=`failover-step${cls}`;
el.textContent=text;
gossipTimeline.appendChild(el);
gossipTimeline.scrollTop=gossipTimeline.scrollHeight;
};

if(newKnowers.length>0){
addEntry(`Round${gossipRound}:${newKnowers.map(id=>NODE_NAMES[id]).join(',')}learnedabout${NODE_NAMES[gossipDeadNode]}'sfailure`,'gossip-step');
}else{
addEntry(`Round${gossipRound}:Nonewnodeslearned(allaware)`,'info-step');
}

constalive=nodeCount-1;
constaware=gossipKnows.size;
gossipStats.innerHTML=`
<span class="gossip-stat">Round:<strong>${gossipRound}</strong></span>
<span class="gossip-stat">Aware:<strong>${aware}/${alive}</strong></span>
<span class="gossip-stat">Coverage:<strong>${Math.round(aware/alive*100)}%</strong></span>
`;

if(aware>=alive){
gossipBadge.className='status-badgedone';
gossipBadge.textContent='CONVERGED';
gossipStatusText.textContent=`Allnodesknowabout${NODE_NAMES[gossipDeadNode]}'sfailureafter${gossipRound}rounds`;
addEntry(`✅Fullconvergencein${gossipRound}gossiprounds!`,'promote-step');
(document.getElementById('stepGossipBtn')).disabled=true;
(document.getElementById('autoGossipBtn')).disabled=true;
}else{
gossipBadge.className='status-badgegossip';
gossipBadge.textContent=`ROUND${gossipRound}`;
gossipStatusText.textContent=`${aware}/${alive}nodesawareoffailure`;
}

renderGossipCanvas();
}

