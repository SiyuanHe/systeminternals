</style>

<script is:inline>
  // ============================================================
  // LINUX I/O MODELS — INTERACTIVE VISUALIZATIONS
  // ============================================================

  // --- Scalability Comparison ---
  var connSlider = document.getElementById("connSlider");
  var connLabel = document.getElementById("connLabel");

  function formatNum(n) {
    if (n >= 1000) return (n / 1000).toFixed(n % 1000 === 0 ? 0 : 1) + "K";
    return String(n);
  }

  function updateScalability() {
    var conns = parseInt(connSlider.value);
    connLabel.textContent = formatNum(conns);

    // Blocking I/O
    var bThreads = conns;
    var bMem = conns; // ~1MB per thread
    var bSwitches = conns * 50;
    document.getElementById("blockingThreads").textContent = formatNum(bThreads);
    document.getElementById("blockingMem").textContent = formatNum(bMem) + " MB";
    document.getElementById("blockingSwitches").textContent = "~" + formatNum(bSwitches);

    var bLoad = Math.min(100, (conns / 100) * 10);
    document.getElementById("blockingBar").style.width = bLoad + "%";
    var bVerdict = document.getElementById("blockingVerdict");
    if (conns <= 100) {
      bVerdict.textContent = "Works fine";
      bVerdict.className = "model-verdict good";
    } else if (conns <= 1000) {
      bVerdict.textContent = "Getting heavy";
      bVerdict.className = "model-verdict warning";
    } else {
      bVerdict.textContent = "UNUSABLE — " + formatNum(bMem) + " MB RAM, scheduling collapse";
      bVerdict.className = "model-verdict danger";
    }

    // epoll
    var eThreads = Math.min(Math.max(1, Math.ceil(conns / 5000)), navigator.hardwareConcurrency || 8);
    document.getElementById("epollThreads").textContent = eThreads <= 4 ? "1-" + eThreads : String(eThreads);
    document.getElementById("epollMem").textContent = "~" + Math.max(1, Math.round(conns * 0.001 + 0.5)) + " MB";
    document.getElementById("epollSyscalls").textContent = "1";
    var eLoad = Math.min(60, conns / 200);
    document.getElementById("epollBar").style.width = eLoad + "%";
    var eVerdict = document.getElementById("epollVerdict");
    eVerdict.textContent = conns <= 5000 ? "Excellent" : "Good — consider multi-worker";
    eVerdict.className = "model-verdict excellent";

    // io_uring
    document.getElementById("iouringThreads").textContent = "1";
    document.getElementById("iouringMem").textContent = "~" + Math.max(0.5, Math.round(conns * 0.0005 * 10) / 10) + " MB";
    document.getElementById("iouringSyscalls").textContent = "0 (polled)";
    var uLoad = Math.min(40, conns / 300);
    document.getElementById("iouringBar").style.width = uLoad + "%";
    var uVerdict = document.getElementById("iouringVerdict");
    uVerdict.textContent = "Optimal";
    uVerdict.className = "model-verdict excellent";
  }

  connSlider.addEventListener("input", updateScalability);
  updateScalability();

  // --- Blocking I/O Visualization ---
  var blockingConns = [];
  var maxBlockingConns = 30;

  function renderBlocking() {
    var threadPool = document.getElementById("threadPool");
    var clientList = document.getElementById("blockingClients");
    var tHtml = "";
    var cHtml = "";

    for (var i = 0; i < blockingConns.length; i++) {
      var state = blockingConns[i];
      tHtml += '<div class="thread-box ' + state + '">T' + (i + 1) + '</div>';
      var cCls = "client-dot" + (state === "blocked" ? " waiting" : "");
      cHtml += '<div class="' + cCls + '">C' + (i + 1) + '</div>';
    }

    if (blockingConns.length === 0) {
      tHtml = '<div style="color:#555;font-size:0.8rem;padding:10px;">No threads spawned yet...</div>';
      cHtml = '<div style="color:#555;font-size:0.8rem;padding:10px;">No clients connected...</div>';
    }

    threadPool.innerHTML = tHtml;
    clientList.innerHTML = cHtml;
  }

  function addBlockingClient() {
    if (blockingConns.length >= maxBlockingConns) return;
    var states = ["busy", "idle", "blocked"];
    var state = states[Math.floor(Math.random() * states.length)];
    blockingConns.push(state);
    renderBlocking();

    // Randomly toggle states
    var idx = blockingConns.length - 1;
    setInterval(function() {
      if (idx < blockingConns.length) {
        var s = ["busy", "idle", "blocked"];
        blockingConns[idx] = s[Math.floor(Math.random() * s.length)];
        renderBlocking();
      }
    }, 1000 + Math.random() * 2000);
  }

  document.getElementById("addClientBtn").addEventListener("click", addBlockingClient);

  document.getElementById("floodBtn").addEventListener("click", function() {
    for (var i = 0; i < 20 && blockingConns.length < maxBlockingConns; i++) {
      addBlockingClient();
    }
  });

  document.getElementById("blockingResetBtn").addEventListener("click", function() {
    blockingConns = [];
    renderBlocking();
  });

  renderBlocking();

  // --- epoll Visualization ---
  var epollFds = [];
  var epollReadyList = [];
  var nextFd = 4;

  function renderEpoll() {
    var interestHtml = "";
    for (var i = 0; i < epollFds.length; i++) {
      interestHtml += '<span class="fd-chip interest">fd:' + epollFds[i] + '</span>';
    }
    if (epollFds.length === 0) {
      interestHtml = '<span style="color:#555;font-size:0.75rem;">No fds registered</span>';
    }
    document.getElementById("interestFds").innerHTML = interestHtml;

    var readyHtml = "";
    for (var r = 0; r < epollReadyList.length; r++) {
      readyHtml += '<span class="fd-chip ready">fd:' + epollReadyList[r] + ' EPOLLIN</span>';
    }
    if (epollReadyList.length === 0) {
      readyHtml = '<span style="color:#555;font-size:0.75rem;">Empty</span>';
    }
    document.getElementById("readyFds").innerHTML = readyHtml;
  }

  document.getElementById("epollAddBtn").addEventListener("click", function() {
    if (epollFds.length >= 12) return;
    epollFds.push(nextFd++);
    renderEpoll();
    var loopEl = document.getElementById("loopWait");
    loopEl.textContent = "epoll_ctl(EPOLL_CTL_ADD, fd:" + (nextFd - 1) + ")";
    loopEl.className = "loop-step active";
    setTimeout(function() {
      loopEl.textContent = "epoll_wait() — sleeping";
      loopEl.className = "loop-step";
    }, 1200);
  });

  document.getElementById("epollDataBtn").addEventListener("click", function() {
    if (epollFds.length === 0) return;
    // Random fd becomes ready
    var readyFd = epollFds[Math.floor(Math.random() * epollFds.length)];
    if (epollReadyList.indexOf(readyFd) === -1) {
      epollReadyList.push(readyFd);
    }
    renderEpoll();
    var loopEl = document.getElementById("loopWait");
    loopEl.textContent = "← IRQ: data on fd:" + readyFd;
    loopEl.className = "loop-step active";
    setTimeout(function() {
      loopEl.textContent = "epoll_wait() — " + epollReadyList.length + " fd(s) ready";
      loopEl.className = "loop-step";
    }, 800);
  });

  document.getElementById("epollWaitBtn").addEventListener("click", function() {
    var loopEl = document.getElementById("loopWait");
    if (epollReadyList.length === 0) {
      loopEl.textContent = "epoll_wait() returned 0 — no events";
      loopEl.className = "loop-step";
      return;
    }
    var count = epollReadyList.length;
    loopEl.textContent = "epoll_wait() → " + count + " events! Dispatching...";
    loopEl.className = "loop-step active";

    var processed = epollReadyList.slice();
    epollReadyList = [];
    renderEpoll();

    setTimeout(function() {
      loopEl.textContent = "Handled fds: [" + processed.join(", ") + "] — back to sleep";
      loopEl.className = "loop-step";
      setTimeout(function() {
        loopEl.textContent = "epoll_wait() — sleeping";
        loopEl.className = "loop-step";
      }, 1500);
    }, 1000);
  });

  document.getElementById("epollResetBtn").addEventListener("click", function() {
    epollFds = [];
    epollReadyList = [];
    nextFd = 4;
    renderEpoll();
    document.getElementById("loopWait").textContent = "epoll_wait() — sleeping";
    document.getElementById("loopWait").className = "loop-step";
  });

  renderEpoll();

  // --- io_uring Ring Buffer Visualization ---
  var RING_SIZE = 8;
  var sqEntries = [];
  var cqEntries = [];
  var sqHeadIdx = 0;
  var sqTailIdx = 0;
  var cqHeadIdx = 0;
  var cqTailIdx = 0;
  var opCounter = 0;

  var opTypes = ["read", "write", "accept", "send", "recv", "fsync", "poll"];

  function renderRings() {
    var sqHtml = "";
    var cqHtml = "";

    for (var i = 0; i < RING_SIZE; i++) {
      var sqEntry = sqEntries[i];
      if (sqEntry) {
        var cls = sqEntry.processing ? "ring-slot processing" : "ring-slot filled";
        sqHtml += '<div class="' + cls + '">' + sqEntry.op + '</div>';
      } else {
        sqHtml += '<div class="ring-slot empty">—</div>';
      }

      var cqEntry = cqEntries[i];
      if (cqEntry) {
        cqHtml += '<div class="ring-slot completed">' + cqEntry.op + ' ✓</div>';
      } else {
        cqHtml += '<div class="ring-slot empty">—</div>';
      }
    }

    document.getElementById("sqRing").innerHTML = sqHtml;
    document.getElementById("cqRing").innerHTML = cqHtml;

    var sqCount = sqEntries.filter(function(e) { return e; }).length;
    var cqCount = cqEntries.filter(function(e) { return e; }).length;

    document.getElementById("sqHead").textContent = String(sqHeadIdx);
    document.getElementById("sqTail").textContent = String(sqTailIdx);
    document.getElementById("sqCount").textContent = String(sqCount);
    document.getElementById("cqHead").textContent = String(cqHeadIdx);
    document.getElementById("cqTail").textContent = String(cqTailIdx);
    document.getElementById("cqCount").textContent = String(cqCount);
  }

  document.getElementById("sqSubmitBtn").addEventListener("click", function() {
    // Find empty slot in SQ
    var sqCount = sqEntries.filter(function(e) { return e; }).length;
    if (sqCount >= RING_SIZE) return;

    var op = opTypes[opCounter % opTypes.length];
    opCounter++;
    sqEntries[sqTailIdx % RING_SIZE] = { op: op, processing: false };
    sqTailIdx = (sqTailIdx + 1) % RING_SIZE;
    renderRings();
  });

  document.getElementById("kernelProcessBtn").addEventListener("click", function() {
    // Process one SQ entry
    var found = false;
    for (var i = 0; i < RING_SIZE; i++) {
      if (sqEntries[i] && !sqEntries[i].processing) {
        sqEntries[i].processing = true;
        renderRings();

        (function(idx) {
          setTimeout(function() {
            var entry = sqEntries[idx];
            sqEntries[idx] = null;
            sqHeadIdx = (sqHeadIdx + 1) % RING_SIZE;

            // Add to CQ
            cqEntries[cqTailIdx % RING_SIZE] = { op: entry.op };
            cqTailIdx = (cqTailIdx + 1) % RING_SIZE;
            renderRings();
          }, 600);
        })(i);

        found = true;
        break;
      }
    }
  });

  document.getElementById("cqReapBtn").addEventListener("click", function() {
    // Reap one CQ entry
    for (var i = 0; i < RING_SIZE; i++) {
      if (cqEntries[i]) {
        cqEntries[i] = null;
        cqHeadIdx = (cqHeadIdx + 1) % RING_SIZE;
        renderRings();
        break;
      }
    }
  });

  document.getElementById("iouringResetBtn").addEventListener("click", function() {
    sqEntries = [];
    cqEntries = [];
    sqHeadIdx = 0;
    sqTailIdx = 0;
    cqHeadIdx = 0;
    cqTailIdx = 0;
    opCounter = 0;
    renderRings();
  });

  renderRings();

  // --- Reactor Pattern ---
  var reactorLog = [];

  function addReactorEvent(type, text) {
    reactorLog.push({ type: type, text: text });
    if (reactorLog.length > 8) reactorLog.shift();

    var html = "";
    for (var i = 0; i < reactorLog.length; i++) {
      var evt = reactorLog[i];
      html += '<div class="reactor-event ' + evt.type + '">' + evt.text + '</div>';
    }
    document.getElementById("reactorEvents").innerHTML = html;
  }

  function flashHandler(id) {
    var el = document.getElementById(id);
    el.classList.add("active");
    setTimeout(function() { el.classList.remove("active"); }, 1500);
  }

  document.getElementById("reactorConnBtn").addEventListener("click", function() {
    addReactorEvent("accept", "→ ACCEPT: new connection on fd:" + (4 + Math.floor(Math.random() * 20)));
    flashHandler("handlerAccept");
  });

  document.getElementById("reactorDataBtn").addEventListener("click", function() {
    var fd = 4 + Math.floor(Math.random() * 20);
    addReactorEvent("read", "→ READ: data ready on fd:" + fd + " (1.2KB)");
    flashHandler("handlerRead");
    setTimeout(function() {
      addReactorEvent("write", "→ WRITE: response sent to fd:" + fd);
      flashHandler("handlerWrite");
    }, 500);
  });

  document.getElementById("reactorTimerBtn").addEventListener("click", function() {
    addReactorEvent("timer", "→ TIMER: keepalive check — closing idle connections");
    flashHandler("handlerTimer");
  });

  document.getElementById("reactorResetBtn").addEventListener("click", function() {
    reactorLog = [];
    document.getElementById("reactorEvents").innerHTML = '<div class="reactor-event idle">Waiting for events...</div>';
    var handlers = ["handlerAccept", "handlerRead", "handlerWrite", "handlerTimer"];
    for (var h = 0; h < handlers.length; h++) {
      document.getElementById(handlers[h]).classList.remove("active");
    }
  });

  // --- epoll Event Loop Animation ---
  var animSteps = [
    { type: "syscall", text: ">>> epoll_wait(epfd, events, 1024, -1)" },
    { type: "highlight", text: "    [sleeping... waiting for events]" },
    { type: "event", text: "    ← IRQ: packet arrived on eth0" },
    { type: "event", text: "    ← kernel: TCP data ready on fd:7" },
    { type: "syscall", text: ">>> epoll_wait() returned 1 event" },
    { type: "highlight", text: "    events[0] = { fd:7, EPOLLIN }" },
    { type: "", text: "    dispatching to read handler..." },
    { type: "syscall", text: ">>> read(7, buf, 4096) = 1380 bytes" },
    { type: "", text: "    processing HTTP request: GET /api/data" },
    { type: "", text: "    building JSON response (234 bytes)" },
    { type: "syscall", text: ">>> write(7, response, 234) = 234" },
    { type: "highlight", text: "    ✓ request handled in 0.12ms" },
    { type: "", text: "" },
    { type: "syscall", text: ">>> epoll_wait(epfd, events, 1024, -1)" },
    { type: "highlight", text: "    [sleeping... waiting for events]" },
    { type: "event", text: "    ← 3 events arrive simultaneously!" },
    { type: "syscall", text: ">>> epoll_wait() returned 3 events" },
    { type: "highlight", text: "    events[0] = { fd:4, EPOLLIN }  ← new connection" },
    { type: "highlight", text: "    events[1] = { fd:8, EPOLLIN }  ← data ready" },
    { type: "highlight", text: "    events[2] = { fd:5, EPOLLOUT } ← write ready" },
    { type: "syscall", text: ">>> accept(4) = fd:12  (new client)" },
    { type: "syscall", text: ">>> epoll_ctl(EPOLL_CTL_ADD, fd:12)" },
    { type: "syscall", text: ">>> read(8, buf, 4096) = 512 bytes" },
    { type: "syscall", text: ">>> write(5, buf, 2048) = 2048" },
    { type: "highlight", text: "    ✓ 3 events handled in 0.08ms total" },
    { type: "", text: "" },
    { type: "highlight", text: "    One thread. Zero wasted cycles. This is epoll." },
  ];

  var animIdx = 0;
  var animInterval = null;

  function renderAnimStep() {
    var el = document.getElementById("animTimeline");
    if (animIdx === 0) el.innerHTML = "";

    if (animIdx >= animSteps.length) {
      clearInterval(animInterval);
      animInterval = null;
      document.getElementById("animStartBtn").disabled = false;
      return;
    }

    var step = animSteps[animIdx];
    var cls = "anim-line";
    if (step.type) cls += " " + step.type;
    el.innerHTML += '<div class="' + cls + '">' + step.text + '</div>';
    el.scrollTop = el.scrollHeight;
    animIdx++;
  }

  document.getElementById("animStartBtn").addEventListener("click", function() {
    if (animInterval) return;
    this.disabled = true;
    animIdx = 0;
    document.getElementById("animTimeline").innerHTML = "";
    animInterval = setInterval(renderAnimStep, 350);
  });

  document.getElementById("animResetBtn").addEventListener("click", function() {
    if (animInterval) {
      clearInterval(animInterval);
      animInterval = null;
    }
    animIdx = 0;
    document.getElementById("animTimeline").innerHTML = '<div class="anim-line" style="color:#555;">Click "Start Animation" to watch the epoll event loop in action...</div>';
    document.getElementById("animStartBtn").disabled = false;
  });
</script>
