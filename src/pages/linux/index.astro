---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "I/O Models", description: "Blocking, non-blocking, epoll, io_uring — how Linux handles concurrent connections", href: "/linux/io-models/", status: "live" },
  { title: "Process Scheduling", description: "CFS, EEVDF, real-time classes, and the O(1) scheduler history", href: "#", status: "coming" },
  { title: "Memory Management", description: "Virtual memory, page tables, TLB, huge pages, and the OOM killer", href: "/linux/memory-management/", status: "live" },
  { title: "Filesystem Internals", description: "VFS layer, ext4, XFS, btrfs — how data reaches the disk", href: "#", status: "coming" },
  { title: "Network Stack", description: "From NIC interrupt to socket buffer — the packet journey", href: "#", status: "coming" },
  { title: "eBPF & Tracing", description: "Programmable kernel hooks for observability and security", href: "#", status: "coming" },
  { title: "Signals & IPC", description: "Signals, pipes, shared memory, Unix domain sockets", href: "#", status: "coming" },
  { title: "Kernel Modules", description: "Loading, unloading, and writing kernel modules", href: "#", status: "coming" },
];
---

<BaseLayout 
  title="Linux Kernel Internals" 
  description="Interactive visualizations for understanding Linux kernel subsystems — I/O, scheduling, memory, networking, and more"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Linux", href: "/linux/" }]}
>
  <section class="section-header">
    <h1>🐧 Linux Kernel Internals</h1>
    <p>
      The Linux kernel is the foundation of modern infrastructure — from phones to supercomputers.
      These interactive visualizations help you understand the subsystems that make it all work.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(0, 212, 255, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
