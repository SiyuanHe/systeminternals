<script is:inline>
//===Utility===
functionlog(containerId,msg,cls=''){
constel=document.getElementById(containerId);
constentry=document.createElement('div');
entry.className='log-entry'+cls;
entry.textContent=msg;
el.insertBefore(entry,el.firstChild);
if(el.children.length>30)el.removeChild(el.lastChild);
}

//===BasicsSection===
letbasicOplogs=[0,0,0];

functionupdateBasics(){
for(leti=0;i<3;i++){
document.getElementById(`basicOplog${i}`).textContent=String(basicOplogs[i]);
}
}

functionwriteBasics(count){
for(leti=0;i<count;i++){
basicOplogs[0]++;
//Secondariesreplicatewithslightdelaysimulation
setTimeout(()=>{basicOplogs[1]++;updateBasics();},100*(i+1));
setTimeout(()=>{basicOplogs[2]++;updateBasics();},200*(i+1));
}
updateBasics();
log('basicsLog',`Primaryaccepted${count}write(s).Secondariesreplicatingviaoplog...`,'good');
}

document.getElementById('writeDocBtn')?.addEventListener('click',()=>writeBasics(1));
document.getElementById('write10Btn')?.addEventListener('click',()=>writeBasics(10));
document.getElementById('basicsResetBtn')?.addEventListener('click',()=>{
basicOplogs=[0,0,0];
updateBasics();
document.getElementById('basicsLog').innerHTML='<div class="log-entry">Reset.Ready.</div>';
});

//===ElectionProtocol===
leteStep=0;
consteSteps=[
()=>{
//Step1:Primarygoesdown
document.getElementById('eNode0').classList.add('e-down');
document.getElementById('eIcon0').textContent='🔴';
document.getElementById('eRole0').textContent='DOWN';
document.getElementById('eRole0').style.color='#f87171';
document.getElementById('electionStep').textContent='1/5';
log('electionLog','Step1:Primary(mongo-0)becomesunreachable.Heartbeattimeoutdetected.','bad');
},
()=>{
//Step2:Timeoutdetected
document.getElementById('electionStep').textContent='2/5';
log('electionLog','Step2:Secondariesdetectnoheartbeatfor10s(electionTimeoutMillis).Triggeringelection.','warn');
},
()=>{
//Step3:Candidateemerges
document.getElementById('eNode1').classList.add('e-candidate');
document.getElementById('eRole1').textContent='CANDIDATE';
document.getElementById('eRole1').style.color='#fbbf24';
document.getElementById('eIcon1').textContent='🟡';
document.getElementById('electionTerm').textContent='2';
document.getElementById('electionStep').textContent='3/5';
log('electionLog','Step3:mongo-1startselectionforterm2.Requestsvotesfrompeers.','warn');
},
()=>{
//Step4:Votesreceived
document.getElementById('eVote1').textContent='✅self-vote';
document.getElementById('eVote2').textContent='✅votedfor1';
document.getElementById('electionVotes').textContent='2/3';
document.getElementById('electionStep').textContent='4/5';
log('electionLog','Step4:mongo-1receivesvotefrommongo-2.Hasmajority(2/3).','good');
},
()=>{
//Step5:Newprimary
document.getElementById('eNode1').classList.remove('e-candidate');
document.getElementById('eNode1').classList.add('e-elected');
document.getElementById('eRole1').textContent='PRIMARY';
document.getElementById('eRole1').style.color='#4ade80';
document.getElementById('eIcon1').textContent='🟢';
document.getElementById('eRole2').textContent='SECONDARY';
document.getElementById('electionStep').textContent='5/5';
document.getElementById('electionVotes').textContent='✅';
log('electionLog','Step5:mongo-1electedasnewprimaryforterm2.Replicasetoperational.','good');
}
;

document.getElementById('electionStepBtn')?.addEventListener('click',()=>{
if(eStep<eSteps.length){
eSteps[eStep]();
eStep++;
}else{
log('electionLog','Electioncomplete.Resettotryagain.','warn');
}
});

document.getElementById('electionResetBtn')?.addEventListener('click',()=>{
eStep=0;
for(leti=0;i<3;i++){
constnode=document.getElementById(`eNode${i}`);
node.classList.remove('e-down','e-candidate','e-elected');
document.getElementById(`eVote${i}`).textContent='';
}
document.getElementById('eIcon0').textContent='🟢';
document.getElementById('eIcon1').textContent='🔵';
document.getElementById('eIcon2').textContent='🔵';
document.getElementById('eRole0').textContent='PRIMARY';
document.getElementById('eRole0').style.color='#4ade80';
document.getElementById('eRole1').textContent='SECONDARY';
document.getElementById('eRole1').style.color='#4ade80';
document.getElementById('eRole2').textContent='SECONDARY';
document.getElementById('eRole2').style.color='#4ade80';
document.getElementById('electionTerm').textContent='1';
document.getElementById('electionStep').textContent='—';
document.getElementById('electionVotes').textContent='—';
document.getElementById('electionLog').innerHTML='<div class="log-entry">Reset.Readyforelectiondemo.</div>';
});

//===Heartbeats&FailureDetection===
constHB_COUNT=5;
lethbAlive=[true,true,true,true,true];
lethbRoles=['PRIMARY','SECONDARY','SECONDARY','SECONDARY','SECONDARY'];
lethbInterval=null;

functionhbUpdateUI(){
for(leti=0;i<HB_COUNT;i++){
constnode=document.getElementById(`hbNode${i}`);
constroleEl=document.getElementById(`hbRole${i}`);
consticonEl=document.getElementById(`hbIcon${i}`);
conststatusEl=document.getElementById(`hbStatus${i}`);
constkillBtn=document.getElementById(`hbKill${i}`);

node.classList.toggle('hb-down',!hbAlive[i]);
node.classList.toggle('hb-primary',hbAlive[i]&&hbRoles[i]==='PRIMARY');
roleEl.textContent=hbAlive[i]?hbRoles[i]:'DOWN';
roleEl.style.color=!hbAlive[i]?'#f87171':hbRoles[i]==='PRIMARY'?'#4ade80':'#60a5fa';
iconEl.textContent=!hbAlive[i]?'🔴':hbRoles[i]==='PRIMARY'?'🟢':'🔵';
statusEl.textContent=hbAlive[i]?'healthy':'unreachable';
statusEl.classList.toggle('dead',!hbAlive[i]);
killBtn.disabled=!hbAlive[i];
killBtn.textContent=hbAlive[i]?'💀Kill':'☠️Dead';
}
}

functionhbPing(){
constcontainer=document.getElementById('hbHeartbeats');
//Clearoldpings
if(container.children.length>20){
while(container.children.length>10)container.removeChild(container.firstChild);
}
constprimaryIdx=hbRoles.indexOf('PRIMARY');
if(primaryIdx===-1||!hbAlive[primaryIdx])return;

for(leti=0;i<HB_COUNT;i++){
if(i===primaryIdx)continue;
constping=document.createElement('span');
ping.className='hb-ping'+(hbAlive[i]?'':'fail');
ping.textContent=`${primaryIdx}→${i}:${hbAlive[i]?'ok':'timeout'}`;
container.appendChild(ping);
}
}

functionhbElect(){
//Findalivesecondaries
constcandidates=[];
for(leti=0;i<HB_COUNT;i++){
if(hbAlive[i]&&hbRoles[i]==='SECONDARY')candidates.push(i);
}
if(candidates.length===0){
log('hbLog','Nocandidatesavailableforelection!Replicasethasnoprimary.','bad');
return;
}
//Checkmajority:need>total/2alivenodes(includingthenewprimary)
constaliveCount=hbAlive.filter(a=>a).length;
if(aliveCount<=Math.floor(HB_COUNT/2)){
log('hbLog',`Only${aliveCount}/${HB_COUNT}membersalive.Cannotreachmajority.Noprimaryelected.`,'bad');
return;
}
constnewPrimary=candidates[0];
hbRoles=hbRoles.map((r,i)=>i===newPrimary?'PRIMARY':(hbAlive[i]?'SECONDARY':r));
hbUpdateUI();
log('hbLog',`Electioncomplete!mongo-${newPrimary}isthenewPRIMARY.`,'good');
}

for(leti=0;i<HB_COUNT;i++){
document.getElementById(`hbKill${i}`)?.addEventListener('click',()=>{
constwasPrimary=hbRoles[i]==='PRIMARY';
hbAlive[i]=false;
hbRoles[i]=wasPrimary?'DOWN':hbRoles[i];
hbUpdateUI();
log('hbLog',`mongo-${i}killed!${wasPrimary?'Primarylost—triggeringelection...':''}`,'bad');
if(wasPrimary){
setTimeout(()=>{
log('hbLog','Heartbeattimeout(10s)expired.Startingelection...','warn');
setTimeout(()=>hbElect(),800);
},1500);
}
});
}

document.getElementById('hbResetBtn')?.addEventListener('click',()=>{
hbAlive=[true,true,true,true,true];
hbRoles=['PRIMARY','SECONDARY','SECONDARY','SECONDARY','SECONDARY'];
hbUpdateUI();
document.getElementById('hbHeartbeats').innerHTML='';
document.getElementById('hbLog').innerHTML='<div class="log-entry">Clusterreset.All5nodeshealthy.</div>';
});

hbInterval=setInterval(hbPing,2000);
hbUpdateUI();

//===WriteConcern&ReadPreference===
letwcMode='1';
letrpMode='primary';
letwcCrashed=false;

document.querySelectorAll('.wc-btn').forEach(btn=>{
btn.addEventListener('click',()=>{
document.querySelectorAll('.wc-btn').forEach(b=>b.classList.remove('active'));
btn.classList.add('active');
wcMode=(btn).dataset.wc;
});
});

document.querySelectorAll('.rp-btn').forEach(btn=>{
btn.addEventListener('click',()=>{
document.querySelectorAll('.rp-btn').forEach(b=>b.classList.remove('active'));
btn.classList.add('active');
rpMode=(btn).dataset.rp;
});
});

functionwcFlashNode(idx,cls){
constind=document.getElementById(`wcInd${idx}`);
constnode=document.getElementById(`wcNode${idx}`);
ind.className='wc-indicator'+cls;
ind.textContent=cls.includes('write')?'✏️write':'📖read';
node.classList.add('wc-flash');
setTimeout(()=>{node.classList.remove('wc-flash');},600);
setTimeout(()=>{ind.textContent='';ind.className='wc-indicator';},1500);
}

document.getElementById('wcWriteBtn')?.addEventListener('click',()=>{
if(wcCrashed){log('wcLog','Primaryiscrashed!Resetfirst.','bad');return;}
wcFlashNode(0,'wc-write-indicator');
if(wcMode==='0'){
log('wcLog','w:0—Writesent.Noacknowledgment.Fireandforget!','warn');
}elseif(wcMode==='1'){
log('wcLog','w:1—Writeacknowledgedbyprimaryonly.Datacouldbelostifprimarycrashesbeforereplication.','warn');
}else{
setTimeout(()=>wcFlashNode(1,'wc-write-indicator'),300);
log('wcLog','w:majority—Writeacknowledgedbyprimary+1secondary(majorityof3).Durableacrossfailover.','good');
}
});

document.getElementById('wcReadBtn')?.addEventListener('click',()=>{
if(wcCrashed&&rpMode==='primary'){
log('wcLog','Primaryisdown!Readfailedwith"primary"readpreference.','bad');
return;
}
consttargets=[];
switch(rpMode){
case'primary':targets.push(0);break;
case'primaryPreferred':targets.push(wcCrashed?1:0);break;
case'secondary':targets.push(1,2);break;
case'secondaryPreferred':targets.push(1);break;
case'nearest':targets.push(Math.floor(Math.random()*3));break;
}
targets.forEach((t,i)=>{
if(!wcCrashed||t!==0)setTimeout(()=>wcFlashNode(t,'wc-read-indicator'),i*200);
});
log('wcLog',`Readroutedto:${targets.map(t=>'mongo-'+t).join(',')}(readPreference:${rpMode})`,'good');
});

document.getElementById('wcCrashBtn')?.addEventListener('click',()=>{
if(wcCrashed){
//Reset
wcCrashed=false;
document.getElementById('wcNode0').classList.remove('wc-crash');
log('wcLog','Primaryrestored.','good');
return;
}
wcCrashed=true;
document.getElementById('wcNode0').classList.add('wc-crash');
if(wcMode==='1'){
log('wcLog','💥Primarycrashed!Withw:1,thelastwritewasonlyontheprimary—DATALOST!Itwasnotreplicated.','bad');
}elseif(wcMode==='majority'){
log('wcLog','💥Primarycrashed!Withw:majority,thelastwritewasreplicatedtoasecondary—dataissafe.','good');
}else{
log('wcLog','💥Primarycrashed!Withw:0,youhavenoideaifthewriteevenmadeit.Probablylost.','bad');
}
});

//===RollbackScenario===
letrbStep=0;
constrbSteps=[
()=>{
//PrimaryacceptsanewwriteD
document.getElementById('rbOplog0').textContent='oplog:[A,B,C,D]';
document.getElementById('rbOplog0').classList.add('diverged');
document.getElementById('rbStatus').textContent='PrimaryacceptedwriteD(notyetreplicatedtosecondaries)';
document.getElementById('rbStatus').style.color='#fbbf24';
log('rbLog','Step1:PrimaryacceptswriteDwithw:1.Notyetreplicated.','warn');
},
()=>{
//Primarycrashes
document.getElementById('rbNode0').classList.add('rb-down');
document.getElementById('rbIcon0').textContent='🔴';
document.getElementById('rbRole0').textContent='DOWN';
document.getElementById('rbRole0').style.color='#f87171';
document.getElementById('rbStatus').textContent='PrimarycrashedbeforereplicatingwriteD!';
document.getElementById('rbStatus').style.color='#f87171';
log('rbLog','Step2:Primarycrashes!WriteDexistsonlyonmongo-0.','bad');
},
()=>{
//Newprimaryelected
document.getElementById('rbRole1').textContent='PRIMARY';
document.getElementById('rbRole1').style.color='#4ade80';
document.getElementById('rbIcon1').textContent='🟢';
document.getElementById('rbStatus').textContent='mongo-1electedasnewprimary(term2).Oplog:[A,B,C]—noD!';
document.getElementById('rbStatus').style.color='#fbbf24';
log('rbLog','Step3:mongo-1elected.Itsoplogis[A,B,C]—writeDdoesnotexist.','warn');
},
()=>{
//NewprimaryacceptswriteE
document.getElementById('rbOplog1').textContent='oplog:[A,B,C,E]';
document.getElementById('rbOplog1').classList.add('diverged');
document.getElementById('rbOplog2').textContent='oplog:[A,B,C,E]';
document.getElementById('rbStatus').textContent='NewprimaryacceptswriteE.Oplogshavediverged!';
log('rbLog','Step4:NewprimaryacceptswriteE,replicatestomongo-2.Oplogsdivergefromoldprimary.','warn');
},
()=>{
//Oldprimarycomesback
document.getElementById('rbNode0').classList.remove('rb-down');
document.getElementById('rbNode0').classList.add('rb-diverged');
document.getElementById('rbIcon0').textContent='⚠️';
document.getElementById('rbRole0').textContent='RECOVERING';
document.getElementById('rbRole0').style.color='#fbbf24';
document.getElementById('rbStatus').textContent='Oldprimarycomesbackonline.Detectsdivergentoplog!';
document.getElementById('rbStatus').style.color='#fbbf24';
log('rbLog','Step5:mongo-0rejoins.Itsoplog[A,B,C,D]divergesfromcurrentprimary[A,B,C,E].','warn');
},
()=>{
//Rollback
document.getElementById('rbNode0').classList.remove('rb-diverged');
document.getElementById('rbNode0').classList.add('rb-rolled-back');
document.getElementById('rbOplog0').textContent='oplog:[A,B,C,D̶]→[A,B,C,E]';
document.getElementById('rbOplog0').classList.remove('diverged');
document.getElementById('rbOplog0').classList.add('rolled-back');
document.getElementById('rbRole0').textContent='SECONDARY';
