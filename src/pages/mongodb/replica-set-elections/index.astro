//===SpecialMembers===
letspCount=0;

functionaddSpecialMember(type){
spCount++;
constcontainer=document.getElementById('specialExtra');
constdiv=document.createElement('div');
div.className='sp-extrasp-'+type;
if(type==='arbiter'){
div.innerHTML=`
<div style="font-size:0.65rem;font-weight:700;color:#fbbf24;letter-spacing:1px;margin-bottom:4px;">ARBITER</div>
<div style="font-size:1.3rem;margin-bottom:4px;">⚖️</div>
<div style="font-size:0.8rem;color:#ccc;margin-bottom:4px;">arbiter-${spCount}</div>
<div style="font-size:0.7rem;color:#666;">votes:1|data:❌</div>
`;
}elseif(type==='hidden'){
div.innerHTML=`
<div style="font-size:0.65rem;font-weight:700;color:#a78bfa;letter-spacing:1px;margin-bottom:4px;">HIDDEN</div>
<div style="font-size:1.3rem;margin-bottom:4px;">👻</div>
<div style="font-size:0.8rem;color:#ccc;margin-bottom:4px;">hidden-${spCount}</div>
<div style="font-size:0.7rem;color:#666;">votes:0|data:✅|priority:0</div>
`;
}else{
div.innerHTML=`
<div style="font-size:0.65rem;font-weight:700;color:#22d3ee;letter-spacing:1px;margin-bottom:4px;">DELAYED</div>
<div style="font-size:1.3rem;margin-bottom:4px;">⏱️</div>
<div style="font-size:0.8rem;color:#ccc;margin-bottom:4px;">delayed-${spCount}</div>
<div style="font-size:0.7rem;color:#666;">votes:0|data:✅(1hbehind)|priority:0</div>
`;
}
container.appendChild(div);
}

document.getElementById('addArbiterBtn')?.addEventListener('click',()=>addSpecialMember('arbiter'));
document.getElementById('addHiddenBtn')?.addEventListener('click',()=>addSpecialMember('hidden'));
document.getElementById('addDelayedBtn')?.addEventListener('click',()=>addSpecialMember('delayed'));
document.getElementById('spResetBtn')?.addEventListener('click',()=>{
spCount=0;
document.getElementById('specialExtra').innerHTML='';
});
</script>
