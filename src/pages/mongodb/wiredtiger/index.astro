<script is:inline>
  // === Utility ===
  function addLog(logId, msg, cls) {
    var el = document.getElementById(logId);
    if (!el) return;
    var entry = document.createElement('div');
    entry.className = 'log-entry ' + (cls || '');
    entry.textContent = msg;
    el.insertBefore(entry, el.firstChild);
    if (el.children.length > 30 && el.lastChild) el.removeChild(el.lastChild);
  }

  // === B-Tree vs LSM-Tree ===
  (function() {
    var btreeData = [];
    var lsmMemtable = [];
    var lsmLevels = [[], []];
    var btreeWrites = 0;
    var btreeReads = 0;
    var lsmWrites = 0;
    var lsmReads = 0;
    var nextKey = 1;

    function renderBTree() {
      var canvas = document.getElementById('btreeCanvas');
      if (!canvas) return;
      if (btreeData.length === 0) {
        canvas.innerHTML = '<div style="color:#555;text-align:center;padding:20px;">Empty B-Tree. Insert keys to build.</div>';
        return;
      }
      var sorted = btreeData.slice().sort(function(a, b) { return a - b; });
      var pageSize = 4;
      var leaves = [];
      for (var i = 0; i < sorted.length; i += pageSize) {
        leaves.push(sorted.slice(i, i + pageSize));
      }
      var html = '<div style="text-align:center;margin-bottom:8px;color:#ef4444;font-weight:600;">Root: [';
      var rootKeys = [];
      for (var j = 1; j < leaves.length; j++) {
        rootKeys.push(leaves[j][0]);
      }
      html += rootKeys.join(', ') + ']</div>';
      html += '<div style="display:flex;gap:6px;justify-content:center;flex-wrap:wrap;">';
      for (var k = 0; k < leaves.length; k++) {
        html += '<div style="background:rgba(34,197,94,0.15);border:1px solid rgba(34,197,94,0.3);border-radius:6px;padding:6px 8px;font-size:0.7rem;">';
        html += '🍃 [' + leaves[k].join(', ') + ']</div>';
      }
      html += '</div>';
      canvas.innerHTML = html;
    }

    function renderLSM() {
      var canvas = document.getElementById('lsmCanvas');
      if (!canvas) return;
      var html = '';
      html += '<div style="margin-bottom:6px;"><span style="color:#a78bfa;font-weight:600;">Memtable: </span>';
      if (lsmMemtable.length === 0) {
        html += '<span style="color:#555;">empty</span>';
      } else {
        html += '[' + lsmMemtable.join(', ') + ']';
      }
      html += '</div>';
      for (var i = 0; i < lsmLevels.length; i++) {
        html += '<div style="margin-bottom:4px;"><span style="color:#60a5fa;">L' + i + ': </span>';
        if (lsmLevels[i].length === 0) {
          html += '<span style="color:#555;">empty</span>';
        } else {
          html += '[' + lsmLevels[i].join(', ') + ']';
        }
        html += '</div>';
      }
      canvas.innerHTML = html;
    }

    function updateTreeStats() {
      var el;
      el = document.getElementById('btreeWrites'); if (el) el.textContent = btreeWrites;
      el = document.getElementById('btreeReads'); if (el) el.textContent = btreeReads;
      el = document.getElementById('lsmWrites'); if (el) el.textContent = lsmWrites;
      el = document.getElementById('lsmReads'); if (el) el.textContent = lsmReads;
    }

    function treeWrite() {
      var key = nextKey++;
      // B-Tree: in-place insert
      btreeData.push(key);
      btreeWrites++;
      // LSM: append to memtable, flush when full
      lsmMemtable.push(key);
      lsmWrites++;
      if (lsmMemtable.length >= 5) {
        var flushed = lsmMemtable.slice().sort(function(a, b) { return a - b; });
        lsmLevels[0] = lsmLevels[0].concat(flushed).sort(function(a, b) { return a - b; });
        lsmMemtable = [];
        addLog('treeLog', 'LSM: Memtable full → flushed to L0', 'warn');
        if (lsmLevels[0].length >= 15) {
          lsmLevels[1] = lsmLevels[1].concat(lsmLevels[0]).sort(function(a, b) { return a - b; });
          lsmLevels[0] = [];
          addLog('treeLog', 'LSM: L0 compaction → merged into L1', 'warn');
        }
      }
      addLog('treeLog', 'Wrote key ' + key + ' — B-Tree: in-place insert, LSM: append to memtable', 'good');
      renderBTree();
      renderLSM();
      updateTreeStats();
    }

    function treeRead() {
      if (btreeData.length === 0) {
        addLog('treeLog', 'No data to read. Write some keys first.', 'bad');
        return;
      }
      var key = btreeData[Math.floor(Math.random() * btreeData.length)];
      btreeReads++;
      lsmReads++;
      var lsmChecked = 0;
      if (lsmMemtable.indexOf(key) >= 0) lsmChecked = 1;
      else {
        lsmChecked = 1;
        for (var i = 0; i < lsmLevels.length; i++) {
          lsmChecked++;
          if (lsmLevels[i].indexOf(key) >= 0) break;
        }
      }
      addLog('treeLog', 'Read key ' + key + ' — B-Tree: 1 lookup (O(log n)), LSM: checked ' + lsmChecked + ' level(s)', 'good');
      updateTreeStats();
    }

    document.getElementById('treeWriteBtn').addEventListener('click', treeWrite);
    document.getElementById('treeReadBtn').addEventListener('click', treeRead);
    document.getElementById('treeBurstBtn').addEventListener('click', function() {
      for (var i = 0; i < 10; i++) treeWrite();
    });
    document.getElementById('treeResetBtn').addEventListener('click', function() {
      btreeData = []; lsmMemtable = []; lsmLevels = [[], []];
      btreeWrites = 0; btreeReads = 0; lsmWrites = 0; lsmReads = 0; nextKey = 1;
      renderBTree(); renderLSM(); updateTreeStats();
      document.getElementById('treeLog').innerHTML = '<div class="log-entry">Reset. Ready.</div>';
    });

    renderBTree();
    renderLSM();
  })();

  // === Page Structure Inspector ===
  (function() {
    var pageData = {
      root: { type: 'Internal (Root)', size: '4KB', keys: ['F', 'N'], children: 3, depth: 0, desc: 'Routes queries to child internal pages based on key ranges.' },
      'int-left': { type: 'Internal', size: '4KB', keys: ['C'], children: 2, depth: 1, desc: 'Routes to leaf pages for keys < F.' },
      'int-mid': { type: 'Internal', size: '4KB', keys: ['J'], children: 2, depth: 1, desc: 'Routes to leaf pages for keys [F, N).' },
      'int-right': { type: 'Internal', size: '4KB', keys: ['R'], children: 2, depth: 1, desc: 'Routes to leaf pages for keys >= N.' },
      'leaf-0': { type: 'Leaf', size: '32KB', docs: ['A', 'B'], depth: 2, desc: 'Stores documents with keys < C. Each doc is a BSON blob with MVCC versions.' },
      'leaf-1': { type: 'Leaf', size: '32KB', docs: ['C', 'D', 'E'], depth: 2, desc: 'Stores documents with keys [C, F). Modified pages are marked dirty.' },
      'leaf-2': { type: 'Leaf', size: '32KB', docs: ['F', 'G', 'H'], depth: 2, desc: 'Stores documents with keys [F, J). In WiredTiger cache when accessed.' },
      'leaf-3': { type: 'Leaf', size: '32KB', docs: ['J', 'K', 'L', 'M'], depth: 2, desc: 'Stores documents with keys [J, N). May have overflow pages for large docs.' },
      'leaf-4': { type: 'Leaf', size: '32KB', docs: ['N', 'O', 'P', 'Q'], depth: 2, desc: 'Stores documents with keys [N, R). Block-compressed on disk.' },
      'leaf-5': { type: 'Leaf', size: '32KB', docs: ['R', 'S', 'T', 'U'], depth: 2, desc: 'Stores documents with keys >= R. Last leaf in this B-Tree.' }
    };

    document.querySelectorAll('.page-node').forEach(function(node) {
      node.addEventListener('click', function() {
        document.querySelectorAll('.page-node').forEach(function(n) { n.classList.remove('highlighted'); });
        node.classList.add('highlighted');
        var id = node.getAttribute('data-page');
        var data = pageData[id];
        if (!data) return;
        var body = document.getElementById('inspectorBody');
        var html = '';
        html += '<div class="inspector-field"><span class="inspector-field-label">Type</span><span class="inspector-field-value">' + data.type + '</span></div>';
        html += '<div class="inspector-field"><span class="inspector-field-label">Page Size</span><span class="inspector-field-value">' + data.size + '</span></div>';
        html += '<div class="inspector-field"><span class="inspector-field-label">Depth</span><span class="inspector-field-value">' + data.depth + '</span></div>';
        if (data.keys) {
          html += '<div class="inspector-field"><span class="inspector-field-label">Separator Keys</span><span class="inspector-field-value">[' + data.keys.join(', ') + ']</span></div>';
          html += '<div class="inspector-field"><span class="inspector-field-label">Children</span><span class="inspector-field-value">' + data.children + ' pages</span></div>';
        }
        if (data.docs) {
          html += '<div class="inspector-field"><span class="inspector-field-label">Documents</span><span class="inspector-field-value">[' + data.docs.join(', ') + ']</span></div>';
          html += '<div class="inspector-field"><span class="inspector-field-label">Doc Count</span><span class="inspector-field-value">' + data.docs.length + '</span></div>';
        }
        html += '<div class="inspector-field" style="margin-top:10px;"><span class="inspector-field-label">Description</span><span class="inspector-field-value" style="font-family:inherit;color:#aaa;font-size:0.8rem;">' + data.desc + '</span></div>';
        body.innerHTML = html;
      });
    });
  })();

  // === MVCC & Snapshots ===
  (function() {
    var currentTs = 1;
    var versions = [{ ts: 1, data: '{ name: "Alice", age: 30 }' }];
    var snapshots = [];
    var fields = [
      ['name: "Alice"', 'name: "Bob"', 'name: "Charlie"', 'name: "Diana"'],
      ['age: 30', 'age: 25', 'age: 35', 'age: 42'],
      ['city: "NYC"', 'city: "SF"', 'city: "London"', 'city: "Tokyo"']
    ];

    function renderMVCC() {
      var container = document.getElementById('mvccVersions');
      var html = '';
      for (var i = versions.length - 1; i >= 0; i--) {
        var v = versions[i];
        var isCurrent = (i === versions.length - 1);
        html += '<div class="mvcc-version ' + (isCurrent ? 'current-version' : 'old-version') + '">';
        html += '<div class="version-ts">ts: ' + v.ts + '</div>';
        html += '<div class="version-data">' + v.data + '</div>';
        if (isCurrent) html += '<div class="version-badge">current</div>';
        html += '</div>';
      }
      container.innerHTML = html;
    }

    function renderSnapshots() {
      var list = document.getElementById('snapshotList');
      if (snapshots.length === 0) {
        list.innerHTML = '<div class="snapshot-empty">No active snapshots.</div>';
        return;
      }
      var html = '';
      for (var i = snapshots.length - 1; i >= 0; i--) {
        var s = snapshots[i];
        html += '<div class="snapshot-item">';
        html += '<div class="snap-ts">Snapshot @ ts ' + s.ts + '</div>';
        html += '<div class="snap-sees">Sees: ' + s.sees + '</div>';
        html += '</div>';
      }
      list.innerHTML = html;
    }

    document.getElementById('mvccWriteBtn').addEventListener('click', function() {
      currentTs++;
      var fIdx = Math.floor(Math.random() * fields.length);
      var vIdx = Math.floor(Math.random() * fields[fIdx].length);
      var newData = '{ ' + fields[fIdx][vIdx] + ' }';
      versions.push({ ts: currentTs, data: newData });
      if (versions.length > 6) versions.shift();
      addLog('mvccLog', 'Txn ts:' + currentTs + ' wrote new version: ' + newData, 'good');
      renderMVCC();
    });

    document.getElementById('mvccReadBtn').addEventListener('click', function() {
      var snapTs = currentTs;
      var visible = null;
      for (var i = versions.length - 1; i >= 0; i--) {
        if (versions[i].ts <= snapTs) { visible = versions[i]; break; }
      }
      if (visible) {
        snapshots.push({ ts: snapTs, sees: visible.data });
        if (snapshots.length > 5) snapshots.shift();
        addLog('mvccLog', 'Snapshot read @ ts:' + snapTs + ' → sees version ts:' + visible.ts, 'good');
      }
      renderSnapshots();
    });

    document.getElementById('mvccConcurrentBtn').addEventListener('click', function() {
      // Take snapshot first, then write — snapshot shouldn't see the new write
      var snapTs = currentTs;
      currentTs++;
      var newData = '{ status: "updated-concurrent" }';
      versions.push({ ts: currentTs, data: newData });
      if (versions.length > 6) versions.shift();

      var visible = null;
      for (var i = versions.length - 1; i >= 0; i--) {
        if (versions[i].ts <= snapTs) { visible = versions[i]; break; }
      }
      if (visible) {
        snapshots.push({ ts: snapTs, sees: visible.data });
        if (snapshots.length > 5) snapshots.shift();
      }
      addLog('mvccLog', 'Concurrent: write ts:' + currentTs + ' + snapshot @ ts:' + snapTs + ' (does NOT see the new write!)', 'warn');
      renderMVCC();
      renderSnapshots();
    });

    document.getElementById('mvccResetBtn').addEventListener('click', function() {
      currentTs = 1;
      versions = [{ ts: 1, data: '{ name: "Alice", age: 30 }' }];
      snapshots = [];
      renderMVCC(); renderSnapshots();
      document.getElementById('mvccLog').innerHTML = '<div class="log-entry">Reset. Ready.</div>';
    });
  })();

  // === Checkpointing ===
  (function() {
    var pages = ['A', 'B', 'C', 'D'];
    var dirty = [false, false, false, false];
    var checkpoints = 0;
    var journalEntries = 0;

    function renderCP() {
      var container = document.getElementById('cpPages');
      var html = '';
      for (var i = 0; i < pages.length; i++) {
        var cls = dirty[i] ? 'dirty' : 'clean';
        var status = dirty[i] ? 'dirty' : 'clean';
        html += '<div class="cp-page ' + cls + '">Page ' + pages[i] + ' <span class="cp-status">' + status + '</span></div>';
      }
      container.innerHTML = html;
      var dirtyCount = dirty.filter(function(d) { return d; }).length;
      var el;
      el = document.getElementById('cpDirtyCount'); if (el) el.textContent = dirtyCount;
      el = document.getElementById('cpCount'); if (el) el.textContent = checkpoints;
      el = document.getElementById('cpJournalCount'); if (el) el.textContent = journalEntries;
    }

    document.getElementById('cpWriteBtn').addEventListener('click', function() {
      var idx = Math.floor(Math.random() * pages.length);
      dirty[idx] = true;
      journalEntries++;
      addLog('cpLog', 'Write to Page ' + pages[idx] + ' → marked dirty, journal entry #' + journalEntries, 'warn');
      renderCP();
    });

    document.getElementById('cpCheckpointBtn').addEventListener('click', function() {
      var dirtyCount = dirty.filter(function(d) { return d; }).length;
      if (dirtyCount === 0) {
        addLog('cpLog', 'No dirty pages — checkpoint skipped.', 'warn');
        return;
      }
      checkpoints++;
      var dirtyPages = [];
      for (var i = 0; i < pages.length; i++) {
        if (dirty[i]) dirtyPages.push(pages[i]);
        dirty[i] = false;
      }
      var disk = document.getElementById('cpDisk');
      var item = document.createElement('div');
      item.className = 'cp-disk-item';
      item.textContent = 'Checkpoint #' + checkpoints + ' — flushed pages: ' + dirtyPages.join(', ');
      disk.appendChild(item);
      addLog('cpLog', 'Checkpoint #' + checkpoints + ': flushed ' + dirtyCount + ' dirty page(s) to disk, new root created.', 'good');
      renderCP();
    });

    document.getElementById('cpCrashBtn').addEventListener('click', function() {
      var dirtyCount = dirty.filter(function(d) { return d; }).length;
      if (dirtyCount > 0) {
        addLog('cpLog', '💥 CRASH! ' + dirtyCount + ' dirty page(s) lost from cache. Replaying ' + journalEntries + ' journal entries from checkpoint #' + checkpoints + '...', 'bad');
        // Simulate recovery
        for (var i = 0; i < pages.length; i++) dirty[i] = false;
        setTimeout(function() {
          addLog('cpLog', '✅ Recovery complete. All data restored from journal replay.', 'good');
        }, 500);
      } else {
        addLog('cpLog', '💥 CRASH! No dirty pages — no data loss. Clean restart from checkpoint #' + checkpoints + '.', 'warn');
      }
      renderCP();
    });

    document.getElementById('cpResetBtn').addEventListener('click', function() {
      dirty = [false, false, false, false];
      checkpoints = 0; journalEntries = 0;
      document.getElementById('cpDisk').innerHTML = '<div class="cp-disk-item">Checkpoint #0 (initial) — all clean</div>';
      document.getElementById('cpLog').innerHTML = '<div class="log-entry">Reset. Ready.</div>';
      renderCP();
    });

    renderCP();
  })();

  // === Cache & Eviction ===
  (function() {
    var maxSlots = 16;
    var evictionTarget = 0.8;
    var cache = []; // array of { id, dirty }
    var nextPageId = 1;
    var evictionCount = 0;

    function renderCache() {
      var slotsEl = document.getElementById('cacheSlots');
      var html = '';
      for (var i = 0; i < maxSlots; i++) {
        if (i < cache.length) {
          var item = cache[i];
          var cls = item.dirty ? 'dirty' : 'clean';
          html += '<div class="cache-slot ' + cls + '">P' + item.id + '</div>';
        } else {
          html += '<div class="cache-slot empty">—</div>';
        }
      }
      slotsEl.innerHTML = html;

      var pct = Math.round((cache.length / maxSlots) * 100);
      var fillEl = document.getElementById('cacheFill');
      fillEl.style.width = pct + '%';
      fillEl.classList.remove('warning', 'critical');
      if (pct >= 90) fillEl.classList.add('critical');
      else if (pct >= 70) fillEl.classList.add('warning');

      document.getElementById('cacheUsed').textContent = cache.length;
      document.getElementById('cachePct').textContent = pct + '%';
    }

    function evictIfNeeded() {
      var threshold = Math.floor(maxSlots * evictionTarget);
      if (cache.length <= threshold) return;

      // Evict clean pages first
      var evicted = false;
      for (var i = 0; i < cache.length; i++) {
        if (!cache[i].dirty) {
          var removed = cache.splice(i, 1)[0];
          evictionCount++;
          addLog('cacheLog', 'Evicted clean page P' + removed.id + ' (eviction #' + evictionCount + ')', 'warn');
          evicted = true;
          break;
        }
      }
      if (!evicted && cache.length > threshold) {
        // Evict dirty page (must flush first)
        var removed = cache.shift();
        evictionCount++;
        addLog('cacheLog', 'Evicted DIRTY page P' + removed.id + ' (flushed to disk first, eviction #' + evictionCount + ')', 'bad');
      }
    }

    document.getElementById('cacheLoadBtn').addEventListener('click', function() {
      if (cache.length >= maxSlots) {
        evictIfNeeded();
      }
      var id = nextPageId++;
      cache.push({ id: id, dirty: false });
      addLog('cacheLog', 'Loaded clean page P' + id + ' into cache', 'good');
      evictIfNeeded();
      renderCache();
    });

    document.getElementById('cacheBurstBtn').addEventListener('click', function() {
      for (var b = 0; b < 5; b++) {
        if (cache.length >= maxSlots) evictIfNeeded();
        var id = nextPageId++;
        cache.push({ id: id, dirty: false });
      }
      addLog('cacheLog', 'Burst loaded 5 pages into cache', 'good');
      evictIfNeeded();
      renderCache();
    });

    document.getElementById('cacheDirtyBtn').addEventListener('click', function() {
      if (cache.length === 0) {
        addLog('cacheLog', 'No pages in cache to dirty. Load some first.', 'bad');
        return;
      }
      var idx = Math.floor(Math.random() * cache.length);
      cache[idx].dirty = true;
      addLog('cacheLog', 'Dirtied page P' + cache[idx].id + ' (modified in cache)', 'warn');
      renderCache();
    });

    document.getElementById('cacheResetBtn').addEventListener('click', function() {
      cache = []; nextPageId = 1; evictionCount = 0;
      document.getElementById('cacheLog').innerHTML = '<div class="log-entry">Reset. Ready.</div>';
      renderCache();
    });

    renderCache();
  })();

  // === Compression Toggle ===
  (function() {
    var profiles = {
      json: { orig: 48, snappy: 28, zlib: 17, zstd: 14, snappyCpu: '0.3ms', zlibCpu: '2.1ms', zstdCpu: '0.5ms' },
      binary: { orig: 48, snappy: 44, zlib: 42, zstd: 41, snappyCpu: '0.2ms', zlibCpu: '1.8ms', zstdCpu: '0.4ms' },
      text: { orig: 48, snappy: 22, zlib: 11, zstd: 9, snappyCpu: '0.4ms', zlibCpu: '2.5ms', zstdCpu: '0.6ms' }
    };

    function updateComp(type) {
      var p = profiles[type];
      var rows = document.querySelectorAll('.comp-row');
      var data = [
        { size: p.orig, cpu: '0ms' },
        { size: p.snappy, cpu: p.snappyCpu },
        { size: p.zlib, cpu: p.zlibCpu },
        { size: p.zstd, cpu: p.zstdCpu }
      ];
      for (var i = 0; i < rows.length; i++) {
        var fill = rows[i].querySelector('.comp-fill');
        var ratio = rows[i].querySelector('.comp-ratio');
        var cpu = rows[i].querySelector('.comp-cpu');
        var pct = (data[i].size / p.orig) * 100;
        fill.style.width = pct + '%';
        fill.textContent = data[i].size + ' KB';
        ratio.textContent = (p.orig / data[i].size).toFixed(1) + 'x';
        cpu.textContent = (data[i].cpu === '0ms' ? '⚡' : (parseFloat(data[i].cpu) > 1 ? '🐢' : '⚡')) + ' ' + data[i].cpu + ' CPU';
      }
    }

    document.querySelectorAll('[data-comp]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('[data-comp]').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        updateComp(btn.getAttribute('data-comp'));
      });
    });
  })();

  // === Journal (WAL) ===
  (function() {
    var bufferCount = 0;
    var syncedCount = 0;
    var cpCount = 0;
    var totalWrites = 0;

    function renderWAL() {
      document.getElementById('walPending').textContent = totalWrites + ' writes';
      document.getElementById('walBufferCount').textContent = bufferCount + ' entries';
      document.getElementById('walDiskCount').textContent = syncedCount + ' synced';
      document.getElementById('walCpCount').textContent = cpCount + ' checkpoints';

      var entries = document.getElementById('walBufferEntries');
      var html = '';
      for (var i = 0; i < Math.min(bufferCount, 20); i++) {
        html += '<div class="wal-entry"></div>';
      }
      entries.innerHTML = html;
    }

    function flashStage(id) {
      var el = document.getElementById(id);
      if (!el) return;
      el.classList.add('flash');
      setTimeout(function() { el.classList.remove('flash'); }, 400);
    }

    document.getElementById('walWriteBtn').addEventListener('click', function() {
      totalWrites++;
      bufferCount++;
      flashStage('walBuffer');
      addLog('walLog', 'Write #' + totalWrites + ' → journal buffer (not yet synced, j:false)', 'warn');
      renderWAL();
    });

    document.getElementById('walWriteSyncBtn').addEventListener('click', function() {
      totalWrites++;
      bufferCount++;
      // Immediate sync
      syncedCount += bufferCount;
      bufferCount = 0;
      flashStage('walBuffer');
      setTimeout(function() { flashStage('walDisk'); }, 200);
      addLog('walLog', 'Write #' + totalWrites + ' → journal buffer → immediately synced to disk (j:true)', 'good');
      renderWAL();
    });

    document.getElementById('walSyncBtn').addEventListener('click', function() {
      if (bufferCount === 0) {
        addLog('walLog', 'Nothing in buffer to sync.', 'warn');
        return;
      }
      var count = bufferCount;
      syncedCount += bufferCount;
      bufferCount = 0;
      flashStage('walDisk');
      addLog('walLog', '50ms sync: flushed ' + count + ' journal entries to disk', 'good');

      // Auto checkpoint if enough synced
      if (syncedCount >= 10 && (syncedCount - (syncedCount % 10)) > (cpCount * 10)) {
        cpCount++;
        flashStage('walCheckpoint');
        addLog('walLog', 'Auto checkpoint #' + cpCount + ' triggered (journal threshold)', 'good');
      }
      renderWAL();
    });

    document.getElementById('walResetBtn').addEventListener('click', function() {
      bufferCount = 0; syncedCount = 0; cpCount = 0; totalWrites = 0;
      document.getElementById('walLog').innerHTML = '<div class="log-entry">Reset. Ready.</div>';
      renderWAL();
    });

    renderWAL();
  })();
</script>
