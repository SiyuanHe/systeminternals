---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="CockroachDB Distributed SQL Architecture" 
  description="Interactive visualization of CockroachDB's layered architecture — SQL, Distribution, Replication, and Storage"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "CockroachDB", href: "/cockroachdb/" },
    { label: "Architecture", href: "/cockroachdb/architecture/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🏗️ Distributed SQL Architecture</h1>
      <p class="subtitle">How CockroachDB routes a query through four layers across a cluster</p>
    </header>

    <!-- Overview -->
    <section class="overview-section">
      <div class="overview-card">
        <p>
          CockroachDB is a <strong>distributed SQL database</strong> where every node is symmetric — 
          any node can serve any query. Data is divided into <em>ranges</em> (512MB sorted key chunks), 
          each replicated via <strong>Raft consensus</strong>. The <em>leaseholder</em> of each range 
          serves reads without consensus (fast!), while writes go through Raft. This creates a system 
          that survives node, rack, and even region failures — all while speaking PostgreSQL wire protocol.
        </p>
      </div>
    </section>

    <!-- Layer Stack -->
    <section class="layer-section">
      <h2>📐 The Four Layers</h2>
      <p class="section-desc">Click each layer to explore how it works</p>

      <div class="layer-stack">
        <div class="layer-card active" data-layer="sql">
          <div class="layer-num">1</div>
          <div class="layer-info">
            <h3>SQL Layer</h3>
            <p>Parse, plan, optimize, execute</p>
          </div>
          <div class="layer-icon">🧠</div>
        </div>
        <div class="layer-arrow">▼</div>
        <div class="layer-card" data-layer="distribution">
          <div class="layer-num">2</div>
          <div class="layer-info">
            <h3>Distribution Layer</h3>
            <p>Route KV ops to the right ranges</p>
          </div>
          <div class="layer-icon">🗺️</div>
        </div>
        <div class="layer-arrow">▼</div>
        <div class="layer-card" data-layer="replication">
          <div class="layer-num">3</div>
          <div class="layer-info">
            <h3>Replication Layer</h3>
            <p>Raft consensus &amp; lease management</p>
          </div>
          <div class="layer-icon">🔄</div>
        </div>
        <div class="layer-arrow">▼</div>
        <div class="layer-card" data-layer="storage">
          <div class="layer-num">4</div>
          <div class="layer-info">
            <h3>Storage Layer</h3>
            <p>Pebble LSM-tree (MVCC on disk)</p>
          </div>
          <div class="layer-icon">💾</div>
        </div>
      </div>

      <div class="layer-detail" id="layerDetail">
        <div class="layer-detail-content" id="layerDetailContent">
          <!-- Filled by JS -->
        </div>
      </div>
    </section>

    <!-- Interactive Cluster -->
    <section class="cluster-section">
      <h2>🖥️ Interactive Cluster</h2>
      <p class="section-desc">A 5-node CockroachDB cluster with ranges replicated 3 ways</p>

      <div class="cluster-controls">
        <button id="sendQueryBtn" class="action-btn primary-btn">📡 Send SQL Query</button>
        <button id="splitRangeBtn" class="action-btn split-btn">✂️ Split Range</button>
        <button id="transferLeaseBtn" class="action-btn lease-btn">🔄 Transfer Lease</button>
        <button id="killNodeBtn" class="action-btn kill-btn">💀 Kill Node</button>
        <button id="clusterResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="cluster-status" id="clusterStatus">
        <span class="status-badge idle">Ready</span>
        <span class="status-text" id="clusterStatusText">5 nodes online · 3 ranges · RF=3</span>
      </div>

      <div class="cluster-viz" id="clusterViz">
        <!-- Rendered by JS -->
      </div>

      <div class="cluster-log" id="clusterLog">
        <div class="log-entry info">Cluster initialized with 3 ranges across 5 nodes</div>
      </div>
    </section>

    <!-- Ranges Deep Dive -->
    <section class="range-section">
      <h2>📦 Ranges: The Unit of Data</h2>
      <p class="section-desc">CockroachDB splits the sorted key space into ~512MB ranges</p>

      <div class="range-viz">
        <div class="keyspace-bar">
          <div class="keyspace-label">Sorted Key Space (entire database)</div>
          <div class="keyspace-ranges" id="keyspaceRanges">
            <!-- Rendered by JS -->
          </div>
        </div>

        <div class="range-details" id="rangeDetails">
          <div class="range-detail-card">
            <h4>Each Range Contains</h4>
            <ul>
              <li><strong>Data:</strong> ~512MB of sorted key-value pairs</li>
              <li><strong>Replicas:</strong> 3 copies on different nodes (configurable)</li>
              <li><strong>Leaseholder:</strong> 1 replica serves reads (no consensus!)</li>
              <li><strong>Raft group:</strong> All replicas form a Raft consensus group</li>
            </ul>
          </div>
          <div class="range-detail-card highlight-card">
            <h4>💡 Range Lease vs Raft Leader</h4>
            <p>
              The <strong>leaseholder</strong> is usually the Raft leader, but they're separate concepts.
              The lease is a <em>time-based</em> grant — the leaseholder can serve reads without 
              talking to other replicas. This is CockroachDB's key performance trick: 
              <strong>reads don't need consensus</strong>.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Query Flow Animation -->
    <section class="query-section">
      <h2>🔍 Query Flow: SELECT → Result</h2>
      <p class="section-desc">Watch a query flow through all four layers</p>

      <div class="query-controls">
        <div class="query-input">
          <code>SELECT balance FROM accounts WHERE id = 42</code>
        </div>
        <button id="runQueryBtn" class="action-btn primary-btn">▶ Trace Query</button>
        <button id="queryStepBtn" class="action-btn step-btn" disabled>⏭ Next Step</button>
        <button id="queryResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="query-flow-viz">
        <div class="query-steps" id="querySteps">
          <!-- Rendered by JS -->
        </div>
      </div>
    </section>

    <!-- Distributed Transactions -->
    <section class="txn-section">
      <h2>🔐 Distributed Transactions</h2>
      <p class="section-desc">CockroachDB uses parallel commits and write pipelining for speed</p>

      <div class="txn-controls">
        <button id="runTxnBtn" class="action-btn primary-btn">▶ Run Transaction</button>
        <button id="txnResetBtn" class="action-btn reset-btn">🔄 Reset</button>
        <div class="txn-toggles">
          <label><input type="checkbox" id="pipelineToggle" checked> Write Pipelining</label>
          <label><input type="checkbox" id="parallelToggle" checked> Parallel Commits</label>
        </div>
      </div>

      <div class="txn-timeline" id="txnTimeline">
        <!-- Filled by JS -->
      </div>

      <div class="txn-explain-grid">
        <div class="explain-card">
          <h3>⚡ Write Pipelining</h3>
          <p>
            Don't wait for Raft consensus on each write — <strong>pipeline them</strong>. 
            Send the next write before the previous one is replicated. As long as all writes 
            succeed before commit, the transaction is valid. Cuts multi-write latency dramatically.
          </p>
        </div>
        <div class="explain-card">
          <h3>🚀 Parallel Commits</h3>
          <p>
            Instead of a separate commit phase, CockroachDB writes the <strong>transaction record</strong> 
            in parallel with the final batch of writes. The transaction is implicitly committed 
            when all writes succeed — saving <strong>one full round trip</strong>.
          </p>
        </div>
      </div>
    </section>

    <!-- Follower Reads -->
    <section class="follower-section">
      <h2>📖 Follower Reads</h2>
      <p class="section-desc">Read from any replica at a historical timestamp — no lease required</p>

      <div class="follower-viz">
        <div class="follower-diagram">
          <div class="follower-node leaseholder-node">
            <div class="node-label">Node 1 (Leaseholder)</div>
            <div class="node-data">
              <div class="data-row">ts=100: balance=$500</div>
              <div class="data-row">ts=90: balance=$300</div>
              <div class="data-row dim">ts=80: balance=$100</div>
            </div>
          </div>
          <div class="follower-node follower-node-style">
            <div class="node-label">Node 2 (Follower)</div>
            <div class="node-data">
              <div class="data-row">ts=100: balance=$500</div>
              <div class="data-row highlight-row">ts=90: balance=$300 ← read here</div>
              <div class="data-row dim">ts=80: balance=$100</div>
            </div>
          </div>
          <div class="follower-node follower-node-style">
            <div class="node-label">Node 3 (Follower)</div>
            <div class="node-data">
              <div class="data-row">ts=100: balance=$500</div>
              <div class="data-row">ts=90: balance=$300</div>
              <div class="data-row dim">ts=80: balance=$100</div>
            </div>
          </div>
        </div>
        <div class="follower-explain">
          <p>
            With <code>AS OF SYSTEM TIME '-5s'</code>, CockroachDB can serve reads from 
            <strong>any replica</strong> — not just the leaseholder. The closed timestamp 
            mechanism guarantees no writes will occur at or below that timestamp. 
            Perfect for analytics, dashboards, and geo-distributed reads.
          </p>
        </div>
      </div>
    </section>

    <!-- Multi-Region -->
    <section class="region-section">
      <h2>🌍 Multi-Region Patterns</h2>
      <p class="section-desc">Control where your data lives and how it's accessed</p>

      <div class="region-controls">
        <div class="region-tabs">
          <button class="region-tab active" data-tab="regional">Regional Tables</button>
          <button class="region-tab" data-tab="global">Global Tables</button>
          <button class="region-tab" data-tab="rbr">Regional by Row</button>
        </div>
      </div>

      <div class="region-content" id="regionContent">
        <!-- Filled by JS -->
      </div>

      <div class="region-map">
        <div class="region-box us-east">
          <div class="region-name">🇺🇸 us-east1</div>
          <div class="region-nodes" id="regionUsEast">N1, N2, N3</div>
        </div>
        <div class="region-box us-west">
          <div class="region-name">🇺🇸 us-west1</div>
          <div class="region-nodes" id="regionUsWest">N4, N5, N6</div>
        </div>
        <div class="region-box eu-west">
          <div class="region-name">🇪🇺 eu-west1</div>
          <div class="region-nodes" id="regionEuWest">N7, N8, N9</div>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://www.cockroachlabs.com/docs/stable/architecture/overview.html" target="_blank">CockroachDB Architecture Docs</a> and <a href="https://dl.acm.org/doi/10.1145/3318464.3386134" target="_blank">CockroachDB: The Resilient Geo-Distributed SQL Database (SIGMOD 2020)</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share this visualization:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20visualization%20of%20CockroachDB%20distributed%20SQL%20architecture&url=https://systeminternals.dev/cockroachdb/architecture/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/cockroachdb/architecture/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/cockroachdb/architecture/&t=Interactive%20CockroachDB%20Architecture%20Visualizer" target="_blank" class="share-btn">🟧 Hacker News</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .viz-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #6ded8a, #3ecf8e, #60a5fa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #888;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 12px;
  }

  .section-desc {
    color: #888;
    margin-bottom: 24px;
    font-size: 1rem;
  }

  /* Overview */
  .overview-section {
    margin-bottom: 50px;
  }

  .overview-card {
    background: linear-gradient(135deg, rgba(110, 237, 138, 0.1), rgba(96, 165, 250, 0.05));
    border: 1px solid rgba(110, 237, 138, 0.3);
    border-radius: 16px;
    padding: 24px 28px;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #ccc;
  }

  .overview-card strong { color: #fff; }
  .overview-card em { color: #6ded8a; font-style: normal; font-weight: 500; }
  .overview-card a { color: #60a5fa; }

  /* Action Buttons */
  .action-btn {
    padding: 10px 20px;
    border: none;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .action-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .primary-btn {
    background: linear-gradient(135deg, #6ded8a, #3ecf8e);
    color: #111;
  }

  .primary-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(62, 207, 142, 0.4);
  }

  .step-btn {
    background: linear-gradient(135deg, #60a5fa, #3b82f6);
    color: white;
  }

  .split-btn {
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    color: #111;
  }

  .lease-btn {
    background: linear-gradient(135deg, #a78bfa, #7c3aed);
    color: white;
  }

  .kill-btn {
    background: linear-gradient(135deg, #f87171, #ef4444);
    color: white;
  }

  .reset-btn {
    background: rgba(255,255,255,0.1);
    color: #aaa;
  }

  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  /* Layer Stack */
  .layer-section {
    margin-bottom: 50px;
  }

  .layer-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    margin-bottom: 24px;
  }

  .layer-arrow {
    color: #555;
    font-size: 1.2rem;
    line-height: 1;
    padding: 4px 0;
  }

  .layer-card {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    max-width: 500px;
    padding: 16px 20px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s;
  }

  .layer-card:hover, .layer-card.active {
    background: rgba(110, 237, 138, 0.08);
    border-color: rgba(110, 237, 138, 0.4);
  }

  .layer-num {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(110, 237, 138, 0.2);
    color: #6ded8a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .layer-info h3 {
    color: #fff;
    font-size: 1rem;
    margin-bottom: 2px;
  }

  .layer-info p {
    color: #888;
    font-size: 0.85rem;
  }

  .layer-icon {
    margin-left: auto;
    font-size: 1.5rem;
  }

  .layer-detail {
    background: rgba(0,0,0,0.2);
    border-radius: 14px;
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.1);
    min-height: 120px;
  }

  .layer-detail-content {
    color: #ccc;
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .layer-detail-content strong { color: #6ded8a; }
  .layer-detail-content code {
    background: rgba(0,0,0,0.3);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.85rem;
    color: #fbbf24;
  }

  /* Cluster Viz */
  .cluster-section {
    margin-bottom: 50px;
  }

  .cluster-controls {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .cluster-status {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    padding: 12px 16px;
    background: rgba(255,255,255,0.03);
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .status-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .status-badge.idle { background: rgba(107, 114, 128, 0.3); color: #9ca3af; }
  .status-badge.routing { background: rgba(251, 191, 36, 0.2); color: #fbbf24; }
  .status-badge.replicating { background: rgba(167, 139, 250, 0.2); color: #a78bfa; }
  .status-badge.done { background: rgba(34, 197, 94, 0.2); color: #22c55e; }
  .status-badge.danger { background: rgba(239, 68, 68, 0.2); color: #f87171; }

  .status-text {
    color: #aaa;
    font-size: 0.95rem;
  }

  .cluster-viz {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
    margin-bottom: 20px;
  }

  .cluster-log {
    background: rgba(0,0,0,0.3);
    border-radius: 12px;
    padding: 16px;
    max-height: 200px;
    overflow-y: auto;
    border: 1px solid rgba(255,255,255,0.1);
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 0.8rem;
  }

  .log-entry {
    padding: 4px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    animation: entryAppear 0.3s ease-out;
  }

  .log-entry.info { color: #9ca3af; }
  .log-entry.route { color: #fbbf24; }
  .log-entry.raft { color: #a78bfa; }
  .log-entry.success { color: #4ade80; }
  .log-entry.error { color: #f87171; }
  .log-entry.lease { color: #60a5fa; }

  @keyframes entryAppear {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Range Section */
  .range-section {
    margin-bottom: 50px;
  }

  .range-viz {
    margin-bottom: 20px;
  }

  .keyspace-bar {
    background: rgba(0,0,0,0.2);
    border-radius: 12px;
    padding: 20px;
    border: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 20px;
  }

  .keyspace-label {
    color: #888;
    font-size: 0.85rem;
    margin-bottom: 12px;
    text-align: center;
  }

  .keyspace-ranges {
    display: flex;
    gap: 4px;
    height: 50px;
  }

  .range-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .range-detail-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 20px;
  }

  .range-detail-card h4 {
    color: #fff;
    font-size: 1rem;
    margin-bottom: 12px;
  }

  .range-detail-card ul {
    list-style: none;
    padding: 0;
  }

  .range-detail-card li {
    color: #aaa;
    padding: 4px 0;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .range-detail-card li strong { color: #6ded8a; }

  .range-detail-card p {
    color: #aaa;
    line-height: 1.7;
    font-size: 0.9rem;
  }

  .range-detail-card strong { color: #6ded8a; }
  .range-detail-card em { color: #fbbf24; font-style: normal; }

  .highlight-card {
    background: linear-gradient(135deg, rgba(110, 237, 138, 0.08), rgba(96, 165, 250, 0.08));
    border-color: rgba(110, 237, 138, 0.3);
  }

  /* Query Flow */
  .query-section {
    margin-bottom: 50px;
  }

  .query-controls {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .query-input {
    flex: 1;
    min-width: 280px;
    padding: 12px 16px;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(110, 237, 138, 0.3);
    border-radius: 10px;
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 0.9rem;
    color: #6ded8a;
  }

  .query-flow-viz {
    background: rgba(0,0,0,0.2);
    border-radius: 14px;
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.1);
    min-height: 200px;
  }

  .query-steps {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .query-step {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 16px;
    border-radius: 10px;
    animation: entryAppear 0.4s ease-out;
  }

  .query-step-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.8rem;
    flex-shrink: 0;
  }

  .query-step-body h4 {
    font-size: 0.95rem;
    margin-bottom: 4px;
  }

  .query-step-body p {
    font-size: 0.85rem;
    color: #aaa;
    line-height: 1.5;
  }

  .step-sql { background: rgba(110, 237, 138, 0.08); border-left: 3px solid #6ded8a; }
  .step-sql .query-step-num { background: rgba(110, 237, 138, 0.3); color: #6ded8a; }
  .step-sql h4 { color: #6ded8a; }

  .step-dist { background: rgba(251, 191, 36, 0.08); border-left: 3px solid #fbbf24; }
  .step-dist .query-step-num { background: rgba(251, 191, 36, 0.3); color: #fbbf24; }
  .step-dist h4 { color: #fbbf24; }

  .step-repl { background: rgba(167, 139, 250, 0.08); border-left: 3px solid #a78bfa; }
  .step-repl .query-step-num { background: rgba(167, 139, 250, 0.3); color: #a78bfa; }
  .step-repl h4 { color: #a78bfa; }

  .step-stor { background: rgba(96, 165, 250, 0.08); border-left: 3px solid #60a5fa; }
  .step-stor .query-step-num { background: rgba(96, 165, 250, 0.3); color: #60a5fa; }
  .step-stor h4 { color: #60a5fa; }

