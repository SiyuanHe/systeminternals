  }
</style>

<script is:inline>
  // ========== LAYER DETAILS ==========
  var layerDetails = {
    sql: '<strong>SQL Layer</strong> — Every CockroachDB node runs a full SQL engine. It parses SQL (PostgreSQL-compatible), builds an AST, runs the <strong>cost-based optimizer</strong>, and produces a logical plan. For distributed queries, it uses <strong>DistSQL</strong> to push computation to nodes that hold the data — like a mini MapReduce. The vectorized execution engine processes data in columnar batches for CPU efficiency.',
    distribution: '<strong>Distribution Layer</strong> — Translates SQL\'s logical KV operations into physical operations on specific ranges. It maintains a <strong>range descriptor cache</strong> (like a routing table) that maps key spans to range locations. When a range splits or moves, the cache updates lazily — if you hit a stale entry, the node returns a "range not found" error and the cache refreshes. This layer also handles <strong>transaction coordination</strong> — the gateway node becomes the transaction coordinator.',
    replication: '<strong>Replication Layer</strong> — Each range is a <strong>Raft consensus group</strong>. Writes go through the Raft leader, get replicated to a quorum (2 of 3), then are applied. The <strong>range lease</strong> is separate from Raft leadership — the leaseholder serves reads without consensus. Leases are time-based (typically 9 seconds) and colocated with the Raft leader. This layer handles <strong>membership changes</strong> (adding/removing replicas) using joint consensus.',
    storage: '<strong>Storage Layer</strong> — Each node runs <strong>Pebble</strong> (CockroachDB\'s custom LSM-tree engine, inspired by RocksDB/LevelDB). Data is stored as MVCC key-value pairs: <code>key@timestamp → value</code>. Pebble uses <strong>bloom filters</strong> for point lookups, <strong>range deletions</strong> for efficient GC, and <strong>table-level properties</strong> for range-key awareness. Each range\'s data lives contiguously in the LSM tree since ranges are sorted key spans.'
  };

  var layerCards = document.querySelectorAll('.layer-card');
  var layerDetailContent = document.getElementById('layerDetailContent');

  layerDetailContent.innerHTML = layerDetails.sql;

  layerCards.forEach(function(card) {
    card.addEventListener('click', function() {
      layerCards.forEach(function(c) { c.classList.remove('active'); });
      card.classList.add('active');
      var layer = card.getAttribute('data-layer');
      layerDetailContent.innerHTML = layerDetails[layer];
    });
  });

  // ========== CLUSTER SIMULATION ==========
  var clusterState = {
    nodes: [
      { id: 1, alive: true },
      { id: 2, alive: true },
      { id: 3, alive: true },
      { id: 4, alive: true },
      { id: 5, alive: true }
    ],
    ranges: [
      { id: 'R1', start: 'a', end: 'm', replicas: [1, 2, 3], leaseholder: 1, color: '#6ded8a' },
      { id: 'R2', start: 'm', end: 't', replicas: [2, 3, 4], leaseholder: 3, color: '#60a5fa' },
      { id: 'R3', start: 't', end: 'z', replicas: [3, 4, 5], leaseholder: 5, color: '#a78bfa' }
    ]
  };

  function renderCluster() {
    var viz = document.getElementById('clusterViz');
    viz.innerHTML = '';

    clusterState.nodes.forEach(function(node) {
      var card = document.createElement('div');
      card.className = 'node-card' + (node.alive ? '' : ' dead');
      card.id = 'node-' + node.id;

      var title = document.createElement('div');
      title.className = 'node-card-title';
      title.textContent = node.alive ? ('Node ' + node.id) : ('Node ' + node.id + ' ☠️');
      card.appendChild(title);

      if (node.alive) {
        clusterState.ranges.forEach(function(range) {
          if (range.replicas.indexOf(node.id) !== -1) {
            var badge = document.createElement('span');
            var isLH = range.leaseholder === node.id;
            badge.className = 'range-badge ' + (isLH ? 'leaseholder' : 'follower');
            badge.textContent = range.id + (isLH ? ' ★' : '');
            badge.style.borderColor = range.color;
            if (isLH) badge.style.color = range.color;
            card.appendChild(badge);
          }
        });
      }

      viz.appendChild(card);
    });

    updateClusterStatus();
  }

  function updateClusterStatus() {
    var alive = clusterState.nodes.filter(function(n) { return n.alive; }).length;
    var statusText = document.getElementById('clusterStatusText');
    statusText.textContent = alive + ' nodes online · ' + clusterState.ranges.length + ' ranges · RF=3';
  }

  function addLog(text, cls) {
    var log = document.getElementById('clusterLog');
    var entry = document.createElement('div');
    entry.className = 'log-entry ' + (cls || 'info');
    entry.textContent = text;
    log.appendChild(entry);
    log.scrollTop = log.scrollHeight;
  }

  renderCluster();

  // Send Query
  document.getElementById('sendQueryBtn').addEventListener('click', function() {
    var badge = document.querySelector('.cluster-status .status-badge');
    var steps = [
      { text: '→ Client sends SELECT to Node 1 (gateway)', cls: 'route', delay: 0 },
      { text: '→ SQL layer: parse → optimize → plan', cls: 'route', delay: 600 },
      { text: '→ Distribution: key "id=42" maps to R1, leaseholder=Node ' + clusterState.ranges[0].leaseholder, cls: 'route', delay: 600 },
      { text: '→ Replication: leaseholder serves read (no Raft needed!)', cls: 'raft', delay: 600 },
      { text: '→ Storage: Pebble point lookup at key@latest_ts', cls: 'info', delay: 400 },
      { text: '✅ Result: balance=$500 returned to client (2.1ms)', cls: 'success', delay: 500 }
    ];

    badge.className = 'status-badge routing';
    badge.textContent = 'Querying';

    var nodeEl = document.getElementById('node-' + clusterState.ranges[0].leaseholder);
    if (nodeEl) nodeEl.classList.add('active-node');

    var totalDelay = 0;
    steps.forEach(function(step) {
      totalDelay += step.delay;
      setTimeout(function() { addLog(step.text, step.cls); }, totalDelay);
    });

    setTimeout(function() {
      badge.className = 'status-badge done';
      badge.textContent = 'Done';
      if (nodeEl) nodeEl.classList.remove('active-node');
    }, totalDelay + 300);
  });

  // Split Range
  document.getElementById('splitRangeBtn').addEventListener('click', function() {
    if (clusterState.ranges.length >= 6) {
      addLog('⚠️ Max ranges reached for demo', 'error');
      return;
    }
    var target = clusterState.ranges[0];
    var mid = String.fromCharCode(target.start.charCodeAt(0) + Math.floor((target.end.charCodeAt(0) - target.start.charCodeAt(0)) / 2));
    var colors = ['#f472b6', '#fbbf24', '#22d3ee'];
    var newRange = {
      id: 'R' + (clusterState.ranges.length + 1),
      start: mid,
      end: target.end,
      replicas: target.replicas.slice(),
      leaseholder: target.replicas[1],
      color: colors[clusterState.ranges.length % colors.length]
    };
    target.end = mid;
    clusterState.ranges.push(newRange);
    renderCluster();
    renderKeyspace();
    addLog('✂️ Split ' + target.id + ' at key "' + mid + '" → new ' + newRange.id, 'lease');
  });

  // Transfer Lease
  document.getElementById('transferLeaseBtn').addEventListener('click', function() {
    var range = clusterState.ranges[Math.floor(Math.random() * clusterState.ranges.length)];
    var aliveReplicas = range.replicas.filter(function(nid) {
      return clusterState.nodes[nid - 1].alive;
    });
    var candidates = aliveReplicas.filter(function(nid) { return nid !== range.leaseholder; });
    if (candidates.length === 0) {
      addLog('⚠️ No candidates for lease transfer on ' + range.id, 'error');
      return;
    }
    var oldLH = range.leaseholder;
    range.leaseholder = candidates[Math.floor(Math.random() * candidates.length)];
    renderCluster();
    addLog('🔄 Lease transfer: ' + range.id + ' Node ' + oldLH + ' → Node ' + range.leaseholder, 'lease');
  });

  // Kill Node
  document.getElementById('killNodeBtn').addEventListener('click', function() {
    var aliveNodes = clusterState.nodes.filter(function(n) { return n.alive; });
    if (aliveNodes.length <= 3) {
      addLog('⚠️ Cannot kill more nodes — need 3 for quorum', 'error');
      return;
    }
    var victim = aliveNodes[Math.floor(Math.random() * aliveNodes.length)];
    victim.alive = false;
    addLog('💀 Node ' + victim.id + ' killed!', 'error');

    // Reassign leases and replicas
    clusterState.ranges.forEach(function(range) {
      if (range.leaseholder === victim.id) {
        var newLH = range.replicas.filter(function(nid) {
          return nid !== victim.id && clusterState.nodes[nid - 1].alive;
        });
        if (newLH.length > 0) {
          range.leaseholder = newLH[0];
          addLog('🔄 ' + range.id + ' lease transferred to Node ' + range.leaseholder, 'lease');
        }
      }
      // Replace dead replica
      if (range.replicas.indexOf(victim.id) !== -1) {
        var available = clusterState.nodes.filter(function(n) {
          return n.alive && range.replicas.indexOf(n.id) === -1;
        });
        if (available.length > 0) {
          var newNode = available[0];
          range.replicas[range.replicas.indexOf(victim.id)] = newNode.id;
          addLog('📦 ' + range.id + ' replica moved to Node ' + newNode.id + ' (rebalancing)', 'raft');
        }
      }
    });

    renderCluster();
  });

  // Cluster Reset
  document.getElementById('clusterResetBtn').addEventListener('click', function() {
    clusterState.nodes = [
      { id: 1, alive: true },
      { id: 2, alive: true },
      { id: 3, alive: true },
      { id: 4, alive: true },
      { id: 5, alive: true }
    ];
    clusterState.ranges = [
      { id: 'R1', start: 'a', end: 'm', replicas: [1, 2, 3], leaseholder: 1, color: '#6ded8a' },
      { id: 'R2', start: 'm', end: 't', replicas: [2, 3, 4], leaseholder: 3, color: '#60a5fa' },
      { id: 'R3', start: 't', end: 'z', replicas: [3, 4, 5], leaseholder: 5, color: '#a78bfa' }
    ];
    document.getElementById('clusterLog').innerHTML = '<div class="log-entry info">Cluster reset — 5 nodes, 3 ranges</div>';
    var badge = document.querySelector('.cluster-status .status-badge');
    badge.className = 'status-badge idle';
    badge.textContent = 'Ready';
    renderCluster();
    renderKeyspace();
  });

  // ========== KEYSPACE VISUALIZATION ==========
  function renderKeyspace() {
    var container = document.getElementById('keyspaceRanges');
    container.innerHTML = '';
    clusterState.ranges.forEach(function(range) {
      var block = document.createElement('div');
      block.className = 'ks-range';
      block.style.backgroundColor = range.color + '33';
      block.style.border = '2px solid ' + range.color;
      block.style.color = range.color;
      block.textContent = range.id + ' [' + range.start + '-' + range.end + ')';
      container.appendChild(block);
    });
  }

  renderKeyspace();

  // ========== QUERY FLOW TRACE ==========
  var queryStep = 0;
  var queryStepData = [
    { cls: 'step-sql', num: '1', title: 'SQL Layer: Parse & Optimize', desc: 'Parse "SELECT balance FROM accounts WHERE id = 42" → AST → cost-based optimizer chooses index scan on primary key → generates KV read: Get(/Table/accounts/42)' },
    { cls: 'step-dist', num: '2', title: 'Distribution: Route to Range', desc: 'Look up key /Table/accounts/42 in range cache → maps to Range R1 [/Table/accounts/1, /Table/accounts/1000) → leaseholder is Node 1 → send KV BatchRequest to Node 1' },
    { cls: 'step-repl', num: '3', title: 'Replication: Leaseholder Read', desc: 'Node 1 holds the lease for R1 → lease is valid (not expired) → serve read locally without Raft consensus. If this were a write, it would go through Raft: propose → replicate to quorum → apply.' },
    { cls: 'step-stor', num: '4', title: 'Storage: Pebble Lookup', desc: 'Pebble reads MVCC key /Table/accounts/42@ts=1679500000 → check bloom filter → binary search in SSTable → find latest version ≤ read timestamp → return value: balance=$500' },
    { cls: 'step-result', num: '✓', title: 'Result Returned', desc: 'Response flows back: Storage → Replication → Distribution → SQL → client. Total latency: ~1-2ms local, ~5-10ms cross-region. No consensus needed for reads!' }
  ];

  document.getElementById('runQueryBtn').addEventListener('click', function() {
    queryStep = 0;
    document.getElementById('querySteps').innerHTML = '';
    renderQueryStep();
    document.getElementById('queryStepBtn').disabled = false;
  });

  document.getElementById('queryStepBtn').addEventListener('click', function() {
    if (queryStep < queryStepData.length - 1) {
      queryStep++;
      renderQueryStep();
      if (queryStep >= queryStepData.length - 1) {
        document.getElementById('queryStepBtn').disabled = true;
      }
    }
  });

  document.getElementById('queryResetBtn').addEventListener('click', function() {
    queryStep = 0;
    document.getElementById('querySteps').innerHTML = '';
    document.getElementById('queryStepBtn').disabled = true;
  });

  function renderQueryStep() {
    var container = document.getElementById('querySteps');
    var step = queryStepData[queryStep];
    var el = document.createElement('div');
    el.className = 'query-step ' + step.cls;
    el.innerHTML = '<div class="query-step-num">' + step.num + '</div><div class="query-step-body"><h4>' + step.title + '</h4><p>' + step.desc + '</p></div>';
    container.appendChild(el);
  }

  // ========== DISTRIBUTED TRANSACTIONS ==========
  document.getElementById('runTxnBtn').addEventListener('click', function() {
    var timeline = document.getElementById('txnTimeline');
    timeline.innerHTML = '';

    var pipelining = document.getElementById('pipelineToggle').checked;
    var parallel = document.getElementById('parallelToggle').checked;

    var steps;
    if (pipelining && parallel) {
      steps = [
        { cls: 'write-step', text: '📝 BEGIN; INSERT INTO orders (id, total) VALUES (1, $99.99)', delay: 0 },
        { cls: 'write-step', text: '📝 UPDATE inventory SET qty = qty - 1 WHERE item = "widget"', delay: 500 },
        { cls: 'pipeline-step', text: '⚡ Write pipelining: both writes sent to Raft without waiting for each other', delay: 500 },
        { cls: 'raft-step', text: '🔄 Raft: replicating INSERT to quorum (2/3 nodes)...', delay: 400 },
        { cls: 'raft-step', text: '🔄 Raft: replicating UPDATE to quorum (2/3 nodes)... (in parallel!)', delay: 300 },
        { cls: 'commit-step', text: '🚀 Parallel commit: transaction record written simultaneously with last batch', delay: 500 },
        { cls: 'result-step', text: '✅ COMMIT — client sees success after 1 consensus round trip! Transaction record is STAGING → COMMITTED async', delay: 600 }
      ];
    } else if (pipelining) {
      steps = [
        { cls: 'write-step', text: '📝 BEGIN; INSERT INTO orders (id, total) VALUES (1, $99.99)', delay: 0 },
        { cls: 'write-step', text: '📝 UPDATE inventory SET qty = qty - 1 WHERE item = "widget"', delay: 500 },
        { cls: 'pipeline-step', text: '⚡ Write pipelining: both writes sent without waiting', delay: 500 },
        { cls: 'raft-step', text: '🔄 Raft: replicating both writes to quorum...', delay: 500 },
        { cls: 'commit-step', text: '📤 COMMIT: write transaction record (separate round trip)', delay: 500 },
        { cls: 'raft-step', text: '🔄 Raft: replicate transaction record...', delay: 400 },
        { cls: 'result-step', text: '✅ COMMIT — 2 consensus round trips total (writes + txn record)', delay: 500 }
      ];
    } else {
      steps = [
        { cls: 'write-step', text: '📝 BEGIN; INSERT INTO orders (id, total) VALUES (1, $99.99)', delay: 0 },
        { cls: 'raft-step', text: '🔄 Raft: replicate INSERT to quorum... waiting...', delay: 600 },
        { cls: 'write-step', text: '📝 UPDATE inventory SET qty = qty - 1 WHERE item = "widget"', delay: 500 },
        { cls: 'raft-step', text: '🔄 Raft: replicate UPDATE to quorum... waiting...', delay: 600 },
        { cls: 'commit-step', text: '📤 COMMIT: write transaction record', delay: 500 },
        { cls: 'raft-step', text: '🔄 Raft: replicate txn record to quorum... waiting...', delay: 500 },
        { cls: 'result-step', text: '✅ COMMIT — 3 sequential consensus round trips 🐌', delay: 500 }
      ];
    }

    var totalDelay = 0;
    steps.forEach(function(step) {
      totalDelay += step.delay;
      setTimeout(function() {
        var el = document.createElement('div');
        el.className = 'txn-step ' + step.cls;
        el.textContent = step.text;
        timeline.appendChild(el);
        timeline.scrollTop = timeline.scrollHeight;
      }, totalDelay);
    });
  });

  document.getElementById('txnResetBtn').addEventListener('click', function() {
    document.getElementById('txnTimeline').innerHTML = '';
  });

  // ========== MULTI-REGION TABS ==========
  var regionData = {
    regional: '<h4 style="color:#6ded8a;margin-bottom:10px;">Regional Tables (default)</h4><p>Data is pinned to the <strong>home region</strong> of the database. All replicas stay within one region. Reads and writes in the home region are fast (~2ms). Cross-region access adds latency (~60-100ms).</p><p style="margin-top:10px;"><code>ALTER DATABASE mydb SET PRIMARY REGION "us-east1";</code></p><p style="margin-top:6px;"><code>ALTER TABLE users SET LOCALITY REGIONAL BY TABLE IN PRIMARY REGION;</code></p>',
    global: '<h4 style="color:#a78bfa;margin-bottom:10px;">Global Tables</h4><p><strong>Reads are fast everywhere</strong> — every region has an up-to-date replica. Writes are slower because they must replicate across all regions via <strong>non-blocking transactions</strong>. Perfect for reference data (countries, config, feature flags) that changes rarely but is read everywhere.</p><p style="margin-top:10px;"><code>ALTER TABLE countries SET LOCALITY GLOBAL;</code></p>',
    rbr: '<h4 style="color:#fbbf24;margin-bottom:10px;">Regional by Row</h4><p>Each <em>row</em> has a <strong>crdb_region</strong> column that determines where it lives. Users in us-east see low latency for their rows. Users in eu-west see low latency for theirs. The same table spans multiple regions, but each row is pinned.</p><p style="margin-top:10px;"><code>ALTER TABLE users SET LOCALITY REGIONAL BY ROW;</code></p><p style="margin-top:6px;"><code>INSERT INTO users (crdb_region, id, name) VALUES (\'eu-west1\', 1, \'Alice\');</code></p>'
  };

  document.querySelectorAll('.region-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.region-tab').forEach(function(t) { t.classList.remove('active'); });
      tab.classList.add('active');
      var tabName = tab.getAttribute('data-tab');
      document.getElementById('regionContent').innerHTML = regionData[tabName];
    });
  });

  // Initial region content
  document.getElementById('regionContent').innerHTML = regionData.regional;
</script>
</BaseLayout>
