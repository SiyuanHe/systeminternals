---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "ZNodes & Watches", description: "Tree hierarchy, node types, one-time watches, and session lifecycle", href: "/zookeeper/znodes-watches/", status: "live" },
  { title: "Leader Election", description: "Ephemeral sequential nodes and the leader election recipe", href: "#", status: "coming" },
  { title: "Distributed Locks", description: "Fair lock queues with sequential nodes and watch predecessor", href: "#", status: "coming" },
  { title: "ZAB Protocol", description: "ZooKeeper Atomic Broadcast — how writes are replicated", href: "#", status: "coming" },
  { title: "Sessions & Heartbeats", description: "Client sessions, timeouts, and reconnection semantics", href: "#", status: "coming" },
  { title: "ACLs & Authentication", description: "Access control lists and pluggable auth schemes", href: "#", status: "coming" },
  { title: "Multi-Op Transactions", description: "Atomic multi-operation requests for compound updates", href: "#", status: "coming" },
  { title: "Observers & Scalability", description: "Read-only replicas for scaling read-heavy workloads", href: "#", status: "coming" },
];
---

<BaseLayout 
  title="ZooKeeper Internals" 
  description="Interactive visualizations for understanding Apache ZooKeeper coordination, ZNodes, watches, and distributed recipes"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "ZooKeeper", href: "/zookeeper/" }]}
>
  <section class="section-header">
    <h1>🦁 ZooKeeper Internals</h1>
    <p>
      Apache ZooKeeper is a centralized coordination service for distributed systems. It provides 
      a hierarchical namespace (ZNodes), ephemeral nodes, sequential nodes, and watches — the 
      building blocks for leader election, distributed locks, configuration management, and more.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(0, 212, 255, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
