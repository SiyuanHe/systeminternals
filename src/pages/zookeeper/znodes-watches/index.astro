---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="ZooKeeper ZNodes & Watches" 
  description="Interactive visualization of ZooKeeper ZNode tree, node types, watches, sessions, and distributed recipes"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "ZooKeeper", href: "/zookeeper/" },
    { label: "ZNodes & Watches", href: "/zookeeper/znodes-watches/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🌳 ZooKeeper ZNodes &amp; Watches</h1>
      <p class="subtitle">Tree Hierarchy, Node Types, One-Time Watches &amp; Distributed Recipes — Visualized</p>
    </header>

    <!-- Overview -->
    <section class="overview-section">
      <div class="overview-card">
        <p>
          <a href="https://zookeeper.apache.org" target="_blank">Apache ZooKeeper</a> provides a
          hierarchical <strong>namespace</strong> of data nodes called <em>ZNodes</em>, organized as
          a tree (like a filesystem). Each ZNode can store data (up to 1MB) and have children.
          ZooKeeper supports <em>ephemeral nodes</em> (tied to client sessions),
          <em>sequential nodes</em> (auto-incrementing suffix), and <strong>one-time watches</strong>
          that fire notifications on changes. These primitives enable distributed
          <strong>leader election</strong>, <strong>locks</strong>, <strong>barriers</strong>,
          and <strong>configuration management</strong>.
        </p>
      </div>
    </section>

    <!-- ZNode Tree Explorer -->
    <section class="tree-section">
      <h2>🌲 ZNode Tree Explorer</h2>
      <p class="section-desc">The ZooKeeper namespace is a tree of ZNodes. Each node can hold data and have children. Explore, create, and delete nodes interactively.</p>

      <div class="tree-controls">
        <div class="tree-input-group">
          <input type="text" id="nodePathInput" class="tree-input" placeholder="Path (e.g., /app/config)" value="/app/config">
          <input type="text" id="nodeDataInput" class="tree-input" placeholder="Data (optional)" value="db_host=10.0.0.1">
          <select id="nodeTypeSelect" class="tree-select">
            <option value="persistent">Persistent</option>
            <option value="ephemeral">Ephemeral</option>
            <option value="persistent_sequential">Persistent Sequential</option>
            <option value="ephemeral_sequential">Ephemeral Sequential</option>
          </select>
        </div>
        <div class="tree-btn-group">
          <button id="createNodeBtn" class="action-btn primary-btn">➕ Create ZNode</button>
          <button id="setDataBtn" class="action-btn step-btn">📝 Set Data</button>
          <button id="deleteNodeBtn" class="action-btn reset-btn">🗑️ Delete</button>
          <button id="loadSampleBtn" class="action-btn sample-btn">📂 Load Sample Tree</button>
        </div>
      </div>

      <div class="tree-layout">
        <div class="tree-view" id="treeView">
          <div class="tree-node root" data-path="/">
            <span class="tree-toggle">▼</span>
            <span class="tree-icon">📁</span>
            <span class="tree-label">/</span>
          </div>
          <div class="tree-children" id="treeRoot"></div>
        </div>
        <div class="node-detail" id="nodeDetail">
          <div class="detail-header">📋 Node Details</div>
          <div class="detail-content" id="detailContent">
            <div class="detail-empty">Select a node to view details</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ZNode Types -->
    <section class="types-section">
      <h2>🏷️ ZNode Types</h2>
      <div class="explain-card highlight-card">
        <h3>💡 Four Node Types</h3>
        <p>
          <strong>Persistent</strong> nodes survive client disconnection — they exist until explicitly deleted.
          <strong>Ephemeral</strong> nodes are tied to the client session — when the session ends, ZooKeeper
          automatically deletes them. <strong>Sequential</strong> nodes get a monotonically increasing
          10-digit suffix (e.g., <code>/lock/node-0000000001</code>). Combining ephemeral + sequential
          gives you the building block for <em>leader election</em> and <em>distributed locks</em>.
          Ephemeral nodes <strong>cannot have children</strong>.
        </p>
      </div>

      <div class="types-grid">
        <div class="type-card" data-type="persistent">
          <div class="type-icon">📦</div>
          <div class="type-name">Persistent</div>
          <div class="type-desc">Survives client disconnect. Must be explicitly deleted.</div>
          <button class="action-btn type-create-btn" data-create-type="persistent">Create Example</button>
        </div>
        <div class="type-card" data-type="ephemeral">
          <div class="type-icon">⏳</div>
          <div class="type-name">Ephemeral</div>
          <div class="type-desc">Deleted when client session ends. Cannot have children.</div>
          <button class="action-btn type-create-btn" data-create-type="ephemeral">Create Example</button>
        </div>
        <div class="type-card" data-type="persistent_sequential">
          <div class="type-icon">📦🔢</div>
          <div class="type-name">Persistent Sequential</div>
          <div class="type-desc">Persistent with auto-incrementing suffix appended.</div>
          <button class="action-btn type-create-btn" data-create-type="persistent_sequential">Create Example</button>
        </div>
        <div class="type-card" data-type="ephemeral_sequential">
          <div class="type-icon">⏳🔢</div>
          <div class="type-name">Ephemeral Sequential</div>
          <div class="type-desc">Ephemeral + sequential. Used for leader election &amp; locks.</div>
          <button class="action-btn type-create-btn" data-create-type="ephemeral_sequential">Create Example</button>
        </div>
      </div>
    </section>

    <!-- Watches -->
    <section class="watch-section">
      <h2>👁️ Watches: One-Time Triggers</h2>
      <div class="explain-card">
        <h3>📡 How Watches Work</h3>
        <p>
          A <strong>watch</strong> is a one-time trigger. When a client reads data with a watch
          (<code>getData(path, watch=true)</code> or <code>getChildren(path, watch=true)</code>),
          ZooKeeper registers the watch. When the watched node changes — data modified, node
          deleted, or children changed — the server sends a <em>WatchEvent</em> notification to the
          client. The watch fires <strong>exactly once</strong> and must be re-registered. Watch
          types: <strong>NodeDataChanged</strong>, <strong>NodeDeleted</strong>,
          <strong>NodeChildrenChanged</strong>, <strong>NodeCreated</strong>.
        </p>
      </div>

      <div class="watch-demo">
        <div class="watch-controls">
          <div class="watch-input-group">
            <input type="text" id="watchPathInput" class="tree-input" placeholder="Path to watch" value="/app/config">
            <select id="watchTypeSelect" class="tree-select">
              <option value="data">getData (data watch)</option>
              <option value="children">getChildren (child watch)</option>
              <option value="exists">exists (existence watch)</option>
            </select>
            <button id="setWatchBtn" class="action-btn primary-btn">👁️ Set Watch</button>
          </div>
        </div>

        <div class="watch-panels">
          <div class="watch-panel active-watches-panel">
            <div class="watch-panel-header">
              <span>🔔 Active Watches</span>
              <span class="watch-count" id="watchCount">0</span>
            </div>
            <div class="watch-list" id="activeWatches">
              <div class="watch-empty">No watches set. Set a watch above, then modify the node to trigger it.</div>
            </div>
          </div>
          <div class="watch-panel notifications-panel">
            <div class="watch-panel-header">
              <span>📨 Watch Notifications</span>
              <button id="clearNotificationsBtn" class="action-btn clear-btn">Clear</button>
            </div>
            <div class="watch-events" id="watchNotifications">
              <div class="watch-empty">Notifications appear here when watches fire...</div>
            </div>
          </div>
        </div>

        <div class="watch-trigger-controls">
          <span class="trigger-label">Trigger a watch:</span>
          <input type="text" id="triggerPathInput" class="tree-input" placeholder="Path" value="/app/config">
          <input type="text" id="triggerDataInput" class="tree-input" placeholder="New data" value="db_host=10.0.0.2">
          <button id="triggerSetDataBtn" class="action-btn step-btn">📝 Set Data</button>
          <button id="triggerDeleteBtn" class="action-btn reset-btn">🗑️ Delete Node</button>
          <button id="triggerAddChildBtn" class="action-btn sample-btn">➕ Add Child</button>
        </div>
      </div>
    </section>

    <!-- Sessions & Ephemeral Nodes -->
    <section class="session-section">
      <h2>🔗 Sessions &amp; Ephemeral Nodes</h2>
      <div class="explain-card highlight-card">
        <h3>💡 Session Lifecycle</h3>
        <p>
          Each client maintains a <strong>session</strong> with the ZooKeeper ensemble via TCP.
          The session has a <em>timeout</em> (e.g., 30s). The client sends heartbeats to keep
          the session alive. If the server doesn't hear from the client within the timeout, the
          session expires and all <strong>ephemeral nodes</strong> created by that session are
          automatically deleted — triggering watches on those nodes. This is the foundation for
          <em>failure detection</em> in leader election and group membership.
        </p>
      </div>

      <div class="session-demo">
        <div class="session-controls">
          <button id="connectClientBtn" class="action-btn primary-btn">🔌 Connect Client</button>
          <button id="disconnectClientBtn" class="action-btn chaos-btn" disabled>💀 Kill Client</button>
          <button id="resetSessionBtn" class="action-btn reset-btn">🔄 Reset</button>
        </div>

        <div class="clients-grid" id="clientsGrid">
          <!-- Rendered by JS -->
        </div>

        <div class="session-status" id="sessionStatus">
          <span class="status-badge idle">Ready</span>
          <span class="status-text" id="sessionStatusText">Connect clients to see ephemeral node lifecycle</span>
        </div>

        <div class="ephemeral-nodes-panel">
          <div class="panel-header">⏳ Ephemeral Nodes in Tree</div>
          <div class="ephemeral-list" id="ephemeralList">
            <div class="watch-empty">No ephemeral nodes yet</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Leader Election Recipe -->
    <section class="election-section">
      <h2>👑 Leader Election Recipe</h2>
      <div class="explain-card highlight-card">
        <h3>🔑 Ephemeral Sequential Nodes</h3>
        <p>
          Each candidate creates an <strong>ephemeral sequential</strong> node under
          <code>/election/</code> (e.g., <code>/election/candidate-0000000001</code>). The node
          with the <em>smallest sequence number</em> is the leader. Other candidates
          <strong>watch the node just before theirs</strong> in sequence order — avoiding the
          thundering herd problem. When the leader dies, its ephemeral node is deleted, and only
          the <em>next</em> candidate gets notified and becomes leader.
        </p>
      </div>

      <div class="election-controls">
        <button id="startElectionBtn" class="action-btn primary-btn">🏁 Start Election (3 candidates)</button>
        <button id="killLeaderBtn" class="action-btn chaos-btn" disabled>💀 Kill Leader</button>
        <button id="addCandidateBtn" class="action-btn step-btn" disabled>➕ Add Candidate</button>
        <button id="resetElectionBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="election-visual">
        <div class="election-path-header">
          <span>📁 /election/</span>
        </div>
        <div class="election-candidates" id="electionCandidates">
          <div class="lock-empty">Click "Start Election" to see the recipe in action</div>
        </div>
      </div>

      <div class="election-status" id="electionStatus">
        <span class="status-badge idle">Ready</span>
        <span class="status-text" id="electionStatusText">Start an election to see ephemeral sequential nodes</span>
      </div>
    </section>

    <!-- Distributed Lock Recipe -->
    <section class="lock-section">
      <h2>🔒 Distributed Lock Recipe</h2>
      <div class="explain-card">
        <h3>🔑 Fair Lock with Watch Predecessor</h3>
        <p>
          The lock recipe is similar to leader election. Each process creates an
          <strong>ephemeral sequential</strong> node under <code>/locks/resource/</code>. The
          process with the <em>smallest sequence number</em> holds the lock. Others watch the
          node with the <strong>next-smaller sequence number</strong> (their predecessor). When
          the predecessor is deleted (lock released or process died), the next process gets the
          lock. This creates a <em>fair FIFO queue</em> with no thundering herd.
        </p>
      </div>

      <div class="lock-controls">
        <button id="lockAcquireBtn" class="action-btn primary-btn">🔒 Acquire Lock (3 processes)</button>
        <button id="lockReleaseBtn" class="action-btn step-btn" disabled>🔓 Release Lock</button>
        <button id="lockResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="lock-visual">
        <div class="lock-key-header">
          <span>📁 /locks/resource/</span>
        </div>
        <div class="lock-queue" id="lockQueue">
          <div class="lock-empty">Click "Acquire Lock" to see the fair queue</div>
        </div>
      </div>

      <div class="lock-status" id="lockStatus">
        <span class="status-badge idle">Ready</span>
        <span class="status-text" id="lockStatusText">Click "Acquire Lock" to see the queue mechanism</span>
      </div>
    </section>

    <!-- Event Log -->
    <section class="event-log-section">
      <h2>📋 Event Log</h2>
      <div class="event-log" id="eventLog">
        <div class="event-log-empty">Events will appear here...</div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://zookeeper.apache.org/doc/current/zookeeperProgrammers.html" target="_blank">ZooKeeper Programmer's Guide</a> and <a href="https://zookeeper.apache.org/doc/current/recipes.html" target="_blank">ZooKeeper Recipes</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share this visualization:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20ZooKeeper%20ZNodes%20%26%20Watches%20visualization&url=https://systeminternals.dev/zookeeper/znodes-watches/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/zookeeper/znodes-watches/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/zookeeper/znodes-watches/&t=Interactive%20ZooKeeper%20ZNodes%20%26%20Watches%20Visualizer" target="_blank" class="share-btn">🟧 Hacker News</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .viz-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #4ade80, #22d3ee, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #888;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 12px;
  }

  .section-desc {
    color: #888;
    margin-bottom: 24px;
    font-size: 1rem;
  }

  /* Overview */
  .overview-section { margin-bottom: 50px; }
  .overview-card {
    background: linear-gradient(135deg, rgba(74, 222, 128, 0.1), rgba(167, 139, 250, 0.05));
    border: 1px solid rgba(74, 222, 128, 0.3);
    border-radius: 16px;
    padding: 24px 28px;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #ccc;
  }
  .overview-card strong { color: #fff; }
  .overview-card em { color: #4ade80; font-style: normal; font-weight: 500; }
  .overview-card a { color: #60a5fa; }

  /* Action Buttons */
  .action-btn {
    padding: 10px 20px;
    border: none;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .action-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .primary-btn { background: linear-gradient(135deg, #4ade80, #22c55e); color: white; }
  .primary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(74, 222, 128, 0.4); }
  .step-btn { background: linear-gradient(135deg, #60a5fa, #3b82f6); color: white; }
  .step-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(59, 130, 246, 0.4); }
  .reset-btn { background: rgba(255,255,255,0.1); color: #ccc; }
  .reset-btn:hover:not(:disabled) { background: rgba(255,255,255,0.15); }
  .chaos-btn { background: linear-gradient(135deg, #ef4444, #dc2626); color: white; }
  .chaos-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(239, 68, 68, 0.4); }
  .sample-btn { background: linear-gradient(135deg, #a78bfa, #7c3aed); color: white; }
  .sample-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(167, 139, 250, 0.4); }
  .clear-btn { background: transparent; color: #888; font-size: 0.75rem; padding: 4px 10px; }
  .type-create-btn { background: linear-gradient(135deg, #22d3ee, #0891b2); color: white; font-size: 0.8rem; padding: 6px 14px; margin-top: 10px; }

  /* Status */
  .election-status, .session-status, .lock-status {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: rgba(255,255,255,0.03);
    border-radius: 10px;
    margin-bottom: 20px;
  }
  .status-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }
  .status-badge.idle { background: rgba(255,255,255,0.1); color: #999; }
  .status-badge.active { background: rgba(74, 222, 128, 0.2); color: #4ade80; }
  .status-badge.success { background: rgba(74, 222, 128, 0.2); color: #4ade80; }
  .status-badge.error { background: rgba(239, 68, 68, 0.2); color: #ef4444; }
  .status-text { color: #aaa; font-size: 0.9rem; }

  /* Tree Explorer */
  .tree-section { margin-bottom: 50px; }
  .tree-controls { margin-bottom: 20px; }
  .tree-input-group { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 10px; }
  .tree-btn-group { display: flex; gap: 10px; flex-wrap: wrap; }
  .tree-input {
    padding: 10px 14px;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    color: #fff;
    font-family: monospace;
    font-size: 0.9rem;
    min-width: 180px;
  }
  .tree-input::placeholder { color: #555; }
  .tree-select {
    padding: 10px 14px;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    color: #fff;
    font-size: 0.9rem;
  }
  .tree-select option { background: #1a1a2e; }

  .tree-layout {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: 16px;
  }

  .tree-view {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 16px;
    min-height: 300px;
    max-height: 500px;
    overflow-y: auto;
    font-family: monospace;
    font-size: 0.85rem;
  }

  .tree-node {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .tree-node:hover { background: rgba(255,255,255,0.05); }
  .tree-node.selected { background: rgba(74, 222, 128, 0.15); border: 1px solid rgba(74, 222, 128, 0.3); }
  .tree-toggle { color: #666; font-size: 0.7rem; width: 14px; text-align: center; }
  .tree-icon { font-size: 0.9rem; }
  .tree-label { color: #fff; }
  .tree-type-badge {
    font-size: 0.65rem;
    padding: 1px 6px;
    border-radius: 4px;
    font-weight: 600;
    margin-left: 6px;
  }
  .tree-type-badge.ephemeral { background: rgba(239, 68, 68, 0.2); color: #ef4444; }
  .tree-type-badge.sequential { background: rgba(96, 165, 250, 0.2); color: #60a5fa; }
  .tree-type-badge.eph-seq { background: rgba(245, 158, 11, 0.2); color: #f59e0b; }
  .tree-children { padding-left: 24px; }
  .tree-node.new-node { animation: nodeFlash 0.6s ease; }
  @keyframes nodeFlash {
    0% { background: rgba(74, 222, 128, 0.4); }
    100% { background: transparent; }
  }
  .tree-node.deleting { animation: nodeDelete 0.4s ease forwards; }
  @keyframes nodeDelete {
    0% { opacity: 1; transform: translateX(0); }
    100% { opacity: 0; transform: translateX(-20px); }
  }

  .node-detail {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    overflow: hidden;
  }
  .detail-header {
    padding: 12px 16px;
    background: rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    font-weight: 600;
    color: #fff;
  }
  .detail-content { padding: 16px; }
  .detail-empty { color: #555; font-style: italic; }
  .detail-row {
    display: flex;
    justify-content: space-between;
    padding: 6px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    font-size: 0.85rem;
  }
  .detail-key { color: #888; }
  .detail-val { color: #fff; font-family: monospace; }
  .detail-val.ephemeral-val { color: #ef4444; }
  .detail-val.persistent-val { color: #4ade80; }
  .detail-watch-badges { margin-top: 12px; display: flex; gap: 6px; flex-wrap: wrap; }
  .detail-watch-badge {
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    background: rgba(96, 165, 250, 0.15);
    color: #60a5fa;
    border: 1px solid rgba(96, 165, 250, 0.3);
  }

  /* Types Section */
  .types-section { margin-bottom: 50px; }
  .types-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .type-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    transition: all 0.3s;
  }
  .type-card:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(74, 222, 128, 0.3);
  }
  .type-icon { font-size: 2rem; margin-bottom: 8px; }
  .type-name { font-weight: 600; color: #fff; margin-bottom: 6px; }
  .type-desc { font-size: 0.85rem; color: #888; line-height: 1.5; }

  /* Watch Section */
  .watch-section { margin-bottom: 50px; }
  .watch-demo { margin-top: 20px; }
  .watch-controls { margin-bottom: 16px; }
  .watch-input-group { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }

  .watch-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 16px;
  }
  .watch-panel {
    background: rgba(0,0,0,0.3);
