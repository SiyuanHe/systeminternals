</style>

<script is:inline>
(function() {
  // ===================== UTILITIES =====================
  var seqCounter = 0;
  var zkTree = { '/': { data: '', type: 'persistent', children: {}, version: 0, cversion: 0, ephemeralOwner: null, watches: [] } };
  var activeWatches = [];
  var clientIdCounter = 0;
  var clients = [];

  function logEvent(type, msg) {
    var log = document.getElementById('eventLog');
    var empty = log.querySelector('.event-log-empty');
    if (empty) empty.remove();
    var entry = document.createElement('div');
    entry.className = 'log-entry';
    var now = new Date();
    var time = now.toLocaleTimeString();
    entry.innerHTML = '<span class="log-time">' + time + '</span><span class="log-type ' + type + '">[' + type.toUpperCase() + ']</span> ' + msg;
    log.prepend(entry);
    if (log.children.length > 100) log.removeChild(log.lastChild);
  }

  function setStatusBadge(containerId, type, text) {
    var container = document.getElementById(containerId);
    if (!container) return;
    var badge = container.querySelector('.status-badge');
    var statusText = container.querySelector('.status-text');
    badge.className = 'status-badge ' + type;
    badge.textContent = type === 'idle' ? 'Ready' : type === 'active' ? 'Active' : type === 'success' ? 'Success' : 'Error';
    statusText.textContent = text;
  }

  // ===================== ZNODE TREE =====================
  function getNode(path) {
    if (path === '/') return zkTree['/'];
    var parts = path.split('/').filter(function(p) { return p.length > 0; });
    var current = zkTree['/'];
    for (var i = 0; i < parts.length; i++) {
      if (!current.children[parts[i]]) return null;
      current = current.children[parts[i]];
    }
    return current;
  }

  function getParentPath(path) {
    if (path === '/') return null;
    var parts = path.split('/').filter(function(p) { return p.length > 0; });
    parts.pop();
    return parts.length === 0 ? '/' : '/' + parts.join('/');
  }

  function getNodeName(path) {
    if (path === '/') return '/';
    var parts = path.split('/').filter(function(p) { return p.length > 0; });
    return parts[parts.length - 1];
  }

  function createNode(path, data, type, sessionId) {
    var parentPath = getParentPath(path);
    if (!parentPath && path !== '/') return false;
    var parent = getNode(parentPath);
    if (!parent) {
      // Auto-create parent paths
      var parts = path.split('/').filter(function(p) { return p.length > 0; });
      var currentPath = '';
      for (var i = 0; i < parts.length - 1; i++) {
        currentPath += '/' + parts[i];
        if (!getNode(currentPath)) {
          createNode(currentPath, '', 'persistent', null);
        }
      }
      parent = getNode(parentPath);
    }
    if (!parent) return false;
    if (parent.ephemeralOwner) {
      logEvent('tree', 'ERROR: Cannot create child under ephemeral node ' + parentPath);
      return false;
    }

    var nodeName = getNodeName(path);
    var actualPath = path;

    if (type === 'persistent_sequential' || type === 'ephemeral_sequential') {
      seqCounter++;
      var suffix = String(seqCounter);
      while (suffix.length < 10) suffix = '0' + suffix;
      nodeName = nodeName + suffix;
      actualPath = parentPath + (parentPath === '/' ? '' : '/') + nodeName;
    }

    parent.children[nodeName] = {
      data: data || '',
      type: type,
      children: {},
      version: 0,
      cversion: 0,
      ephemeralOwner: (type === 'ephemeral' || type === 'ephemeral_sequential') ? sessionId : null,
      watches: []
    };
    parent.cversion++;

    // Trigger children watches on parent
    fireWatches(parentPath, 'NodeChildrenChanged');
    // Trigger exists watches on this path
    fireWatches(actualPath, 'NodeCreated');

    logEvent('tree', 'Created ' + actualPath + ' [' + type + ']' + (data ? ' data="' + data + '"' : ''));
    renderTree();
    return actualPath;
  }

  function setNodeData(path, data) {
    var node = getNode(path);
    if (!node) {
      logEvent('tree', 'ERROR: Node ' + path + ' does not exist');
      return false;
    }
    node.data = data;
    node.version++;
    fireWatches(path, 'NodeDataChanged');
    logEvent('tree', 'Set data on ' + path + ' = "' + data + '" (version=' + node.version + ')');
    renderTree();
    return true;
  }

  function deleteNode(path) {
    if (path === '/') return false;
    var node = getNode(path);
    if (!node) return false;
    var childKeys = Object.keys(node.children);
    if (childKeys.length > 0) {
      logEvent('tree', 'ERROR: Cannot delete ' + path + ' — has ' + childKeys.length + ' children');
      return false;
    }
    var parentPath = getParentPath(path);
    var parent = getNode(parentPath);
    var nodeName = getNodeName(path);
    // Fire watches before deletion
    fireWatches(path, 'NodeDeleted');
    delete parent.children[nodeName];
    parent.cversion++;
    fireWatches(parentPath, 'NodeChildrenChanged');
    logEvent('tree', 'Deleted ' + path);
    renderTree();
    return true;
  }

  function deleteNodeRecursive(path) {
    var node = getNode(path);
    if (!node) return;
    var childKeys = Object.keys(node.children);
    for (var i = 0; i < childKeys.length; i++) {
      var childPath = path === '/' ? '/' + childKeys[i] : path + '/' + childKeys[i];
      deleteNodeRecursive(childPath);
    }
    if (path !== '/') deleteNode(path);
  }

  var selectedPath = null;

  function renderTree() {
    var root = document.getElementById('treeRoot');
    root.innerHTML = '';
    var rootNode = zkTree['/'];
    var childKeys = Object.keys(rootNode.children).sort();
    childKeys.forEach(function(key) {
      renderTreeNode(root, '/' + key, key, rootNode.children[key], 0);
    });
    updateEphemeralList();
  }

  function renderTreeNode(container, path, name, node, depth) {
    var childKeys = Object.keys(node.children).sort();
    var hasChildren = childKeys.length > 0;

    var div = document.createElement('div');
    div.className = 'tree-node' + (selectedPath === path ? ' selected' : '') + ' new-node';
    div.setAttribute('data-path', path);

    var toggleSpan = '<span class="tree-toggle">' + (hasChildren ? '▼' : '·') + '</span>';
    var isEph = node.type === 'ephemeral' || node.type === 'ephemeral_sequential';
    var isSeq = node.type === 'persistent_sequential' || node.type === 'ephemeral_sequential';
    var iconSpan = '<span class="tree-icon">' + (isEph ? '⏳' : (hasChildren ? '📁' : '📄')) + '</span>';
    var labelSpan = '<span class="tree-label">' + name + '</span>';
    var badge = '';
    if (isEph && isSeq) {
      badge = '<span class="tree-type-badge eph-seq">eph+seq</span>';
    } else if (isEph) {
      badge = '<span class="tree-type-badge ephemeral">ephemeral</span>';
    } else if (isSeq) {
      badge = '<span class="tree-type-badge sequential">sequential</span>';
    }
    var watchIndicator = '';
    var watchCount = getWatchesForPath(path).length;
    if (watchCount > 0) {
      watchIndicator = '<span class="tree-type-badge" style="background:rgba(96,165,250,0.2);color:#60a5fa;">👁️' + watchCount + '</span>';
    }

    div.innerHTML = toggleSpan + iconSpan + labelSpan + badge + watchIndicator;

    div.addEventListener('click', function(e) {
      e.stopPropagation();
      selectedPath = path;
      showNodeDetail(path, node);
      document.querySelectorAll('.tree-node').forEach(function(n) { n.classList.remove('selected'); });
      div.classList.add('selected');
      document.getElementById('nodePathInput').value = path;
      document.getElementById('nodeDataInput').value = node.data || '';
      document.getElementById('watchPathInput').value = path;
      document.getElementById('triggerPathInput').value = path;
    });

    container.appendChild(div);

    if (hasChildren) {
      var childContainer = document.createElement('div');
      childContainer.className = 'tree-children';
      childKeys.forEach(function(ck) {
        var childPath = path + '/' + ck;
        renderTreeNode(childContainer, childPath, ck, node.children[ck], depth + 1);
      });
      container.appendChild(childContainer);
    }
  }

  function showNodeDetail(path, node) {
    var content = document.getElementById('detailContent');
    var watches = getWatchesForPath(path);
    var isEph = node.type === 'ephemeral' || node.type === 'ephemeral_sequential';
    var html = '';
    html += '<div class="detail-row"><span class="detail-key">Path</span><span class="detail-val">' + path + '</span></div>';
    html += '<div class="detail-row"><span class="detail-key">Data</span><span class="detail-val">' + (node.data || '(empty)') + '</span></div>';
    html += '<div class="detail-row"><span class="detail-key">Type</span><span class="detail-val ' + (isEph ? 'ephemeral-val' : 'persistent-val') + '">' + node.type + '</span></div>';
    html += '<div class="detail-row"><span class="detail-key">Version</span><span class="detail-val">' + node.version + '</span></div>';
    html += '<div class="detail-row"><span class="detail-key">Children Version</span><span class="detail-val">' + node.cversion + '</span></div>';
    html += '<div class="detail-row"><span class="detail-key">Children</span><span class="detail-val">' + Object.keys(node.children).length + '</span></div>';
    html += '<div class="detail-row"><span class="detail-key">Ephemeral Owner</span><span class="detail-val">' + (node.ephemeralOwner || 'none') + '</span></div>';
    if (watches.length > 0) {
      html += '<div class="detail-watch-badges">';
      watches.forEach(function(w) {
        html += '<span class="detail-watch-badge">👁️ ' + w.type + '</span>';
      });
      html += '</div>';
    }
    content.innerHTML = html;
  }

  // Tree controls
  document.getElementById('createNodeBtn').addEventListener('click', function() {
    var path = document.getElementById('nodePathInput').value.trim();
    var data = document.getElementById('nodeDataInput').value.trim();
    var type = document.getElementById('nodeTypeSelect').value;
    if (!path || path[0] !== '/') { logEvent('tree', 'ERROR: Path must start with /'); return; }
    createNode(path, data, type, 'user-session');
  });

  document.getElementById('setDataBtn').addEventListener('click', function() {
    var path = document.getElementById('nodePathInput').value.trim();
    var data = document.getElementById('nodeDataInput').value.trim();
    if (!path) return;
    setNodeData(path, data);
  });

  document.getElementById('deleteNodeBtn').addEventListener('click', function() {
    var path = document.getElementById('nodePathInput').value.trim();
    if (!path || path === '/') return;
    deleteNode(path);
  });

  document.getElementById('loadSampleBtn').addEventListener('click', function() {
    // Clear existing
    zkTree['/'].children = {};
    zkTree['/'].cversion = 0;
    // Create sample tree
    createNode('/app', '', 'persistent', null);
    createNode('/app/config', 'db_host=10.0.0.1', 'persistent', null);
    createNode('/app/config/database', 'port=3306', 'persistent', null);
    createNode('/app/config/cache', 'ttl=300', 'persistent', null);
    createNode('/app/leader', '', 'persistent', null);
    createNode('/app/members', '', 'persistent', null);
    createNode('/app/members/node-1', 'host=10.0.0.1', 'ephemeral', 'session-1');
    createNode('/app/members/node-2', 'host=10.0.0.2', 'ephemeral', 'session-2');
    createNode('/app/locks', '', 'persistent', null);
    logEvent('tree', 'Loaded sample ZNode tree');
    renderTree();
  });

  // Click root node
  document.querySelector('.tree-node.root').addEventListener('click', function() {
    selectedPath = '/';
    showNodeDetail('/', zkTree['/']);
    document.querySelectorAll('.tree-node').forEach(function(n) { n.classList.remove('selected'); });
    this.classList.add('selected');
    document.getElementById('nodePathInput').value = '/';
  });

  // ===================== ZNODE TYPES =====================
  document.querySelectorAll('.type-create-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var type = btn.getAttribute('data-create-type');
      var basePaths = {
        'persistent': '/demo/persistent-node',
        'ephemeral': '/demo/ephemeral-node',
        'persistent_sequential': '/demo/seq-',
        'ephemeral_sequential': '/demo/eph-seq-'
      };
      var baseData = {
        'persistent': 'I persist forever',
        'ephemeral': 'I vanish when session ends',
        'persistent_sequential': 'Ordered persistent',
        'ephemeral_sequential': 'Ordered ephemeral'
      };
      createNode(basePaths[type], baseData[type], type, 'demo-session');
    });
  });

  // ===================== WATCHES =====================
  function getWatchesForPath(path) {
    return activeWatches.filter(function(w) { return w.path === path; });
  }

  function fireWatches(path, eventType) {
    var toFire = [];
    var remaining = [];
    activeWatches.forEach(function(w) {
      if (w.path !== path) { remaining.push(w); return; }
      var shouldFire = false;
      if (w.type === 'data' && (eventType === 'NodeDataChanged' || eventType === 'NodeDeleted')) shouldFire = true;
      if (w.type === 'children' && (eventType === 'NodeChildrenChanged' || eventType === 'NodeDeleted')) shouldFire = true;
      if (w.type === 'exists' && (eventType === 'NodeCreated' || eventType === 'NodeDeleted' || eventType === 'NodeDataChanged')) shouldFire = true;
      if (shouldFire) {
        toFire.push(w);
        // One-time: do not keep
      } else {
        remaining.push(w);
      }
    });
    activeWatches = remaining;

    toFire.forEach(function(w) {
      addWatchNotification(eventType, w.path, w.type);
      logEvent('watch', eventType + ' on ' + w.path + ' (watch type: ' + w.type + ') — watch removed (one-time)');
    });

    renderWatches();
  }

  function addWatchNotification(eventType, path, watchType) {
    var panel = document.getElementById('watchNotifications');
    var empty = panel.querySelector('.watch-empty');
    if (empty) empty.remove();
    var div = document.createElement('div');
    var cssClass = 'data-changed';
    if (eventType === 'NodeDeleted') cssClass = 'node-deleted';
    if (eventType === 'NodeChildrenChanged') cssClass = 'children-changed';
    if (eventType === 'NodeCreated') cssClass = 'node-created';
    div.className = 'watch-notification ' + cssClass;
    div.textContent = '⚡ ' + eventType + ' — ' + path + ' (was: ' + watchType + ' watch)';
    panel.prepend(div);
    if (panel.children.length > 30) panel.removeChild(panel.lastChild);
  }

  function renderWatches() {
    var list = document.getElementById('activeWatches');
    var count = document.getElementById('watchCount');
    count.textContent = activeWatches.length;
    if (activeWatches.length === 0) {
      list.innerHTML = '<div class="watch-empty">No watches set. Set a watch above, then modify the node to trigger it.</div>';
      return;
    }
    list.innerHTML = '';
    activeWatches.forEach(function(w, idx) {
      var div = document.createElement('div');
      div.className = 'watch-entry';
      div.innerHTML = '👁️ ' + w.path + ' <span style="color:#888">(' + w.type + ')</span><span class="watch-remove" data-idx="' + idx + '">✕</span>';
      div.querySelector('.watch-remove').addEventListener('click', function(e) {
        e.stopPropagation();
        activeWatches.splice(idx, 1);
        renderWatches();
      });
      list.appendChild(div);
    });
    // Also update tree to show watch indicators
    renderTree();
  }

  document.getElementById('setWatchBtn').addEventListener('click', function() {
    var path = document.getElementById('watchPathInput').value.trim();
    var type = document.getElementById('watchTypeSelect').value;
    if (!path) return;
    activeWatches.push({ path: path, type: type });
    logEvent('watch', 'Set ' + type + ' watch on ' + path);
    renderWatches();
  });

  document.getElementById('clearNotificationsBtn').addEventListener('click', function() {
    document.getElementById('watchNotifications').innerHTML = '<div class="watch-empty">Notifications appear here when watches fire...</div>';
  });

  // Watch trigger controls
  document.getElementById('triggerSetDataBtn').addEventListener('click', function() {
    var path = document.getElementById('triggerPathInput').value.trim();
    var data = document.getElementById('triggerDataInput').value.trim();
    if (!path) return;
    var node = getNode(path);
    if (!node) {
      createNode(path, data, 'persistent', null);
    } else {
      setNodeData(path, data);
    }
  });

  document.getElementById('triggerDeleteBtn').addEventListener('click', function() {
    var path = document.getElementById('triggerPathInput').value.trim();
    if (!path || path === '/') return;
    deleteNode(path);
  });

  document.getElementById('triggerAddChildBtn').addEventListener('click', function() {
    var path = document.getElementById('triggerPathInput').value.trim();
    if (!path) return;
    var childName = 'child-' + Math.floor(Math.random() * 1000);
    var childPath = path === '/' ? '/' + childName : path + '/' + childName;
    createNode(childPath, 'auto-created', 'persistent', null);
  });

  // ===================== SESSIONS & EPHEMERAL NODES =====================
  function updateEphemeralList() {
    var list = document.getElementById('ephemeralList');
    var ephemerals = [];
    function findEphemerals(node, path) {
      if (node.ephemeralOwner) {
        ephemerals.push({ path: path, owner: node.ephemeralOwner });
      }
      Object.keys(node.children).forEach(function(k) {
        findEphemerals(node.children[k], path === '/' ? '/' + k : path + '/' + k);
      });
    }
    findEphemerals(zkTree['/'], '/');
    if (ephemerals.length === 0) {
      list.innerHTML = '<div class="watch-empty">No ephemeral nodes yet</div>';
    } else {
      list.innerHTML = '';
      ephemerals.forEach(function(e) {
        var div = document.createElement('div');
        div.className = 'ephemeral-entry alive';
        div.textContent = '⏳ ' + e.path + '  (owner: ' + e.owner + ')';
        list.appendChild(div);
      });
    }
  }

  function renderClients() {
    var grid = document.getElementById('clientsGrid');
    grid.innerHTML = '';
    clients.forEach(function(client) {
      var div = document.createElement('div');
      div.className = 'client-card ' + (client.alive ? 'connected' : 'dead');
      var ephNodes = client.ephemeralPaths.map(function(p) { return '⏳ ' + p; }).join('<br>');
      div.innerHTML =
        '<div class="client-header">' +
          '<span style="font-size:1.2rem">' + (client.alive ? '🖥️' : '💀') + '</span>' +
          '<span class="client-name">' + client.name + '</span>' +
          '<span class="client-session-badge ' + (client.alive ? 'connected' : 'dead') + '">' + (client.alive ? 'CONNECTED' : 'EXPIRED') + '</span>' +
        '</div>' +
        '<div class="client-heartbeat"><div class="client-heartbeat-bar" style="width:' + (client.alive ? client.heartbeat : 0) + '%"></div></div>' +
        '<div class="client-info">Session: ' + client.sessionId + ' | Timeout: 30s</div>' +
        (ephNodes ? '<div class="client-ephemeral">' + ephNodes + '</div>' : '') +
        (client.alive ? '<button class="client-kill-btn" data-client-id="' + client.id + '">💀 Kill</button>' : '<div class="client-info" style="color:#ef4444;margin-top:4px">Session expired — ephemeral nodes deleted</div>');
      var killBtn = div.querySelector('.client-kill-btn');
      if (killBtn) {
        killBtn.addEventListener('click', function() {
          killClient(client.id);
        });
      }
      grid.appendChild(div);
    });
    document.getElementById('disconnectClientBtn').disabled = clients.filter(function(c) { return c.alive; }).length === 0;
  }

  function killClient(clientId) {
    var client = clients.find(function(c) { return c.id === clientId; });
    if (!client || !client.alive) return;
    client.alive = false;
    if (client.heartbeatTimer) { clearInterval(client.heartbeatTimer); client.heartbeatTimer = null; }
    // Delete ephemeral nodes
    client.ephemeralPaths.forEach(function(path) {
      deleteNode(path);
      logEvent('session', 'Ephemeral node ' + path + ' deleted (session ' + client.sessionId + ' expired)');
    });
    logEvent('session', client.name + ' session expired — all ephemeral nodes removed');
    setStatusBadge('sessionStatus', 'error', client.name + ' died — ' + client.ephemeralPaths.length + ' ephemeral node(s) deleted');
    renderClients();
    renderTree();
  }

  document.getElementById('connectClientBtn').addEventListener('click', function() {
    clientIdCounter++;
    var id = clientIdCounter;
    var sessionId = '0x' + (1000 + id).toString(16);
    var name = 'Client-' + id;
    var ephPath = '/app/members/' + name.toLowerCase();

    // Create ephemeral node
    createNode(ephPath, 'host=10.0.0.' + id, 'ephemeral', sessionId);

    var client = {
      id: id,
      name: name,
      sessionId: sessionId,
      alive: true,
      heartbeat: 100,
      ephemeralPaths: [ephPath],
      heartbeatTimer: null
    };

    // Heartbeat countdown
    client.heartbeatTimer = setInterval(function() {
      if (!client.alive) { clearInterval(client.heartbeatTimer); return; }
      client.heartbeat -= 3;
      if (client.heartbeat <= 20) {
        client.heartbeat = 100; // Reset (simulate heartbeat sent)
      }
      renderClients();
    }, 1000);

    clients.push(client);
    logEvent('session', name + ' connected (session=' + sessionId + '), created ephemeral node ' + ephPath);
    setStatusBadge('sessionStatus', 'success', name + ' connected with session ' + sessionId);
    renderClients();
  });

  document.getElementById('disconnectClientBtn').addEventListener('click', function() {
    var aliveClients = clients.filter(function(c) { return c.alive; });
    if (aliveClients.length === 0) return;
    killClient(aliveClients[aliveClients.length - 1].id);
  });

  document.getElementById('resetSessionBtn').addEventListener('click', function() {
    clients.forEach(function(c) {
      if (c.heartbeatTimer) clearInterval(c.heartbeatTimer);
    });
    clients = [];
    clientIdCounter = 0;
    renderClients();
    setStatusBadge('sessionStatus', 'idle', 'Connect clients to see ephemeral node lifecycle');
  });

  // ===================== LEADER ELECTION RECIPE =====================
  (function() {
    var electionCandidates = [];
    var electionSeq = 0;
    var CANDIDATE_NAMES = ['Server-A', 'Server-B', 'Server-C', 'Server-D', 'Server-E'];
    var CANDIDATE_COLORS = ['#4ade80', '#60a5fa', '#a78bfa', '#f59e0b', '#22d3ee'];

    function getLeaderIdx() {
      var alive = electionCandidates.filter(function(c) { return c.alive; });
      if (alive.length === 0) return -1;
      alive.sort(function(a, b) { return a.seq - b.seq; });
      return electionCandidates.indexOf(alive[0]);
    }

    function renderElection() {
      var container = document.getElementById('electionCandidates');
      var alive = electionCandidates.filter(function(c) { return c.alive; });
      alive.sort(function(a, b) { return a.seq - b.seq; });
      var dead = electionCandidates.filter(function(c) { return !c.alive; });
      var sorted = alive.concat(dead);

      if (sorted.length === 0) {
        container.innerHTML = '<div class="lock-empty">Click "Start Election" to see the recipe in action</div>';
        return;
      }

      container.innerHTML = '';
      sorted.forEach(function(c, idx) {
        var isLeader = c.alive && alive.length > 0 && alive[0] === c;
        var predecessorName = '';
        if (c.alive && !isLeader) {
          var myAliveIdx = alive.indexOf(c);
          if (myAliveIdx > 0) {
            predecessorName = alive[myAliveIdx - 1].name;
          }
        }
        var div = document.createElement('div');
        div.className = 'election-entry ' + (c.alive ? (isLeader ? 'leader-entry' : 'follower-entry') : 'dead-entry');
        div.innerHTML =
          '<span class="election-icon">' + (c.alive ? (isLeader ? '👑' : '🖥️') : '💀') + '</span>' +
          '<div>' +
            '<span class="election-name" style="color:' + c.color + '">' + c.name + '</span>' +
            '<span class="election-path"> /election/candidate-' + String(c.seq).padStart(10, '0') + '</span>' +
            (predecessorName ? '<div class="election-watch-info">👁️ watching ' + predecessorName + '\'s node</div>' : '') +
            (!c.alive ? '<div class="election-watch-info">Node deleted (session expired)</div>' : '') +
          '</div>' +
          '<span class="election-role ' + (isLeader ? 'leader' : 'follower') + '">' + (c.alive ? (isLeader ? 'LEADER' : 'FOLLOWER') : 'DEAD') + '</span>';
        container.appendChild(div);
      });

      document.getElementById('killLeaderBtn').disabled = alive.length === 0;
      document.getElementById('addCandidateBtn').disabled = electionCandidates.length >= 5;
    }

    document.getElementById('startElectionBtn').addEventListener('click', function() {
      electionCandidates = [];
      electionSeq = 0;
      for (var i = 0; i < 3; i++) {
        electionSeq++;
        electionCandidates.push({
          name: CANDIDATE_NAMES[i],
          color: CANDIDATE_COLORS[i],
          seq: electionSeq,
          alive: true
        });
        logEvent('election', CANDIDATE_NAMES[i] + ' created /election/candidate-' + String(electionSeq).padStart(10, '0') + ' (ephemeral sequential)');
      }
      var leaderIdx = getLeaderIdx();
      logEvent('election', CANDIDATE_NAMES[leaderIdx] + ' is leader (smallest sequence number)');
      logEvent('election', 'Others watch their predecessor — no thundering herd');
      setStatusBadge('electionStatus', 'success', CANDIDATE_NAMES[leaderIdx] + ' is leader (seq=' + electionCandidates[leaderIdx].seq + ')');
      document.getElementById('killLeaderBtn').disabled = false;
      document.getElementById('addCandidateBtn').disabled = false;
      renderElection();
    });

    document.getElementById('killLeaderBtn').addEventListener('click', function() {
      var alive = electionCandidates.filter(function(c) { return c.alive; });
      alive.sort(function(a, b) { return a.seq - b.seq; });
      if (alive.length === 0) return;
      var leader = alive[0];
      leader.alive = false;
      logEvent('election', leader.name + ' died! Ephemeral node deleted');
      var newAlive = electionCandidates.filter(function(c) { return c.alive; });
      newAlive.sort(function(a, b) { return a.seq - b.seq; });
      if (newAlive.length > 0) {
        logEvent('election', newAlive[0].name + ' detected predecessor deletion via watch — became new leader');
        setStatusBadge('electionStatus', 'success', newAlive[0].name + ' is new leader (automatic failover)');
      } else {
        setStatusBadge('electionStatus', 'error', 'No candidates alive — no leader');
      }
      renderElection();
    });

    document.getElementById('addCandidateBtn').addEventListener('click', function() {
      var total = electionCandidates.length;
      if (total >= 5) return;
      electionSeq++;
      electionCandidates.push({
        name: CANDIDATE_NAMES[total],
        color: CANDIDATE_COLORS[total],
        seq: electionSeq,
        alive: true
      });
      logEvent('election', CANDIDATE_NAMES[total] + ' joined election (seq=' + electionSeq + ')');
      renderElection();
    });

    document.getElementById('resetElectionBtn').addEventListener('click', function() {
      electionCandidates = [];
      electionSeq = 0;
      setStatusBadge('electionStatus', 'idle', 'Start an election to see ephemeral sequential nodes');
      document.getElementById('killLeaderBtn').disabled = true;
      document.getElementById('addCandidateBtn').disabled = true;
      renderElection();
    });
  })();

  // ===================== DISTRIBUTED LOCK RECIPE =====================
  (function() {
    var lockQueue = [];
    var lockSeq = 0;
    var PROCESS_NAMES = ['Process-A', 'Process-B', 'Process-C'];
    var PROCESS_COLORS = ['#4ade80', '#60a5fa', '#a78bfa'];

    function renderLockQueue() {
      var container = document.getElementById('lockQueue');
      if (lockQueue.length === 0) {
        container.innerHTML = '<div class="lock-empty">Click "Acquire Lock" to see the fair queue</div>';
        return;
      }
      container.innerHTML = '';
      lockQueue.forEach(function(entry, idx) {
        var predecessorName = '';
        if (idx > 0) {
          predecessorName = PROCESS_NAMES[lockQueue[idx - 1].processId];
        }
        var div = document.createElement('div');
        div.className = 'lock-entry ' + (idx === 0 ? 'holder' : 'waiting');
        div.innerHTML =
          '<span class="lock-icon">' + (idx === 0 ? '🔒' : '⏳') + '</span>' +
          '<div>' +
            '<span class="lock-name" style="color:' + PROCESS_COLORS[entry.processId] + '">' + PROCESS_NAMES[entry.processId] + '</span>' +
            '<span class="lock-seq"> /locks/resource/lock-' + String(entry.seq).padStart(10, '0') + '</span>' +
            (predecessorName ? '<div class="lock-watch-info">👁️ watching ' + predecessorName + '\'s node (predecessor)</div>' : '') +
          '</div>' +
          '<span class="lock-state ' + (idx === 0 ? 'holding' : 'queued') + '">' + (idx === 0 ? 'HOLDING' : 'QUEUED') + '</span>';
        container.appendChild(div);
      });
    }

    document.getElementById('lockAcquireBtn').addEventListener('click', function() {
      lockQueue = [];
      lockSeq = 0;
      for (var i = 0; i < 3; i++) {
        lockSeq++;
        lockQueue.push({ processId: i, seq: lockSeq });
        logEvent('lock', PROCESS_NAMES[i] + ' created /locks/resource/lock-' + String(lockSeq).padStart(10, '0') + ' (ephemeral sequential)');
      }
      lockQueue.sort(function(a, b) { return a.seq - b.seq; });
      logEvent('lock', PROCESS_NAMES[lockQueue[0].processId] + ' holds the lock (smallest seq). Others watch predecessor.');
      setStatusBadge('lockStatus', 'success', PROCESS_NAMES[lockQueue[0].processId] + ' holds lock. Fair FIFO queue — no thundering herd.');
      document.getElementById('lockReleaseBtn').disabled = false;
      renderLockQueue();
    });

    document.getElementById('lockReleaseBtn').addEventListener('click', function() {
      if (lockQueue.length === 0) return;
      var released = lockQueue.shift();
      logEvent('lock', PROCESS_NAMES[released.processId] + ' released lock (deleted ephemeral node)');
      if (lockQueue.length > 0) {
        logEvent('lock', PROCESS_NAMES[lockQueue[0].processId] + ' watch fired — now holds the lock');
        setStatusBadge('lockStatus', 'success', PROCESS_NAMES[lockQueue[0].processId] + ' now holds the lock');
      } else {
        setStatusBadge('lockStatus', 'idle', 'Lock released — no more waiters');
        document.getElementById('lockReleaseBtn').disabled = true;
      }
      renderLockQueue();
    });

    document.getElementById('lockResetBtn').addEventListener('click', function() {
      lockQueue = [];
      lockSeq = 0;
      renderLockQueue();
      document.getElementById('lockReleaseBtn').disabled = true;
      setStatusBadge('lockStatus', 'idle', 'Click "Acquire Lock" to see the queue mechanism');
    });
  })();

  // Initial render
  renderTree();
})();
</script>
</BaseLayout>
