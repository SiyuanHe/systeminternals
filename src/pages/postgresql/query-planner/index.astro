<script is:inline>
  // ========== HELPERS ==========
  function fmtNum(n) {
    if (n >= 1000000000) return (n / 1000000000).toFixed(1) + 'B';
    if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
    return String(Math.round(n));
  }

  function fmtCost(n) {
    if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
    return n.toFixed(1);
  }

  // ========== SECTION 1: SCAN TYPES ==========
  var scanTypes = ['Seq Scan', 'Index Scan', 'Index-Only Scan', 'Bitmap Scan'];
  var scanCardIds = ['scanCardSeq', 'scanCardIndex', 'scanCardIndexOnly', 'scanCardBitmap'];

  function updateScan() {
    var rows = parseInt(document.getElementById('scanRowsSlider').value);
    var selectivity = parseInt(document.getElementById('scanSelectSlider').value) / 100;
    var hasIndex = document.getElementById('scanIndexExists').checked;
    var covering = document.getElementById('scanCovering').checked;

    document.getElementById('scanRowsValue').textContent = fmtNum(rows);
    document.getElementById('scanSelectValue').textContent = Math.round(selectivity * 100) + '%';

    var pages = Math.max(1, Math.ceil(rows / 100)); // ~100 rows per 8KB page
    var matchedRows = Math.max(1, Math.round(rows * selectivity));
    var matchedPages = Math.max(1, Math.ceil(matchedRows / 100));

    // Cost estimates (simplified but realistic)
    var seqCost = pages * 1.0 + rows * 0.01;
    var indexCost = hasIndex ? (Math.log2(rows) * 0.5 + matchedRows * 4.0 + matchedRows * 0.01) : Infinity;
    var indexOnlyCost = (hasIndex && covering) ? (Math.log2(rows) * 0.5 + matchedRows * 1.0 + matchedRows * 0.01) : Infinity;
    var bitmapCost = hasIndex ? (Math.log2(rows) * 0.5 + matchedPages * 1.0 + matchedRows * 0.01 + matchedRows * 0.005) : Infinity;

    var costs = [seqCost, indexCost, indexOnlyCost, bitmapCost];
    var minCost = Math.min.apply(null, costs);
    var chosenIdx = costs.indexOf(minCost);

    var reasons = [
      'Full table scan is cheapest — high selectivity or small table',
      'Low selectivity + index — random I/O beats full scan',
      'Index covers all columns — no heap access needed',
      'Moderate selectivity — bitmap reduces random I/O via batching'
    ];

    document.getElementById('scanChosenName').textContent = scanTypes[chosenIdx];
    document.getElementById('scanChosenReason').textContent = reasons[chosenIdx];

    // Render comparison bars
    var comp = document.getElementById('scanComparison');
    var html = '';
    for (var i = 0; i < 4; i++) {
      var isChosen = i === chosenIdx;
      var isDisabled = costs[i] === Infinity;
      var cls = isChosen ? 'chosen' : (isDisabled ? 'disabled' : '');
      html += '<div class="scan-cost-bar ' + cls + '">';
      html += '<div class="scan-cost-name">' + scanTypes[i] + '</div>';
      html += '<div class="scan-cost-value">' + (isDisabled ? 'N/A' : fmtCost(costs[i])) + '</div>';
      html += '</div>';
    }
    comp.innerHTML = html;

    // Highlight active card
    for (var j = 0; j < scanCardIds.length; j++) {
      var card = document.getElementById(scanCardIds[j]);
      if (j === chosenIdx) {
        card.className = 'scan-card active';
      } else {
        card.className = 'scan-card';
      }
    }
  }

  document.getElementById('scanRowsSlider').addEventListener('input', updateScan);
  document.getElementById('scanSelectSlider').addEventListener('input', updateScan);
  document.getElementById('scanIndexExists').addEventListener('change', updateScan);
  document.getElementById('scanCovering').addEventListener('change', updateScan);
  updateScan();

  // ========== SECTION 2: JOIN STRATEGIES ==========
  function updateJoin() {
    var left = parseInt(document.getElementById('joinLeftSlider').value);
    var right = parseInt(document.getElementById('joinRightSlider').value);
    var hasIndex = document.getElementById('joinIndexExists').checked;
    var preSorted = document.getElementById('joinPreSorted').checked;

    document.getElementById('joinLeftValue').textContent = fmtNum(left);
    document.getElementById('joinRightValue').textContent = fmtNum(right);

    var smaller = Math.min(left, right);
    var larger = Math.max(left, right);

    // Nested Loop: outer * (index lookup or seq scan of inner)
    var nestedCost = hasIndex
      ? left * (Math.log2(right) * 0.5 + 4.0 + 0.01)
      : left * (right * 0.01 + Math.ceil(right / 100));

    // Hash Join: build hash on smaller + probe with larger
    var hashCost = smaller * 0.03 + larger * 0.02 + smaller * 0.01;

    // Merge Join: sort both (if needed) + merge
    var sortCostLeft = preSorted ? 0 : left * Math.log2(Math.max(2, left)) * 0.005;
    var sortCostRight = preSorted ? 0 : right * Math.log2(Math.max(2, right)) * 0.005;
    var mergeCost = sortCostLeft + sortCostRight + left * 0.01 + right * 0.01;

    var costs = [nestedCost, hashCost, mergeCost];
    var names = ['Nested Loop', 'Hash Join', 'Merge Join'];
    var reasons = [
      'One side is small' + (hasIndex ? ' + index lookup on inner' : '') + ' — loop is efficient',
      'Best for medium-large unsorted inputs — O(N+M) with hash',
      (preSorted ? 'Pre-sorted inputs' : 'Worth sorting') + ' — merge walk is very efficient'
    ];
    var cardIds = ['joinCardNested', 'joinCardHash', 'joinCardMerge'];

    var minCost = Math.min.apply(null, costs);
    var chosenIdx = costs.indexOf(minCost);

    document.getElementById('joinChosenName').textContent = names[chosenIdx];
    document.getElementById('joinChosenReason').textContent = reasons[chosenIdx];

    // Cost items
    var costsHtml = '';
    for (var i = 0; i < 3; i++) {
      costsHtml += '<div class="join-cost-item ' + (i === chosenIdx ? 'chosen' : '') + '">';
      costsHtml += '<div class="join-cost-label">' + names[i] + '</div>';
      costsHtml += '<div class="join-cost-val">' + fmtCost(costs[i]) + '</div>';
      costsHtml += '</div>';
    }
    document.getElementById('joinCosts').innerHTML = costsHtml;

    // Update cost display in cards
    document.getElementById('nestedCost').textContent = 'Est. cost: ' + fmtCost(nestedCost);
    document.getElementById('hashCost').textContent = 'Est. cost: ' + fmtCost(hashCost);
    document.getElementById('mergeCost').textContent = 'Est. cost: ' + fmtCost(mergeCost);

    // Highlight active card
    for (var j = 0; j < cardIds.length; j++) {
      var card = document.getElementById(cardIds[j]);
      if (j === chosenIdx) {
        card.className = 'join-card active';
      } else {
        card.className = 'join-card';
      }
    }
  }

  document.getElementById('joinLeftSlider').addEventListener('input', updateJoin);
  document.getElementById('joinRightSlider').addEventListener('input', updateJoin);
  document.getElementById('joinIndexExists').addEventListener('change', updateJoin);
  document.getElementById('joinPreSorted').addEventListener('change', updateJoin);
  updateJoin();

  // ========== SECTION 3: EXPLAIN VISUALIZER ==========
  var sampleExplain = 'Hash Join  (cost=230.47..713.98 rows=101 width=32)\n  Hash Cond: (orders.customer_id = customers.id)\n  ->  Bitmap Heap Scan on orders  (cost=4.66..220.09 rows=101 width=16)\n        Recheck Cond: (amount > 500)\n        ->  Bitmap Index Scan on orders_amount_idx  (cost=0.00..4.63 rows=101 width=0)\n              Index Cond: (amount > 500)\n  ->  Hash  (cost=145.00..145.00 rows=5000 width=16)\n        ->  Seq Scan on customers  (cost=0.00..145.00 rows=5000 width=16)';

  function classifyNode(name) {
    var n = name.toLowerCase();
    if (n.indexOf('scan') !== -1) return 'scan-type';
    if (n.indexOf('join') !== -1 || n.indexOf('loop') !== -1) return 'join-type';
    if (n.indexOf('sort') !== -1 || n.indexOf('aggregate') !== -1 || n.indexOf('group') !== -1 || n.indexOf('unique') !== -1) return 'sort-type';
    return 'other-type';
  }

  function parseExplain(text) {
    var lines = text.split('\n');
    var nodes = [];
    for (var i = 0; i < lines.length; i++) {
      var line = lines[i];
      var stripped = line.replace(/^[\s\-\>]+/, '');
      if (!stripped) continue;

      // Compute indent level
      var match = line.match(/^([\s\->]*)/);
      var rawIndent = match ? match[1].length : 0;
      var indent = Math.floor(rawIndent / 2);

      // Try to parse as a plan node: "NodeType ... (cost=X..Y rows=Z width=W)"
      var nodeMatch = stripped.match(/^([A-Z][A-Za-z\s]+?)(?:\s+on\s+\S+)?(?:\s+using\s+\S+)?(?:\s+on\s+\S+)?\s*\(cost=([0-9.]+)\.\.([0-9.]+)\s+rows=(\d+)\s+width=(\d+)\)/);
      if (nodeMatch) {
        nodes.push({
          type: 'node',
          name: stripped.split('(cost=')[0].trim(),
          startCost: parseFloat(nodeMatch[2]),
          totalCost: parseFloat(nodeMatch[3]),
          rows: parseInt(nodeMatch[4]),
          width: parseInt(nodeMatch[5]),
          indent: indent,
          cls: classifyNode(nodeMatch[1])
        });
      } else if (stripped.match(/^(Filter|Index Cond|Hash Cond|Recheck Cond|Sort Key|Join Filter|Merge Cond)/)) {
        nodes.push({
          type: 'detail',
          text: stripped,
          indent: indent
        });
      }
    }
    return nodes;
  }

  function renderExplainTree(nodes) {
    var container = document.getElementById('explainTree');
    var html = '';
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      if (n.type === 'node') {
        var margin = n.indent * 24;
        html += '<div class="explain-node" style="margin-left:' + margin + 'px">';
        html += '<div class="explain-node-content ' + n.cls + '">';
        html += '<span>' + n.name + '</span>';
        html += '<span class="explain-node-cost">cost=' + n.startCost.toFixed(2) + '..' + n.totalCost.toFixed(2) + '</span>';
        html += '<span class="explain-node-rows">rows=' + n.rows + '</span>';
        html += '</div></div>';
      } else {
        var detailMargin = n.indent * 24;
        html += '<div class="explain-node-detail" style="margin-left:' + detailMargin + 'px">' + n.text + '</div>';
      }
    }
    container.innerHTML = html;
  }

  document.getElementById('parseExplainBtn').addEventListener('click', function() {
    var text = document.getElementById('explainInput').value.trim();
    if (!text) return;
    var nodes = parseExplain(text);
    if (nodes.length === 0) return;
    renderExplainTree(nodes);
    document.getElementById('explainTreeContainer').style.display = 'block';
  });

  document.getElementById('loadSampleBtn').addEventListener('click', function() {
    document.getElementById('explainInput').value = sampleExplain;
  });

  document.getElementById('clearExplainBtn').addEventListener('click', function() {
    document.getElementById('explainInput').value = '';
    document.getElementById('explainTreeContainer').style.display = 'none';
    document.getElementById('explainTree').innerHTML = '';
  });

  // ========== SECTION 4: pg_stats ==========
  var statsData = [
    { label: 'US', freq: 0.30, color: '#60a5fa' },
    { label: 'DE', freq: 0.15, color: '#a78bfa' },
    { label: 'GB', freq: 0.12, color: '#34d399' },
    { label: 'FR', freq: 0.08, color: '#f472b6' },
    { label: 'JP', freq: 0.06, color: '#fbbf24' },
    { label: 'Other', freq: 0.29, color: '#6b7280' }
  ];

  function renderStatsBars() {
    var container = document.getElementById('statsBars');
    var maxFreq = 0.30;
    var html = '';
    for (var i = 0; i < statsData.length; i++) {
      var d = statsData[i];
      var height = (d.freq / maxFreq) * 100;
      html += '<div class="stats-bar">';
      html += '<div class="stats-bar-pct">' + Math.round(d.freq * 100) + '%</div>';
      html += '<div class="stats-bar-fill" style="height:' + height + '%;background:' + d.color + '"></div>';
      html += '<div class="stats-bar-label">' + d.label + '</div>';
      html += '</div>';
    }
    container.innerHTML = html;
  }

  function updateStatsEstimate() {
    var country = document.getElementById('statsCountrySelect').value;
    var totalRows = 100000;
    var freqMap = { US: 0.30, DE: 0.15, GB: 0.12, FR: 0.08, JP: 0.06, OTHER: 0.29 };
    var freq = freqMap[country] || 0.02;
    var est = Math.round(totalRows * freq);
    document.getElementById('statsEstRows').textContent = est.toLocaleString();
    document.getElementById('statsEstDetail').textContent = '= ' + totalRows.toLocaleString() + ' rows × ' + freq.toFixed(2) + ' frequency';
  }

  document.getElementById('statsCountrySelect').addEventListener('change', updateStatsEstimate);
  renderStatsBars();
  updateStatsEstimate();

  // ========== SECTION 5: COST MODEL ==========
  function updateCostModel() {
    var seqPageCost = parseInt(document.getElementById('seqPageCostSlider').value) / 10;
    var randomPageCost = parseInt(document.getElementById('randomPageCostSlider').value) / 10;
    var cpuTupleCost = parseInt(document.getElementById('cpuTupleCostSlider').value) / 1000;
    var cacheGB = parseInt(document.getElementById('cacheSizeSlider').value);

    document.getElementById('seqPageCostValue').textContent = seqPageCost.toFixed(1);
    document.getElementById('randomPageCostValue').textContent = randomPageCost.toFixed(1);
    document.getElementById('cpuTupleCostValue').textContent = cpuTupleCost.toFixed(3);
    document.getElementById('cacheSizeValue').textContent = cacheGB + ' GB';

    // Scenario: 1M rows, 125K pages, index on customer_id, 100 matching rows
    var totalRows = 1000000;
    var totalPages = 125000;
    var matchRows = 100;
    var matchPages = Math.max(1, Math.ceil(matchRows / 8)); // rows spread across pages

    // Cache effect: higher cache = lower effective random cost
    var cacheRatio = Math.min(1.0, (cacheGB * 128000) / totalPages); // cache in pages vs total
    var effectiveRandomCost = randomPageCost * (1 - cacheRatio * 0.6);

    // Seq Scan cost
    var seqTotal = totalPages * seqPageCost + totalRows * cpuTupleCost;

    // Index Scan cost
    var indexTotal = (4 * effectiveRandomCost) + (matchRows * effectiveRandomCost) + (matchRows * cpuTupleCost);

    // Bitmap Scan cost
    var bitmapTotal = (4 * effectiveRandomCost) + (matchPages * seqPageCost) + (matchRows * cpuTupleCost) + (matchRows * 0.005);

    var plans = [
      { name: 'Seq Scan', cost: seqTotal, detail: totalPages + ' pages × ' + seqPageCost.toFixed(1) + ' + ' + fmtNum(totalRows) + ' rows × ' + cpuTupleCost.toFixed(3) },
      { name: 'Index Scan', cost: indexTotal, detail: matchRows + ' lookups × ' + effectiveRandomCost.toFixed(2) + ' random cost' },
      { name: 'Bitmap Scan', cost: bitmapTotal, detail: matchPages + ' pages seq + ' + matchRows + ' rows CPU' }
    ];

    var minCost = Math.min(seqTotal, indexTotal, bitmapTotal);

    var compHtml = '';
    for (var i = 0; i < plans.length; i++) {
      var isWinner = plans[i].cost === minCost;
      compHtml += '<div class="cost-plan ' + (isWinner ? 'winner' : '') + '">';
      compHtml += '<div class="cost-plan-name">' + plans[i].name + (isWinner ? ' ✓' : '') + '</div>';
      compHtml += '<div class="cost-plan-value">' + fmtCost(plans[i].cost) + '</div>';
      compHtml += '<div class="cost-plan-detail">' + plans[i].detail + '</div>';
      compHtml += '</div>';
    }
    document.getElementById('costComparison').innerHTML = compHtml;

    var winnerName = plans[plans.indexOf(plans.filter(function(p) { return p.cost === minCost; })[0])].name;
    var verdictHtml = '<span class="cost-verdict-text">Winner: ' + winnerName + '</span>';
    if (randomPageCost <= 1.5) {
      verdictHtml += ' — SSD-like random_page_cost makes index scans much cheaper';
    } else if (seqPageCost >= 2.0) {
      verdictHtml += ' — High seq_page_cost penalizes full table scans';
    }
    document.getElementById('costVerdict').innerHTML = verdictHtml;
  }

  document.getElementById('seqPageCostSlider').addEventListener('input', updateCostModel);
  document.getElementById('randomPageCostSlider').addEventListener('input', updateCostModel);
  document.getElementById('cpuTupleCostSlider').addEventListener('input', updateCostModel);
  document.getElementById('cacheSizeSlider').addEventListener('input', updateCostModel);
  updateCostModel();

  // ========== SECTION 6: STRATEGY SWITCHER ==========
  function updateStrategy() {
    var orders = parseInt(document.getElementById('stratOrdersSlider').value);
    var customers = parseInt(document.getElementById('stratCustomersSlider').value);
    var selectivity = parseInt(document.getElementById('stratSelectSlider').value) / 100;
    var hasIndex = document.getElementById('stratIndex').checked;
    var isSSD = document.getElementById('stratSSD').checked;

    document.getElementById('stratOrdersValue').textContent = fmtNum(orders);
    document.getElementById('stratCustomersValue').textContent = fmtNum(customers);
    document.getElementById('stratSelectValue').textContent = Math.round(selectivity * 100) + '%';

    var matchedOrders = Math.max(1, Math.round(orders * selectivity));
    var randomCost = isSSD ? 1.1 : 4.0;

    // Determine scan on orders
    var scanType;
    var scanReason;
    if (selectivity > 0.3 || !hasIndex) {
      scanType = 'Seq Scan on orders';
      scanReason = selectivity > 0.3 ? 'High selectivity → seq scan is cheaper' : 'No index available';
    } else if (selectivity < 0.01 && hasIndex) {
      scanType = 'Index Scan using orders_customer_id_idx on orders';
      scanReason = 'Very selective (' + fmtNum(matchedOrders) + ' rows) → index scan';
    } else {
      scanType = 'Bitmap Heap Scan on orders';
      scanReason = 'Moderate selectivity (' + fmtNum(matchedOrders) + ' rows) → bitmap scan';
    }

    // Determine join
    var joinType;
    var joinReason;
    if (matchedOrders < 100 && hasIndex) {
      joinType = 'Nested Loop';
      joinReason = 'Tiny outer set → loop with index lookup';
    } else if (matchedOrders > customers * 0.5 || (matchedOrders > 1000 && customers > 1000)) {
      joinType = 'Hash Join';
      joinReason = 'Large join → build hash on customers, probe with orders';
    } else {
      joinType = 'Nested Loop';
      joinReason = 'Small result set → nested loop efficient';
    }

    // Build plan text
    var plan = '';
    var indent = '';
    if (joinType === 'Hash Join') {
      var hashCost = (customers * 0.03 + matchedOrders * 0.02);
      plan += 'Hash Join  (cost=0.00..' + fmtCost(hashCost) + ' rows=' + fmtNum(matchedOrders) + ')\n';
      plan += '  Hash Cond: (orders.customer_id = customers.id)\n';
      if (scanType.indexOf('Bitmap') !== -1) {
        plan += '  ->  Bitmap Heap Scan on orders  (rows=' + fmtNum(matchedOrders) + ')\n';
        plan += '        Recheck Cond: (customer_id filter)\n';
        plan += '        ->  Bitmap Index Scan on orders_customer_id_idx\n';
      } else if (scanType.indexOf('Index') !== -1) {
        plan += '  ->  Index Scan using orders_customer_id_idx on orders  (rows=' + fmtNum(matchedOrders) + ')\n';
      } else {
        plan += '  ->  Seq Scan on orders  (rows=' + fmtNum(matchedOrders) + ')\n';
        if (selectivity < 1.0) {
          plan += '        Filter: (WHERE clause)\n';
        }
      }
      plan += '  ->  Hash  (rows=' + fmtNum(customers) + ')\n';
      plan += '        ->  Seq Scan on customers  (rows=' + fmtNum(customers) + ')';
    } else {
      // Nested Loop
      var nlCost = matchedOrders * (Math.log2(Math.max(2, customers)) * 0.5 + randomCost);
      plan += 'Nested Loop  (cost=0.00..' + fmtCost(nlCost) + ' rows=' + fmtNum(matchedOrders) + ')\n';
      if (scanType.indexOf('Bitmap') !== -1) {
        plan += '  ->  Bitmap Heap Scan on orders  (rows=' + fmtNum(matchedOrders) + ')\n';
        plan += '        ->  Bitmap Index Scan on orders_customer_id_idx\n';
      } else if (scanType.indexOf('Index Scan') !== -1) {
        plan += '  ->  Index Scan using orders_customer_id_idx on orders  (rows=' + fmtNum(matchedOrders) + ')\n';
      } else {
        plan += '  ->  Seq Scan on orders  (rows=' + fmtNum(matchedOrders) + ')\n';
      }
      plan += '  ->  Index Scan using customers_pkey on customers  (rows=1)\n';
      plan += '        Index Cond: (id = orders.customer_id)';
    }

    document.getElementById('strategyPlan').textContent = plan;

    var explainHtml = '<p><strong>Scan:</strong> ' + scanReason + '</p>';
    explainHtml += '<p><strong>Join:</strong> ' + joinReason + '</p>';
    if (isSSD) {
      explainHtml += '<p><strong>Storage:</strong> SSD (random_page_cost=1.1) — index scans are favored</p>';
    } else {
      explainHtml += '<p><strong>Storage:</strong> HDD (random_page_cost=4.0) — sequential access preferred</p>';
    }
    document.getElementById('strategyExplain').innerHTML = explainHtml;
  }

  document.getElementById('stratOrdersSlider').addEventListener('input', updateStrategy);
  document.getElementById('stratCustomersSlider').addEventListener('input', updateStrategy);
  document.getElementById('stratSelectSlider').addEventListener('input', updateStrategy);
  document.getElementById('stratIndex').addEventListener('change', updateStrategy);
  document.getElementById('stratSSD').addEventListener('change', updateStrategy);
  updateStrategy();
</script>
