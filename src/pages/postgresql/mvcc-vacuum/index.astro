}

functionupdateAutovac(){
constthreshold=parseInt((document.getElementById('thresholdSlider')).value);
constscaleFactor=parseInt((document.getElementById('scaleFactorSlider')).value)/100;
constrowCount=parseInt((document.getElementById('rowCountSlider')).value);

document.getElementById('thresholdValue').textContent=String(threshold);
document.getElementById('scaleFactorValue').textContent=scaleFactor.toFixed(2);
document.getElementById('rowCountValue').textContent=formatNum(rowCount);

consttrigger=threshold+Math.floor(scaleFactor*rowCount);
document.getElementById('formulaThreshold').textContent=String(threshold);
document.getElementById('formulaScale').textContent=scaleFactor.toFixed(2);
document.getElementById('formulaRows').textContent=formatNum(rowCount);
document.getElementById('formulaResult').textContent=formatNum(trigger);

constpct=((trigger/rowCount)*100).toFixed(1);
document.getElementById('autovacDesc').textContent=
`Autovacuumwilltriggerwhen${formatNum(trigger)}deadtuplesaccumulate(${pct}%oftable).`+
(trigger>rowCount?'⚠️Triggerislargerthanthetable—autovacuummayneverfire!':'');
}

document.getElementById('thresholdSlider')?.addEventListener('input',updateAutovac);
document.getElementById('scaleFactorSlider')?.addEventListener('input',updateAutovac);
document.getElementById('rowCountSlider')?.addEventListener('input',updateAutovac);
updateAutovac();

//==========SECTION6:TXNIDWRAPAROUND==========
constMAX_AGE=2147483647;//2^31-1
constWARN_AGE=1500000000;
constDANGER_AGE=2000000000;

functionupdateWraparound(){
constage=parseInt((document.getElementById('txnAgeSlider')).value);
constremaining=MAX_AGE-age;

//Formatagedisplay
if(age>=1000000000){
document.getElementById('txnAgeValue').textContent=(age/1000000000).toFixed(2)+'billion';
}else{
document.getElementById('txnAgeValue').textContent=(age/1000000).toFixed(0)+'million';
}

//Cursorposition(percentageofMAX_AGE)
constpct=(age/MAX_AGE)*100;
(document.getElementById('wrapCursor')).style.left=pct+'%';

//Colorzones
constsafePct=Math.min(pct,(WARN_AGE/MAX_AGE)*100);
constwarnPct=pct>(WARN_AGE/MAX_AGE)*100
?Math.min(pct-safePct,((DANGER_AGE-WARN_AGE)/MAX_AGE)*100)
:0;
constdangerPct=pct>(DANGER_AGE/MAX_AGE)*100
?pct-safePct-warnPct
:0;

(document.getElementById('wrapSafe')).style.width=safePct+'%';
(document.getElementById('wrapWarning')).style.width=warnPct+'%';
(document.getElementById('wrapDanger')).style.width=dangerPct+'%';

//Status
conststatusEl=document.getElementById('wrapStatus');
if(age<WARN_AGE){
statusEl.innerHTML='<span class="wrap-status-icon">✅</span><span class="wrap-status-text">Healthy—plentyofheadroombeforewraparound</span>';
statusEl.style.background='rgba(34,197,94,0.1)';
}elseif(age<DANGER_AGE){
statusEl.innerHTML='<span class="wrap-status-icon">⚠️</span><span class="wrap-status-text">Warning—scheduleVACUUMFREEZEsoon!</span>';
statusEl.style.background='rgba(245,158,11,0.1)';
}else{
statusEl.innerHTML='<span class="wrap-status-icon">💀</span><span class="wrap-status-text">CRITICAL—PostgreSQLwillshutdowntopreventdataloss!</span>';
statusEl.style.background='rgba(239,68,68,0.15)';
}

//Remaining
if(remaining>=1000000000){
document.getElementById('wrapRemaining').textContent=(remaining/1000000000).toFixed(2)+'billiontxns';
}else{
document.getElementById('wrapRemaining').textContent=(remaining/1000000).toFixed(0)+'milliontxns';
}

//Timeestimateat1000txn/s
constseconds=remaining/1000;
if(seconds>86400){
document.getElementById('wrapTime').textContent='~'+Math.floor(seconds/86400)+'days';
}elseif(seconds>3600){
document.getElementById('wrapTime').textContent='~'+Math.floor(seconds/3600)+'hours';
}else{
document.getElementById('wrapTime').textContent='~'+Math.floor(seconds/60)+'minutes';
}
}

document.getElementById('txnAgeSlider')?.addEventListener('input',updateWraparound);

document.getElementById('ageTxnBtn')?.addEventListener('click',()=>{
constslider=document.getElementById('txnAgeSlider');
constnewVal=Math.min(parseInt(slider.value)+100000000,MAX_AGE);
slider.value=String(newVal);
updateWraparound();
});

document.getElementById('freezeBtn')?.addEventListener('click',()=>{
constslider=document.getElementById('txnAgeSlider');
slider.value='0';
updateWraparound();
});

document.getElementById('resetWrapBtn')?.addEventListener('click',()=>{
constslider=document.getElementById('txnAgeSlider');
slider.value='500000000';
updateWraparound();
});

updateWraparound();
</script>
