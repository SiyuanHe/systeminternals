bloatInterval=setInterval(()=>{
constrate=parseInt((document.getElementById('updateRateSlider')).value);
//Eachupdatecreatesadeadtuplebutkeepslivecountsame(it'sanUPDATE)
bloatDead+=Math.ceil(rate/10);
renderBloat();
