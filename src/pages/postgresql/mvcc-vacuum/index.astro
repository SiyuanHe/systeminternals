<div class="snap-rowcommitted"><span>150</span><span>—</span><span>alice</span><span>$500</span></div>
<div class="snap-rowcommitted"><span>160</span><span>—</span><span>bob</span><span>$300</span></div>
`;
document.getElementById('snapExplanation').innerHTML='<p>Twosessionswilloperateconcurrently.Watchhowsnapshotisolationensureseachseesaconsistentview.</p>';
