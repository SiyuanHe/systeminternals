<script is:inline>
//==========SECTION1:TABLEHEAP==========

lettuples=[];
letcurrentTxn=100;
letctidCounter=0;
constnames=['alice','bob','carol','dave','eve','frank'];
constbalances=['$500','$300','$1200','$50','$800','$420'];

functionupdateHeapStats(){
constlive=tuples.filter(t=>t.live).length;
constdead=tuples.filter(t=>!t.live).length;
document.getElementById('liveCount').textContent=String(live);
document.getElementById('deadCount').textContent=String(dead);
document.getElementById('txnCounter').textContent=String(currentTxn);
(document.getElementById('updateBtn')).disabled=live===0;
(document.getElementById('deleteBtn')).disabled=live===0;
}

functionrenderHeap(){
constbody=document.getElementById('heapBody');
if(tuples.length===0){
body.innerHTML='<div class="heap-empty">Tableisempty—INSERTsomerows!</div>';
updateHeapStats();
return;
}
body.innerHTML=tuples.map(t=>`
<div class="heap-row${t.live?'live':'dead'}">
<span>${t.ctid}</span>
<span>${t.xmin}</span>
<span>${t.xmax??'—'}</span>
<span>${t.data}</span>
<span class="row-status">${t.live?'●LIVE':'✗DEAD'}</span>
</div>
`).join('');
updateHeapStats();
}

functionsetHeapStatus(badge,cls,text){
document.getElementById('heapBadge').className='status-badge'+cls;
document.getElementById('heapBadge').textContent=badge;
document.getElementById('heapStatusText').textContent=text;
}

document.getElementById('insertBtn')?.addEventListener('click',()=>{
constidx=tuples.filter(t=>t.live).length%names.length;
constname=names[idx];
constbalance=balances[idx];
currentTxn++;
ctidCounter++;
tuples.push({
ctid:`(0,${ctidCounter})`,
xmin:currentTxn,
xmax:null,
data:`${name},${balance}`,
live:true,
name
});
setHeapStatus('Insert','insert',`Txn${currentTxn}:INSERT(${name},${balance})→newtupleat(0,${ctidCounter})`);
renderHeap();
});

document.getElementById('updateBtn')?.addEventListener('click',()=>{
constliveTuples=tuples.filter(t=>t.live);
if(liveTuples.length===0)return;
consttarget=liveTuples[Math.floor(Math.random()*liveTuples.length)];
currentTxn++;
//Markolddead
target.xmax=currentTxn;
target.live=false;
//Insertnewversion
ctidCounter++;
constnewBalance='$'+(Math.floor(Math.random()*2000));
tuples.push({
ctid:`(0,${ctidCounter})`,
xmin:currentTxn,
xmax:null,
data:`${target.name},${newBalance}`,
live:true,
name:target.name
});
setHeapStatus('Update','update',`Txn${currentTxn}:UPDATE${target.name}→old${target.ctid}dead(xmax=${currentTxn}),newat(0,${ctidCounter})`);
renderHeap();
});

document.getElementById('deleteBtn')?.addEventListener('click',()=>{
constliveTuples=tuples.filter(t=>t.live);
if(liveTuples.length===0)return;
consttarget=liveTuples[Math.floor(Math.random()*liveTuples.length)];
currentTxn++;
target.xmax=currentTxn;
target.live=false;
setHeapStatus('Delete','delete',`Txn${currentTxn}:DELETE${target.name}→${target.ctid}dead(xmax=${currentTxn})`);
renderHeap();
});

document.getElementById('resetHeapBtn')?.addEventListener('click',()=>{
tuples=[];
currentTxn=100;
