  .scan-flow { font-size: 0.75rem; font-family: 'Monaco','Menlo',monospace; color: #888; margin-bottom: 8px; }
  .heap-hop { color: #f97316; font-weight: 600; }
  .skip-heap { color: #34d399; font-weight: 600; }
  .scan-card code { display: block; background: rgba(0,0,0,0.3); padding: 6px 10px; border-radius: 6px; font-size: 0.75rem; color: #60a5fa; }

  /* Page Split */
