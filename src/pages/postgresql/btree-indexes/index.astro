  .split-viz { display: flex; align-items: center; gap: 20px; margin-bottom: 16px; justify-content: center; flex-wrap: wrap; }
  .split-label { font-size: 0.8rem; color: #888; margin-bottom: 8px; text-align: center; }
  .split-page { display: flex; gap: 3px; padding: 10px; background: rgba(0,0,0,0.2); border: 1px solid rgba(96,165,250,0.3); border-radius: 10px; justify-content: center; min-width: 120px; }
  :global(.sp-key) { padding: 6px 10px; border-radius: 4px; font-size: 0.8rem; font-weight: 700; font-family: 'Monaco','Menlo',monospace; background: rgba(96,165,250,0.15); color: #93c5fd; animation: msgAppear 0.3s ease-out; }
  :global(.sp-key.new) { background: rgba(52,211,153,0.2); color: #34d399; border: 1px solid rgba(52,211,153,0.4); }
  :global(.sp-key.promoted) { background: rgba(167,139,250,0.2); color: #a78bfa; border: 1px solid rgba(167,139,250,0.4); }
  @keyframes msgAppear { from { opacity: 0; transform: scale(0.8); } to { opacity: 1; transform: scale(1); } }
  .split-arrow { font-size: 2rem; color: #60a5fa; }
  .split-pages { display: flex; gap: 12px; }
  .split-new-key { font-size: 0.8rem; color: #a78bfa; text-align: center; margin-top: 8px; }
  .split-actions { display: flex; gap: 12px; justify-content: center; margin-bottom: 12px; }
  .split-info { font-size: 0.9rem; color: #888; text-align: center; }

  /* Cost Estimation */
  .cost-section { margin-bottom: 50px; }
  .cost-controls { margin-bottom: 24px; }
  .slider-group { margin-bottom: 16px; }
  .slider-group label { color: #ccc; font-size: 0.95rem; display: block; margin-bottom: 8px; }
  .slider-group strong { color: #60a5fa; }
  .cost-bars { display: flex; flex-direction: column; gap: 16px; margin-bottom: 16px; }
  .cost-bar-group { }
  .cost-bar-label { font-size: 0.85rem; color: #ccc; margin-bottom: 6px; font-weight: 600; }
  .cost-bar-track { height: 28px; background: rgba(255,255,255,0.05); border-radius: 6px; overflow: hidden; margin-bottom: 4px; }
  .cost-bar-fill { height: 100%; border-radius: 6px; transition: width 0.5s ease; }
  .seq-fill { background: linear-gradient(90deg, #f97316, #ef4444); }
  .idx-fill { background: linear-gradient(90deg, #34d399, #60a5fa); }
  .cost-bar-value { font-size: 0.8rem; color: #888; text-align: right; }
  .cost-verdict { padding: 14px 18px; border-radius: 10px; font-size: 0.9rem; line-height: 1.6; }

  /* Explain */
  .explain-section { margin-bottom: 50px; }
  .explain-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .explain-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 24px; }
  .explain-card h3 { font-size: 1rem; color: #fff; margin-bottom: 10px; }
  .explain-card p { color: #aaa; line-height: 1.6; font-size: 0.9rem; }
  .explain-card strong { color: #60a5fa; }
  .explain-card code { background: rgba(0,0,0,0.3); padding: 2px 6px; border-radius: 4px; font-size: 0.85rem; color: #34d399; }
  .highlight-card { background: linear-gradient(135deg, rgba(96,165,250,0.08), rgba(52,211,153,0.08)); border-color: rgba(96,165,250,0.3); }

  .viz-footer { text-align: center; color: #666; font-size: 0.9rem; padding: 20px 0; border-top: 1px solid rgba(255,255,255,0.1); margin-bottom: 30px; }
  .viz-footer a { color: #60a5fa; }
  .share-buttons { display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; }
  .share-buttons span { color: #666; }
  .share-btn { padding: 10px 20px; background: rgba(255,255,255,0.1); border-radius: 8px; color: #fff; font-size: 0.9rem; transition: background 0.2s; }
  .share-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  @media (max-width: 768px) {
    .viz-header h1 { font-size: 1.8rem; }
    .explain-grid { grid-template-columns: 1fr; }
    .scan-cards { grid-template-columns: 1fr; }
    .split-viz { flex-direction: column; }
  }
</style>

<script>
  // ========== B-TREE IMPLEMENTATION ==========
  const ORDER = 4; // max keys per node
  interface BTreeNode { keys: number[]; children: BTreeNode[]; isLeaf: boolean; }

  let btRoot: BTreeNode = { keys: [], children: [], isLeaf: true };
  let allKeys: number[] = [];

  function btInsert(key: number) {
    if (allKeys.includes(key)) return;
    allKeys.push(key);
    const root = btRoot;
    if (root.keys.length === ORDER) {
      const newRoot: BTreeNode = { keys: [], children: [root], isLeaf: false };
      btSplitChild(newRoot, 0);
      btRoot = newRoot;
      btInsertNonFull(newRoot, key);
    } else {
      btInsertNonFull(root, key);
    }
  }

  function btInsertNonFull(node: BTreeNode, key: number) {
    let i = node.keys.length - 1;
    if (node.isLeaf) {
      while (i >= 0 && key < node.keys[i]) i--;
      node.keys.splice(i + 1, 0, key);
    } else {
      while (i >= 0 && key < node.keys[i]) i--;
      i++;
      if (node.children[i].keys.length === ORDER) {
        btSplitChild(node, i);
        if (key > node.keys[i]) i++;
      }
      btInsertNonFull(node.children[i], key);
    }
  }

  function btSplitChild(parent: BTreeNode, idx: number) {
    const child = parent.children[idx];
    const mid = Math.floor(ORDER / 2);
    const newNode: BTreeNode = { keys: child.keys.splice(mid + 1), children: [], isLeaf: child.isLeaf };
    const midKey = child.keys.pop()!;
    if (!child.isLeaf) {
      newNode.children = child.children.splice(mid + 1);
    }
    parent.keys.splice(idx, 0, midKey);
    parent.children.splice(idx + 1, 0, newNode);
  }

  function btSearch(node: BTreeNode, key: number): number[] {
    const path: number[] = [];
    let current = node;
    while (true) {
      path.push(current.keys[0] || 0); // track visited
      let i = 0;
      while (i < current.keys.length && key > current.keys[i]) i++;
      if (i < current.keys.length && key === current.keys[i]) return path;
      if (current.isLeaf) return path;
      current = current.children[i];
    }
  }

  function btHeight(node: BTreeNode): number {
    if (node.isLeaf) return 1;
    return 1 + btHeight(node.children[0]);
  }

  function btNodeCount(node: BTreeNode): number {
    if (node.isLeaf) return 1;
    return 1 + node.children.reduce((sum, c) => sum + btNodeCount(c), 0);
  }

  // ========== RENDER B-TREE ==========
  function renderBTree(highlightKey?: number) {
    const viz = document.getElementById('btreeViz')!;
    viz.innerHTML = '';
    if (allKeys.length === 0) {
      viz.innerHTML = '<div style="text-align:center;color:#666;padding:30px">Empty tree — insert some keys!</div>';
      return;
    }

    const levels: BTreeNode[][] = [];
    let currentLevel = [btRoot];
    while (currentLevel.length > 0) {
      levels.push(currentLevel);
      const nextLevel: BTreeNode[] = [];
      currentLevel.forEach(n => { if (!n.isLeaf) nextLevel.push(...n.children); });
      currentLevel = nextLevel;
    }

    const labels = ['Root', 'Internal', 'Leaf'];
    levels.forEach((level, li) => {
      const levelEl = document.createElement('div');
      levelEl.className = 'bt-level';
      const labelText = li === 0 ? 'Root' : li === levels.length - 1 ? 'Leaf' : 'Internal';
      levelEl.innerHTML = `<div class="bt-level-label">${labelText}</div>`;

      level.forEach(node => {
        const nodeEl = document.createElement('div');
        const cls = li === 0 ? 'root' : node.isLeaf ? 'leaf' : '';
        nodeEl.className = `bt-node ${cls}`;
        nodeEl.innerHTML = node.keys.map(k =>
          `<span class="bt-key ${highlightKey === k ? 'found' : ''}">${k}</span>`
        ).join('');
        levelEl.appendChild(nodeEl);
      });

      viz.appendChild(levelEl);
    });

    document.getElementById('btreeKeyCount')!.textContent = String(allKeys.length);
    document.getElementById('btreeHeight')!.textContent = String(btHeight(btRoot));
    document.getElementById('btreeNodeCount')!.textContent = String(btNodeCount(btRoot));
    document.getElementById('btreePageReads')!.textContent = String(btHeight(btRoot));
  }

  document.getElementById('btreeInsertBtn')?.addEventListener('click', () => {
    const input = document.getElementById('btreeKey') as HTMLInputElement;
    const key = parseInt(input.value);
    if (isNaN(key) || key < 1 || key > 999) {
      document.getElementById('btreeInfo')!.textContent = '⚠️ Enter a key between 1-999';
      return;
    }
    if (allKeys.includes(key)) {
      document.getElementById('btreeInfo')!.textContent = `Key ${key} already exists`;
      return;
    }
    btInsert(key);
    renderBTree(key);
    input.value = '';
    document.getElementById('btreeInfo')!.textContent = `Inserted ${key}. Tree height: ${btHeight(btRoot)}`;
  });

  document.getElementById('btreeInsert5Btn')?.addEventListener('click', () => {
    const inserted: number[] = [];
    for (let i = 0; i < 5; i++) {
      let key: number;
      do { key = Math.floor(Math.random() * 200) + 1; } while (allKeys.includes(key));
      btInsert(key);
      inserted.push(key);
    }
    renderBTree();
    document.getElementById('btreeInfo')!.textContent = `Inserted: ${inserted.sort((a, b) => a - b).join(', ')}`;
  });

  document.getElementById('btreeSearchBtn')?.addEventListener('click', () => {
    const input = document.getElementById('btreeKey') as HTMLInputElement;
    const key = parseInt(input.value);
    if (isNaN(key)) {
      document.getElementById('btreeInfo')!.textContent = '⚠️ Enter a key to search';
      return;
    }
    const path = btSearch(btRoot, key);
    const found = allKeys.includes(key);
    renderBTree(found ? key : undefined);
    document.getElementById('btreeInfo')!.textContent = found
      ? `✅ Found ${key} in ${path.length} page read(s)`
      : `❌ Key ${key} not found (searched ${path.length} page(s))`;
  });

  document.getElementById('btreeResetBtn')?.addEventListener('click', () => {
    btRoot = { keys: [], children: [], isLeaf: true };
    allKeys = [];
    renderBTree();
    document.getElementById('btreeInfo')!.textContent = 'Tree reset. Order (max keys per node): 4';
  });

  // ========== PAGE SPLIT DEMO ==========
  let splitKeys: number[] = [];

  document.getElementById('splitFillBtn')?.addEventListener('click', () => {
    splitKeys = [10, 20, 30, 40];
    const page = document.getElementById('splitPageBefore')!;
    page.innerHTML = splitKeys.map(k => `<span class="sp-key">${k}</span>`).join('');
    document.getElementById('splitAfter')!.style.display = 'none';
    document.getElementById('splitArrow')!.style.display = 'none';
    (document.getElementById('splitDoBtn') as HTMLButtonElement).disabled = false;
    document.getElementById('splitInfo')!.textContent = 'Page full (4 keys). Now insert key 25 — triggers split!';
  });

  document.getElementById('splitDoBtn')?.addEventListener('click', () => {
    // Insert 25 into [10, 20, 30, 40] — splits at median
    const page = document.getElementById('splitPageBefore')!;
    page.innerHTML = splitKeys.map(k => `<span class="sp-key">${k}</span>`).join('') + `<span class="sp-key new">25</span>`;

    setTimeout(() => {
      document.getElementById('splitArrow')!.style.display = 'block';
      document.getElementById('splitAfter')!.style.display = 'block';
      document.getElementById('splitPageLeft')!.innerHTML = [10, 20].map(k => `<span class="sp-key">${k}</span>`).join('');
      document.getElementById('splitPageRight')!.innerHTML = [30, 40].map(k => `<span class="sp-key">${k}</span>`).join('') ;
      // Show promoted key
      document.getElementById('splitPageRight')!.insertAdjacentHTML('afterbegin', '<span class="sp-key new">25</span>');
      document.getElementById('splitInfo')!.textContent = 'Split! Key 25 goes right. Median (25) promoted to parent. Left: [10,20], Right: [25,30,40].';
      (document.getElementById('splitDoBtn') as HTMLButtonElement).disabled = true;
    }, 400);
  });

  document.getElementById('splitResetBtn')?.addEventListener('click', () => {
    splitKeys = [];
    document.getElementById('splitPageBefore')!.innerHTML = '';
    document.getElementById('splitAfter')!.style.display = 'none';
    document.getElementById('splitArrow')!.style.display = 'none';
    (document.getElementById('splitDoBtn') as HTMLButtonElement).disabled = true;
    document.getElementById('splitInfo')!.textContent = 'Click "Fill Page" to load a page to capacity, then split it.';
  });

  // ========== COST ESTIMATION ==========
  function updateCost() {
    const rows = parseInt((document.getElementById('costRowsSlider') as HTMLInputElement).value);
    const sel = parseFloat((document.getElementById('costSelSlider') as HTMLInputElement).value);

    document.getElementById('costRowsLabel')!.textContent = rows.toLocaleString();
    document.getElementById('costSelLabel')!.textContent = sel.toFixed(1);

    // Simplified cost model
    const heapPages = Math.ceil(rows / 100); // ~100 rows per 8KB page
    const seqCost = heapPages; // read all pages

    const matchingRows = Math.ceil(rows * sel / 100);
    const treeHeight = Math.ceil(Math.log(rows) / Math.log(100)); // fanout ~100
    const leafReads = Math.ceil(matchingRows / 100);
    const heapFetches = matchingRows; // random I/O
    const idxCost = treeHeight + leafReads + heapFetches * 4; // random I/O is ~4x costlier

    const maxCost = Math.max(seqCost, idxCost);
    const seqPct = Math.min(100, seqCost / maxCost * 100);
    const idxPct = Math.min(100, idxCost / maxCost * 100);

    document.getElementById('costSeqBar')!.style.width = seqPct + '%';
    document.getElementById('costSeqVal')!.textContent = `~${seqCost.toLocaleString()} page reads (sequential)`;
    document.getElementById('costIdxBar')!.style.width = idxPct + '%';
    document.getElementById('costIdxVal')!.textContent = `~${idxCost.toLocaleString()} page reads (random I/O weighted)`;

    const verdict = document.getElementById('costVerdict')!;
    if (idxCost < seqCost) {
      verdict.style.background = 'rgba(52,211,153,0.08)';
      verdict.style.border = '1px solid rgba(52,211,153,0.25)';
      verdict.style.color = '#6ee7b7';
      verdict.innerHTML = `✅ <strong>Index Scan wins!</strong> At ${sel}% selectivity, reading ${matchingRows.toLocaleString()} rows via index is faster than scanning ${heapPages.toLocaleString()} pages.`;
    } else {
      verdict.style.background = 'rgba(249,115,22,0.08)';
      verdict.style.border = '1px solid rgba(249,115,22,0.25)';
      verdict.style.color = '#fdba74';
      verdict.innerHTML = `⚠️ <strong>Sequential Scan wins!</strong> At ${sel}% selectivity (${matchingRows.toLocaleString()} rows), random I/O from index is costlier than just reading the whole table.`;
    }
  }

  document.getElementById('costRowsSlider')?.addEventListener('input', updateCost);
  document.getElementById('costSelSlider')?.addEventListener('input', updateCost);

  // ========== INIT ==========
  renderBTree();
  updateCost();
</script>
</BaseLayout>
