      explain: "On COMMIT, WAL buffers are flushed (fsync'd) to disk. This is the durability point — the data is now safe even if the server crashes."
    },
    {
      stage: 3,
      detail: "COMMIT → OK ✅",
      explain: "The client receives acknowledgment. The INSERT is committed and durable. Note: the actual data file has NOT been updated yet!"
    },
    {
      stage: 4,
      detail: "Background writer...",
      explain: "Eventually, the background writer or checkpointer lazily writes the dirty page to the data file. This is asynchronous — no client waiting."
    },
    {
      stage: 5,
      detail: "All dirty pages flushed",
      explain: "At checkpoint time, all dirty buffers are flushed to data files and a checkpoint record is written to WAL. Recovery only needs to replay from here."
    }
  ];

  function resetWalPipeline() {
    for (var i = 0; i < 6; i++) {
      var stage = document.getElementById('walStage' + i);
      if (stage) {
        stage.classList.remove('active');
        stage.classList.remove('done');
      }
      if (i < 5) {
        var arrow = document.getElementById('walArrow' + i);
        if (arrow) arrow.classList.remove('active');
      }
    }
    document.getElementById('walDetail0').textContent = 'Waiting...';
    document.getElementById('walDetail1').textContent = 'Shared memory';
    document.getElementById('walDetail2').textContent = 'pg_wal/';
    document.getElementById('walDetail3').textContent = 'COMMIT ok';
    document.getElementById('walDetail4').textContent = 'Lazy write';
    document.getElementById('walDetail5').textContent = 'Sync all';
  }

  function renderWalStep(idx) {
    var step = walSteps[idx];
    // Mark previous stages as done
    for (var i = 0; i < step.stage; i++) {
      var s = document.getElementById('walStage' + i);
      if (s) { s.classList.remove('active'); s.classList.add('done'); }
      if (i > 0) {
        var a = document.getElementById('walArrow' + (i - 1));
        if (a) a.classList.add('active');
      }
    }
    // Mark current active
    var cur = document.getElementById('walStage' + step.stage);
    if (cur) { cur.classList.remove('done'); cur.classList.add('active'); }
    if (step.stage > 0) {
      var prevArrow = document.getElementById('walArrow' + (step.stage - 1));
      if (prevArrow) prevArrow.classList.add('active');
    }
    // Update detail
    document.getElementById('walDetail' + step.stage).textContent = step.detail;
    // Update explanation
    document.getElementById('walExplanation').innerHTML = '<p>' + step.explain + '</p>';

    // Update LSN on WAL disk step
    if (step.stage >= 2) {
      document.getElementById('walLsnValue').textContent = '0/14C0000';
      var seg0Fill = document.querySelector('#walSeg0 .seg-fill');
      if (seg0Fill) seg0Fill.style.width = '85%';
    }
  }

  document.getElementById('walStepBtn').addEventListener('click', function() {
    walStep = 0;
    resetWalPipeline();
    renderWalStep(0);
    document.getElementById('walNextBtn').disabled = false;
  });

  document.getElementById('walNextBtn').addEventListener('click', function() {
    if (walStep < walSteps.length - 1) {
      walStep++;
      renderWalStep(walStep);
      if (walStep >= walSteps.length - 1) {
        document.getElementById('walNextBtn').disabled = true;
        // Mark last as done
        var last = document.getElementById('walStage5');
        if (last) { last.classList.remove('active'); last.classList.add('done'); }
      }
    }
  });

  document.getElementById('walResetBtn').addEventListener('click', function() {
    walStep = -1;
    resetWalPipeline();
    document.getElementById('walNextBtn').disabled = true;
    document.getElementById('walExplanation').innerHTML = '<p>Click "Run INSERT Step-Through" to see how a single INSERT flows through WAL to disk.</p>';
    document.getElementById('walLsnValue').textContent = '0/1480000';
    var seg0Fill = document.querySelector('#walSeg0 .seg-fill');
    if (seg0Fill) seg0Fill.style.width = '72%';
  });

  // ========== SECTION 2: SYNCHRONOUS_COMMIT ==========
  var syncLevels = {
    off: {
      ackAfter: 0,
      durability: "None — data can be lost on crash (up to 3× wal_writer_delay)",
      latency: "~0ms (no fsync wait)",
      risk: "Recent commits may vanish after crash. Good for unimportant data."
    },
    on: {
      ackAfter: 1,
      durability: "Full — committed data survives local crash",
      latency: "~1-2ms (local fsync)",
      risk: "None — standard PostgreSQL guarantee"
    },
    local: {
      ackAfter: 1,
      durability: "Local only — survives local crash, not standby failure",
      latency: "~1-2ms (local fsync)",
      risk: "If primary is destroyed, undelivered WAL is lost"
    },
    remote_write: {
      ackAfter: 2,
      durability: "Remote write — standby received but hasn't flushed to disk",
      latency: "~5-50ms (network round-trip)",
      risk: "Standby OS crash could lose data. Server crash is safe."
    },
    remote_apply: {
      ackAfter: 4,
      durability: "Maximum — standby has applied the change (visible to queries)",
      latency: "~10-100ms (network + apply)",
      risk: "None — highest consistency guarantee. Reads on standby always see committed data."
    }
  };

  function updateSyncViz(level) {
    var info = syncLevels[level];
    var ackAfter = info.ackAfter;

    // Update dots and lines
    for (var i = 0; i < 5; i++) {
      var dot = document.getElementById('syncDot' + i);
      var line = document.getElementById('syncLine' + i);
      if (dot) {
        dot.className = 'sync-dot';
        if (i <= ackAfter) dot.classList.add('done');
        if (i === ackAfter) dot.classList.add('ack-point');
      }
      if (line) {
        line.className = 'sync-line';
        if (i < ackAfter) line.classList.add('done');
      }
    }
    // First dot is always done
    var dot0 = document.querySelector('#syncStep0 .sync-dot');
    if (dot0) dot0.className = 'sync-dot done';

    var ackLabels = ['WAL Buffer Write', 'Local WAL Flush', 'Remote WAL Write', 'Remote WAL Flush', 'Remote Apply'];
    document.getElementById('syncAck').textContent = '↑ Client ACK after: ' + ackLabels[ackAfter];
    document.getElementById('syncDurability').textContent = info.durability;
    document.getElementById('syncLatency').textContent = info.latency;
    document.getElementById('syncRisk').textContent = info.risk;
  }

  document.querySelectorAll('.sync-option').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.sync-option').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      updateSyncViz(btn.getAttribute('data-level'));
    });
  });

  updateSyncViz('on');

  // ========== SECTION 3: STREAMING REPLICATION ==========
  var replRunning = false;
  var replLsn = 0x1480000;
  var replStandbyLsn = 0x1480000;
  var replWriteCount = 0;
  var replSyncMode = 'async';

  function formatLsn(val) {
    var hi = Math.floor(val / 0x100000000);
    var lo = val % 0x100000000;
    return hi.toString(16).toUpperCase() + '/' + lo.toString(16).toUpperCase().padStart(7, '0');
  }

  function addWalEntry(containerId, lsn, text) {
    var log = document.getElementById(containerId);
    var entry = document.createElement('div');
    entry.className = 'repl-wal-entry new';
    entry.textContent = 'LSN ' + formatLsn(lsn) + ' — ' + text;
    log.appendChild(entry);
    log.scrollTop = log.scrollHeight;
    setTimeout(function() { entry.classList.remove('new'); }, 500);
  }

  function updateReplLag() {
    var latency = parseInt(document.getElementById('replLatencySlider').value);
    var lagMs = replRunning ? latency : 0;
    var maxLag = 2000;
    var pct = Math.min((lagMs / maxLag) * 100, 100);
    document.getElementById('replLagFill').style.width = pct + '%';
    document.getElementById('replLagValue').textContent = lagMs + ' ms';
  }

  document.getElementById('replLatencySlider').addEventListener('input', function(e) {
    document.getElementById('replLatencyValue').textContent = e.target.value + 'ms';
    updateReplLag();
  });

  document.getElementById('replStartBtn').addEventListener('click', function() {
    replRunning = true;
    document.getElementById('replStartBtn').disabled = true;
    document.getElementById('replWriteBtn').disabled = false;
  });

  document.getElementById('replWriteBtn').addEventListener('click', function() {
    if (!replRunning) return;
    replWriteCount++;
    replLsn += 0x40000;
    var ops = ['INSERT INTO orders', 'UPDATE accounts SET balance', 'DELETE FROM sessions', 'INSERT INTO logs'];
    var op = ops[replWriteCount % ops.length];

    addWalEntry('primaryWalLog', replLsn, op);
    document.getElementById('primaryLsn').textContent = formatLsn(replLsn);

    // Animate packet
    var packets = document.getElementById('replPackets');
    var pkt = document.createElement('div');
    pkt.className = 'repl-packet';
    packets.appendChild(pkt);

    var latency = parseInt(document.getElementById('replLatencySlider').value);
    updateReplLag();

    // Standby receives after latency
    var capturedLsn = replLsn;
    var capturedOp = op;
    setTimeout(function() {
      replStandbyLsn = capturedLsn;
      addWalEntry('standbyWalLog', capturedLsn, capturedOp);
      document.getElementById('standbyLsn').textContent = formatLsn(capturedLsn);
      pkt.remove();
      updateReplLag();
    }, latency);

    // If sync mode, show wait indicator
    if (replSyncMode === 'sync') {
      document.getElementById('replWriteBtn').disabled = true;
      setTimeout(function() {
        if (replRunning) document.getElementById('replWriteBtn').disabled = false;
      }, latency);
    }
  });

  document.getElementById('replResetBtn').addEventListener('click', function() {
    replRunning = false;
    replLsn = 0x1480000;
    replStandbyLsn = 0x1480000;
    replWriteCount = 0;
    document.getElementById('replStartBtn').disabled = false;
    document.getElementById('replWriteBtn').disabled = true;
    document.getElementById('primaryWalLog').innerHTML = '<div class="repl-wal-entry">LSN 0/1480000 — CHECKPOINT</div>';
    document.getElementById('standbyWalLog').innerHTML = '<div class="repl-wal-entry">LSN 0/1480000 — CHECKPOINT</div>';
    document.getElementById('primaryLsn').textContent = '0/1480000';
    document.getElementById('standbyLsn').textContent = '0/1480000';
    document.getElementById('replLagFill').style.width = '0%';
    document.getElementById('replLagValue').textContent = '0 ms';
    document.getElementById('replPackets').innerHTML = '';
  });

  document.querySelectorAll('.repl-mode').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.repl-mode').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      replSyncMode = btn.getAttribute('data-mode');
    });
  });

  // ========== SECTION 4: REPLICATION SLOTS ==========
  var slotStep = -1;
  var slotMode = ''; // 'with' or 'without'
  var slotStepsWithout = [
    {
      segments: ['active', 'active', 'active', '', ''],
      standby: { icon: '🔴', text: 'Disconnected!' },
      info: 'Standby disconnects (network failure, maintenance, etc.).',
      explain: 'The standby has gone offline. Without a replication slot, the primary has no reason to keep old WAL segments.'
    },
    {
      segments: ['active', 'active', 'active', 'active', ''],
      standby: { icon: '🔴', text: 'Still disconnected...' },
      info: 'Primary continues accepting writes, generating new WAL.',
      explain: 'New WAL segments are created as writes continue. The primary is running out of WAL space budget.'
    },
    {
      segments: ['recycled', 'recycled', 'active', 'active', 'active'],
      standby: { icon: '🔴', text: 'Still disconnected...' },
      info: '⚠️ Primary recycled old WAL segments (SEG 1, SEG 2)!',
      explain: 'The primary recycled segments the standby still needed! Those WAL records are gone forever.'
    },
    {
      segments: ['recycled', 'recycled', 'active', 'active', 'active'],
      standby: { icon: '💀', text: 'Cannot reconnect — must rebuild from scratch!' },
      info: '💀 Standby tries to reconnect but required WAL is gone.',
      explain: 'The standby needs SEG 1 and SEG 2 to catch up, but they were recycled. The ONLY option is pg_basebackup — a full rebuild. This can take hours for large databases.'
    }
  ];

  var slotStepsWith = [
    {
      segments: ['retained', 'retained', 'active', '', ''],
      standby: { icon: '🔴', text: 'Disconnected!' },
      info: 'Standby disconnects. Replication slot retains needed WAL.',
      explain: 'The standby has gone offline, but the replication slot tells the primary: "do NOT recycle segments this standby still needs."'
    },
    {
      segments: ['retained', 'retained', 'active', 'active', ''],
      standby: { icon: '🔴', text: 'Still disconnected...' },
      info: 'Primary continues writes. Old segments still retained by slot.',
      explain: 'New WAL accumulates, but the slot prevents recycling. ⚠️ This means pg_wal/ grows — monitor disk space!'
    },
    {
      segments: ['retained', 'retained', 'active', 'active', 'active'],
      standby: { icon: '🟡', text: 'Reconnecting...' },
      info: 'Standby comes back online and reconnects.',
      explain: 'The standby reconnects and requests WAL from where it left off. All segments are still available!'
    },
    {
      segments: ['active', 'active', 'active', 'active', 'active'],
      standby: { icon: '🟢', text: 'Connected — caught up!' },
      info: '✅ Standby replays retained WAL and catches up. No rebuild needed!',
      explain: 'The standby successfully catches up by replaying the retained WAL segments. Crisis averted. The slot can now release old segments.'
    }
  ];

  function renderSlotStep(steps, idx) {
    var step = steps[idx];
    var segs = document.getElementById('slotSegments');
    var segEls = segs.querySelectorAll('.slot-seg');
    for (var i = 0; i < segEls.length; i++) {
      segEls[i].className = 'slot-seg';
      if (step.segments[i]) segEls[i].classList.add(step.segments[i]);
    }
    document.getElementById('slotStandbyStatus').innerHTML =
      '<span class="slot-status-icon">' + step.standby.icon + '</span>' +
      '<span class="slot-status-text">' + step.standby.text + '</span>';
    document.getElementById('slotInfo').textContent = step.info;
    document.getElementById('slotExplanation').innerHTML = '<p>' + step.explain + '</p>';
  }

  document.getElementById('slotWithoutBtn').addEventListener('click', function() {
    slotMode = 'without';
    slotStep = 0;
    renderSlotStep(slotStepsWithout, 0);
    document.getElementById('slotNextBtn').disabled = false;
  });

  document.getElementById('slotWithBtn').addEventListener('click', function() {
    slotMode = 'with';
    slotStep = 0;
    renderSlotStep(slotStepsWith, 0);
    document.getElementById('slotNextBtn').disabled = false;
  });

  document.getElementById('slotNextBtn').addEventListener('click', function() {
    var steps = slotMode === 'with' ? slotStepsWith : slotStepsWithout;
    if (slotStep < steps.length - 1) {
      slotStep++;
      renderSlotStep(steps, slotStep);
      if (slotStep >= steps.length - 1) {
        document.getElementById('slotNextBtn').disabled = true;
      }
    }
  });

  document.getElementById('slotResetBtn').addEventListener('click', function() {
    slotStep = -1;
    slotMode = '';
    document.getElementById('slotNextBtn').disabled = true;
    var segs = document.getElementById('slotSegments');
    var segEls = segs.querySelectorAll('.slot-seg');
    for (var i = 0; i < segEls.length; i++) {
      segEls[i].className = 'slot-seg';
      if (i < 3) segEls[i].classList.add('active');
    }
    document.getElementById('slotStandbyStatus').innerHTML =
      '<span class="slot-status-icon">🟢</span><span class="slot-status-text">Connected — replaying WAL</span>';
    document.getElementById('slotInfo').textContent = 'Standby is connected and caught up.';
    document.getElementById('slotExplanation').innerHTML = '<p>Choose a scenario to see what happens when the standby disconnects.</p>';
  });

  // ========== SECTION 5: LOGICAL REPLICATION ==========
  var logicalNextId = 2;
  var logicalPubRows = [
    { id: 1, product: 'Widget A', qty: 10, status: 'shipped' }
  ];
  var logicalRunning = false;

  function renderLogicalTable(containerId, rows) {
    var body = document.getElementById(containerId);
    body.innerHTML = rows.map(function(r) {
      var cls = r.cls || '';
      return '<div class="logical-row ' + cls + '">' +
        '<span>' + r.id + '</span>' +
        '<span>' + r.product + '</span>' +
        '<span>' + r.qty + '</span>' +
        '<span>' + r.status + '</span></div>';
    }).join('');
  }

  document.getElementById('logicalStartBtn').addEventListener('click', function() {
    logicalRunning = true;
    document.getElementById('logicalStartBtn').disabled = true;
    document.getElementById('logicalInsertBtn').disabled = false;
    document.getElementById('logicalUpdateBtn').disabled = false;
    document.getElementById('logicalDeleteBtn').disabled = false;
  });

  document.getElementById('logicalInsertBtn').addEventListener('click', function() {
    if (!logicalRunning) return;
    var products = ['Gadget B', 'Gizmo C', 'Doohickey D', 'Thingamajig E'];
    var prod = products[(logicalNextId - 2) % products.length];
    var qty = Math.floor(Math.random() * 50) + 1;
    var row = { id: logicalNextId, product: prod, qty: qty, status: 'pending', cls: 'new' };
    logicalNextId++;
    logicalPubRows.push(row);
    renderLogicalTable('logicalPubBody', logicalPubRows);

    document.getElementById('logicalStreamMsg').textContent = 'INSERT: {id:' + row.id + ', product:"' + prod + '", qty:' + qty + '}';

    setTimeout(function() {
      renderLogicalTable('logicalSubBody', logicalPubRows.map(function(r) { return Object.assign({}, r); }));
    }, 400);
  });

  document.getElementById('logicalUpdateBtn').addEventListener('click', function() {
    if (!logicalRunning || logicalPubRows.length === 0) return;
    var active = logicalPubRows.filter(function(r) { return r.cls !== 'deleted'; });
    if (active.length === 0) return;
    var target = active[active.length - 1];
    target.qty = target.qty + 5;
    target.status = 'updated';
    target.cls = 'updated';
    renderLogicalTable('logicalPubBody', logicalPubRows);

    document.getElementById('logicalStreamMsg').textContent = 'UPDATE: {id:' + target.id + ', qty:' + target.qty + ', status:"updated"}';

    setTimeout(function() {
      renderLogicalTable('logicalSubBody', logicalPubRows.map(function(r) { return Object.assign({}, r); }));
    }, 400);
  });

  document.getElementById('logicalDeleteBtn').addEventListener('click', function() {
    if (!logicalRunning || logicalPubRows.length === 0) return;
    var active = logicalPubRows.filter(function(r) { return r.cls !== 'deleted'; });
    if (active.length === 0) return;
    var target = active[0];
    target.cls = 'deleted';
    renderLogicalTable('logicalPubBody', logicalPubRows);

    document.getElementById('logicalStreamMsg').textContent = 'DELETE: {id:' + target.id + '}';

    setTimeout(function() {
      renderLogicalTable('logicalSubBody', logicalPubRows.map(function(r) { return Object.assign({}, r); }));
    }, 400);
  });

  document.getElementById('logicalResetBtn').addEventListener('click', function() {
    logicalRunning = false;
    logicalNextId = 2;
    logicalPubRows = [{ id: 1, product: 'Widget A', qty: 10, status: 'shipped' }];
    document.getElementById('logicalStartBtn').disabled = false;
    document.getElementById('logicalInsertBtn').disabled = true;
    document.getElementById('logicalUpdateBtn').disabled = true;
    document.getElementById('logicalDeleteBtn').disabled = true;
    document.getElementById('logicalStreamMsg').textContent = '';
    renderLogicalTable('logicalPubBody', logicalPubRows);
    renderLogicalTable('logicalSubBody', logicalPubRows);
  });

  // ========== SECTION 6: POINT-IN-TIME RECOVERY ==========
  var pitrEvents = [
    { time: 0, label: '🟡 Base Backup', type: 'backup' },
    { time: 15, label: 'INSERT 1000 orders', type: 'event' },
    { time: 30, label: 'Schema migration', type: 'event' },
    { time: 50, label: 'UPDATE accounts', type: 'event' },
    { time: 65, label: 'INSERT 500 users', type: 'event' },
    { time: 80, label: '💀 Accidental DROP TABLE', type: 'disaster' },
    { time: 100, label: 'Now', type: 'event' }
  ];

  document.getElementById('pitrSetupBtn').addEventListener('click', function() {
    var viz = document.getElementById('pitrViz');
    var markers = pitrEvents.map(function(e) {
      var dotClass = e.type === 'backup' ? 'backup' : (e.type === 'disaster' ? 'disaster' : 'event');
      return '<div class="pitr-marker" style="left:' + e.time + '%;">' +
        '<div class="pitr-marker-dot ' + dotClass + '"></div>' +
        '<div class="pitr-marker-label">' + e.label + '</div></div>';
    }).join('');

    viz.innerHTML =
      '<div class="pitr-timeline">' +
        '<div class="pitr-track">' +
          '<div class="pitr-wal-fill" style="width: 100%;"></div>' +
          markers +
          '<div class="pitr-recovery-cursor" id="pitrCursor" style="left: 50%;"></div>' +
        '</div>' +
      '</div>';

    var recovery = document.getElementById('pitrRecovery');
    recovery.style.display = 'block';
    document.getElementById('pitrSlider').value = '50';
    updatePitr(50);
  });

  function updatePitr(val) {
    var cursor = document.getElementById('pitrCursor');
    if (cursor) cursor.style.left = val + '%';

    // Find which events are recoverable
    var before = pitrEvents.filter(function(e) { return e.time <= val; });
    var after = pitrEvents.filter(function(e) { return e.time > val; });
    var disasterIncluded = before.some(function(e) { return e.type === 'disaster'; });

    var hours = Math.floor(val * 0.24);
    var mins = Math.floor((val * 0.24 - hours) * 60);
    var timeStr = String(hours).padStart(2, '0') + ':' + String(mins).padStart(2, '0');
    document.getElementById('pitrTimeValue').textContent = timeStr + ' (T+' + val + '%)';

    var info = '';
    if (disasterIncluded) {
      info = '⚠️ Recovery point INCLUDES the DROP TABLE disaster. Move the slider left to recover before it.';
    } else if (val >= 80) {
      info = '💀 This point is after the disaster. Data is lost.';
    } else {
      info = '✅ Recovery to this point preserves all data. ' + before.length + ' events recovered, ' + after.length + ' events after this point.';
    }
    document.getElementById('pitrRecoveryInfo').textContent = info;
  }

  var pitrSlider = document.getElementById('pitrSlider');
  if (pitrSlider) {
    pitrSlider.addEventListener('input', function(e) {
      updatePitr(parseInt(e.target.value));
    });
  }

  document.getElementById('pitrResetBtn').addEventListener('click', function() {
    document.getElementById('pitrViz').innerHTML = '<div class="pitr-empty">Click "Setup Timeline" to visualize a PITR scenario</div>';
    document.getElementById('pitrRecovery').style.display = 'none';
  });
</script>
</BaseLayout>
