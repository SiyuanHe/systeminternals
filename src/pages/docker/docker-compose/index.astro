    .health-services { flex-direction: column; }
  }
</style>

<script is:inline>
  // ============================================================
  // DOCKER COMPOSE INTERNALS INTERACTIVE VISUALIZATIONS
  // ============================================================

  // --- Compose Lifecycle ---
  var composeSteps = [
    {
      icon: "📄", label: "Parse YAML", sub: "validate config",
      detail: 'Compose reads and parses <code>docker-compose.yml</code> (or <code>compose.yaml</code>). It validates the schema, resolves <strong>variable interpolation</strong> (<code>${VAR}</code>), merges override files (<code>docker-compose.override.yml</code>), and normalizes all service definitions into an internal model.'
    },
    {
      icon: "🕸️", label: "Build DAG", sub: "resolve dependencies",
      detail: 'Compose analyzes <code>depends_on</code> declarations across all services and builds a <strong>directed acyclic graph</strong>. It performs a topological sort to determine the correct startup order. If a cycle is detected, Compose exits with an error — circular dependencies are forbidden.'
    },
    {
      icon: "🌐", label: "Create Network", sub: "bridge + DNS",
      detail: 'Compose creates a <strong>project-scoped bridge network</strong> (e.g., <code>myapp_default</code>). This network includes Docker\'s embedded DNS server at <code>127.0.0.11</code>, which resolves service names to container IPs. Each service gets a DNS A record matching its service name.'
    },
    {
      icon: "💾", label: "Create Volumes", sub: "named volumes",
      detail: 'Any <strong>named volumes</strong> declared in the top-level <code>volumes:</code> section are created if they don\'t already exist. Docker allocates storage under <code>/var/lib/docker/volumes/</code>. Existing volumes are reused — this is how data persists across <code>docker compose down</code> and <code>up</code> cycles.'
    },
    {
      icon: "📥", label: "Pull / Build", sub: "images ready",
      detail: 'For each service, Compose either <strong>pulls</strong> the specified image from a registry or <strong>builds</strong> it from a Dockerfile (if <code>build:</code> is specified). Images are pulled in parallel when possible. Build cache is used to skip unchanged layers.'
    },
    {
      icon: "🚀", label: "Start Services", sub: "in DAG order",
      detail: 'Services start in <strong>topological order</strong>. For each service, Compose calls <code>container create</code> then <code>container start</code>. If <code>depends_on</code> has <code>condition: service_healthy</code>, Compose waits for the dependency\'s health check to pass before starting the dependent service.'
    }
  ];

  var composeCurrentStep = -1;
  var composeAutoInterval = null;

  function renderComposeTimeline() {
    var el = document.getElementById("composeTimeline");
    var html = "";
    for (var i = 0; i < composeSteps.length; i++) {
      var cls = "lc-step";
      if (i === composeCurrentStep) cls += " active";
      else if (i < composeCurrentStep) cls += " done";
      html += '<div class="' + cls + '"><div class="lc-icon">' + composeSteps[i].icon + '</div><div class="lc-label">' + composeSteps[i].label + '</div><div class="lc-sub">' + composeSteps[i].sub + '</div></div>';
    }
    el.innerHTML = html;
  }

  function showComposeDetail() {
    var el = document.getElementById("composeDetail");
    if (composeCurrentStep < 0 || composeCurrentStep >= composeSteps.length) {
      el.innerHTML = '<div class="log-empty">Click "Next Step" to begin the compose lifecycle...</div>';
      return;
    }
    var s = composeSteps[composeCurrentStep];
    el.innerHTML = '<strong>Step ' + (composeCurrentStep + 1) + '/' + composeSteps.length + ': ' + s.label + '</strong><br><br>' + s.detail;
  }

  document.getElementById("composeNextBtn").addEventListener("click", function() {
    if (composeCurrentStep < composeSteps.length - 1) {
      composeCurrentStep++;
      renderComposeTimeline();
      showComposeDetail();
    }
    if (composeCurrentStep >= composeSteps.length - 1) this.disabled = true;
  });

  document.getElementById("composeAutoBtn").addEventListener("click", function() {
    if (composeAutoInterval) return;
    var btn = this;
    btn.disabled = true;
    composeCurrentStep = -1;
    function step() {
      if (composeCurrentStep < composeSteps.length - 1) {
        composeCurrentStep++;
        renderComposeTimeline();
        showComposeDetail();
      } else {
        clearInterval(composeAutoInterval);
        composeAutoInterval = null;
        btn.disabled = false;
        document.getElementById("composeNextBtn").disabled = true;
      }
    }
    composeAutoInterval = setInterval(step, 1800);
    step();
  });

  document.getElementById("composeResetBtn").addEventListener("click", function() {
    if (composeAutoInterval) { clearInterval(composeAutoInterval); composeAutoInterval = null; }
    composeCurrentStep = -1;
    renderComposeTimeline();
    showComposeDetail();
    document.getElementById("composeNextBtn").disabled = false;
    document.getElementById("composeAutoBtn").disabled = false;
  });

  renderComposeTimeline();
  showComposeDetail();

  // --- DAG Dependency Resolution ---
  var dagServices = {
    db:     { x: 200, y: 20,  label: "db", sub: "postgres:15", deps: [] },
    redis:  { x: 370, y: 20,  label: "redis", sub: "redis:7-alpine", deps: [] },
    api:    { x: 120, y: 130, label: "api", sub: "node:20", deps: ["db", "redis"] },
    worker: { x: 320, y: 130, label: "worker", sub: "python:3.11", deps: ["db", "redis"] },
    web:    { x: 220, y: 240, label: "web", sub: "nginx:latest", deps: ["api"] }
  };

  var dagHasCycle = false;

  function renderDagYaml() {
    var el = document.getElementById("dagYaml");
    var lines = '<span class="key">services:</span>\n';
    var order = ["db", "redis", "api", "worker", "web"];
    for (var i = 0; i < order.length; i++) {
      var k = order[i];
      var s = dagServices[k];
      lines += '  <span class="key">' + k + ':</span>\n';
      lines += '    <span class="key">image:</span> <span class="val">' + s.sub + '</span>\n';
      if (s.deps.length > 0) {
        lines += '    <span class="key">depends_on:</span>\n';
        for (var d = 0; d < s.deps.length; d++) {
          lines += '      - <span class="val">' + s.deps[d] + '</span>\n';
        }
      }
    }
    el.innerHTML = lines;
  }

  function renderDag() {
    var canvas = document.getElementById("dagCanvas");
    var html = '<svg width="100%" height="100%" style="position:absolute;top:0;left:0;z-index:1;">';

    // Draw edges
    var order = ["db", "redis", "api", "worker", "web"];
    for (var i = 0; i < order.length; i++) {
      var k = order[i];
      var s = dagServices[k];
      for (var d = 0; d < s.deps.length; d++) {
        var dep = dagServices[s.deps[d]];
        var x1 = dep.x + 45;
        var y1 = dep.y + 40;
        var x2 = s.x + 45;
        var y2 = s.y;
        html += '<line x1="' + x1 + '" y1="' + y1 + '" x2="' + x2 + '" y2="' + y2 + '" stroke="rgba(255,255,255,0.15)" stroke-width="2" marker-end="url(#arrow)"/>';
      }
    }
    html += '<defs><marker id="arrow" viewBox="0 0 10 10" refX="10" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse"><path d="M 0 0 L 10 5 L 0 10 z" fill="rgba(255,255,255,0.3)"/></marker></defs>';
    html += '</svg>';

    // Draw nodes
    for (var j = 0; j < order.length; j++) {
      var nk = order[j];
      var ns = dagServices[nk];
      var state = ns.state || "idle";
      html += '<div class="dag-node ' + state + '" style="left:' + ns.x + 'px;top:' + ns.y + 'px;" data-svc="' + nk + '">';
      html += '<div class="dag-node-label">' + ns.label + '</div>';
      html += '<div class="dag-node-sub">' + ns.sub + '</div>';
      html += '</div>';
    }

    canvas.innerHTML = html;
  }

  function dagResolve() {
    var log = document.getElementById("dagLog");
    log.innerHTML = "";

    // Topological sort (Kahn's algorithm)
    var inDegree = {};
    var adj = {};
    var order = ["db", "redis", "api", "worker", "web"];
    for (var i = 0; i < order.length; i++) {
      inDegree[order[i]] = 0;
      adj[order[i]] = [];
    }
    for (var j = 0; j < order.length; j++) {
      var deps = dagServices[order[j]].deps;
      inDegree[order[j]] = deps.length;
      for (var d = 0; d < deps.length; d++) {
        adj[deps[d]].push(order[j]);
      }
    }

    // Check for cycle
    if (dagHasCycle) {
      log.innerHTML = '<div style="color:#ef4444;">❌ ERROR: Circular dependency detected! db → api → db</div><div style="color:#ef4444;">Compose cannot start — dependency graph has a cycle.</div>';
      for (var ci = 0; ci < order.length; ci++) dagServices[order[ci]].state = "error";
      renderDag();
      return;
    }

    var queue = [];
    for (var k in inDegree) {
      if (inDegree[k] === 0) queue.push(k);
    }

    var sorted = [];
    var stepIdx = 0;

    function processNext() {
      if (queue.length === 0) {
        if (sorted.length < order.length) {
          log.innerHTML += '<div style="color:#ef4444;">Cycle detected!</div>';
        } else {
          log.innerHTML += '<div style="color:#4ade80;margin-top:8px;">✓ All services started successfully.</div>';
          log.innerHTML += '<div style="color:#888;">Start order: ' + sorted.join(' → ') + '</div>';
        }
        return;
      }

      var batch = queue.slice();
      queue = [];
      var batchLabel = batch.join(", ");
      log.innerHTML += '<div><span style="color:#06b6d4;">[batch ' + (stepIdx + 1) + ']</span> Starting: <span style="color:#fcd34d;">' + batchLabel + '</span></div>';

      for (var b = 0; b < batch.length; b++) {
        dagServices[batch[b]].state = "starting";
      }
      renderDag();

      setTimeout(function() {
        for (var b2 = 0; b2 < batch.length; b2++) {
          var svc = batch[b2];
          dagServices[svc].state = "running";
          sorted.push(svc);
          log.innerHTML += '<div><span style="color:#4ade80;">  ✓ ' + svc + ' is running</span></div>';

          // Reduce in-degree of dependents
          for (var a = 0; a < adj[svc].length; a++) {
            inDegree[adj[svc][a]]--;
            if (inDegree[adj[svc][a]] === 0) queue.push(adj[svc][a]);
          }
        }
        renderDag();
        log.scrollTop = log.scrollHeight;
        stepIdx++;
        setTimeout(processNext, 800);
      }, 1000);
    }

    processNext();
  }

  document.getElementById("dagResolveBtn").addEventListener("click", function() {
    var order = ["db", "redis", "api", "worker", "web"];
    for (var i = 0; i < order.length; i++) dagServices[order[i]].state = "idle";
    renderDag();
    dagResolve();
  });

  document.getElementById("dagCycleBtn").addEventListener("click", function() {
    dagHasCycle = true;
    dagServices.db.deps = ["api"];
    renderDagYaml();
    document.getElementById("dagLog").innerHTML = '<div style="color:#f59e0b;">⚠️ Added circular dependency: db now depends on api (which depends on db). Click "Resolve" to see the error.</div>';
  });

  document.getElementById("dagResetBtn").addEventListener("click", function() {
    dagHasCycle = false;
    dagServices.db.deps = [];
    dagServices.redis.deps = [];
    dagServices.api.deps = ["db", "redis"];
    dagServices.worker.deps = ["db", "redis"];
    dagServices.web.deps = ["api"];
    var order = ["db", "redis", "api", "worker", "web"];
    for (var i = 0; i < order.length; i++) dagServices[order[i]].state = "idle";
    renderDagYaml();
    renderDag();
    document.getElementById("dagLog").innerHTML = '<div class="log-empty">Click "Resolve Start Order" to see topological sort...</div>';
  });

  renderDagYaml();
  renderDag();

  // --- Inter-Service Networking ---
  var netServices = {
    web:    { x: 30,  y: 30,  ip: "172.20.0.2", color: "rgba(6, 182, 212, 0.15)", border: "rgba(6, 182, 212, 0.4)" },
    api:    { x: 200, y: 30,  ip: "172.20.0.3", color: "rgba(139, 92, 246, 0.15)", border: "rgba(139, 92, 246, 0.4)" },
    worker: { x: 30,  y: 140, ip: "172.20.0.4", color: "rgba(251, 191, 36, 0.15)", border: "rgba(251, 191, 36, 0.4)" },
    db:     { x: 200, y: 140, ip: "172.20.0.5", color: "rgba(74, 222, 128, 0.15)", border: "rgba(74, 222, 128, 0.4)" },
    redis:  { x: 120, y: 215, ip: "172.20.0.6", color: "rgba(239, 68, 68, 0.15)", border: "rgba(239, 68, 68, 0.4)" }
  };

  function renderNetwork() {
    var el = document.getElementById("networkViz");
    var html = '<div class="net-bridge" style="left:10px;top:10px;right:10px;bottom:10px;"></div>';
    html += '<div class="net-bridge-label" style="left:16px;bottom:16px;">myapp_default (172.20.0.0/16)</div>';

    var keys = ["web", "api", "worker", "db", "redis"];
    for (var i = 0; i < keys.length; i++) {
      var k = keys[i];
      var s = netServices[k];
      html += '<div class="net-service" style="left:' + s.x + 'px;top:' + s.y + 'px;background:' + s.color + ';border:2px solid ' + s.border + ';">';
      html += '<div class="svc-name">' + k + '</div>';
      html += '<div class="svc-ip">' + s.ip + '</div>';
      html += '</div>';
    }

    el.innerHTML = html;

    // Network info
    var info = document.getElementById("networkInfo");
    info.innerHTML = '';
    var rows = [
      ["Network Name", "myapp_default"],
      ["Driver", "bridge"],
      ["Subnet", "172.20.0.0/16"],
      ["Gateway", "172.20.0.1"],
      ["DNS Server", "127.0.0.11"],
      ["Scope", "local"]
    ];
    for (var r = 0; r < rows.length; r++) {
      info.innerHTML += '<div class="info-row"><span class="info-key">' + rows[r][0] + '</span><span class="info-val">' + rows[r][1] + '</span></div>';
    }
  }

  document.getElementById("dnsResolveBtn").addEventListener("click", function() {
    var src = document.getElementById("dnsSrc").value;
    var dst = document.getElementById("dnsDst").value;
    var dstIp = netServices[dst] ? netServices[dst].ip : "?";
    var result = document.getElementById("dnsResult");

    result.innerHTML = '<span style="color:#fbbf24;">Resolving...</span>';

    setTimeout(function() {
      var html = '';
      html += '<div><span style="color:#06b6d4;">1.</span> <span style="color:#fff;">' + src + '</span> calls <code>getaddrinfo("' + dst + '")</code></div>';
      html += '<div><span style="color:#06b6d4;">2.</span> Request goes to Docker DNS at <span style="color:#22c55e;">127.0.0.11:53</span></div>';
      html += '<div><span style="color:#06b6d4;">3.</span> DNS resolves <span style="color:#fff;">' + dst + '</span> → <span style="color:#4ade80;">' + dstIp + '</span> (A record)</div>';
      html += '<div><span style="color:#06b6d4;">4.</span> TCP connection: <span style="color:#888;">' + netServices[src].ip + '</span> → <span style="color:#4ade80;">' + dstIp + '</span> via bridge <span style="color:#888;">myapp_default</span></div>';
      result.innerHTML = html;
    }, 600);
  });

  renderNetwork();

  // --- Volume Mounts ---
  var volData = {
    named: {
      title: "Named Volumes",
      desc: '<strong>Managed by Docker.</strong> Data is stored in <code>/var/lib/docker/volumes/&lt;name&gt;/_data</code> on the host. Volumes persist across container restarts and <code>docker compose down</code>. Ideal for <strong>database data</strong>, application state, and anything that must survive container recreation.',
      yaml: 'volumes:\n  db-data:    # ← top-level declaration\n\nservices:\n  db:\n    image: postgres:15\n    volumes:\n      - db-data:/var/lib/postgresql/data',
      diagram: [
        { label: "Docker Volume\ndb-data", cls: "docker" },
        { label: "/var/lib/postgresql/data", cls: "container" }
      ]
    },
    bind: {
      title: "Bind Mounts",
      desc: '<strong>Maps a host directory into the container.</strong> Changes are bidirectional — edits on the host appear in the container and vice versa. Perfect for <strong>development</strong> (live code reloading) but dangerous in production (host path must exist, no Docker management).',
      yaml: 'services:\n  web:\n    image: nginx\n    volumes:\n      - ./html:/usr/share/nginx/html:ro\n      # host path : container path : options',
      diagram: [
        { label: "Host Dir\n./html", cls: "host" },
        { label: "/usr/share/nginx/html", cls: "container" }
      ]
    },
    tmpfs: {
      title: "tmpfs Mounts",
      desc: '<strong>In-memory filesystem.</strong> Data exists only in RAM and is <strong>lost when the container stops</strong>. Use for sensitive data (secrets, tokens) that should never be written to disk, or for scratch space that benefits from RAM speed.',
      yaml: 'services:\n  api:\n    image: node:20\n    tmpfs:\n      - /tmp\n      - /run/secrets',
      diagram: [
        { label: "RAM\n(tmpfs)", cls: "ram" },
        { label: "/tmp", cls: "container" }
      ]
    }
  };

  function renderVolDisplay(type) {
    var el = document.getElementById("volDisplay");
    var d = volData[type];
    var html = '<h4>' + d.title + '</h4>';
    html += '<p>' + d.desc + '</p>';
    html += '<pre class="code-block" style="font-size:0.75rem;">' + d.yaml + '</pre>';
    html += '<div class="vol-diagram">';
    for (var i = 0; i < d.diagram.length; i++) {
      if (i > 0) html += '<span class="vol-arrow">⟷</span>';
      html += '<div class="vol-box ' + d.diagram[i].cls + '">' + d.diagram[i].label.replace('\n', '<br>') + '</div>';
    }
    html += '</div>';
    el.innerHTML = html;
  }

  var volTabs = document.querySelectorAll(".vol-tab");
  for (var vt = 0; vt < volTabs.length; vt++) {
    volTabs[vt].addEventListener("click", function() {
      for (var j = 0; j < volTabs.length; j++) volTabs[j].classList.remove("active");
      this.classList.add("active");
      renderVolDisplay(this.getAttribute("data-vol"));
    });
  }

  renderVolDisplay("named");

  // Volume lifecycle
  var volState = { containers: false, volumes: false };

  function renderVolLifecycle() {
    var el = document.getElementById("volLifecycle");
    var cColor = volState.containers ? "#4ade80" : "#555";
    var vColor = volState.volumes ? "#06b6d4" : "#555";
    var cLabel = volState.containers ? "● Running" : "○ Stopped";
    var vLabel = volState.volumes ? "● Exists" : "○ Removed";
    el.innerHTML = '<div style="display:flex;gap:24px;flex-wrap:wrap;">' +
      '<div><span style="color:#888;">Containers:</span> <span style="color:' + cColor + ';">' + cLabel + '</span></div>' +
      '<div><span style="color:#888;">Named Volumes:</span> <span style="color:' + vColor + ';">' + vLabel + '</span></div>' +
      '</div>' +
      (volState.volumes && !volState.containers ? '<div style="color:#fbbf24;margin-top:8px;">💡 Volume data persists! Next "up" will reuse existing data.</div>' : '') +
      (!volState.volumes && !volState.containers ? '<div style="color:#ef4444;margin-top:8px;">⚠️ Volume data is gone forever. Database must be re-initialized.</div>' : '');
  }

  document.getElementById("volUpBtn").addEventListener("click", function() {
    volState.containers = true;
    volState.volumes = true;
    renderVolLifecycle();
  });

  document.getElementById("volDownBtn").addEventListener("click", function() {
    volState.containers = false;
    renderVolLifecycle();
  });

  document.getElementById("volDownVBtn").addEventListener("click", function() {
    volState.containers = false;
    volState.volumes = false;
    renderVolLifecycle();
  });

  document.getElementById("volResetBtn").addEventListener("click", function() {
    volState = { containers: false, volumes: false };
    renderVolLifecycle();
  });

  renderVolLifecycle();

  // --- Health Checks ---
  var healthSvcs = [
    { name: "db", icon: "🗄️", check: "pg_isready -U postgres", deps: [], startTime: 3000, healthy: true },
    { name: "redis", icon: "📮", check: "redis-cli ping", deps: [], startTime: 1000, healthy: true },
    { name: "api", icon: "⚡", check: "curl -f http://localhost:3000/health", deps: ["db", "redis"], startTime: 2000, healthy: true },
    { name: "worker", icon: "🔧", check: "celery inspect ping", deps: ["db", "redis"], startTime: 1500, healthy: true },
    { name: "web", icon: "🌐", check: "curl -f http://localhost:80/", deps: ["api"], startTime: 500, healthy: true }
  ];

  var healthStates = {};
  var healthInterval = null;
  var dbFailed = false;

  function resetHealthStates() {
    for (var i = 0; i < healthSvcs.length; i++) {
      healthStates[healthSvcs[i].name] = "waiting";
    }
    dbFailed = false;
  }

  function renderHealthServices() {
    var el = document.getElementById("healthServices");
    var html = "";
    for (var i = 0; i < healthSvcs.length; i++) {
      var s = healthSvcs[i];
      var state = healthStates[s.name] || "waiting";
      html += '<div class="health-svc ' + state + '">';
      html += '<div class="health-svc-icon">' + s.icon + '</div>';
      html += '<div class="health-svc-name">' + s.name + '</div>';
      html += '<div class="health-svc-status">' + state + '</div>';
      html += '<div class="health-svc-check">' + s.check + '</div>';
      html += '</div>';
    }
    el.innerHTML = html;
  }

  function addHealthLog(msg) {
    var log = document.getElementById("healthLog");
    var ts = new Date().toLocaleTimeString();
    log.innerHTML += "<div>[" + ts + "] " + msg + "</div>";
    log.scrollTop = log.scrollHeight;
  }

  function startHealthSequence() {
    var log = document.getElementById("healthLog");
    log.innerHTML = "";
    resetHealthStates();
    renderHealthServices();

    // Start services with no deps first
    var pending = healthSvcs.slice();
    var started = {};

    function tick() {
      var anyStarted = false;
      for (var i = 0; i < pending.length; i++) {
        var s = pending[i];
        if (started[s.name]) continue;

        // Check if all deps are healthy
        var depsReady = true;
        for (var d = 0; d < s.deps.length; d++) {
          if (healthStates[s.deps[d]] !== "healthy") {
            depsReady = false;
            break;
          }
        }

        if (!depsReady) continue;

        if (healthStates[s.name] === "waiting") {
          healthStates[s.name] = "starting";
          started[s.name] = Date.now();
          addHealthLog('<span style="color:#fbbf24;">▶ Starting ' + s.name + '...</span>');
          anyStarted = true;
          renderHealthServices();
        } else if (healthStates[s.name] === "starting") {
          var elapsed = Date.now() - started[s.name];
          if (elapsed >= s.startTime) {
            if (s.name === "db" && dbFailed) {
              healthStates[s.name] = "unhealthy";
              addHealthLog('<span style="color:#ef4444;">✗ ' + s.name + ' health check FAILED: ' + s.check + '</span>');
              renderHealthServices();
              // Dependents will never start
              addHealthLog('<span style="color:#ef4444;">⚠ Services depending on db are blocked!</span>');
              clearInterval(healthInterval);
              healthInterval = null;
              return;
            }
            healthStates[s.name] = "healthy";
            addHealthLog('<span style="color:#4ade80;">✓ ' + s.name + ' is healthy (' + s.check + ')</span>');
            renderHealthServices();
          }
        }
      }

      // Check if all healthy
      var allDone = true;
      for (var k in healthStates) {
        if (healthStates[k] !== "healthy") { allDone = false; break; }
      }
      if (allDone) {
        addHealthLog('<span style="color:#4ade80;font-weight:700;">✓ All services healthy and running!</span>');
        clearInterval(healthInterval);
        healthInterval = null;
      }
    }

    healthInterval = setInterval(tick, 300);
  }

  document.getElementById("healthStartBtn").addEventListener("click", startHealthSequence);

  document.getElementById("healthFailBtn").addEventListener("click", function() {
    dbFailed = true;
    startHealthSequence();
  });

  document.getElementById("healthResetBtn").addEventListener("click", function() {
    if (healthInterval) { clearInterval(healthInterval); healthInterval = null; }
    resetHealthStates();
    renderHealthServices();
    document.getElementById("healthLog").innerHTML = '<div class="log-empty">Click "Start Services" to watch health-check-aware startup...</div>';
  });

  resetHealthStates();
  renderHealthServices();
</script>
