---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Docker Compose Internals: Service Dependencies, Networking & Lifecycle" 
  description="Interactive visualization of Docker Compose internals — DAG dependency resolution, inter-service networking, volume mounts, health checks, and the compose lifecycle"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "Docker", href: "/docker/" },
    { label: "Docker Compose", href: "/docker/docker-compose/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🐳 Docker Compose Internals</h1>
      <p class="subtitle">Service Dependencies, Networking &amp; the Compose Lifecycle</p>
    </header>

    <!-- Overview -->
    <section class="overview-section">
      <div class="overview-card">
        <p>
          Docker Compose is <strong>not an orchestrator</strong> — it's a <em>single-host</em> tool
          that reads a declarative YAML file and translates it into Docker API calls. It resolves
          <strong>service dependency order</strong> using a DAG (directed acyclic graph), creates a
          <em>dedicated network</em> for inter-service communication, manages <strong>volume mounts</strong>
          for persistent data, and monitors <strong>health checks</strong> to ensure services start in
          the right order. Understanding these internals helps you debug startup failures, networking
          issues, and data persistence problems.
        </p>
      </div>
    </section>

    <!-- Compose File Lifecycle -->
    <section class="lifecycle-section">
      <h2>🔄 Compose File Lifecycle</h2>
      <p class="section-desc">Step through what happens when you run <code>docker compose up</code>.</p>

      <div class="lifecycle-timeline" id="composeTimeline">
        <!-- Rendered by JS -->
      </div>

      <div class="lifecycle-controls">
        <button class="action-btn primary-btn" id="composeNextBtn">▶ Next Step</button>
        <button class="action-btn election-btn" id="composeAutoBtn">⏩ Auto Play</button>
        <button class="action-btn reset-btn" id="composeResetBtn">🔄 Reset</button>
      </div>

      <div class="lifecycle-detail" id="composeDetail">
        <div class="log-empty">Click "Next Step" to begin the compose lifecycle...</div>
      </div>
    </section>

    <!-- DAG Dependency Resolution -->
    <section class="dag-section">
      <h2>🕸️ Service Dependency Resolution (DAG)</h2>
      <p class="section-desc">Compose builds a directed acyclic graph from <code>depends_on</code> declarations and starts services in topological order. Click services to see their dependencies.</p>

      <div class="dag-demo">
        <div class="dag-canvas" id="dagCanvas">
          <!-- SVG rendered by JS -->
        </div>
        <div class="dag-controls">
          <div class="dag-yaml">
            <h3>📄 docker-compose.yml</h3>
            <pre class="code-block" id="dagYaml"></pre>
          </div>
          <div class="dag-actions">
            <button class="action-btn primary-btn" id="dagResolveBtn">▶ Resolve Start Order</button>
            <button class="action-btn chaos-btn" id="dagCycleBtn">💥 Add Circular Dep</button>
            <button class="action-btn reset-btn" id="dagResetBtn">🔄 Reset</button>
          </div>
          <div class="dag-log" id="dagLog">
            <div class="log-empty">Click "Resolve Start Order" to see topological sort...</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Networking Between Services -->
    <section class="network-section">
      <h2>🌐 Inter-Service Networking</h2>
      <p class="section-desc">Compose creates a bridge network for each project. Services discover each other by <strong>service name</strong> via Docker's embedded DNS server at <code>127.0.0.11</code>.</p>

      <div class="network-demo">
        <div class="network-viz" id="networkViz">
          <!-- Rendered by JS -->
        </div>
        <div class="network-controls">
          <h3>🔍 DNS Resolution</h3>
          <p class="section-desc">Select a source and destination service to trace DNS resolution and packet flow.</p>
          <div class="dns-controls">
            <select id="dnsSrc" class="config-select">
              <option value="web">web (nginx)</option>
              <option value="api">api (node)</option>
              <option value="worker">worker (python)</option>
            </select>
            <span class="dns-arrow">→</span>
            <select id="dnsDst" class="config-select">
              <option value="db">db (postgres)</option>
              <option value="redis">redis</option>
              <option value="api">api (node)</option>
            </select>
            <button class="action-btn primary-btn" id="dnsResolveBtn">Resolve</button>
          </div>
          <div class="dns-result" id="dnsResult"></div>
          <div class="network-info">
            <h3>📋 Network Details</h3>
            <div class="info-grid" id="networkInfo">
              <!-- Rendered by JS -->
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Volume Mounts -->
    <section class="volume-section">
      <h2>💾 Volume Mounts</h2>
      <p class="section-desc">Compose supports three volume types. Understanding the difference is critical for data persistence.</p>

      <div class="volume-demo">
        <div class="volume-types" id="volumeTypes">
          <div class="vol-tab-bar">
            <button class="vol-tab active" data-vol="named">Named Volumes</button>
            <button class="vol-tab" data-vol="bind">Bind Mounts</button>
            <button class="vol-tab" data-vol="tmpfs">tmpfs</button>
          </div>
          <div class="vol-display" id="volDisplay">
            <!-- Rendered by JS -->
          </div>
        </div>

        <div class="volume-lifecycle">
          <h3>♻️ Volume Lifecycle</h3>
          <p class="section-desc">Named volumes survive <code>docker compose down</code>. Only <code>docker compose down -v</code> removes them.</p>
          <div class="vol-lifecycle-demo" id="volLifecycle">
            <!-- Rendered by JS -->
          </div>
          <div class="vol-controls">
            <button class="action-btn primary-btn" id="volUpBtn">docker compose up</button>
            <button class="action-btn election-btn" id="volDownBtn">docker compose down</button>
            <button class="action-btn chaos-btn" id="volDownVBtn">docker compose down -v</button>
            <button class="action-btn reset-btn" id="volResetBtn">🔄 Reset</button>
          </div>
        </div>
      </div>
    </section>

    <!-- Health Checks -->
    <section class="health-section">
      <h2>🏥 Health Checks &amp; Startup Order</h2>
      <p class="section-desc"><code>depends_on</code> alone only waits for a container to <em>start</em>. With <code>condition: service_healthy</code>, Compose waits for the health check to pass before starting dependent services.</p>

      <div class="health-demo">
        <div class="health-services" id="healthServices">
          <!-- Rendered by JS -->
        </div>
        <div class="health-controls">
          <button class="action-btn primary-btn" id="healthStartBtn">▶ Start Services</button>
          <button class="action-btn chaos-btn" id="healthFailBtn">💥 Fail DB Health</button>
          <button class="action-btn reset-btn" id="healthResetBtn">🔄 Reset</button>
        </div>
        <div class="health-log" id="healthLog">
          <div class="log-empty">Click "Start Services" to watch health-check-aware startup...</div>
        </div>
      </div>
    </section>

    <!-- Compose Architecture -->
    <section class="explain-section">
      <h2>🏗️ Compose Architecture</h2>
      <p class="section-desc">Key concepts that power Docker Compose under the hood.</p>
      <div class="explain-grid">
        <div class="explain-card">
          <h3>📋 Project = Isolation Unit</h3>
          <p>
            Each Compose project (directory name by default, or <code>-p</code> flag) gets its own
            namespace: containers are prefixed with the project name, a dedicated network is created,
            and volumes are scoped. This lets you run multiple copies of the same stack side by side.
          </p>
        </div>
        <div class="explain-card">
          <h3>🔄 Reconciliation Model</h3>
          <p>
            <code>docker compose up</code> is <strong>declarative</strong>: it compares the desired
            state (YAML) with the current state (running containers) and only changes what's different.
            If you modify a service's image, only that service restarts. Unchanged services keep running.
          </p>
        </div>
        <div class="explain-card highlight-card">
          <h3>📡 Docker API Under the Hood</h3>
          <p>
            Compose V2 is a Go binary that calls the Docker Engine API directly. Each service becomes
            a <code>container create</code> + <code>container start</code> call. Networks use
            <code>network create</code>. Volumes use <code>volume create</code>. There's no magic —
            it's just API orchestration.
          </p>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://docs.docker.com/compose/compose-file/" target="_blank">Compose Specification</a>, <a href="https://docs.docker.com/network/" target="_blank">Docker Networking</a>, and <a href="https://docs.docker.com/compose/startup-order/" target="_blank">Startup Order</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share this visualization:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20Docker%20Compose%20Internals%20—%20DAG%20resolution%2C%20networking%2C%20volumes&url=https://systeminternals.dev/docker/docker-compose/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/docker/docker-compose/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/docker/docker-compose/&t=Interactive%20Docker%20Compose%20Internals" target="_blank" class="share-btn">🟧 Hacker News</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .viz-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #06b6d4, #3b82f6, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #888;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 12px;
  }

  .section-desc {
    color: #888;
    margin-bottom: 24px;
    font-size: 1rem;
  }

  .section-desc code {
    background: rgba(0,0,0,0.3);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.85rem;
    color: #22c55e;
  }

  /* Overview */
  .overview-section {
    margin-bottom: 50px;
  }

  .overview-card {
    background: linear-gradient(135deg, rgba(6, 182, 212, 0.1), rgba(139, 92, 246, 0.05));
    border: 1px solid rgba(6, 182, 212, 0.3);
    border-radius: 16px;
    padding: 24px 28px;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #ccc;
  }

  .overview-card strong { color: #fff; }
  .overview-card em { color: #06b6d4; font-style: normal; font-weight: 500; }

  /* Lifecycle Section */
  .lifecycle-section {
    margin-bottom: 50px;
  }

  .lifecycle-timeline {
    display: flex;
    gap: 4px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .lc-step {
    flex: 1;
    min-width: 100px;
    padding: 14px 10px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    text-align: center;
    transition: all 0.4s;
  }

  .lc-step.active {
    border-color: rgba(6, 182, 212, 0.6);
    background: rgba(6, 182, 212, 0.1);
    box-shadow: 0 0 25px rgba(6, 182, 212, 0.15);
    transform: scale(1.03);
  }

  .lc-step.done {
    border-color: rgba(74, 222, 128, 0.4);
    background: rgba(74, 222, 128, 0.05);
  }

  .lc-icon { font-size: 1.5rem; margin-bottom: 4px; }
  .lc-label { font-size: 0.75rem; font-weight: 600; color: #fff; }
  .lc-sub { font-size: 0.65rem; color: #888; margin-top: 2px; }

  .lifecycle-controls {
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
  }

  .lifecycle-detail {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 20px;
    font-size: 0.9rem;
    color: #aaa;
    line-height: 1.7;
    min-height: 80px;
  }

  .lifecycle-detail strong { color: #fff; }
  .lifecycle-detail code {
    background: rgba(0,0,0,0.3);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.8rem;
    color: #22c55e;
  }

  .log-empty { color: #555; }

  /* DAG Section */
  .dag-section {
    margin-bottom: 50px;
  }

  .dag-demo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .dag-canvas {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    min-height: 350px;
    position: relative;
    overflow: hidden;
  }

  .dag-node {
    position: absolute;
    padding: 12px 20px;
    border-radius: 12px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.4s;
    text-align: center;
    z-index: 2;
    min-width: 90px;
  }

  .dag-node.idle {
    background: rgba(255,255,255,0.05);
    border: 2px solid rgba(255,255,255,0.15);
    color: #aaa;
  }

  .dag-node.starting {
    background: rgba(251, 191, 36, 0.15);
    border: 2px solid rgba(251, 191, 36, 0.5);
    color: #fcd34d;
    animation: dagPulse 1s infinite;
  }

  .dag-node.running {
    background: rgba(74, 222, 128, 0.15);
    border: 2px solid rgba(74, 222, 128, 0.5);
    color: #4ade80;
  }

  .dag-node.error {
    background: rgba(239, 68, 68, 0.15);
    border: 2px solid rgba(239, 68, 68, 0.5);
    color: #fca5a5;
  }

  .dag-node.selected {
    box-shadow: 0 0 20px rgba(6, 182, 212, 0.4);
    border-color: rgba(6, 182, 212, 0.7);
  }

  .dag-node-label { font-size: 0.8rem; }
  .dag-node-sub { font-size: 0.65rem; color: #888; margin-top: 2px; }

  @keyframes dagPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  .dag-yaml {
    margin-bottom: 16px;
  }

  .dag-yaml h3 {
    font-size: 1rem;
    color: #fff;
    margin-bottom: 8px;
  }

  .code-block {
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 14px 18px;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    color: #aaa;
    line-height: 1.6;
    overflow-x: auto;
    white-space: pre;
  }

  .code-block .key { color: #06b6d4; }
  .code-block .val { color: #4ade80; }
  .code-block .comment { color: #555; }

  .dag-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .dag-log {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 14px;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    color: #888;
    line-height: 1.6;
    max-height: 160px;
    overflow-y: auto;
  }

  .dag-controls {
    display: flex;
    flex-direction: column;
  }

  /* Network Section */
  .network-section {
    margin-bottom: 50px;
  }

  .network-demo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .network-viz {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 20px;
    min-height: 300px;
    position: relative;
  }

  .net-service {
    position: absolute;
    padding: 10px 16px;
    border-radius: 10px;
    font-size: 0.8rem;
    font-weight: 600;
    text-align: center;
    z-index: 2;
    min-width: 100px;
    transition: all 0.3s;
  }

  .net-service .svc-name { font-size: 0.85rem; color: #fff; }
  .net-service .svc-ip { font-size: 0.7rem; color: #888; margin-top: 2px; font-family: 'JetBrains Mono', monospace; }

  .net-bridge {
    position: absolute;
    border: 2px dashed rgba(6, 182, 212, 0.3);
    border-radius: 16px;
    z-index: 1;
  }

  .net-bridge-label {
    position: absolute;
    font-size: 0.7rem;
    color: #06b6d4;
    font-weight: 600;
  }

  .dns-controls {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .dns-arrow {
    color: #888;
    font-size: 1.2rem;
  }

  .config-select {
    padding: 8px 10px;
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    color: #ddd;
    font-size: 0.85rem;
    min-width: 120px;
  }

  .dns-result {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: #aaa;
    line-height: 1.7;
    min-height: 60px;
    margin-bottom: 16px;
  }

  .network-info h3 {
    font-size: 1rem;
    color: #fff;
    margin-bottom: 8px;
  }

  .info-grid {
    display: grid;
    gap: 8px;
  }

  .info-row {
    display: flex;
    justify-content: space-between;
    padding: 6px 12px;
    background: rgba(255,255,255,0.03);
    border-radius: 6px;
    font-size: 0.8rem;
  }

  .info-key { color: #888; }
  .info-val { color: #06b6d4; font-family: 'JetBrains Mono', monospace; }

  .network-controls {
    display: flex;
    flex-direction: column;
  }

  /* Volume Section */
  .volume-section {
    margin-bottom: 50px;
  }

  .volume-demo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .vol-tab-bar {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .vol-tab {
    padding: 8px 18px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 10px;
    background: rgba(255,255,255,0.03);
    color: #aaa;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .vol-tab:hover {
    border-color: rgba(6, 182, 212, 0.4);
    color: #fff;
  }

  .vol-tab.active {
    background: rgba(6, 182, 212, 0.15);
    border-color: rgba(6, 182, 212, 0.5);
    color: #67e8f9;
  }

  .vol-display {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 20px;
    min-height: 200px;
  }

  .vol-display h4 {
    font-size: 1rem;
    color: #fff;
    margin-bottom: 8px;
  }

  .vol-display p {
    color: #aaa;
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 12px;
  }

  .vol-display strong { color: #fff; }
  .vol-display code {
    background: rgba(0,0,0,0.3);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.8rem;
    color: #22c55e;
  }

  .vol-diagram {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .vol-box {
    padding: 10px 16px;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    text-align: center;
  }

  .vol-box.host {
    background: rgba(251, 191, 36, 0.15);
    border: 1px solid rgba(251, 191, 36, 0.3);
    color: #fcd34d;
  }

  .vol-box.docker {
    background: rgba(6, 182, 212, 0.15);
    border: 1px solid rgba(6, 182, 212, 0.3);
    color: #67e8f9;
  }

  .vol-box.container {
    background: rgba(139, 92, 246, 0.15);
    border: 1px solid rgba(139, 92, 246, 0.3);
    color: #c4b5fd;
  }

  .vol-box.ram {
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #fca5a5;
  }

  .vol-arrow {
    color: #555;
    font-size: 1.2rem;
  }

  .volume-lifecycle h3 {
    font-size: 1rem;
    color: #fff;
    margin-bottom: 8px;
  }

  .vol-lifecycle-demo {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 16px;
    min-height: 100px;
    margin-bottom: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    line-height: 1.7;
    color: #aaa;
  }

  .vol-controls {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  /* Health Check Section */
  .health-section {
    margin-bottom: 50px;
  }

  .health-demo {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 24px;
  }

  .health-services {
    display: flex;
    gap: 16px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .health-svc {
    flex: 1;
    min-width: 150px;
    padding: 16px;
    border-radius: 12px;
    text-align: center;
    transition: all 0.4s;
  }

  .health-svc.waiting {
    background: rgba(255,255,255,0.03);
    border: 2px solid rgba(255,255,255,0.1);
  }

  .health-svc.starting {
    background: rgba(251, 191, 36, 0.1);
    border: 2px solid rgba(251, 191, 36, 0.4);
    animation: dagPulse 1s infinite;
  }

  .health-svc.healthy {
    background: rgba(74, 222, 128, 0.1);
    border: 2px solid rgba(74, 222, 128, 0.4);
  }

  .health-svc.unhealthy {
    background: rgba(239, 68, 68, 0.1);
    border: 2px solid rgba(239, 68, 68, 0.4);
  }

  .health-svc-icon { font-size: 1.5rem; margin-bottom: 6px; }
  .health-svc-name { font-size: 0.9rem; font-weight: 600; color: #fff; }
