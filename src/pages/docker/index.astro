---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "Container Internals", description: "Namespaces, cgroups, overlay filesystem — how containers actually work under the hood", href: "/docker/container-internals/", status: "live" },
  { title: "Networking Deep Dive", description: "Bridge, host, overlay networks, iptables, and veth pairs", href: "#", status: "coming" },
  { title: "Image Building", description: "Dockerfile layers, build cache, multi-stage builds, and BuildKit", href: "#", status: "coming" },
  { title: "Storage Drivers", description: "overlay2, devicemapper, btrfs — how container storage actually works", href: "#", status: "coming" },
  { title: "Container Security", description: "Capabilities, seccomp, AppArmor, rootless containers", href: "#", status: "coming" },
  { title: "Container Runtimes", description: "containerd, runc, gVisor, Kata — the OCI runtime landscape", href: "#", status: "coming" },
];
---

<BaseLayout 
  title="Docker & Container Internals" 
  description="Interactive visualizations for understanding how containers really work — namespaces, cgroups, overlay filesystems, and more"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Docker", href: "/docker/" }]}
>
  <section class="section-header">
    <h1>🐳 Docker &amp; Container Internals</h1>
    <p>
      Containers are not lightweight VMs. They're processes with kernel-enforced isolation via 
      Linux namespaces and resource limits via cgroups. These visualizations peel back the abstraction 
      to show what's really happening when you run <code>docker run</code>.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .section-header code {
    background: rgba(0,0,0,0.3);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.95rem;
    color: #22c55e;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(0, 212, 255, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
