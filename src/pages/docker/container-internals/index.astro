</style>

<script is:inline>
  // ============================================================
  // CONTAINER INTERNALS INTERACTIVE VISUALIZATIONS
  // ============================================================

  // --- Namespace Data ---
  var nsData = {
    pid: {
      title: "PID Namespace — Process Isolation",
      desc: 'Each container gets its own <strong>PID numbering</strong>. The first process in the container is <strong>PID 1</strong> (init). The host kernel tracks the real PIDs — the container only sees its own processes. If PID 1 dies, the entire container stops.',
      example: '<span class="host-label">HOST VIEW:</span>\nPID 1    systemd\nPID 4521 containerd\nPID 4590 nginx        ← container PID 1\nPID 4591 nginx worker  ← container PID 2\n\n<span class="container-label">CONTAINER VIEW:</span>\nPID 1    nginx        ← thinks it is PID 1\nPID 2    nginx worker'
    },
    net: {
      title: "NET Namespace — Network Stack Isolation",
      desc: 'Each container gets its own <strong>network interfaces</strong>, routing table, iptables rules, and port space. Docker creates a <code>veth</code> pair: one end in the container, one on the host bridge (<code>docker0</code>). Containers can bind to port 80 without conflicting — they each have their own port space.',
      example: '<span class="host-label">HOST:</span>\neth0: 192.168.1.100\ndocker0: 172.17.0.1 (bridge)\nveth7a3f → container-1\nveth9b2c → container-2\n\n<span class="container-label">CONTAINER-1:</span>\neth0: 172.17.0.2  ← only sees this\nlo: 127.0.0.1'
    },
    mnt: {
      title: "MNT Namespace — Filesystem Isolation",
      desc: 'Each container gets its own <strong>mount table</strong>. The container sees the overlay filesystem as its root (<code>/</code>). Host mounts are invisible. <code>docker run -v</code> adds bind mounts into the container\'s mount namespace. <code>pivot_root</code> swaps the container\'s root to the overlay.',
      example: '<span class="host-label">HOST:</span>\n/           ext4 (real root)\n/home       ext4\n/var/lib/docker  overlay layers\n\n<span class="container-label">CONTAINER:</span>\n/           overlay (image layers)\n/app        bind mount from host\n/proc       procfs\n/dev        devtmpfs'
    },
    uts: {
      title: "UTS Namespace — Hostname Isolation",
      desc: 'Each container gets its own <strong>hostname</strong> and <strong>domain name</strong>. By default, Docker sets the hostname to the short container ID. You can override it with <code>docker run --hostname myapp</code>. This is how containers identify themselves on the network.',
      example: '<span class="host-label">HOST:</span>\n$ hostname\nprod-server-01\n\n<span class="container-label">CONTAINER (a1b2c3d4):</span>\n$ hostname\na1b2c3d4e5f6\n\n<span class="container-label">CONTAINER (--hostname myapp):</span>\n$ hostname\nmyapp'
    },
    ipc: {
      title: "IPC Namespace — Inter-Process Communication",
      desc: 'Isolates <strong>System V IPC</strong> objects (shared memory segments, message queues, semaphores) and <strong>POSIX message queues</strong>. Processes in different IPC namespaces cannot see each other\'s IPC resources. Use <code>docker run --ipc=host</code> to share the host\'s IPC namespace (needed for some databases).',
      example: '<span class="host-label">HOST IPC:</span>\n$ ipcs\nShared Memory: 0x1234 (shmid=100)\nSemaphore:     0x5678 (semid=200)\n\n<span class="container-label">CONTAINER IPC (isolated):</span>\n$ ipcs\n(empty — cannot see host IPC)'
    },
    user: {
      title: "USER Namespace — UID/GID Mapping",
      desc: 'Maps <strong>user and group IDs</strong> inside the container to different IDs on the host. A process can be <strong>root (UID 0) inside the container</strong> but map to an unprivileged user (e.g., UID 100000) on the host. This is the foundation of <strong>rootless containers</strong> — even if an attacker escapes, they\'re unprivileged on the host.',
      example: '<span class="host-label">HOST:</span>\nUID 100000 → runs container process\n(unprivileged!)\n\n<span class="container-label">CONTAINER:</span>\nUID 0 (root) → thinks it is root\n  ↳ mapped to host UID 100000\nUID 1000 (app) → mapped to host UID 101000'
    }
  };

  // Render namespace info
  function renderNsInfo(ns) {
    var data = nsData[ns];
    var el = document.getElementById("nsDisplay");
    el.innerHTML = '<div class="ns-info-title">' + data.title + '</div>' +
      '<div class="ns-info-desc">' + data.desc + '</div>' +
      '<div class="ns-example">' + data.example + '</div>';
  }

  // Namespace tabs
  var nsTabs = document.querySelectorAll(".ns-tab");
  for (var i = 0; i < nsTabs.length; i++) {
    nsTabs[i].addEventListener("click", function() {
      for (var j = 0; j < nsTabs.length; j++) nsTabs[j].classList.remove("active");
      this.classList.add("active");
      renderNsInfo(this.getAttribute("data-ns"));
    });
  }

  renderNsInfo("pid");

  // --- Process Tree ---
  var containers = [];
  var nextHostPid = 100;
  var currentView = "host";

  var hostProcesses = [
    { pid: 1, name: "systemd", ns: "host", indent: 0 },
    { pid: 2, name: "kthreadd", ns: "host", indent: 0 },
    { pid: 45, name: "sshd", ns: "host", indent: 1 },
    { pid: 67, name: "containerd", ns: "host", indent: 1 },
    { pid: 89, name: "dockerd", ns: "host", indent: 2 }
  ];

  var containerTemplates = [
    [
      { name: "nginx", cPid: 1 },
      { name: "nginx: worker", cPid: 2 },
      { name: "nginx: worker", cPid: 3 }
    ],
    [
      { name: "node server.js", cPid: 1 },
      { name: "node worker", cPid: 2 }
    ],
    [
      { name: "python app.py", cPid: 1 },
      { name: "gunicorn", cPid: 2 },
      { name: "gunicorn", cPid: 3 },
      { name: "gunicorn", cPid: 4 }
    ]
  ];

  function spawnContainer() {
    if (containers.length >= 3) return;
    var idx = containers.length;
    var template = containerTemplates[idx];
    var procs = [];
    for (var p = 0; p < template.length; p++) {
      procs.push({
        hostPid: nextHostPid++,
        cPid: template[p].cPid,
        name: template[p].name
      });
    }
    containers.push({ id: idx + 1, procs: procs });

    // Enable view button
    var btnId = "viewC" + (idx + 1) + "Btn";
    var btn = document.getElementById(btnId);
    if (btn) btn.disabled = false;

    renderPtree();
  }

  function renderPtree() {
    var el = document.getElementById("ptree");
    var html = "";

    if (currentView === "host") {
      // Show all host processes + container processes with host PIDs
      for (var h = 0; h < hostProcesses.length; h++) {
        var p = hostProcesses[h];
        var indent = "";
        for (var d = 0; d < p.indent; d++) indent += "  ";
        html += '<div class="ptree-line">' + indent +
          '<span class="pid">PID ' + p.pid + '</span>  <span class="proc">' + p.name + '</span>' +
          '<span class="ns-badge host-ns">host</span></div>';
      }
      for (var c = 0; c < containers.length; c++) {
        var cont = containers[c];
        var nsCls = "c" + (c + 1) + "-ns";
        for (var cp = 0; cp < cont.procs.length; cp++) {
          var proc = cont.procs[cp];
          var prefix = cp === 0 ? "    ├── " : "    │   ├── ";
          html += '<div class="ptree-line highlight">' + prefix +
            '<span class="pid">PID ' + proc.hostPid + '</span>  <span class="proc">' + proc.name + '</span>' +
            '<span class="ns-badge ' + nsCls + '">container-' + cont.id + '</span></div>';
        }
      }
    } else {
      // Container view — show only that container's processes with container PIDs
      var cIdx = parseInt(currentView.replace("c", "")) - 1;
      if (cIdx >= 0 && cIdx < containers.length) {
        var cont2 = containers[cIdx];
        html += '<div class="ptree-line" style="color:#4ade80;margin-bottom:8px;">Container ' + cont2.id + ' sees only its own processes:</div>';
        for (var cp2 = 0; cp2 < cont2.procs.length; cp2++) {
          var proc2 = cont2.procs[cp2];
          var indent2 = cp2 === 0 ? "" : "  ";
          html += '<div class="ptree-line highlight">' + indent2 +
            '<span class="pid">PID ' + proc2.cPid + '</span>  <span class="proc">' + proc2.name + '</span></div>';
        }
        html += '<div class="ptree-line" style="margin-top:12px;color:#666;">(' + (hostProcesses.length + containers.reduce(function(s, c2) { return s + c2.procs.length; }, 0) - cont2.procs.length) + ' other processes on the host are completely invisible)</div>';
      }
    }

    if (containers.length === 0) {
      html += '<div class="ptree-line" style="color:#555;margin-top:8px;">Click "Spawn Container" to add containers...</div>';
    }

    el.innerHTML = html;
  }

  document.getElementById("spawnContainerBtn").addEventListener("click", function() {
    spawnContainer();
    if (containers.length >= 3) this.disabled = true;
  });

  document.getElementById("ptreeResetBtn").addEventListener("click", function() {
    containers = [];
    nextHostPid = 100;
    currentView = "host";
    document.getElementById("spawnContainerBtn").disabled = false;
    document.getElementById("viewC1Btn").disabled = true;
    document.getElementById("viewC2Btn").disabled = true;
    document.getElementById("viewC3Btn").disabled = true;
    document.getElementById("viewHostBtn").classList.add("active");
    document.getElementById("viewC1Btn").classList.remove("active");
    document.getElementById("viewC2Btn").classList.remove("active");
    document.getElementById("viewC3Btn").classList.remove("active");
    renderPtree();
  });

  // View buttons
  var viewBtns = ["viewHostBtn", "viewC1Btn", "viewC2Btn", "viewC3Btn"];
  var viewMap = { viewHostBtn: "host", viewC1Btn: "c1", viewC2Btn: "c2", viewC3Btn: "c3" };

  for (var v = 0; v < viewBtns.length; v++) {
    (function(btnId) {
      document.getElementById(btnId).addEventListener("click", function() {
        if (this.disabled) return;
        for (var vv = 0; vv < viewBtns.length; vv++) {
          document.getElementById(viewBtns[vv]).classList.remove("active");
        }
        this.classList.add("active");
        currentView = viewMap[btnId];
        renderPtree();
      });
    })(viewBtns[v]);
  }

  renderPtree();

  // --- Cgroups Demo ---
  var cgStressInterval = null;
  var cgCpuUsage = 0;
  var cgMemUsage = 0;
  var cgIoUsage = 0;
  var cgTargetCpu = 0;
  var cgTargetMem = 0;
  var cgTargetIo = 0;

  function getCgLimits() {
    return {
      cpu: parseInt(document.getElementById("cgCpuSlider").value),
      mem: parseInt(document.getElementById("cgMemSlider").value),
      io: parseInt(document.getElementById("cgIoSlider").value)
    };
  }

  function updateCgLabels() {
    document.getElementById("cgCpuLabel").textContent = document.getElementById("cgCpuSlider").value + "%";
    document.getElementById("cgMemLabel").textContent = document.getElementById("cgMemSlider").value + "Mi";
    document.getElementById("cgIoLabel").textContent = document.getElementById("cgIoSlider").value + "MB/s";

    // Update limit markers
    var limits = getCgLimits();
    document.getElementById("cpuMeterLimit").style.left = limits.cpu + "%";
    document.getElementById("memMeterLimit").style.left = (limits.mem / 1024 * 100) + "%";
    document.getElementById("ioMeterLimit").style.left = (limits.io / 200 * 100) + "%";
  }

  document.getElementById("cgCpuSlider").addEventListener("input", updateCgLabels);
  document.getElementById("cgMemSlider").addEventListener("input", updateCgLabels);
  document.getElementById("cgIoSlider").addEventListener("input", updateCgLabels);
  updateCgLabels();

  function addCgLog(msg) {
    var log = document.getElementById("cgLog");
    var ts = new Date().toLocaleTimeString();
    log.innerHTML += "<div>[" + ts + "] " + msg + "</div>";
    log.scrollTop = log.scrollHeight;
  }

  function stressTick() {
    var limits = getCgLimits();

    // Ramp up usage toward targets
    cgCpuUsage += (cgTargetCpu - cgCpuUsage) * 0.15 + (Math.random() - 0.5) * 3;
    cgMemUsage += (cgTargetMem - cgMemUsage) * 0.1 + (Math.random() - 0.5) * 5;
    cgIoUsage += (cgTargetIo - cgIoUsage) * 0.12 + (Math.random() - 0.5) * 4;

    // Apply limits
    var cpuClamped = Math.min(cgCpuUsage, limits.cpu);
    var cpuThrottled = cgCpuUsage > limits.cpu;
    var memClamped = Math.min(cgMemUsage, limits.mem);
    var memOom = cgMemUsage > limits.mem;
    var ioClamped = Math.min(cgIoUsage, limits.io);
    var ioThrottled = cgIoUsage > limits.io;

    // Clamp display values
    cpuClamped = Math.max(0, Math.min(100, cpuClamped));
    memClamped = Math.max(0, Math.min(1024, memClamped));
    ioClamped = Math.max(0, Math.min(200, ioClamped));

    // CPU
    var cpuPct = cpuClamped;
    document.getElementById("cpuMeterFill").style.width = cpuPct + "%";
    document.getElementById("cpuMeterVal").textContent = Math.round(cpuPct) + "%";
    var cpuFillEl = document.getElementById("cpuMeterFill");
    var cpuStatusEl = document.getElementById("cpuStatus");
    cpuFillEl.className = "meter-fill cpu-fill";
    cpuStatusEl.className = "meter-status";
    if (cpuThrottled) {
      cpuFillEl.classList.add("warning");
      cpuStatusEl.className = "meter-status throttled";
      cpuStatusEl.textContent = "THROTTLED — cfs_quota exceeded, process slowed to " + limits.cpu + "% of core";
    } else if (cpuPct > 70) {
      cpuStatusEl.textContent = "Running at " + Math.round(cpuPct) + "% CPU";
    } else {
      cpuStatusEl.textContent = "Normal";
    }

    // Memory
    var memPct = (memClamped / 1024) * 100;
    document.getElementById("memMeterFill").style.width = memPct + "%";
    document.getElementById("memMeterVal").textContent = Math.round(memClamped) + " Mi";
    var memFillEl = document.getElementById("memMeterFill");
    var memStatusEl = document.getElementById("memStatus");
    memFillEl.className = "meter-fill mem-fill";
    memStatusEl.className = "meter-status";
    if (memOom) {
      memFillEl.classList.add("critical");
      memStatusEl.className = "meter-status oom";
      memStatusEl.textContent = "OOM KILLED! memory.max exceeded — kernel sent SIGKILL";
      addCgLog('<span style="color:#ef4444">OOM Kill! Process exceeded ' + limits.mem + 'Mi memory limit. Container restarting...</span>');
      // Reset after OOM
      cgTargetMem = 0;
      cgMemUsage = 0;
      cgTargetCpu = cgTargetCpu * 0.3;
      cgTargetIo = cgTargetIo * 0.3;
    } else if (memPct > 80) {
      memFillEl.classList.add("warning");
      memStatusEl.className = "meter-status throttled";
      memStatusEl.textContent = "High memory pressure — approaching limit";
    } else {
      memStatusEl.textContent = Math.round(memClamped) + "Mi / " + limits.mem + "Mi";
    }

    // IO
    var ioPct = (ioClamped / 200) * 100;
    document.getElementById("ioMeterFill").style.width = ioPct + "%";
    document.getElementById("ioMeterVal").textContent = Math.round(ioClamped) + " MB/s";
    var ioFillEl = document.getElementById("ioMeterFill");
    var ioStatusEl = document.getElementById("ioStatus");
    ioFillEl.className = "meter-fill io-fill";
    ioStatusEl.className = "meter-status";
    if (ioThrottled) {
      ioFillEl.classList.add("warning");
      ioStatusEl.className = "meter-status throttled";
      ioStatusEl.textContent = "IO THROTTLED — blkio.max capping at " + limits.io + " MB/s";
    } else {
      ioStatusEl.textContent = Math.round(ioClamped) + " MB/s throughput";
    }
  }

  document.getElementById("stressBtn").addEventListener("click", function() {
    if (cgStressInterval) {
      clearInterval(cgStressInterval);
    }
    cgTargetCpu = 75 + Math.random() * 50;
    cgTargetMem = 300 + Math.random() * 600;
    cgTargetIo = 80 + Math.random() * 150;
    addCgLog('<span style="color:#f59e0b">Starting stress test: CPU target=' + Math.round(cgTargetCpu) + '%, Mem target=' + Math.round(cgTargetMem) + 'Mi, IO target=' + Math.round(cgTargetIo) + 'MB/s</span>');
    cgStressInterval = setInterval(stressTick, 200);
  });

  document.getElementById("cgResetBtn").addEventListener("click", function() {
    if (cgStressInterval) clearInterval(cgStressInterval);
    cgStressInterval = null;
    cgCpuUsage = 0; cgMemUsage = 0; cgIoUsage = 0;
    cgTargetCpu = 0; cgTargetMem = 0; cgTargetIo = 0;
    document.getElementById("cpuMeterFill").style.width = "0%";
    document.getElementById("memMeterFill").style.width = "0%";
    document.getElementById("ioMeterFill").style.width = "0%";
    document.getElementById("cpuMeterVal").textContent = "0%";
    document.getElementById("memMeterVal").textContent = "0 Mi";
    document.getElementById("ioMeterVal").textContent = "0 MB/s";
    document.getElementById("cpuMeterFill").className = "meter-fill cpu-fill";
    document.getElementById("memMeterFill").className = "meter-fill mem-fill";
    document.getElementById("ioMeterFill").className = "meter-fill io-fill";
    document.getElementById("cpuStatus").textContent = "Idle";
    document.getElementById("cpuStatus").className = "meter-status";
    document.getElementById("memStatus").textContent = "Idle";
    document.getElementById("memStatus").className = "meter-status";
    document.getElementById("ioStatus").textContent = "Idle";
    document.getElementById("ioStatus").className = "meter-status";
    document.getElementById("cgLog").innerHTML = "";
  });

  // --- Overlay Filesystem ---
  var overlayState = {
    layers: [
      {
        name: "Container Layer",
        type: "rw",
        files: [],
        instruction: "writable"
      },
      {
        name: "Layer 4: COPY . /app",
        type: "ro",
        files: ["/app/server.js", "/app/package.json", "/app/config.json"],
        instruction: "COPY . /app"
      },
      {
        name: "Layer 3: RUN npm install",
        type: "ro",
        files: ["/app/node_modules/express", "/app/node_modules/lodash"],
        instruction: "RUN npm install"
      },
      {
        name: "Layer 2: RUN apt-get install nginx",
        type: "ro",
        files: ["/usr/sbin/nginx", "/etc/nginx/nginx.conf", "/var/log/nginx/"],
        instruction: "RUN apt-get install"
      },
      {
        name: "Layer 1: Ubuntu 22.04 Base",
        type: "ro",
        files: ["/usr/lib/libc.so", "/bin/bash", "/etc/hosts"],
        instruction: "FROM ubuntu:22.04"
      }
    ]
  };

  var origOverlayState = JSON.parse(JSON.stringify(overlayState));

  function renderOverlay(highlightFile, searchLayer, foundLayer) {
    var el = document.getElementById("overlayLayers");
    var html = "";
    for (var i = 0; i < overlayState.layers.length; i++) {
      var layer = overlayState.layers[i];
      var cls = "overlay-layer " + (layer.type === "rw" ? "writable" : "readonly");
      if (searchLayer === i) cls += " searching";
      if (foundLayer === i) cls += " found";

      html += '<div class="' + cls + '">';
      html += '<div class="layer-header">';
      html += '<span class="layer-name">' + layer.name + '</span>';
      html += '<span class="layer-badge ' + (layer.type === "rw" ? "rw" : "ro") + '">' + (layer.type === "rw" ? "R/W" : "R/O") + '</span>';
      html += '</div>';
      html += '<div class="layer-files">';
      for (var f = 0; f < layer.files.length; f++) {
        var fileCls = "layer-file";
        if (highlightFile && layer.files[f] === highlightFile && foundLayer === i) fileCls += " highlight";
        if (layer.files[f].indexOf(".wh.") !== -1) fileCls += " whiteout";
        if (layer.files[f].indexOf("[COW]") !== -1) fileCls += " cow";
        html += '<span class="' + fileCls + '">' + layer.files[f] + '</span>';
      }
      if (layer.files.length === 0 && layer.type === "rw") {
        html += '<span class="layer-file" style="color:#555;font-style:italic;">empty</span>';
      }
      html += '</div>';
      html += '</div>';
    }
    el.innerHTML = html;
  }

  // File lookup map
  var fileLayerMap = {
    "/app/server.js": 1,
    "/etc/nginx/nginx.conf": 2,
    "/var/log/app.log": -1,
    "/usr/lib/libc.so": 4,
    "/tmp/session.dat": -1,
    "/app/config.json": 1
  };

  function lookupFile() {
    var file = document.getElementById("fileLookupSelect").value;
    var resultEl = document.getElementById("lookupResult");

    // Check writable layer first for COW copies
    var cowIdx = -1;
    for (var f = 0; f < overlayState.layers[0].files.length; f++) {
      if (overlayState.layers[0].files[f] === file || overlayState.layers[0].files[f] === file + " [COW]") {
        cowIdx = 0;
        break;
      }
    }
    // Check for whiteout
    var whiteout = false;
    for (var wf = 0; wf < overlayState.layers[0].files.length; wf++) {
      if (overlayState.layers[0].files[wf] === ".wh." + file.split("/").pop()) {
        whiteout = true;
        break;
      }
    }

    if (whiteout) {
      renderOverlay(null, null, null);
      resultEl.innerHTML = '<span style="color:#ef4444;">✗ File "' + file + '" has been deleted (whiteout in container layer)</span>';
      return;
    }

    var targetLayer = cowIdx >= 0 ? 0 : (fileLayerMap[file] !== undefined ? fileLayerMap[file] : -1);

    // Animate search through layers
    var currentSearch = 0;
    resultEl.innerHTML = '<span style="color:#fbbf24;">Searching...</span>';

    function searchStep() {
      if (currentSearch > Math.min(targetLayer >= 0 ? targetLayer : overlayState.layers.length - 1, overlayState.layers.length - 1)) {
        if (targetLayer < 0) {
          renderOverlay(null, null, null);
          resultEl.innerHTML = '<span style="color:#ef4444;">✗ File "' + file + '" not found in any layer</span>';
        } else {
          renderOverlay(file, null, targetLayer);
          var layerName = overlayState.layers[targetLayer].name;
          resultEl.innerHTML = '<span style="color:#4ade80;">✓ Found "' + file + '" in ' + layerName + '</span>';
          if (cowIdx >= 0) {
            resultEl.innerHTML += '<br><span style="color:#fbbf24;">(copy-on-write version in container layer)</span>';
          }
        }
        return;
      }
      renderOverlay(file, currentSearch, null);
      currentSearch++;
      setTimeout(searchStep, 400);
    }

    searchStep();
  }

  document.getElementById("lookupBtn").addEventListener("click", lookupFile);

  // Copy-on-write demo
  document.getElementById("cowBtn").addEventListener("click", function() {
    var file = "/etc/nginx/nginx.conf";
    // Copy to writable layer
    var alreadyCopied = false;
    for (var f = 0; f < overlayState.layers[0].files.length; f++) {
      if (overlayState.layers[0].files[f].indexOf(file) !== -1) {
        alreadyCopied = true;
        break;
      }
    }
    if (!alreadyCopied) {
      overlayState.layers[0].files.push(file + " [COW]");
    }
    renderOverlay(file + " [COW]", null, 0);
    document.getElementById("lookupResult").innerHTML = '<span style="color:#fbbf24;">✏️ Copy-on-Write: "' + file + '" copied from Layer 2 → Container Layer, then modified. Original in Layer 2 is unchanged.</span>';
  });

  // Delete demo
  document.getElementById("deleteBtn").addEventListener("click", function() {
    var file = "/app/server.js";
    var alreadyDeleted = false;
    for (var f = 0; f < overlayState.layers[0].files.length; f++) {
      if (overlayState.layers[0].files[f] === ".wh.server.js") {
        alreadyDeleted = true;
        break;
      }
    }
    if (!alreadyDeleted) {
      overlayState.layers[0].files.push(".wh.server.js");
    }
    renderOverlay(null, null, null);
    renderOverlay(null, null, null);
    document.getElementById("lookupResult").innerHTML = '<span style="color:#ef4444;">🗑️ Whiteout: ".wh.server.js" created in container layer. File appears deleted even though it still exists in Layer 4. Image layer is NOT modified.</span>';
  });

  document.getElementById("overlayResetBtn").addEventListener("click", function() {
    overlayState = JSON.parse(JSON.stringify(origOverlayState));
    renderOverlay(null, null, null);
    document.getElementById("lookupResult").innerHTML = "";
  });

  renderOverlay(null, null, null);

  // --- Container Lifecycle ---
  var lcSteps = [
    {
      icon: "🖥️",
      label: "docker run",
      sub: "CLI → daemon",
      detail: 'You type <code>docker run -d -p 80:80 nginx</code>. The Docker CLI sends a request to the <strong>Docker daemon</strong> (dockerd) via the Unix socket <code>/var/run/docker.sock</code>. The daemon validates the request and begins orchestrating the container creation.'
    },
    {
      icon: "📥",
      label: "Pull Image",
      sub: "Registry → layers",
      detail: 'The daemon checks if the image exists locally. If not, it <strong>pulls layers</strong> from the registry (e.g., Docker Hub). Each layer is downloaded independently and verified by SHA256 hash. Layers shared with other images are skipped — this is why second pulls are fast.'
    },
    {
      icon: "📦",
      label: "Create Namespaces",
      sub: "clone(NEWPID|NEWNET|...)",
      detail: 'The runtime calls <code>clone()</code> with namespace flags: <strong>CLONE_NEWPID</strong>, <strong>CLONE_NEWNET</strong>, <strong>CLONE_NEWNS</strong>, <strong>CLONE_NEWUTS</strong>, <strong>CLONE_NEWIPC</strong>, <strong>CLONE_NEWUSER</strong>. This creates isolated namespaces. The child process starts in a fresh environment — it cannot see host processes, network, or filesystem.'
    },
    {
      icon: "⚙️",
      label: "Apply Cgroups",
      sub: "cpu.max, memory.max",
      detail: 'The container runtime creates a cgroup under <code>/sys/fs/cgroup/system.slice/docker-&lt;id&gt;.scope/</code> and writes resource limits: <strong>cpu.max</strong> (CPU quota), <strong>memory.max</strong> (memory limit), <strong>io.max</strong> (IO throttle). The container process is moved into this cgroup.'
    },
    {
      icon: "📂",
      label: "Mount Overlay FS",
      sub: "pivot_root",
      detail: 'The overlay filesystem is assembled: image layers as <strong>lowerdir</strong> (read-only), a new directory as <strong>upperdir</strong> (writable), and a <strong>workdir</strong> for atomicity. Then <code>pivot_root()</code> swaps the container\'s root filesystem to this overlay mount. The host root becomes invisible.'
    },
    {
      icon: "🚀",
      label: "exec",
      sub: "PID 1 starts",
      detail: 'Finally, <code>execve()</code> replaces the setup process with the container\'s <strong>entrypoint</strong> (e.g., <code>nginx -g "daemon off;"</code>). This becomes <strong>PID 1</strong> inside the container\'s PID namespace. The container is now running. If PID 1 exits, the container stops.'
    }
  ];

  var lcCurrentStep = -1;
  var lcAutoInterval = null;

  function renderLifecycle() {
    var el = document.getElementById("lifecycleTimeline");
    var html = "";
    for (var i = 0; i < lcSteps.length; i++) {
      var cls = "lc-step";
      if (i === lcCurrentStep) cls += " active";
      else if (i < lcCurrentStep) cls += " done";
      html += '<div class="' + cls + '">';
      html += '<div class="lc-icon">' + lcSteps[i].icon + '</div>';
      html += '<div class="lc-label">' + lcSteps[i].label + '</div>';
      html += '<div class="lc-sub">' + lcSteps[i].sub + '</div>';
      html += '</div>';
    }
    el.innerHTML = html;
  }

  function showLcDetail() {
    var el = document.getElementById("lcDetail");
    if (lcCurrentStep < 0 || lcCurrentStep >= lcSteps.length) {
      el.innerHTML = '<div class="log-empty">Click "Next Step" to begin the container lifecycle...</div>';
      return;
    }
    el.innerHTML = '<strong>Step ' + (lcCurrentStep + 1) + '/' + lcSteps.length + ': ' + lcSteps[lcCurrentStep].label + '</strong><br><br>' + lcSteps[lcCurrentStep].detail;
  }

  document.getElementById("lcNextBtn").addEventListener("click", function() {
    if (lcCurrentStep < lcSteps.length - 1) {
      lcCurrentStep++;
      renderLifecycle();
      showLcDetail();
    }
    if (lcCurrentStep >= lcSteps.length - 1) {
      this.disabled = true;
    }
  });

  document.getElementById("lcAutoBtn").addEventListener("click", function() {
    if (lcAutoInterval) return;
    var btn = this;
    btn.disabled = true;
    lcCurrentStep = -1;

    function autoStep() {
      if (lcCurrentStep < lcSteps.length - 1) {
        lcCurrentStep++;
        renderLifecycle();
        showLcDetail();
      } else {
        clearInterval(lcAutoInterval);
        lcAutoInterval = null;
        btn.disabled = false;
        document.getElementById("lcNextBtn").disabled = true;
      }
    }

    lcAutoInterval = setInterval(autoStep, 1800);
    autoStep();
  });

  document.getElementById("lcResetBtn").addEventListener("click", function() {
    if (lcAutoInterval) {
      clearInterval(lcAutoInterval);
      lcAutoInterval = null;
    }
    lcCurrentStep = -1;
    renderLifecycle();
    showLcDetail();
    document.getElementById("lcNextBtn").disabled = false;
    document.getElementById("lcAutoBtn").disabled = false;
  });

  renderLifecycle();
  showLcDetail();
</script>
