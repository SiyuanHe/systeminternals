---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Container Internals: Namespaces, Cgroups & Overlay FS" 
  description="Interactive visualization of how containers work under the hood — Linux namespaces, cgroups v2, overlay filesystems, and the container lifecycle"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "Docker", href: "/docker/" },
    { label: "Container Internals", href: "/docker/container-internals/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🐳 Container Internals</h1>
      <p class="subtitle">Namespaces, Cgroups &amp; Overlay FS — What Really Happens Under the Hood</p>
    </header>

    <!-- Overview -->
    <section class="overview-section">
      <div class="overview-card">
        <p>
          Containers are <strong>not lightweight VMs</strong>. A VM runs a full guest kernel on
          virtualized hardware. A container is just a <em>regular Linux process</em> with three
          kernel features applied: <strong>namespaces</strong> for isolation (what the process can
          <em>see</em>), <strong>cgroups</strong> for resource limits (what the process can <em>use</em>),
          and a <strong>union filesystem</strong> for efficient image layering. The kernel is
          <em>shared</em> — there is no second OS.
        </p>
      </div>
    </section>

    <!-- Containers vs VMs -->
    <section class="compare-section">
      <h2>🔀 Containers vs Virtual Machines</h2>
      <p class="section-desc">Same goal (isolation), fundamentally different approach.</p>
      <div class="compare-grid">
        <div class="compare-card vm-card">
          <h3>Virtual Machine</h3>
          <div class="stack-viz" id="vmStack">
            <div class="stack-layer hardware">Hardware</div>
            <div class="stack-layer hypervisor">Hypervisor (KVM / VMware)</div>
            <div class="stack-layer guest-os">Guest OS Kernel</div>
            <div class="stack-layer guest-os">Guest OS Libs</div>
            <div class="stack-layer app">App Process</div>
          </div>
          <p class="compare-note">Full kernel copy per VM. GBs of overhead. Minutes to boot.</p>
        </div>
        <div class="compare-card container-card">
          <h3>Container</h3>
          <div class="stack-viz" id="containerStack">
            <div class="stack-layer hardware">Hardware</div>
            <div class="stack-layer host-kernel">Host Kernel (shared)</div>
            <div class="stack-layer namespace">Namespaces + Cgroups</div>
            <div class="stack-layer app">App Process</div>
          </div>
          <p class="compare-note">Shared kernel. MBs of overhead. Milliseconds to start.</p>
        </div>
      </div>
    </section>

    <!-- Linux Namespaces -->
    <section class="ns-section">
      <h2>📦 Linux Namespaces</h2>
      <p class="section-desc">Each namespace type isolates a different aspect of the system. Click to explore.</p>

      <div class="ns-tabs" id="nsTabs">
        <button class="ns-tab active" data-ns="pid">PID</button>
        <button class="ns-tab" data-ns="net">NET</button>
        <button class="ns-tab" data-ns="mnt">MNT</button>
        <button class="ns-tab" data-ns="uts">UTS</button>
        <button class="ns-tab" data-ns="ipc">IPC</button>
        <button class="ns-tab" data-ns="user">USER</button>
      </div>

      <div class="ns-display" id="nsDisplay">
        <!-- Rendered by JS -->
      </div>

      <!-- Interactive Process Tree -->
      <div class="ptree-section">
        <h3>🌳 Process Tree: Namespace Isolation</h3>
        <p class="section-desc">Host sees all processes. Each container sees only its own PID tree starting from PID 1.</p>
        <div class="ptree-controls">
          <button class="action-btn primary-btn" id="spawnContainerBtn">+ Spawn Container</button>
          <button class="action-btn reset-btn" id="ptreeResetBtn">🔄 Reset</button>
          <span class="ptree-view-label">View as:</span>
          <button class="action-btn view-btn active" id="viewHostBtn">Host</button>
          <button class="action-btn view-btn" id="viewC1Btn">Container 1</button>
          <button class="action-btn view-btn" id="viewC2Btn" disabled>Container 2</button>
          <button class="action-btn view-btn" id="viewC3Btn" disabled>Container 3</button>
        </div>
        <div class="ptree" id="ptree">
          <!-- Rendered by JS -->
        </div>
      </div>
    </section>

    <!-- Cgroups v2 -->
    <section class="cgroup-section">
      <h2>⚙️ Cgroups v2: Resource Limits</h2>
      <p class="section-desc">Cgroups control how much CPU, memory, and I/O a container can consume. Drag the sliders to see what happens when processes hit their limits.</p>

      <div class="cgroup-demo">
        <div class="cgroup-config">
          <h3>Container Resource Limits</h3>
          <div class="config-group">
            <label>CPU Limit: <strong id="cgCpuLabel">100%</strong> (of 1 core)</label>
            <input type="range" id="cgCpuSlider" min="10" max="100" value="100" step="5" class="slider">
          </div>
          <div class="config-group">
            <label>Memory Limit: <strong id="cgMemLabel">512Mi</strong></label>
            <input type="range" id="cgMemSlider" min="64" max="1024" value="512" step="64" class="slider">
          </div>
          <div class="config-group">
            <label>IO Bandwidth: <strong id="cgIoLabel">100MB/s</strong></label>
            <input type="range" id="cgIoSlider" min="10" max="200" value="100" step="10" class="slider">
          </div>
          <button class="action-btn chaos-btn" id="stressBtn">🔥 Stress Test Container</button>
          <button class="action-btn reset-btn" id="cgResetBtn">🔄 Reset</button>
        </div>

        <div class="cgroup-meters">
          <div class="meter-card">
            <div class="meter-header">
              <span class="meter-icon">⚡</span>
              <span class="meter-title">CPU Usage</span>
              <span class="meter-value" id="cpuMeterVal">0%</span>
            </div>
            <div class="meter-bar">
              <div class="meter-fill cpu-fill" id="cpuMeterFill" style="width: 0%"></div>
              <div class="meter-limit" id="cpuMeterLimit" style="left: 100%"></div>
            </div>
            <div class="meter-status" id="cpuStatus">Idle</div>
          </div>
          <div class="meter-card">
            <div class="meter-header">
              <span class="meter-icon">🧠</span>
              <span class="meter-title">Memory Usage</span>
              <span class="meter-value" id="memMeterVal">0 Mi</span>
            </div>
            <div class="meter-bar">
              <div class="meter-fill mem-fill" id="memMeterFill" style="width: 0%"></div>
              <div class="meter-limit" id="memMeterLimit" style="left: 100%"></div>
            </div>
            <div class="meter-status" id="memStatus">Idle</div>
          </div>
          <div class="meter-card">
            <div class="meter-header">
              <span class="meter-icon">💾</span>
              <span class="meter-title">IO Throughput</span>
              <span class="meter-value" id="ioMeterVal">0 MB/s</span>
            </div>
            <div class="meter-bar">
              <div class="meter-fill io-fill" id="ioMeterFill" style="width: 0%"></div>
              <div class="meter-limit" id="ioMeterLimit" style="left: 100%"></div>
            </div>
            <div class="meter-status" id="ioStatus">Idle</div>
          </div>
          <div class="cgroup-log" id="cgLog"></div>
        </div>
      </div>
    </section>

    <!-- Overlay Filesystem -->
    <section class="overlay-section">
      <h2>📂 Union / Overlay Filesystem</h2>
      <p class="section-desc">Container images are stacks of read-only layers. The container gets a thin writable layer on top. File lookups walk top-down.</p>

      <div class="overlay-demo">
        <div class="overlay-layers" id="overlayLayers">
          <!-- Rendered by JS -->
        </div>

        <div class="overlay-controls">
          <div class="overlay-lookup">
            <h3>🔍 File Lookup</h3>
            <p class="section-desc">Type a filename to see how overlay FS resolves it through layers.</p>
            <div class="lookup-input-wrap">
              <select id="fileLookupSelect" class="config-select">
                <option value="/app/server.js">/app/server.js</option>
                <option value="/etc/nginx/nginx.conf">/etc/nginx/nginx.conf</option>
                <option value="/var/log/app.log">/var/log/app.log</option>
                <option value="/usr/lib/libc.so">/usr/lib/libc.so</option>
                <option value="/tmp/session.dat">/tmp/session.dat</option>
                <option value="/app/config.json">/app/config.json</option>
              </select>
              <button class="action-btn primary-btn" id="lookupBtn">Lookup</button>
            </div>
            <div class="lookup-result" id="lookupResult"></div>
          </div>

          <div class="overlay-write">
            <h3>✏️ Copy-on-Write</h3>
            <p class="section-desc">Modifying a file from a lower layer copies it to the writable layer first.</p>
            <button class="action-btn election-btn" id="cowBtn">Modify /etc/nginx/nginx.conf</button>
            <button class="action-btn chaos-btn" id="deleteBtn">Delete /app/server.js</button>
            <button class="action-btn reset-btn" id="overlayResetBtn">🔄 Reset</button>
          </div>
        </div>
      </div>
    </section>

    <!-- Container Lifecycle -->
    <section class="lifecycle-section">
      <h2>🔄 Container Lifecycle</h2>
      <p class="section-desc">Step through what happens when you run <code>docker run nginx</code>.</p>

      <div class="lifecycle-timeline" id="lifecycleTimeline">
        <!-- Rendered by JS -->
      </div>

      <div class="lifecycle-controls">
        <button class="action-btn primary-btn" id="lcNextBtn">▶ Next Step</button>
        <button class="action-btn election-btn" id="lcAutoBtn">⏩ Auto Play</button>
        <button class="action-btn reset-btn" id="lcResetBtn">🔄 Reset</button>
      </div>

      <div class="lifecycle-detail" id="lcDetail">
        <div class="log-empty">Click "Next Step" to begin the container lifecycle...</div>
      </div>
    </section>

    <!-- Image Layers -->
    <section class="explain-section">
      <h2>🏗️ Image Layers &amp; Builds</h2>
      <p class="section-desc">Each Dockerfile instruction creates a layer. Understanding layers is key to fast builds.</p>
      <div class="explain-grid">
        <div class="explain-card">
          <h3>📋 One Instruction = One Layer</h3>
          <p>
            Each <code>RUN</code>, <code>COPY</code>, and <code>ADD</code> instruction creates a new
            layer in the image. Layers are <strong>content-addressable</strong> (SHA256 hash) and
            <strong>shared</strong> across images. If two images use the same base, they share those layers on disk.
          </p>
        </div>
        <div class="explain-card">
          <h3>⚡ Layer Caching</h3>
          <p>
            Docker caches each layer. If a layer's instruction and inputs haven't changed, the cached
            version is reused. <strong>Order matters</strong>: put rarely-changing instructions (install deps)
            before frequently-changing ones (copy source code) to maximize cache hits.
          </p>
        </div>
        <div class="explain-card highlight-card">
          <h3>🎯 Multi-Stage Builds</h3>
          <p>
            Use multiple <code>FROM</code> statements. Build in a fat image (compilers, tools), then
            <code>COPY --from=builder</code> only the binary into a slim runtime image. Result:
            <strong>10x smaller images</strong>, no build tools in production.
          </p>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://man7.org/linux/man-pages/man7/namespaces.7.html" target="_blank">Linux namespaces(7)</a>, <a href="https://www.kernel.org/doc/html/latest/admin-guide/cgroup-v2.html" target="_blank">cgroups v2</a>, and <a href="https://docs.kernel.org/filesystems/overlayfs.html" target="_blank">OverlayFS</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share this visualization:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20Container%20Internals%20visualizer%20—%20namespaces%2C%20cgroups%2C%20overlay%20FS&url=https://systeminternals.dev/docker/container-internals/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/docker/container-internals/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/docker/container-internals/&t=Interactive%20Container%20Internals%20Visualizer" target="_blank" class="share-btn">🟧 Hacker News</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .viz-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #06b6d4, #3b82f6, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #888;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 12px;
  }

  .section-desc {
    color: #888;
    margin-bottom: 24px;
    font-size: 1rem;
  }

  .section-desc code {
    background: rgba(0,0,0,0.3);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.85rem;
    color: #22c55e;
  }

  /* Overview */
  .overview-section {
    margin-bottom: 50px;
  }

  .overview-card {
    background: linear-gradient(135deg, rgba(6, 182, 212, 0.1), rgba(139, 92, 246, 0.05));
    border: 1px solid rgba(6, 182, 212, 0.3);
    border-radius: 16px;
    padding: 24px 28px;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #ccc;
  }

  .overview-card strong { color: #fff; }
  .overview-card em { color: #06b6d4; font-style: normal; font-weight: 500; }

  /* Compare Section */
  .compare-section {
    margin-bottom: 50px;
  }

  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .compare-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
  }

  .compare-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 16px;
    text-align: center;
  }

  .stack-viz {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 16px;
  }

  .stack-layer {
    padding: 10px 16px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    transition: all 0.3s;
  }

  .stack-layer.hardware {
    background: rgba(107, 114, 128, 0.3);
    color: #9ca3af;
    border: 1px solid rgba(107, 114, 128, 0.4);
  }

  .stack-layer.hypervisor {
    background: rgba(239, 68, 68, 0.15);
    color: #fca5a5;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  .stack-layer.guest-os {
    background: rgba(251, 191, 36, 0.15);
    color: #fcd34d;
    border: 1px solid rgba(251, 191, 36, 0.3);
  }

  .stack-layer.host-kernel {
    background: rgba(34, 197, 94, 0.15);
    color: #86efac;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .stack-layer.namespace {
    background: rgba(6, 182, 212, 0.15);
    color: #67e8f9;
    border: 1px solid rgba(6, 182, 212, 0.3);
  }

  .stack-layer.app {
    background: rgba(139, 92, 246, 0.15);
    color: #c4b5fd;
    border: 1px solid rgba(139, 92, 246, 0.3);
  }

  .compare-note {
    font-size: 0.85rem;
    color: #888;
    text-align: center;
    font-style: italic;
  }

  /* Namespace Section */
  .ns-section {
    margin-bottom: 50px;
  }

  .ns-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .ns-tab {
    padding: 8px 20px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.03);
    color: #aaa;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .ns-tab:hover {
    border-color: rgba(6, 182, 212, 0.4);
    color: #fff;
  }

  .ns-tab.active {
    background: rgba(6, 182, 212, 0.15);
    border-color: rgba(6, 182, 212, 0.5);
    color: #67e8f9;
  }

  .ns-display {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 30px;
    min-height: 120px;
  }

  .ns-info-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }

  .ns-info-desc {
    color: #aaa;
    line-height: 1.7;
    font-size: 0.95rem;
    margin-bottom: 12px;
  }

  .ns-info-desc strong { color: #fff; }
  .ns-info-desc code {
    background: rgba(0,0,0,0.3);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.8rem;
    color: #22c55e;
  }

  .ns-example {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 14px 18px;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.8rem;
    color: #aaa;
    line-height: 1.6;
    white-space: pre-wrap;
  }

  .ns-example .host-label { color: #f87171; font-weight: 700; }
  .ns-example .container-label { color: #4ade80; font-weight: 700; }

  /* Process Tree */
  .ptree-section {
    margin-top: 30px;
  }

  .ptree-section h3 {
    font-size: 1.1rem;
    color: #fff;
    margin-bottom: 8px;
  }

  .ptree-controls {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .ptree-view-label {
    color: #888;
    font-size: 0.85rem;
    margin-left: 8px;
  }

  .view-btn {
    padding: 6px 14px;
    font-size: 0.8rem;
    background: rgba(255,255,255,0.05);
    color: #888;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .view-btn.active {
    background: rgba(6, 182, 212, 0.15);
    border-color: rgba(6, 182, 212, 0.4);
    color: #67e8f9;
  }

  .view-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ptree {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 20px;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.8rem;
    line-height: 1.8;
    overflow-x: auto;
  }

  .ptree-line { color: #888; }
  .ptree-line.highlight { color: #4ade80; background: rgba(74, 222, 128, 0.08); border-radius: 4px; }
  .ptree-line .pid { color: #60a5fa; font-weight: 700; }
  .ptree-line .proc { color: #e2e8f0; }
  .ptree-line .ns-badge {
    font-size: 0.7rem;
    padding: 1px 6px;
    border-radius: 4px;
    margin-left: 8px;
  }
  .ns-badge.host-ns { background: rgba(239, 68, 68, 0.2); color: #fca5a5; }
  .ns-badge.c1-ns { background: rgba(6, 182, 212, 0.2); color: #67e8f9; }
  .ns-badge.c2-ns { background: rgba(168, 85, 247, 0.2); color: #c4b5fd; }
  .ns-badge.c3-ns { background: rgba(251, 191, 36, 0.2); color: #fcd34d; }

  /* Cgroups Section */
  .cgroup-section {
    margin-bottom: 50px;
  }

  .cgroup-demo {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 24px;
  }

  .cgroup-config {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 20px;
  }

  .cgroup-config h3 {
    font-size: 1rem;
    color: #fff;
    margin-bottom: 16px;
    font-weight: 600;
  }

  .config-group {
    margin-bottom: 16px;
  }

  .config-group label {
    display: block;
    font-size: 0.85rem;
    color: #aaa;
    margin-bottom: 6px;
  }

  .config-group label strong {
    color: #06b6d4;
  }

  .slider {
    width: 100%;
    height: 6px;
    -webkit-appearance: none;
    background: rgba(255,255,255,0.15);
    border-radius: 3px;
    cursor: pointer;
  }

  .slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #06b6d4;
    cursor: pointer;
  }

  .config-select {
    width: 100%;
    padding: 8px 10px;
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    color: #ddd;
    font-size: 0.85rem;
  }

  .cgroup-config .action-btn {
    width: 100%;
    margin-top: 8px;
  }

  .cgroup-meters {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .meter-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    padding: 16px 20px;
  }

  .meter-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .meter-icon { font-size: 1.2rem; }
  .meter-title { font-size: 0.9rem; color: #fff; font-weight: 600; flex: 1; }
  .meter-value { font-size: 0.9rem; color: #06b6d4; font-weight: 700; font-family: 'JetBrains Mono', monospace; }

  .meter-bar {
    height: 10px;
    background: rgba(255,255,255,0.08);
    border-radius: 5px;
    position: relative;
    overflow: visible;
    margin-bottom: 8px;
  }

  .meter-fill {
    height: 100%;
    border-radius: 5px;
    transition: width 0.3s ease, background 0.3s;
  }

  .meter-fill.cpu-fill { background: linear-gradient(90deg, #06b6d4, #3b82f6); }
  .meter-fill.mem-fill { background: linear-gradient(90deg, #8b5cf6, #a855f7); }
  .meter-fill.io-fill { background: linear-gradient(90deg, #22c55e, #16a34a); }

  .meter-fill.warning { background: linear-gradient(90deg, #f59e0b, #ef4444) !important; }
  .meter-fill.critical { background: linear-gradient(90deg, #ef4444, #dc2626) !important; animation: meterPulse 0.5s infinite; }

