---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Google Spanner: TrueTime & Commit-Wait" 
  description="Interactive visualization of Spanner's TrueTime API, commit-wait protocol, Paxos replication, and external consistency guarantees"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "Spanner", href: "/spanner/" },
    { label: "TrueTime", href: "/spanner/truetime/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>⏱️ TrueTime &amp; Commit-Wait</h1>
      <p class="subtitle">How Google Spanner uses physical clocks to guarantee external consistency at global scale</p>
    </header>

    <!-- Overview -->
    <section class="overview-section">
      <div class="overview-card">
        <p>
          Google Spanner is the only production system that provides <strong>external consistency</strong> 
          for globally-distributed transactions. The key insight: if you can <em>bound clock uncertainty</em>, 
          you can use real time as a consistency primitive. <strong>TrueTime</strong> exposes clock uncertainty 
          explicitly — instead of returning a single timestamp, <code>TT.now()</code> returns an interval 
          <code>[earliest, latest]</code>. Spanner's <em>commit-wait</em> rule then waits out the uncertainty, 
          guaranteeing that if transaction T1 commits before T2 starts, T1's timestamp is less than T2's.
        </p>
      </div>
    </section>

    <!-- TrueTime API -->
    <section class="api-section">
      <h2>🕐 The TrueTime API</h2>
      <p class="section-desc">Three methods that expose clock uncertainty to the database</p>

      <div class="api-grid">
        <div class="api-card" data-api="now">
          <div class="api-name">TT.now()</div>
          <div class="api-return">→ TTinterval [earliest, latest]</div>
          <div class="api-desc">Returns a time interval guaranteed to contain the true absolute time. The width (ε) is typically 1-7ms.</div>
        </div>
        <div class="api-card" data-api="after">
          <div class="api-name">TT.after(t)</div>
          <div class="api-return">→ boolean</div>
          <div class="api-desc">Returns true if timestamp t has definitely passed. Equivalent to: t &lt; TT.now().earliest</div>
        </div>
        <div class="api-card" data-api="before">
          <div class="api-name">TT.before(t)</div>
          <div class="api-return">→ boolean</div>
          <div class="api-desc">Returns true if timestamp t has definitely not arrived yet. Equivalent to: t &gt; TT.now().latest</div>
        </div>
      </div>

      <div class="uncertainty-viz">
        <h3>Clock Uncertainty (ε) Over Time</h3>
        <p class="section-desc">Between GPS/atomic clock syncs, uncertainty grows. After sync, it collapses back.</p>
        <div class="uncertainty-canvas-wrap">
          <canvas id="uncertaintyCanvas" width="800" height="200"></canvas>
        </div>
        <div class="uncertainty-controls">
          <button id="syncClockBtn" class="action-btn primary-btn">📡 GPS Sync</button>
          <div class="epsilon-display">ε = <span id="epsilonValue">1.0</span> ms</div>
        </div>
      </div>
    </section>

    <!-- Interactive TrueTime Interval -->
    <section class="interval-section">
      <h2>📊 Live TrueTime Interval</h2>
      <p class="section-desc">Watch TT.now() return an interval that shrinks after each clock sync</p>

      <div class="interval-viz">
        <div class="interval-timeline" id="intervalTimeline">
          <div class="interval-bar" id="intervalBar">
            <div class="interval-label-left" id="intervalEarliest">earliest</div>
            <div class="interval-center-mark"></div>
            <div class="interval-label-right" id="intervalLatest">latest</div>
          </div>
          <div class="true-time-marker" id="trueTimeMarker">
            <div class="marker-label">true time (unknown)</div>
          </div>
        </div>
        <div class="interval-readout">
          <div class="readout-item">
            <span class="readout-label">TT.now().earliest</span>
            <span class="readout-value" id="readoutEarliest">—</span>
          </div>
          <div class="readout-item">
            <span class="readout-label">TT.now().latest</span>
            <span class="readout-value" id="readoutLatest">—</span>
          </div>
          <div class="readout-item highlight-readout">
            <span class="readout-label">Uncertainty (ε)</span>
            <span class="readout-value" id="readoutEpsilon">—</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Commit-Wait -->
    <section class="commit-section">
      <h2>⏳ Commit-Wait Protocol</h2>
      <p class="section-desc">After assigning a commit timestamp s, Spanner waits until TT.after(s) is true</p>

      <div class="commit-controls">
        <button id="runCommitBtn" class="action-btn primary-btn">▶ Run Commit-Wait</button>
        <button id="commitResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="commit-viz" id="commitViz">
        <div class="commit-timeline-bar">
          <div class="commit-phase" id="commitPhase1">
            <span class="phase-label">① Acquire locks &amp; pick s = TT.now().latest</span>
          </div>
          <div class="commit-phase waiting" id="commitPhase2">
            <span class="phase-label">② Commit-wait: sleep until TT.after(s)</span>
            <div class="wait-progress" id="waitProgress"></div>
          </div>
          <div class="commit-phase" id="commitPhase3">
            <span class="phase-label">③ Release locks &amp; notify client</span>
          </div>
        </div>
      </div>

      <div class="commit-log" id="commitLog">
        <div class="log-entry info">Ready — click "Run Commit-Wait" to begin</div>
      </div>

      <div class="commit-explain-grid">
        <div class="explain-card">
          <h3>Why Wait?</h3>
          <p>
            The commit timestamp <strong>s</strong> is chosen as <code>TT.now().latest</code> — the upper bound 
            of the uncertainty interval. By waiting until <code>TT.after(s)</code> returns true, Spanner guarantees 
            that <strong>s has definitely passed in absolute time</strong> before any locks are released. 
            Any subsequent transaction will see a strictly greater timestamp.
          </p>
        </div>
        <div class="explain-card">
          <h3>The Cost</h3>
          <p>
            Commit-wait adds <strong>~2ε</strong> of latency to every write transaction (typically 7-14ms). 
            This is the price of external consistency. Google minimizes ε with <strong>GPS receivers</strong> 
            and <strong>atomic clocks</strong> in every datacenter — GPS for accuracy, atomic clocks as 
            backup when GPS signal drops.
          </p>
        </div>
      </div>
    </section>

    <!-- External Consistency -->
    <section class="consistency-section">
      <h2>🔒 External Consistency</h2>
      <p class="section-desc">If T1 commits before T2 starts, then T1's timestamp &lt; T2's timestamp — always</p>

      <div class="consistency-controls">
        <button id="runConsistencyBtn" class="action-btn primary-btn">▶ Run Two Transactions</button>
        <button id="consistencyResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="consistency-viz" id="consistencyViz">
        <div class="txn-lane" id="txnLane1">
          <div class="lane-label">T1</div>
          <div class="lane-bar" id="laneBar1"></div>
        </div>
        <div class="txn-lane" id="txnLane2">
          <div class="lane-label">T2</div>
          <div class="lane-bar" id="laneBar2"></div>
        </div>
        <div class="time-axis">
          <span>real time →</span>
        </div>
      </div>

      <div class="consistency-log" id="consistencyLog">
        <div class="log-entry info">Click "Run Two Transactions" to see external consistency in action</div>
      </div>
    </section>

    <!-- Paxos Groups -->
    <section class="paxos-section">
      <h2>🗳️ Paxos Groups &amp; Multi-Datacenter Replication</h2>
      <p class="section-desc">Each split (range of rows) is replicated via Paxos across datacenters</p>

      <div class="paxos-controls">
        <button id="paxosWriteBtn" class="action-btn primary-btn">📝 Write to Split</button>
        <button id="paxosFailBtn" class="action-btn kill-btn">💀 Kill Replica</button>
        <button id="paxosResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="dc-grid">
        <div class="dc-box" id="dc1">
          <div class="dc-name">🇺🇸 US-East</div>
          <div class="dc-detail">GPS + Atomic Clock</div>
          <div class="replica-box leader" id="replica1">
            <div class="replica-role">Leader</div>
            <div class="replica-data" id="replicaData1">v1: balance=$100</div>
          </div>
        </div>
        <div class="dc-box" id="dc2">
          <div class="dc-name">🇪🇺 EU-West</div>
          <div class="dc-detail">GPS + Atomic Clock</div>
          <div class="replica-box follower" id="replica2">
            <div class="replica-role">Follower</div>
            <div class="replica-data" id="replicaData2">v1: balance=$100</div>
          </div>
        </div>
        <div class="dc-box" id="dc3">
          <div class="dc-name">🇯🇵 Asia-NE</div>
          <div class="dc-detail">GPS + Atomic Clock</div>
          <div class="replica-box follower" id="replica3">
            <div class="replica-role">Follower</div>
            <div class="replica-data" id="replicaData3">v1: balance=$100</div>
          </div>
        </div>
      </div>

      <div class="paxos-log" id="paxosLog">
        <div class="log-entry info">3 replicas across 3 datacenters — quorum = 2</div>
      </div>

      <div class="paxos-explain">
        <div class="explain-card">
          <h3>Why Paxos, Not Raft?</h3>
          <p>
            Spanner uses <strong>Multi-Paxos</strong> (with a long-lived leader) for each split. Unlike Raft, 
            Paxos allows more flexibility in leader election and log management. Each datacenter has 
            <strong>GPS receivers</strong> and <strong>atomic clocks</strong> feeding into local TrueTime daemons. 
            The leader coordinates writes, but <strong>read-only transactions are lock-free</strong> — they 
            pick a safe timestamp and read from any sufficiently up-to-date replica.
          </p>
        </div>
      </div>
    </section>

    <!-- Read-Only Transactions -->
    <section class="readonly-section">
      <h2>📖 Read-Only Transactions</h2>
      <p class="section-desc">Lock-free, globally consistent reads at a chosen timestamp</p>

      <div class="readonly-viz">
        <div class="readonly-diagram">
          <div class="ro-step">
            <div class="ro-num">1</div>
            <div class="ro-content">
              <h4>Pick read timestamp</h4>
              <p>Choose <code>s_read = TT.now().latest</code> — guaranteed to be in the past or present</p>
            </div>
          </div>
          <div class="ro-arrow">→</div>
          <div class="ro-step">
            <div class="ro-num">2</div>
            <div class="ro-content">
              <h4>Read from any replica</h4>
              <p>Any replica that is up-to-date through <code>s_read</code> can serve the read — no locks needed</p>
            </div>
          </div>
          <div class="ro-arrow">→</div>
          <div class="ro-step">
            <div class="ro-num">3</div>
            <div class="ro-content">
              <h4>Snapshot isolation</h4>
              <p>All reads see a consistent snapshot — no write can sneak in at <code>s_read</code> because commit-wait guarantees ordering</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CockroachDB Comparison -->
    <section class="compare-section">
      <h2>⚔️ Spanner vs CockroachDB: Clocks</h2>
      <p class="section-desc">TrueTime (hardware clocks) vs Hybrid Logical Clocks (software only)</p>

      <div class="compare-grid">
        <div class="compare-card spanner-card">
          <h3>🌐 Google Spanner</h3>
          <div class="compare-items">
            <div class="compare-item">
              <strong>Clock Source</strong>
              <span>GPS + Atomic Clocks (hardware)</span>
            </div>
            <div class="compare-item">
              <strong>Uncertainty</strong>
              <span>Bounded: ~1-7ms (ε)</span>
            </div>
            <div class="compare-item">
              <strong>Consistency</strong>
              <span>External consistency via commit-wait</span>
            </div>
            <div class="compare-item">
              <strong>Write Latency Cost</strong>
              <span>+2ε (~7-14ms) commit-wait</span>
            </div>
            <div class="compare-item">
              <strong>Read-Only Txns</strong>
              <span>Lock-free at safe timestamp</span>
            </div>
            <div class="compare-item">
              <strong>Availability</strong>
              <span>Google Cloud only</span>
            </div>
          </div>
        </div>
        <div class="compare-card crdb-card">
          <h3>🪳 CockroachDB</h3>
          <div class="compare-items">
            <div class="compare-item">
              <strong>Clock Source</strong>
              <span>NTP + Hybrid Logical Clocks (software)</span>
            </div>
            <div class="compare-item">
              <strong>Uncertainty</strong>
              <span>Unbounded: relies on max-offset (default 500ms)</span>
            </div>
            <div class="compare-item">
              <strong>Consistency</strong>
              <span>Serializable SI + uncertainty restart</span>
            </div>
            <div class="compare-item">
              <strong>Write Latency Cost</strong>
              <span>No commit-wait, but possible txn restarts</span>
            </div>
            <div class="compare-item">
              <strong>Read-Only Txns</strong>
              <span>Leaseholder reads (no consensus)</span>
            </div>
            <div class="compare-item">
              <strong>Availability</strong>
              <span>Open source, runs anywhere</span>
            </div>
          </div>
        </div>
      </div>

      <div class="compare-insight">
        <p>
          <strong>Key trade-off:</strong> Spanner pays a small, predictable latency cost (commit-wait ~7ms) on 
          every write to guarantee external consistency. CockroachDB avoids this cost but must occasionally 
          <strong>restart transactions</strong> when it detects possible clock skew — and cannot guarantee 
          external consistency without specialized hardware. For most applications, CockroachDB's approach 
          is sufficient. For financial systems requiring strict real-time ordering, Spanner's guarantee is stronger.
        </p>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://research.google/pubs/pub39966/" target="_blank">Spanner: Google's Globally-Distributed Database (OSDI 2012)</a> and <a href="https://research.google/pubs/pub45855/" target="_blank">Spanner, TrueTime &amp; the CAP Theorem (2017)</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share this visualization:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20visualization%20of%20Google%20Spanner%20TrueTime%20%26%20Commit-Wait&url=https://systeminternals.dev/spanner/truetime/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/spanner/truetime/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/spanner/truetime/&t=Interactive%20Google%20Spanner%20TrueTime%20Visualizer" target="_blank" class="share-btn">🟧 Hacker News</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .viz-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #ffb347, #ff6723, #f87171);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #888;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 12px;
  }

  .section-desc {
    color: #888;
    margin-bottom: 24px;
    font-size: 1rem;
  }

  /* Overview */
  .overview-section {
    margin-bottom: 50px;
  }

  .overview-card {
    background: linear-gradient(135deg, rgba(255, 179, 71, 0.1), rgba(248, 113, 113, 0.05));
    border: 1px solid rgba(255, 179, 71, 0.3);
    border-radius: 16px;
    padding: 24px 28px;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #ccc;
  }

  .overview-card strong { color: #fff; }
  .overview-card em { color: #ffb347; font-style: normal; font-weight: 500; }
  .overview-card code {
    background: rgba(0,0,0,0.3);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9rem;
    color: #fbbf24;
  }

  /* Action Buttons */
  .action-btn {
    padding: 10px 20px;
    border: none;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .action-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .primary-btn {
    background: linear-gradient(135deg, #ffb347, #ff6723);
    color: #111;
  }

  .primary-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(255, 103, 35, 0.4);
  }

  .kill-btn {
    background: linear-gradient(135deg, #f87171, #ef4444);
    color: white;
  }

  .reset-btn {
    background: rgba(255,255,255,0.1);
    color: #aaa;
  }

  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  /* API Section */
  .api-section {
    margin-bottom: 50px;
  }

  .api-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 30px;
  }

  .api-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 20px;
    transition: all 0.3s;
    cursor: default;
  }

  .api-card:hover {
    background: rgba(255, 179, 71, 0.08);
    border-color: rgba(255, 179, 71, 0.4);
  }

  .api-name {
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffb347;
    margin-bottom: 6px;
  }

  .api-return {
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 12px;
  }

  .api-desc {
    font-size: 0.9rem;
    color: #aaa;
    line-height: 1.6;
  }

  /* Uncertainty Canvas */
  .uncertainty-viz {
    background: rgba(0,0,0,0.2);
    border-radius: 14px;
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .uncertainty-viz h3 {
    color: #fff;
    font-size: 1.1rem;
    margin-bottom: 8px;
  }

  .uncertainty-canvas-wrap {
    margin: 16px 0;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(0,0,0,0.3);
  }

  #uncertaintyCanvas {
    width: 100%;
    height: auto;
    display: block;
  }

  .uncertainty-controls {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 12px;
  }

  .epsilon-display {
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 1.1rem;
    color: #ffb347;
    font-weight: 600;
  }

  /* Interval Section */
  .interval-section {
    margin-bottom: 50px;
  }

  .interval-viz {
    background: rgba(0,0,0,0.2);
    border-radius: 14px;
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .interval-timeline {
    position: relative;
    height: 80px;
    margin: 20px 0;
    background: rgba(0,0,0,0.3);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .interval-bar {
    position: relative;
    height: 36px;
    background: linear-gradient(90deg, rgba(255, 179, 71, 0.4), rgba(248, 113, 113, 0.4));
    border: 2px solid #ffb347;
    border-radius: 8px;
    min-width: 100px;
    max-width: 80%;
    transition: width 0.5s ease;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 8px;
  }

  .interval-label-left, .interval-label-right {
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 0.7rem;
    color: #ffb347;
    white-space: nowrap;
  }

  .interval-center-mark {
    width: 2px;
    height: 20px;
    background: #fff;
    opacity: 0.5;
    flex-shrink: 0;
  }

  .true-time-marker {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    pointer-events: none;
  }

  .marker-label {
    font-size: 0.7rem;
    color: #666;
    margin-top: 40px;
    white-space: nowrap;
  }

  .interval-readout {
    display: flex;
    gap: 20px;
    margin-top: 16px;
  }

  .readout-item {
    flex: 1;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    padding: 12px 16px;
    text-align: center;
  }

  .highlight-readout {
    border-color: rgba(255, 179, 71, 0.4);
    background: rgba(255, 179, 71, 0.06);
  }

  .readout-label {
    display: block;
    font-size: 0.75rem;
    color: #888;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .readout-value {
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 1rem;
    color: #fff;
    font-weight: 600;
  }

  /* Commit-Wait */
  .commit-section {
    margin-bottom: 50px;
  }

  .commit-controls {
    display: flex;
    gap: 12px;
    margin-bottom: 20px;
  }

  .commit-viz {
    background: rgba(0,0,0,0.2);
    border-radius: 14px;
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 16px;
  }

  .commit-timeline-bar {
    display: flex;
    gap: 4px;
  }

  .commit-phase {
    flex: 1;
    padding: 16px;
    border-radius: 10px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    position: relative;
    overflow: hidden;
    transition: all 0.5s;
  }

  .commit-phase.active-phase {
    border-color: rgba(255, 179, 71, 0.5);
    background: rgba(255, 179, 71, 0.1);
  }

  .commit-phase.done-phase {
    border-color: rgba(34, 197, 94, 0.4);
    background: rgba(34, 197, 94, 0.08);
  }

  .phase-label {
    font-size: 0.85rem;
    color: #ccc;
    position: relative;
    z-index: 1;
  }

  .wait-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 3px;
    background: linear-gradient(90deg, #ffb347, #ff6723);
    width: 0%;
    transition: width 0.1s linear;
  }

  .commit-log, .paxos-log, .consistency-log {
    background: rgba(0,0,0,0.3);
    border-radius: 12px;
    padding: 16px;
    max-height: 180px;
