</style>

<script is:inline>
  // ========== UNCERTAINTY CANVAS ==========
  var canvas = document.getElementById('uncertaintyCanvas');
  var ctx = canvas.getContext('2d');
  var epsilon = 1.0;
  var maxEpsilon = 7.0;
  var epsilonGrowRate = 0.015;
  var dataPoints = [];
  var maxPoints = 200;
  var uncertaintyRunning = true;

  function initDataPoints() {
    dataPoints = [];
    for (var i = 0; i < maxPoints; i++) {
      dataPoints.push(1.0);
    }
  }
  initDataPoints();

  function drawUncertainty() {
    var w = canvas.width;
    var h = canvas.height;
    ctx.clearRect(0, 0, w, h);

    // Grid
    ctx.strokeStyle = 'rgba(255,255,255,0.05)';
    ctx.lineWidth = 1;
    for (var y = 0; y < h; y += 40) {
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(w, y);
      ctx.stroke();
    }

    // Labels
    ctx.fillStyle = '#666';
    ctx.font = '11px Monaco, Menlo, monospace';
    ctx.fillText('7ms', 5, 20);
    ctx.fillText('4ms', 5, h * 0.45);
    ctx.fillText('1ms', 5, h - 10);

    // Upper bound line
    ctx.beginPath();
    ctx.strokeStyle = 'rgba(255, 179, 71, 0.8)';
    ctx.lineWidth = 2;
    for (var i = 0; i < dataPoints.length; i++) {
      var x = (i / maxPoints) * w;
      var normalized = (dataPoints[i] - 0.5) / (maxEpsilon + 0.5);
      var y2 = h / 2 - normalized * (h / 2 - 10);
      if (i === 0) ctx.moveTo(x, y2);
      else ctx.lineTo(x, y2);
    }
    ctx.stroke();

    // Lower bound line (mirror)
    ctx.beginPath();
    ctx.strokeStyle = 'rgba(248, 113, 113, 0.8)';
    ctx.lineWidth = 2;
    for (var i = 0; i < dataPoints.length; i++) {
      var x = (i / maxPoints) * w;
      var normalized = (dataPoints[i] - 0.5) / (maxEpsilon + 0.5);
      var y2 = h / 2 + normalized * (h / 2 - 10);
      if (i === 0) ctx.moveTo(x, y2);
      else ctx.lineTo(x, y2);
    }
    ctx.stroke();

    // Fill between
    ctx.beginPath();
    for (var i = 0; i < dataPoints.length; i++) {
      var x = (i / maxPoints) * w;
      var normalized = (dataPoints[i] - 0.5) / (maxEpsilon + 0.5);
      var y2 = h / 2 - normalized * (h / 2 - 10);
      if (i === 0) ctx.moveTo(x, y2);
      else ctx.lineTo(x, y2);
    }
    for (var i = dataPoints.length - 1; i >= 0; i--) {
      var x = (i / maxPoints) * w;
      var normalized = (dataPoints[i] - 0.5) / (maxEpsilon + 0.5);
      var y2 = h / 2 + normalized * (h / 2 - 10);
      ctx.lineTo(x, y2);
    }
    ctx.closePath();
    ctx.fillStyle = 'rgba(255, 179, 71, 0.1)';
    ctx.fill();

    // Center line (true time)
    ctx.beginPath();
    ctx.strokeStyle = 'rgba(255,255,255,0.2)';
    ctx.setLineDash([4, 4]);
    ctx.lineWidth = 1;
    ctx.moveTo(0, h / 2);
    ctx.lineTo(w, h / 2);
    ctx.stroke();
    ctx.setLineDash([]);
  }

  function tickUncertainty() {
    epsilon = Math.min(epsilon + epsilonGrowRate, maxEpsilon);
    dataPoints.push(epsilon);
    if (dataPoints.length > maxPoints) dataPoints.shift();

    document.getElementById('epsilonValue').textContent = epsilon.toFixed(1);
    drawUncertainty();
    updateInterval();

    if (uncertaintyRunning) {
      requestAnimationFrame(tickUncertainty);
    }
  }

  document.getElementById('syncClockBtn').addEventListener('click', function() {
    epsilon = 0.5 + Math.random() * 0.5;
    document.getElementById('epsilonValue').textContent = epsilon.toFixed(1);
    addLogTo('commitLog', ''); // no-op, just visual feedback
  });

  tickUncertainty();

  // ========== LIVE INTERVAL ==========
  var baseTime = Date.now();

  function updateInterval() {
    var now = Date.now() - baseTime;
    var earliest = now - epsilon;
    var latest = now + epsilon;

    document.getElementById('readoutEarliest').textContent = earliest.toFixed(1) + ' ms';
    document.getElementById('readoutLatest').textContent = latest.toFixed(1) + ' ms';
    document.getElementById('readoutEpsilon').textContent = '±' + epsilon.toFixed(1) + ' ms';

    document.getElementById('intervalEarliest').textContent = earliest.toFixed(0);
    document.getElementById('intervalLatest').textContent = latest.toFixed(0);

    // Width of bar proportional to epsilon
    var barWidth = Math.max(10, Math.min(80, (epsilon / maxEpsilon) * 80));
    document.getElementById('intervalBar').style.width = barWidth + '%';
  }

  // ========== COMMIT-WAIT ==========
  var commitRunning = false;

  document.getElementById('runCommitBtn').addEventListener('click', function() {
    if (commitRunning) return;
    commitRunning = true;
    var log = document.getElementById('commitLog');
    log.innerHTML = '';
    var phases = document.querySelectorAll('.commit-phase');
    phases.forEach(function(p) { p.className = 'commit-phase'; });
    document.getElementById('commitPhase2').classList.add('waiting');

    var commitTs = (Date.now() - baseTime + epsilon).toFixed(1);

    // Phase 1
    phases[0].classList.add('active-phase');
    addLogTo('commitLog', '① Acquire locks on affected rows', 'time');
    addLogTo('commitLog', '① Pick commit timestamp s = TT.now().latest = ' + commitTs + ' ms', 'time');

    setTimeout(function() {
      phases[0].classList.remove('active-phase');
      phases[0].classList.add('done-phase');
      phases[1].classList.add('active-phase');
      addLogTo('commitLog', '② Commit-wait begins: waiting until TT.after(' + commitTs + ') = true...', 'wait');

      var waitDuration = epsilon * 2;
      var waitStart = Date.now();
      var progress = document.getElementById('waitProgress');

      function animateWait() {
        var elapsed = Date.now() - waitStart;
        var pct = Math.min(100, (elapsed / (waitDuration * 15)) * 100);
        progress.style.width = pct + '%';

        if (pct < 100) {
          requestAnimationFrame(animateWait);
        } else {
          phases[1].classList.remove('active-phase');
          phases[1].classList.add('done-phase');
          phases[2].classList.add('active-phase');
          addLogTo('commitLog', '② TT.after(' + commitTs + ') = true — uncertainty resolved!', 'success');
          addLogTo('commitLog', '③ Release locks, notify client — commit complete ✅', 'success');

          setTimeout(function() {
            phases[2].classList.remove('active-phase');
            phases[2].classList.add('done-phase');
            commitRunning = false;
          }, 500);
        }
      }
      animateWait();
    }, 1200);
  });

  document.getElementById('commitResetBtn').addEventListener('click', function() {
    commitRunning = false;
    document.getElementById('commitLog').innerHTML = '<div class="log-entry info">Ready — click "Run Commit-Wait" to begin</div>';
    var phases = document.querySelectorAll('.commit-phase');
    phases.forEach(function(p) { p.className = 'commit-phase'; });
    document.getElementById('commitPhase2').classList.add('waiting');
    document.getElementById('waitProgress').style.width = '0%';
  });

  // ========== EXTERNAL CONSISTENCY ==========
  document.getElementById('runConsistencyBtn').addEventListener('click', function() {
    var log = document.getElementById('consistencyLog');
    log.innerHTML = '';
    var bar1 = document.getElementById('laneBar1');
    var bar2 = document.getElementById('laneBar2');
    bar1.innerHTML = '';
    bar2.innerHTML = '';

    var t1Start = 5;
    var t1CommitWait = 30;
    var t1End = 55;
    var t2Start = 60;
    var t2End = 85;

    // T1 segments
    function addSegment(bar, left, width, color, label, delay) {
      setTimeout(function() {
        var seg = document.createElement('div');
        seg.className = 'lane-segment';
        seg.style.left = left + '%';
        seg.style.width = width + '%';
        seg.style.background = color;
        seg.style.color = '#111';
        seg.textContent = label;
        bar.appendChild(seg);
      }, delay);
    }

    addSegment(bar1, t1Start, t1CommitWait - t1Start, 'rgba(255,179,71,0.6)', 'execute', 0);
    addLogTo('consistencyLog', 'T1 begins executing...', 'time');

    addSegment(bar1, t1CommitWait, t1End - t1CommitWait, 'rgba(251,191,36,0.8)', 'commit-wait', 800);
    setTimeout(function() {
      addLogTo('consistencyLog', 'T1 picks s1 = TT.now().latest, begins commit-wait...', 'wait');
    }, 800);

    setTimeout(function() {
      addLogTo('consistencyLog', 'T1 committed at s1. TT.after(s1) confirmed. ✅', 'success');
    }, 1600);

    addSegment(bar2, t2Start, t2End - t2Start, 'rgba(96,165,250,0.6)', 'T2 execute', 2000);
    setTimeout(function() {
      addLogTo('consistencyLog', 'T2 starts. Picks s2 = TT.now().latest.', 'time');
      addLogTo('consistencyLog', 'Because T1 waited out uncertainty: s1 < s2 guaranteed! 🔒', 'success');
      addLogTo('consistencyLog', 'External consistency: T1 committed before T2 started → s1 < s2', 'success');
    }, 2000);
  });

  document.getElementById('consistencyResetBtn').addEventListener('click', function() {
    document.getElementById('consistencyLog').innerHTML = '<div class="log-entry info">Click "Run Two Transactions" to see external consistency in action</div>';
    document.getElementById('laneBar1').innerHTML = '';
    document.getElementById('laneBar2').innerHTML = '';
  });

  // ========== PAXOS REPLICATION ==========
  var paxosState = {
    version: 1,
    balance: 100,
    replicas: [
      { id: 1, alive: true, role: 'leader' },
      { id: 2, alive: true, role: 'follower' },
      { id: 3, alive: true, role: 'follower' }
    ]
  };

  document.getElementById('paxosWriteBtn').addEventListener('click', function() {
    var leader = paxosState.replicas.find(function(r) { return r.role === 'leader' && r.alive; });
    if (!leader) {
      addLogTo('paxosLog', '❌ No leader available! Need to elect a new one.', 'error');
      // Try to elect
      var alive = paxosState.replicas.filter(function(r) { return r.alive; });
      if (alive.length >= 2) {
        alive[0].role = 'leader';
        addLogTo('paxosLog', '🗳️ Elected Replica ' + alive[0].id + ' as new leader', 'paxos');
        renderPaxos();
      }
      return;
    }

    paxosState.version++;
    paxosState.balance += Math.floor(Math.random() * 100) + 10;
    var newData = 'v' + paxosState.version + ': balance=$' + paxosState.balance;

    addLogTo('paxosLog', '📝 Client writes to leader (Replica ' + leader.id + ')', 'info');

    // Leader accepts
    document.getElementById('replica' + leader.id).classList.add('syncing');
    setTimeout(function() {
      document.getElementById('replicaData' + leader.id).textContent = newData;
      document.getElementById('replica' + leader.id).classList.remove('syncing');
      addLogTo('paxosLog', '✍️ Leader accepts: ' + newData, 'time');

      // Replicate to followers
      var quorumNeeded = 1; // leader + 1 more = majority of 3
      var acked = 0;
      paxosState.replicas.forEach(function(r) {
        if (r.id !== leader.id && r.alive) {
          setTimeout(function() {
            document.getElementById('replica' + r.id).classList.add('syncing');
            setTimeout(function() {
              document.getElementById('replicaData' + r.id).textContent = newData;
              document.getElementById('replica' + r.id).classList.remove('syncing');
              acked++;
              addLogTo('paxosLog', '📨 Replica ' + r.id + ' acked (quorum: ' + (acked + 1) + '/2)', 'paxos');
              if (acked >= quorumNeeded) {
                addLogTo('paxosLog', '✅ Quorum reached — write committed!', 'success');
              }
            }, 400 + Math.random() * 300);
          }, 200 + Math.random() * 200);
        }
      });
    }, 500);
  });

  document.getElementById('paxosFailBtn').addEventListener('click', function() {
    var alive = paxosState.replicas.filter(function(r) { return r.alive; });
    if (alive.length <= 2) {
      addLogTo('paxosLog', '⚠️ Cannot kill more — need 2 for quorum!', 'error');
      return;
    }
    // Kill a follower preferably
    var victim = alive.find(function(r) { return r.role === 'follower'; }) || alive[alive.length - 1];
    victim.alive = false;
    addLogTo('paxosLog', '💀 Replica ' + victim.id + ' (' + victim.role + ') killed!', 'error');
    if (victim.role === 'leader') {
      victim.role = 'follower';
      var newLeader = paxosState.replicas.find(function(r) { return r.alive; });
      if (newLeader) {
        newLeader.role = 'leader';
        addLogTo('paxosLog', '🗳️ Replica ' + newLeader.id + ' elected as new leader', 'paxos');
      }
    }
    renderPaxos();
  });

  document.getElementById('paxosResetBtn').addEventListener('click', function() {
    paxosState = {
      version: 1,
      balance: 100,
      replicas: [
        { id: 1, alive: true, role: 'leader' },
        { id: 2, alive: true, role: 'follower' },
        { id: 3, alive: true, role: 'follower' }
      ]
    };
    renderPaxos();
    document.getElementById('paxosLog').innerHTML = '<div class="log-entry info">3 replicas across 3 datacenters — quorum = 2</div>';
  });

  function renderPaxos() {
    paxosState.replicas.forEach(function(r) {
      var box = document.getElementById('replica' + r.id);
      box.className = 'replica-box ' + (r.alive ? r.role : 'dead');
      box.querySelector('.replica-role').textContent = r.alive ? (r.role.charAt(0).toUpperCase() + r.role.slice(1)) : 'Dead';
      if (!r.alive) {
        document.getElementById('replicaData' + r.id).textContent = '(offline)';
      } else {
        document.getElementById('replicaData' + r.id).textContent = 'v' + paxosState.version + ': balance=$' + paxosState.balance;
      }
    });
  }

  // ========== UTILITY ==========
  function addLogTo(containerId, text, cls) {
    var log = document.getElementById(containerId);
    var entry = document.createElement('div');
    entry.className = 'log-entry ' + (cls || 'info');
    entry.textContent = text;
    log.appendChild(entry);
    log.scrollTop = log.scrollHeight;
  }
</script>
</BaseLayout>
