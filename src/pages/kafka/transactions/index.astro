  .rpw-proc-status.processing { color: #fbbf24; }
  .rpw-proc-status.done { color: #34d399; }
  .rpw-proc-status.crashed { color: #ef4444; }
  .rpw-proc-detail { font-size: 0.8rem; color: #888; margin-top: 4px; font-family: 'Monaco','Menlo',monospace; }

  .rpw-txn-badge { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 12px 20px; background: rgba(167,139,250,0.1); border: 1px solid rgba(167,139,250,0.3); border-radius: 10px; margin-bottom: 16px; font-size: 0.9rem; color: #c4b5fd; }
