  .share-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  @media (max-width: 768px) {
    .viz-header h1 { font-size: 1.8rem; }
    .explain-grid { grid-template-columns: 1fr; }
    .txn-viz { flex-direction: column; }
    .idemp-viz { flex-direction: column; }
    .idemp-network { width: 100%; writing-mode: initial; flex-direction: row; height: 30px; }
    .idemp-net-label { writing-mode: initial; }
    .guarantee-viz { flex-direction: column; }
    .gv-arrow-line::after { content: '↓'; right: 50%; top: auto; bottom: -14px; }
    .rpw-outputs { flex-direction: column; align-items: center; }
  }
</style>

<script>
  // ========== DELIVERY GUARANTEES ==========
  let gvMode = 'at-most-once';
  let gvMsgCount = 0;
  let gvBrokerMsgs: string[] = [];
  let gvConsumerMsgs: string[] = [];
  let gvFailed = false;

  const GUARANTEE_DESCS: Record<string, string> = {
    'at-most-once': '<strong>At-Most-Once:</strong> Producer sends and doesn\'t retry. If the send fails (network timeout, broker crash), the message is lost. Fast but unreliable. <code>acks=0</code> or fire-and-forget.',
    'at-least-once': '<strong>At-Least-Once:</strong> Producer retries on failure until acknowledged. Guarantees delivery but may produce <em>duplicates</em> if the ack was lost (broker wrote it, but producer didn\'t get the ack). <code>acks=all, retries=MAX</code>.',
    'exactly-once': '<strong>Exactly-Once:</strong> Idempotent producer + transactions. Broker detects duplicates via PID+seq. Even with retries, each message appears in the log <em>exactly once</em>. <code>enable.idempotence=true</code>.'
  };

  function renderGvMsgs(container: string, msgs: string[], style: string) {
    const el = document.getElementById(container)!;
    el.innerHTML = msgs.map(m => `<span class="gv-msg ${style}">${m}</span>`).join('');
  }

  function gvReset() {
    gvMsgCount = 0;
    gvBrokerMsgs = [];
    gvConsumerMsgs = [];
    gvFailed = false;
    document.getElementById('gvProducerMsgs')!.innerHTML = '';
    document.getElementById('gvBrokerMsgs')!.innerHTML = '';
    document.getElementById('gvConsumerMsgs')!.innerHTML = '';
    document.getElementById('gvArrowStatus')!.textContent = '';
  }

  document.querySelectorAll('.guarantee-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.guarantee-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      gvMode = (tab as HTMLElement).dataset.mode!;
      document.getElementById('guaranteeDesc')!.innerHTML = GUARANTEE_DESCS[gvMode];
      gvReset();
    });
  });

  document.getElementById('gvSendBtn')?.addEventListener('click', () => {
    gvMsgCount++;
    const msgId = `M${gvMsgCount}`;
    const prodEl = document.getElementById('gvProducerMsgs')!;
    prodEl.innerHTML += `<span class="gv-msg normal">${msgId}</span>`;

    if (!gvFailed) {
      gvBrokerMsgs.push(msgId);
      renderGvMsgs('gvBrokerMsgs', gvBrokerMsgs, 'normal');
      gvConsumerMsgs.push(msgId);
      renderGvMsgs('gvConsumerMsgs', gvConsumerMsgs, 'normal');
      document.getElementById('gvArrowStatus')!.textContent = '✓ ack';
    }
  });

  document.getElementById('gvFailBtn')?.addEventListener('click', () => {
    gvMsgCount++;
    const msgId = `M${gvMsgCount}`;
    const prodEl = document.getElementById('gvProducerMsgs')!;
    gvFailed = true;

    if (gvMode === 'at-most-once') {
      prodEl.innerHTML += `<span class="gv-msg lost">${msgId}</span>`;
      document.getElementById('gvArrowStatus')!.textContent = '✗ lost (no retry)';
    } else if (gvMode === 'at-least-once') {
      // Broker got it but ack was lost -> producer retries -> duplicate
      gvBrokerMsgs.push(msgId);
      prodEl.innerHTML += `<span class="gv-msg normal">${msgId}</span>`;
      document.getElementById('gvArrowStatus')!.textContent = '✗ ack lost...';

      setTimeout(() => {
        prodEl.innerHTML += `<span class="gv-msg duplicate">${msgId} (retry)</span>`;
        gvBrokerMsgs.push(msgId);
        renderGvMsgs('gvBrokerMsgs', gvBrokerMsgs, 'normal');
        // Show duplicate on broker side
        const brokerEl = document.getElementById('gvBrokerMsgs')!;
        brokerEl.lastElementChild?.classList.add('duplicate');
        (brokerEl.lastElementChild as HTMLElement).classList.remove('normal');
        gvConsumerMsgs.push(msgId);
        gvConsumerMsgs.push(msgId);
        const consEl = document.getElementById('gvConsumerMsgs')!;
        consEl.innerHTML = '';
        gvConsumerMsgs.forEach((m, i) => {
          const isDup = i > 0 && gvConsumerMsgs[i - 1] === m;
          consEl.innerHTML += `<span class="gv-msg ${isDup ? 'duplicate' : 'normal'}">${m}${isDup ? ' ⚠️' : ''}</span>`;
        });
        document.getElementById('gvArrowStatus')!.textContent = '⚠️ duplicate!';
        gvFailed = false;
      }, 800);
      return;
    } else {
      // Exactly-once: broker deduplicates
      gvBrokerMsgs.push(msgId);
      prodEl.innerHTML += `<span class="gv-msg normal">${msgId}</span>`;
      document.getElementById('gvArrowStatus')!.textContent = '✗ ack lost...';

      setTimeout(() => {
        prodEl.innerHTML += `<span class="gv-msg deduped">${msgId} (retry)</span>`;
        document.getElementById('gvArrowStatus')!.textContent = '✓ deduped (PID+seq)';
        // Broker does NOT add duplicate
        renderGvMsgs('gvBrokerMsgs', gvBrokerMsgs, 'normal');
        gvConsumerMsgs.push(msgId);
        renderGvMsgs('gvConsumerMsgs', gvConsumerMsgs, 'normal');
        gvFailed = false;
      }, 800);
      return;
    }
    gvFailed = false;
  });

  document.getElementById('gvResetBtn')?.addEventListener('click', gvReset);

  // ========== IDEMPOTENT PRODUCER ==========
  let idempOn = false;
  let idempSeq = 0;
  let idempBrokerSeq = -1;
  let idempMsgNum = 0;
  let lastSentSeq = -1;

  document.getElementById('idempToggle')?.addEventListener('click', () => {
    idempOn = !idempOn;
    const btn = document.getElementById('idempToggle')!;
    btn.dataset.on = String(idempOn);
    btn.querySelector('.toggle-label')!.textContent = String(idempOn);
    idempReset();
  });

  function idempReset() {
    idempSeq = 0;
    idempBrokerSeq = -1;
    idempMsgNum = 0;
    lastSentSeq = -1;
    document.getElementById('idempSeq')!.textContent = '0';
    document.getElementById('idempCache')!.textContent = 'PID:42 → seq -1';
    document.getElementById('idempOutbox')!.innerHTML = '';
    document.getElementById('idempLog')!.innerHTML = '';
    document.getElementById('idempResult')!.textContent = '';
  }

  document.getElementById('idempSendBtn')?.addEventListener('click', () => {
    idempMsgNum++;
    const seq = idempSeq;
    lastSentSeq = seq;
    idempSeq++;
    document.getElementById('idempSeq')!.textContent = String(idempSeq);

    const outbox = document.getElementById('idempOutbox')!;
    outbox.innerHTML += `<div class="idemp-msg sent">→ msg-${idempMsgNum} [seq=${seq}]</div>`;

    // Broker accepts
    idempBrokerSeq = seq;
    document.getElementById('idempCache')!.textContent = `PID:42 → seq ${idempBrokerSeq}`;
    document.getElementById('idempLog')!.innerHTML += `<div class="idemp-msg accepted">✓ msg-${idempMsgNum} [seq=${seq}]</div>`;
    document.getElementById('idempResult')!.textContent = `✅ Message ${idempMsgNum} written at sequence ${seq}`;
  });

  document.getElementById('idempRetryBtn')?.addEventListener('click', () => {
    if (lastSentSeq < 0) {
      document.getElementById('idempResult')!.textContent = '⚠️ Send a message first!';
      return;
    }

    const outbox = document.getElementById('idempOutbox')!;
    outbox.innerHTML += `<div class="idemp-msg duplicate">↻ msg-${idempMsgNum} [seq=${lastSentSeq}] (retry)</div>`;

    if (idempOn) {
      // Broker rejects duplicate
      document.getElementById('idempLog')!.innerHTML += `<div class="idemp-msg rejected">✗ msg-${idempMsgNum} [seq=${lastSentSeq}] DUPLICATE (seq ≤ ${idempBrokerSeq})</div>`;
      document.getElementById('idempResult')!.textContent = `🛡️ Duplicate detected! Broker already has seq ${lastSentSeq}. Message discarded.`;
    } else {
      // Without idempotence, broker accepts duplicate
      document.getElementById('idempLog')!.innerHTML += `<div class="idemp-msg duplicate">⚠️ msg-${idempMsgNum} [seq=${lastSentSeq}] DUPLICATE WRITTEN!</div>`;
      document.getElementById('idempResult')!.textContent = `⚠️ Duplicate written! Without idempotence, broker has no way to detect retries.`;
    }
  });

  document.getElementById('idempResetBtn')?.addEventListener('click', idempReset);

  // ========== TRANSACTIONAL PRODUCER ==========
  let txnActive = false;
  let txnSendCount = 0;
  let txnPartMsgs: Record<string, Array<{msg: string; status: string}>> = { P0: [], P1: [], P2: [] };
  let txnIsolation = 'read_uncommitted';
  let txnMsgCounter = 0;
  let txnHistory: Array<{msgs: Array<{part: string; msg: string}>; status: string}> = [];

  function txnLog(container: string, text: string, cls: string) {
    const el = document.getElementById(container)!;
    el.innerHTML += `<div class="txn-log-entry ${cls}">${text}</div>`;
    el.scrollTop = el.scrollHeight;
  }

  function renderTxnPartitions() {
    ['P0', 'P1', 'P2'].forEach(p => {
      const logEl = document.getElementById(`txn${p}Log`)!;
      const partEl = document.getElementById(`txn${p}`)!;
      logEl.innerHTML = txnPartMsgs[p].map(m => `<span class="txn-msg ${m.status}">${m.msg}</span>`).join('');
      partEl.className = 'txn-part';
      if (txnPartMsgs[p].some(m => m.status === 'uncommitted')) partEl.classList.add('has-uncommitted');
      else if (txnPartMsgs[p].some(m => m.status === 'committed')) partEl.classList.add('committed');
      else if (txnPartMsgs[p].some(m => m.status === 'aborted')) partEl.classList.add('aborted');
    });
  }

  function renderTxnConsumer() {
    const view = document.getElementById('txnConsumerView')!;
    if (txnHistory.length === 0) {
      view.innerHTML = '<p class="consumer-hint">Run a transaction above to see what the consumer reads</p>';
      return;
    }
    let html = '';
    txnHistory.forEach(txn => {
      txn.msgs.forEach(m => {
        if (txnIsolation === 'read_committed') {
          if (txn.status === 'committed') {
            html += `<span class="txn-cv-msg visible">${m.msg}</span>`;
          } else {
            html += `<span class="txn-cv-msg hidden">${m.msg} (filtered)</span>`;
          }
        } else {
          html += `<span class="txn-cv-msg visible">${m.msg}</span>`;
        }
      });
    });
    view.innerHTML = html || '<p class="consumer-hint">No messages yet</p>';
  }

  function txnSetBtnState(begin: boolean, send: boolean, commit: boolean, abort: boolean) {
    (document.getElementById('txnBeginBtn') as HTMLButtonElement).disabled = !begin;
    (document.getElementById('txnSendBtn') as HTMLButtonElement).disabled = !send;
    (document.getElementById('txnCommitBtn') as HTMLButtonElement).disabled = !commit;
    (document.getElementById('txnAbortBtn') as HTMLButtonElement).disabled = !abort;
  }

  function txnSetState(label: string, cls: string) {
    const badge = document.getElementById('txnState')!;
    badge.textContent = label;
    badge.className = `txn-state-badge ${cls}`;
  }

  document.getElementById('txnBeginBtn')?.addEventListener('click', () => {
    txnActive = true;
    txnSendCount = 0;
    txnSetState('IN_TRANSACTION', 'active');
    txnSetBtnState(false, true, true, true);
    txnLog('txnApiLog', '→ beginTransaction()', 'api');
    txnLog('txnCoordLog', 'TXN state: Empty → Ongoing', 'coord');
  });

  document.getElementById('txnSendBtn')?.addEventListener('click', () => {
    if (!txnActive) return;
    txnMsgCounter++;
    txnSendCount++;
    const parts = ['P0', 'P1', 'P2'];
    const targetPart = parts[(txnSendCount - 1) % 3];
    const msgName = `txn-${txnMsgCounter}`;
    txnPartMsgs[targetPart].push({ msg: msgName, status: 'uncommitted' });
    renderTxnPartitions();
    txnLog('txnApiLog', `→ send("${msgName}") → ${targetPart}`, 'api');
    txnLog('txnCoordLog', `AddPartition: ${targetPart}`, 'coord');
  });

  document.getElementById('txnCommitBtn')?.addEventListener('click', () => {
    if (!txnActive) return;
    txnSetState('COMMITTING', 'committing');
    txnLog('txnApiLog', '→ commitTransaction()', 'api');
    txnLog('txnCoordLog', 'TXN state: Ongoing → PrepareCommit', 'coord');

    const currentTxnMsgs: Array<{part: string; msg: string}> = [];
    ['P0', 'P1', 'P2'].forEach(p => {
      txnPartMsgs[p].forEach(m => {
        if (m.status === 'uncommitted') {
          m.status = 'committed';
          currentTxnMsgs.push({ part: p, msg: m.msg });
        }
      });
    });
    txnHistory.push({ msgs: currentTxnMsgs, status: 'committed' });

    setTimeout(() => {
      renderTxnPartitions();
      txnLog('txnCoordLog', 'Write COMMIT markers to partitions', 'ok');
      txnLog('txnCoordLog', 'TXN state: PrepareCommit → CompleteCommit', 'ok');
      txnSetState('IDLE', '');
      txnActive = false;
      txnSetBtnState(true, false, false, false);
      renderTxnConsumer();
    }, 500);
  });

  document.getElementById('txnAbortBtn')?.addEventListener('click', () => {
    if (!txnActive) return;
    txnSetState('ABORTING', 'aborting');
    txnLog('txnApiLog', '→ abortTransaction()', 'api');
    txnLog('txnCoordLog', 'TXN state: Ongoing → PrepareAbort', 'coord');

    const currentTxnMsgs: Array<{part: string; msg: string}> = [];
    ['P0', 'P1', 'P2'].forEach(p => {
      txnPartMsgs[p].forEach(m => {
        if (m.status === 'uncommitted') {
          m.status = 'aborted';
          currentTxnMsgs.push({ part: p, msg: m.msg });
        }
      });
    });
    txnHistory.push({ msgs: currentTxnMsgs, status: 'aborted' });

    setTimeout(() => {
      renderTxnPartitions();
      txnLog('txnCoordLog', 'Write ABORT markers to partitions', 'err');
      txnLog('txnCoordLog', 'TXN state: PrepareAbort → CompleteAbort', 'err');
      txnSetState('IDLE', '');
      txnActive = false;
      txnSetBtnState(true, false, false, false);
      renderTxnConsumer();
    }, 500);
  });

  document.querySelectorAll('.iso-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.iso-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      txnIsolation = (btn as HTMLElement).dataset.iso!;
      renderTxnConsumer();
    });
  });

  document.getElementById('txnResetBtn')?.addEventListener('click', () => {
    txnActive = false;
    txnSendCount = 0;
    txnMsgCounter = 0;
    txnPartMsgs = { P0: [], P1: [], P2: [] };
    txnHistory = [];
    txnSetState('IDLE', '');
    txnSetBtnState(true, false, false, false);
    document.getElementById('txnApiLog')!.innerHTML = '';
    document.getElementById('txnCoordLog')!.innerHTML = '';
    renderTxnPartitions();
    renderTxnConsumer();
  });

  // ========== READ-PROCESS-WRITE ==========
  let rpwInputMsgs = ['E1', 'E2', 'E3', 'E4', 'E5', 'E6', 'E7', 'E8'];
  let rpwInputIdx = 0;
  let rpwOutputMsgs: string[] = [];
  let rpwOffsetVal = 0;

  function renderRpw() {
    const inputEl = document.getElementById('rpwInput')!;
    inputEl.innerHTML = rpwInputMsgs.map((m, i) =>
      `<span class="rpw-msg ${i < rpwInputIdx ? 'processed' : 'pending'}">${m}</span>`
    ).join('');

    document.getElementById('rpwOutput')!.innerHTML = rpwOutputMsgs.map(m =>
      `<span class="rpw-msg processed">${m}</span>`
    ).join('');

    document.getElementById('rpwOffsets')!.innerHTML = rpwOffsetVal > 0
      ? `<span class="rpw-msg processed">offset=${rpwOffsetVal}</span>`
      : '';
  }

  document.getElementById('rpwRunBtn')?.addEventListener('click', async () => {
    if (rpwInputIdx >= rpwInputMsgs.length) {
      document.getElementById('rpwResult')!.textContent = '✅ All messages processed!';
      return;
    }

    const batchSize = Math.min(2, rpwInputMsgs.length - rpwInputIdx);
    const batch = rpwInputMsgs.slice(rpwInputIdx, rpwInputIdx + batchSize);
    const statusEl = document.getElementById('rpwProcStatus')!;
    const detailEl = document.getElementById('rpwProcDetail')!;
    const badgeEl = document.getElementById('rpwTxnText')!;

    // Step 1: consume
    statusEl.textContent = 'Consuming...';
    statusEl.className = 'rpw-proc-status processing';
    detailEl.textContent = `poll() → [${batch.join(', ')}]`;
    badgeEl.textContent = 'beginTransaction()';
    await new Promise(r => setTimeout(r, 400));

    // Step 2: process
    statusEl.textContent = 'Processing...';
    detailEl.textContent = `transform(${batch.join(', ')}) → [${batch.map(b => b + "'").join(', ')}]`;
    await new Promise(r => setTimeout(r, 400));

    // Step 3: produce + commit
    statusEl.textContent = 'Producing + Committing...';
    badgeEl.textContent = 'send() + sendOffsetsToTransaction() + commitTransaction()';
    await new Promise(r => setTimeout(r, 400));

    rpwInputIdx += batchSize;
    batch.forEach(b => rpwOutputMsgs.push(b + "'"));
    rpwOffsetVal = rpwInputIdx;

    statusEl.textContent = 'Done ✓';
    statusEl.className = 'rpw-proc-status done';
    detailEl.textContent = `committed offset=${rpwOffsetVal}`;
    badgeEl.textContent = 'All three operations happen in ONE transaction';
    renderRpw();
    document.getElementById('rpwResult')!.textContent = `✅ Batch [${batch.join(', ')}] processed atomically. Offset committed to ${rpwOffsetVal}.`;
  });

  document.getElementById('rpwCrashBtn')?.addEventListener('click', async () => {
    if (rpwInputIdx >= rpwInputMsgs.length) return;
    const statusEl = document.getElementById('rpwProcStatus')!;
    const detailEl = document.getElementById('rpwProcDetail')!;
    const badgeEl = document.getElementById('rpwTxnText')!;

    const batch = rpwInputMsgs.slice(rpwInputIdx, rpwInputIdx + 2);
    statusEl.textContent = 'Processing...';
    statusEl.className = 'rpw-proc-status processing';
    detailEl.textContent = `transform(${batch.join(', ')})`;
    badgeEl.textContent = 'beginTransaction() → send()...';
    await new Promise(r => setTimeout(r, 500));

    statusEl.textContent = '💥 CRASHED!';
    statusEl.className = 'rpw-proc-status crashed';
    detailEl.textContent = 'Transaction aborted — no partial writes';
    badgeEl.textContent = 'Transaction never committed → all writes rolled back';
    document.getElementById('rpwResult')!.textContent = `💥 Crash! Transaction aborted. Offset still at ${rpwOffsetVal}. On restart, batch [${batch.join(', ')}] will be reprocessed — exactly once!`;
  });

  document.getElementById('rpwResetBtn')?.addEventListener('click', () => {
    rpwInputIdx = 0;
    rpwOutputMsgs = [];
    rpwOffsetVal = 0;
    document.getElementById('rpwProcStatus')!.textContent = 'Idle';
    document.getElementById('rpwProcStatus')!.className = 'rpw-proc-status';
    document.getElementById('rpwProcDetail')!.textContent = '';
    document.getElementById('rpwTxnText')!.textContent = 'All three operations happen in ONE transaction';
    document.getElementById('rpwResult')!.textContent = '';
    renderRpw();
  });

  // ========== PERFORMANCE TRADEOFFS ==========
  let perfTxnOn = true;

  function updatePerf() {
    const batch = parseInt((document.getElementById('perfBatchSlider') as HTMLInputElement).value);
    const timeout = parseInt((document.getElementById('perfTimeoutSlider') as HTMLInputElement).value);

    // Model: without txn ~1M msgs/s, with txn overhead depends on batch size
    let throughputPct: number, latencyMs: number, cpuPct: number;

    if (!perfTxnOn) {
      // Idempotence only (always on since Kafka 3.0)
      throughputPct = 95;
      latencyMs = 5;
      cpuPct = 3;
    } else {
      // Transactions on: overhead inversely proportional to batch size
      const batchFactor = Math.min(1, batch / 500); // 0-1, higher = less overhead
      throughputPct = 50 + 45 * batchFactor; // 50-95%
      latencyMs = 5 + 80 * (1 - batchFactor); // 5-85ms
      cpuPct = 3 + 20 * (1 - batchFactor); // 3-23%
    }

    document.getElementById('perfThroughput')!.style.width = throughputPct + '%';
    document.getElementById('perfThroughputVal')!.textContent = `~${Math.round(throughputPct * 10)}K msgs/sec`;
    document.getElementById('perfLatency')!.style.width = Math.min(100, latencyMs) + '%';
    document.getElementById('perfLatencyVal')!.textContent = `~${Math.round(latencyMs)}ms`;
    document.getElementById('perfCpu')!.style.width = cpuPct + '%';
    document.getElementById('perfCpuVal')!.textContent = `~${Math.round(cpuPct)}%`;

    // Update tip
    const tip = document.getElementById('perfTip')!;
    if (!perfTxnOn) {
      tip.innerHTML = '💡 <strong>Tip:</strong> Idempotence alone adds <2% overhead (just PID+seq tracking). Kafka 3.0+ enables it by default.';
    } else if (batch < 10) {
      tip.innerHTML = '⚠️ <strong>Warning:</strong> Tiny batches with transactions = high overhead. Each commit is a 2PC round-trip. Batch more messages per transaction!';
    } else if (batch < 100) {
      tip.innerHTML = '💡 <strong>Tip:</strong> Increasing batch size will significantly reduce per-message overhead. Aim for 100+ messages per transaction.';
    } else {
      tip.innerHTML = '💡 <strong>Tip:</strong> At this batch size, transaction overhead is well amortized. The throughput cost is minimal (~3-5%).';
    }
  }

  document.getElementById('perfBatchSlider')?.addEventListener('input', (e) => {
    document.getElementById('perfBatchLabel')!.textContent = (e.target as HTMLInputElement).value;
    updatePerf();
  });

  document.getElementById('perfTimeoutSlider')?.addEventListener('input', (e) => {
    document.getElementById('perfTimeoutLabel')!.textContent = (e.target as HTMLInputElement).value;
    updatePerf();
  });

  document.getElementById('perfTxnToggle')?.addEventListener('click', () => {
    perfTxnOn = !perfTxnOn;
    const btn = document.getElementById('perfTxnToggle')!;
    btn.dataset.on = String(perfTxnOn);
    btn.querySelector('.toggle-label')!.textContent = perfTxnOn ? 'ON' : 'OFF';
    updatePerf();
  });

  // ========== INIT ==========
  renderRpw();
  renderTxnPartitions();
  updatePerf();
</script>
</BaseLayout>
