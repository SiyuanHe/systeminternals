  .rpw-result { font-size: 0.9rem; color: #aaa; min-height: 24px; padding: 8px; text-align: center; }

  /* Performance Section */
  .perf-section { margin-bottom: 50px; }
  .perf-controls { margin-bottom: 24px; }
  .perf-slider-group { margin-bottom: 16px; }
  .perf-slider-group label { color: #ccc; font-size: 0.95rem; display: block; margin-bottom: 8px; }
  .perf-slider-group strong { color: #34d399; }
  .perf-slider-group input[type="range"] { max-width: 500px; }
  .perf-toggle-row { display: flex; gap: 30px; flex-wrap: wrap; }
  .perf-toggle { display: flex; align-items: center; gap: 10px; }
  .perf-toggle label { color: #ccc; font-size: 0.9rem; }
  .perf-always-on { color: #34d399; font-size: 0.85rem; font-weight: 600; }
  .perf-txn-toggle { font-size: 0.8rem; }

  .perf-meters { display: flex; flex-direction: column; gap: 20px; margin-bottom: 20px; }
  .perf-meter { }
  .perf-meter-label { font-size: 0.85rem; color: #ccc; margin-bottom: 6px; font-weight: 600; }
  .perf-bar-track { height: 28px; background: rgba(255,255,255,0.05); border-radius: 6px; overflow: hidden; margin-bottom: 4px; }
  .perf-bar-fill { height: 100%; border-radius: 6px; transition: width 0.5s ease; }
  .throughput-bar { background: linear-gradient(90deg, #34d399, #059669); }
  .latency-bar { background: linear-gradient(90deg, #fbbf24, #f97316); }
  .cpu-bar { background: linear-gradient(90deg, #60a5fa, #a78bfa); }
  .perf-bar-value { font-size: 0.8rem; color: #888; text-align: right; }

  .perf-tip { padding: 14px 18px; background: rgba(52,211,153,0.06); border: 1px solid rgba(52,211,153,0.2); border-radius: 10px; font-size: 0.9rem; color: #aaa; line-height: 1.6; }
  .perf-tip strong { color: #34d399; }

  /* Explain Section */
  .explain-section { margin-bottom: 50px; }
  .explain-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .explain-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 24px; }
  .explain-card h3 { font-size: 1rem; color: #fff; margin-bottom: 10px; }
  .explain-card p { color: #aaa; line-height: 1.6; font-size: 0.9rem; }
