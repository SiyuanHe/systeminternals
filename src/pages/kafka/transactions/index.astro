---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Kafka Transactions & Exactly-Once Semantics" 
  description="Interactive visualization of Kafka exactly-once semantics (EOS), idempotent producers, transactional messaging, and the read-process-write pattern"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "Kafka", href: "/kafka/" },
    { label: "Transactions & EOS", href: "/kafka/transactions/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🔒 Transactions & Exactly-Once Semantics</h1>
      <p class="subtitle">How Kafka Guarantees Each Message Is Processed Exactly Once</p>
    </header>

    <section class="overview-section">
      <div class="overview-card">
        <p>
          <strong>Exactly-once semantics (EOS)</strong> means every message is delivered and processed
          <em>exactly once</em> — no duplicates, no losses. Kafka achieves this through three layers:
          <strong>idempotent producers</strong> (dedup at the broker), <strong>transactions</strong>
          (atomic multi-partition writes), and the <strong>read-process-write</strong> pattern
          (consume + produce + commit offsets atomically).
        </p>
      </div>
    </section>

    <!-- Delivery Guarantees Comparison -->
    <section class="guarantees-section">
      <h2>📊 Delivery Guarantees Compared</h2>
      <p class="section-desc">Click each mode to see what happens when a producer retry or failure occurs.</p>

      <div class="guarantee-tabs">
        <button class="guarantee-tab active" data-mode="at-most-once">At-Most-Once</button>
        <button class="guarantee-tab" data-mode="at-least-once">At-Least-Once</button>
        <button class="guarantee-tab" data-mode="exactly-once">Exactly-Once</button>
      </div>

      <div class="guarantee-viz" id="guaranteeViz">
        <div class="gv-producer">
          <div class="gv-label">Producer</div>
          <div class="gv-messages" id="gvProducerMsgs"></div>
        </div>
        <div class="gv-arrow" id="gvArrow">
          <div class="gv-arrow-line"></div>
          <div class="gv-arrow-status" id="gvArrowStatus"></div>
        </div>
        <div class="gv-broker">
          <div class="gv-label">Broker</div>
          <div class="gv-messages" id="gvBrokerMsgs"></div>
        </div>
        <div class="gv-arrow">
          <div class="gv-arrow-line"></div>
        </div>
        <div class="gv-consumer">
          <div class="gv-label">Consumer</div>
          <div class="gv-messages" id="gvConsumerMsgs"></div>
        </div>
      </div>

      <div class="guarantee-desc" id="guaranteeDesc">
        <strong>At-Most-Once:</strong> Producer sends and doesn't retry. If the send fails (network timeout, broker crash), the message is lost. Fast but unreliable. <code>acks=0</code> or fire-and-forget.
      </div>

      <div class="guarantee-actions">
        <button id="gvSendBtn" class="action-btn primary-btn">📤 Send Message</button>
        <button id="gvFailBtn" class="action-btn danger-btn">💥 Simulate Failure</button>
        <button id="gvResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>
    </section>

    <!-- Idempotent Producer -->
    <section class="idempotent-section">
      <h2>🆔 Idempotent Producer</h2>
      <p class="section-desc">Each producer gets a unique PID + sequence number per partition. Brokers detect and discard duplicates.</p>

      <div class="idemp-controls">
        <div class="toggle-group">
          <label>enable.idempotence:</label>
          <button class="toggle-btn" id="idempToggle" data-on="false">
            <span class="toggle-knob"></span>
            <span class="toggle-label">false</span>
          </button>
        </div>
      </div>

      <div class="idemp-viz" id="idempViz">
        <div class="idemp-producer">
          <div class="idemp-box-label">Producer (PID: 42)</div>
          <div class="idemp-seq">Next Seq: <strong id="idempSeq">0</strong></div>
          <div class="idemp-outbox" id="idempOutbox"></div>
        </div>
        <div class="idemp-network" id="idempNetwork">
          <div class="idemp-net-label" id="idempNetLabel">Network</div>
        </div>
        <div class="idemp-broker">
          <div class="idemp-box-label">Broker (Partition 0)</div>
          <div class="idemp-dedup-cache">
            <span class="idemp-cache-label">Dedup Cache:</span>
            <span id="idempCache">PID:42 → seq -1</span>
          </div>
          <div class="idemp-log" id="idempLog"></div>
        </div>
      </div>

      <div class="idemp-actions">
        <button id="idempSendBtn" class="action-btn primary-btn">📤 Send Message</button>
        <button id="idempRetryBtn" class="action-btn secondary-btn">🔄 Retry (network glitch)</button>
        <button id="idempResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="idemp-result" id="idempResult"></div>
    </section>

    <!-- Transactional Producer -->
    <section class="txn-section">
      <h2>⚛️ Transactional Producer</h2>
      <p class="section-desc">Atomically write to multiple partitions. Either all writes commit, or all abort.</p>

      <div class="txn-viz" id="txnViz">
        <div class="txn-producer-col">
          <div class="txn-box-label">Producer</div>
          <div class="txn-state-badge" id="txnState">IDLE</div>
          <div class="txn-api-log" id="txnApiLog"></div>
        </div>

        <div class="txn-partitions-col">
          <div class="txn-box-label">Topic Partitions</div>
          <div class="txn-part" id="txnP0">
            <div class="txn-part-label">P0</div>
            <div class="txn-part-log" id="txnP0Log"></div>
          </div>
          <div class="txn-part" id="txnP1">
            <div class="txn-part-label">P1</div>
            <div class="txn-part-log" id="txnP1Log"></div>
          </div>
          <div class="txn-part" id="txnP2">
            <div class="txn-part-label">P2</div>
            <div class="txn-part-log" id="txnP2Log"></div>
          </div>
        </div>

        <div class="txn-coordinator-col">
          <div class="txn-box-label">Transaction Coordinator</div>
          <div class="txn-coord-log" id="txnCoordLog"></div>
        </div>
      </div>

      <div class="txn-actions">
        <button id="txnBeginBtn" class="action-btn primary-btn">▶ beginTransaction()</button>
        <button id="txnSendBtn" class="action-btn secondary-btn" disabled>📤 send()</button>
        <button id="txnCommitBtn" class="action-btn commit-btn" disabled>✅ commitTransaction()</button>
        <button id="txnAbortBtn" class="action-btn danger-btn" disabled>❌ abortTransaction()</button>
        <button id="txnResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="txn-consumer-section">
        <h3>Consumer View</h3>
        <div class="txn-iso-toggle">
          <label>isolation.level:</label>
          <button class="iso-btn active" data-iso="read_uncommitted">read_uncommitted</button>
          <button class="iso-btn" data-iso="read_committed">read_committed</button>
        </div>
        <div class="txn-consumer-view" id="txnConsumerView">
          <p class="consumer-hint">Run a transaction above to see what the consumer reads</p>
        </div>
      </div>
    </section>

    <!-- Read-Process-Write -->
    <section class="rpw-section">
      <h2>🔄 Read-Process-Write Pattern</h2>
      <p class="section-desc">The holy grail: consume → process → produce → commit offsets — all in one atomic transaction.</p>

      <div class="rpw-viz" id="rpwViz">
        <div class="rpw-stage rpw-input">
          <div class="rpw-stage-label">Input Topic</div>
          <div class="rpw-messages" id="rpwInput"></div>
        </div>
        <div class="rpw-arrow-container">
          <div class="rpw-arrow-down">consume</div>
        </div>
        <div class="rpw-stage rpw-processor">
          <div class="rpw-stage-label">Stream Processor</div>
          <div class="rpw-proc-status" id="rpwProcStatus">Idle</div>
          <div class="rpw-proc-detail" id="rpwProcDetail"></div>
        </div>
        <div class="rpw-outputs">
          <div class="rpw-output-branch">
            <div class="rpw-arrow-down">produce</div>
            <div class="rpw-stage rpw-output">
              <div class="rpw-stage-label">Output Topic</div>
              <div class="rpw-messages" id="rpwOutput"></div>
            </div>
          </div>
          <div class="rpw-output-branch">
            <div class="rpw-arrow-down">commit offsets</div>
            <div class="rpw-stage rpw-offsets">
              <div class="rpw-stage-label">__consumer_offsets</div>
              <div class="rpw-messages" id="rpwOffsets"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="rpw-txn-badge" id="rpwTxnBadge">
        <span class="rpw-txn-icon">⚛️</span>
        <span id="rpwTxnText">All three operations happen in ONE transaction</span>
      </div>

      <div class="rpw-actions">
        <button id="rpwRunBtn" class="action-btn primary-btn">▶ Process Next Batch</button>
        <button id="rpwCrashBtn" class="action-btn danger-btn">💥 Crash Mid-Transaction</button>
        <button id="rpwResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="rpw-result" id="rpwResult"></div>
    </section>

    <!-- Performance Tradeoffs -->
    <section class="perf-section">
      <h2>⚡ Performance Tradeoffs</h2>
      <p class="section-desc">EOS isn't free. Tune these knobs to understand the cost.</p>

      <div class="perf-controls">
        <div class="perf-slider-group">
          <label>Transaction batch size: <strong id="perfBatchLabel">100</strong> msgs</label>
          <input type="range" id="perfBatchSlider" min="1" max="1000" value="100">
        </div>
        <div class="perf-slider-group">
          <label>transaction.timeout.ms: <strong id="perfTimeoutLabel">60000</strong></label>
          <input type="range" id="perfTimeoutSlider" min="1000" max="120000" value="60000" step="1000">
        </div>
        <div class="perf-toggle-row">
          <div class="perf-toggle">
            <label>Idempotence:</label>
            <span class="perf-always-on">Always ON (Kafka 3.0+)</span>
          </div>
          <div class="perf-toggle">
            <label>Transactions:</label>
            <button class="toggle-btn perf-txn-toggle" id="perfTxnToggle" data-on="true">
              <span class="toggle-knob"></span>
              <span class="toggle-label">ON</span>
            </button>
          </div>
        </div>
      </div>

      <div class="perf-meters">
        <div class="perf-meter">
          <div class="perf-meter-label">Throughput</div>
          <div class="perf-bar-track">
            <div class="perf-bar-fill throughput-bar" id="perfThroughput" style="width:85%"></div>
          </div>
          <div class="perf-bar-value" id="perfThroughputVal">~850K msgs/sec</div>
        </div>
        <div class="perf-meter">
          <div class="perf-meter-label">Latency (p99)</div>
          <div class="perf-bar-track">
            <div class="perf-bar-fill latency-bar" id="perfLatency" style="width:15%"></div>
          </div>
          <div class="perf-bar-value" id="perfLatencyVal">~15ms</div>
        </div>
        <div class="perf-meter">
          <div class="perf-meter-label">Broker CPU Overhead</div>
          <div class="perf-bar-track">
            <div class="perf-bar-fill cpu-bar" id="perfCpu" style="width:8%"></div>
          </div>
          <div class="perf-bar-value" id="perfCpuVal">~8%</div>
        </div>
      </div>

      <div class="perf-tip" id="perfTip">
        💡 <strong>Tip:</strong> Larger batch sizes amortize the fixed cost of transactions. At 100+ messages per transaction, overhead drops below 3%.
      </div>
    </section>

    <!-- Explanations -->
    <section class="explain-section">
      <div class="explain-grid">
        <div class="explain-card highlight-card">
          <h3>💡 EOS ≠ Magic</h3>
          <p>
            Kafka's EOS guarantees apply <strong>within Kafka</strong>. If your processor has external
            side effects (HTTP calls, database writes), you need to handle idempotency in those
            systems too. EOS ensures the Kafka log is consistent — it can't undo an email you already sent.
          </p>
        </div>
        <div class="explain-card">
          <h3>🔑 transactional.id</h3>
          <p>
            Each transactional producer needs a stable <code>transactional.id</code>.
            On restart, the new instance <em>fences out</em> the old one using this ID —
            preventing zombie producers from committing stale transactions.
            Choose IDs based on input partition assignment for stream processing.
          </p>
        </div>
        <div class="explain-card">
          <h3>⚡ Kafka Streams Makes It Easy</h3>
          <p>
            Set <code>processing.guarantee=exactly_once_v2</code> and Kafka Streams handles
            all the transaction lifecycle automatically. It wraps each task's
            read-process-write cycle in a transaction behind the scenes.
          </p>
        </div>
        <div class="explain-card">
          <h3>📊 When NOT to Use EOS</h3>
          <p>
            If duplicates are harmless (metrics, logs, idempotent consumers),
            <code>at-least-once</code> with <code>acks=all</code> gives you
            better throughput. EOS adds ~3-10% overhead. Use it when correctness
            matters: financial transactions, inventory, state machines.
          </p>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://kafka.apache.org/documentation/#semantics" target="_blank">Apache Kafka Semantics Documentation</a> and <a href="https://cwiki.apache.org/confluence/display/KAFKA/KIP-447%3A+Producer+scalability+for+exactly+once+semantics" target="_blank">KIP-447: Exactly Once v2</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20Kafka%20Exactly-Once%20Semantics%20Visualizer&url=https://systeminternals.dev/kafka/transactions/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/kafka/transactions/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/kafka/transactions/&t=Interactive%20Kafka%20Transactions%20%26%20Exactly-Once%20Visualizer" target="_blank" class="share-btn">🟧 HN</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container { max-width: 1100px; margin: 0 auto; }
  .viz-header { text-align: center; margin-bottom: 40px; }
  .viz-header h1 { font-size: 2.5rem; margin-bottom: 10px; background: linear-gradient(90deg, #34d399, #60a5fa, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .subtitle { color: #888; font-size: 1.1rem; }
  h2 { font-size: 1.5rem; color: #fff; margin-bottom: 12px; }
  h3 { font-size: 1.15rem; color: #fff; margin-bottom: 10px; }
  .section-desc { color: #888; margin-bottom: 24px; }

  .overview-section { margin-bottom: 50px; }
  .overview-card { background: linear-gradient(135deg, rgba(52,211,153,0.1), rgba(96,165,250,0.05)); border: 1px solid rgba(52,211,153,0.3); border-radius: 16px; padding: 24px 28px; font-size: 1.05rem; line-height: 1.8; color: #ccc; }
  .overview-card strong { color: #fff; }
  .overview-card em { color: #34d399; font-style: normal; font-weight: 500; }
  .overview-card code { background: rgba(0,0,0,0.3); padding: 2px 6px; border-radius: 4px; font-size: 0.9rem; color: #34d399; }

  .action-btn { padding: 10px 20px; border: none; border-radius: 10px; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .action-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .primary-btn { background: linear-gradient(135deg, #34d399, #059669); color: white; }
  .primary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(52,211,153,0.4); }
  .secondary-btn { background: linear-gradient(135deg, #60a5fa, #3b82f6); color: white; }
  .secondary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(96,165,250,0.4); }
  .danger-btn { background: linear-gradient(135deg, #f87171, #ef4444); color: white; }
  .danger-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(239,68,68,0.4); }
  .commit-btn { background: linear-gradient(135deg, #a78bfa, #7c3aed); color: white; }
  .commit-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(167,139,250,0.4); }
  .reset-btn { background: rgba(255,255,255,0.1); color: #aaa; }
  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  input[type="range"] { -webkit-appearance: none; height: 8px; background: rgba(255,255,255,0.15); border-radius: 4px; cursor: pointer; width: 100%; }
  input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 20px; height: 20px; border-radius: 50%; background: #34d399; cursor: pointer; }

  /* Guarantee Section */
  .guarantees-section { margin-bottom: 50px; }
  .guarantee-tabs { display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
  .guarantee-tab { padding: 10px 20px; border: 1px solid rgba(255,255,255,0.15); border-radius: 10px; background: rgba(255,255,255,0.03); color: #ccc; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .guarantee-tab.active { border-color: #34d399; background: rgba(52,211,153,0.15); color: #34d399; }

  .guarantee-viz { display: flex; align-items: center; gap: 12px; background: rgba(0,0,0,0.2); border-radius: 14px; padding: 24px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 16px; overflow-x: auto; }
  .gv-producer, .gv-broker, .gv-consumer { min-width: 140px; text-align: center; }
  .gv-label { font-size: 0.85rem; font-weight: 700; color: #60a5fa; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
  .gv-messages { min-height: 60px; display: flex; flex-direction: column; gap: 4px; align-items: center; }
  :global(.gv-msg) { padding: 6px 14px; border-radius: 8px; font-size: 0.8rem; font-weight: 600; animation: msgAppear 0.3s ease-out; white-space: nowrap; }
  @keyframes msgAppear { from { opacity: 0; transform: scale(0.8); } to { opacity: 1; transform: scale(1); } }
  :global(.gv-msg.normal) { background: rgba(52,211,153,0.2); border: 1px solid rgba(52,211,153,0.4); color: #34d399; }
  :global(.gv-msg.duplicate) { background: rgba(251,191,36,0.2); border: 1px solid rgba(251,191,36,0.4); color: #fbbf24; }
  :global(.gv-msg.lost) { background: rgba(239,68,68,0.15); border: 1px dashed rgba(239,68,68,0.4); color: #f87171; text-decoration: line-through; }
  :global(.gv-msg.deduped) { background: rgba(167,139,250,0.2); border: 1px solid rgba(167,139,250,0.4); color: #a78bfa; }

  .gv-arrow { flex: 1; display: flex; flex-direction: column; align-items: center; min-width: 60px; }
  .gv-arrow-line { width: 100%; height: 2px; background: rgba(255,255,255,0.2); position: relative; }
  .gv-arrow-line::after { content: '→'; position: absolute; right: -6px; top: -10px; color: rgba(255,255,255,0.3); font-size: 1.2rem; }
  .gv-arrow-status { font-size: 0.75rem; color: #888; margin-top: 6px; min-height: 18px; }

  .guarantee-desc { padding: 14px 18px; background: rgba(52,211,153,0.06); border: 1px solid rgba(52,211,153,0.2); border-radius: 10px; font-size: 0.9rem; color: #aaa; line-height: 1.6; margin-bottom: 16px; }
  .guarantee-desc strong { color: #34d399; }
  .guarantee-desc code { background: rgba(0,0,0,0.3); padding: 2px 6px; border-radius: 4px; font-size: 0.85rem; color: #34d399; }
  .guarantee-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  /* Idempotent Section */
  .idempotent-section { margin-bottom: 50px; }
  .idemp-controls { margin-bottom: 20px; }
  .toggle-group { display: flex; align-items: center; gap: 12px; }
  .toggle-group label { color: #ccc; font-size: 0.95rem; font-family: 'Monaco','Menlo',monospace; }
  .toggle-btn { display: flex; align-items: center; gap: 8px; padding: 6px 14px; border: 1px solid rgba(255,255,255,0.2); border-radius: 20px; background: rgba(239,68,68,0.15); color: #f87171; font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all 0.3s; }
  .toggle-btn[data-on="true"] { background: rgba(52,211,153,0.15); border-color: rgba(52,211,153,0.4); color: #34d399; }
  .toggle-knob { width: 18px; height: 18px; border-radius: 50%; background: #f87171; transition: all 0.3s; }
  .toggle-btn[data-on="true"] .toggle-knob { background: #34d399; }

  .idemp-viz { display: flex; align-items: stretch; gap: 16px; margin-bottom: 16px; }
  .idemp-producer, .idemp-broker { flex: 1; background: rgba(0,0,0,0.2); border-radius: 14px; padding: 18px; border: 1px solid rgba(255,255,255,0.1); }
  .idemp-network { width: 80px; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .idemp-net-label { font-size: 0.75rem; color: #888; writing-mode: vertical-rl; text-orientation: mixed; }
  .idemp-box-label { font-size: 0.85rem; font-weight: 700; color: #60a5fa; margin-bottom: 10px; }
  .idemp-seq { font-size: 0.85rem; color: #aaa; margin-bottom: 10px; font-family: 'Monaco','Menlo',monospace; }
  .idemp-seq strong { color: #34d399; }
  .idemp-outbox { min-height: 40px; display: flex; flex-direction: column; gap: 4px; }
  .idemp-dedup-cache { font-size: 0.8rem; color: #888; margin-bottom: 10px; font-family: 'Monaco','Menlo',monospace; padding: 8px; background: rgba(0,0,0,0.3); border-radius: 8px; }
  .idemp-cache-label { color: #a78bfa; font-weight: 600; }
  .idemp-log { min-height: 40px; display: flex; flex-direction: column; gap: 4px; }
  .idemp-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 12px; }
  .idemp-result { font-size: 0.9rem; color: #aaa; min-height: 24px; padding: 8px; text-align: center; }

  :global(.idemp-msg) { padding: 5px 12px; border-radius: 6px; font-size: 0.8rem; font-family: 'Monaco','Menlo',monospace; animation: msgAppear 0.3s ease-out; }
  :global(.idemp-msg.sent) { background: rgba(96,165,250,0.15); border: 1px solid rgba(96,165,250,0.3); color: #93c5fd; }
  :global(.idemp-msg.accepted) { background: rgba(52,211,153,0.15); border: 1px solid rgba(52,211,153,0.3); color: #6ee7b7; }
  :global(.idemp-msg.rejected) { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; text-decoration: line-through; }
