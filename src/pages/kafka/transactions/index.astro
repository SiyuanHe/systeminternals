  .rpw-stage-label { font-size: 0.8rem; font-weight: 700; color: #60a5fa; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
  .rpw-messages { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; min-height: 28px; }
  :global(.rpw-msg) { padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 600; animation: msgAppear 0.3s ease-out; }
  :global(.rpw-msg.pending) { background: rgba(96,165,250,0.15); border: 1px solid rgba(96,165,250,0.3); color: #93c5fd; }
  :global(.rpw-msg.processed) { background: rgba(52,211,153,0.15); border: 1px solid rgba(52,211,153,0.3); color: #6ee7b7; }
  :global(.rpw-msg.failed) { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; }

  .rpw-arrow-container { display: flex; justify-content: center; }
  .rpw-arrow-down { font-size: 0.75rem; color: #888; padding: 4px 0; text-align: center; }
  .rpw-outputs { display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
  .rpw-output-branch { display: flex; flex-direction: column; align-items: center; gap: 4px; }
