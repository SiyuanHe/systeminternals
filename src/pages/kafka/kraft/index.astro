---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Kafka KRaft — Replacing ZooKeeper" 
  description="Interactive visualization of Kafka KRaft mode: controller quorum, Raft-based leader election, metadata event log, and migration from ZooKeeper"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "Kafka", href: "/kafka/" },
    { label: "KRaft", href: "/kafka/kraft/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>⚡ KRaft — Kafka Without ZooKeeper</h1>
      <p class="subtitle">How Kafka replaced an external dependency with a built-in Raft-based consensus layer</p>
    </header>

    <section class="overview-section">
      <div class="overview-card">
        <p>
          For years, Apache Kafka relied on <strong>ZooKeeper</strong> for metadata management — tracking brokers,
          topics, partitions, and leader elections. KRaft (Kafka Raft) replaces ZooKeeper with an
          <em>internal consensus protocol</em> built on Raft. A dedicated <strong>controller quorum</strong>
          manages cluster metadata as an <em>event log</em>, eliminating the operational burden of running
          a separate ZooKeeper ensemble. ZooKeeper support was removed in Kafka 4.0.
        </p>
      </div>
    </section>

    <!-- Why Replace ZooKeeper -->
    <section class="problems-section">
      <h2>🚨 Why Replace ZooKeeper?</h2>
      <p class="section-desc">Three fundamental problems with the ZooKeeper dependency.</p>

      <div class="problems-grid">
        <div class="problem-card" id="problemSpof">
          <div class="problem-icon">🎯</div>
          <h3>Single Point of Failure</h3>
          <p>
            ZooKeeper is a <strong>separate distributed system</strong> that must be deployed, monitored,
            and maintained independently. A ZK quorum failure takes down <em>all Kafka metadata operations</em> —
            no new topics, no leader elections, no partition reassignment.
          </p>
          <div class="problem-stat">2 systems to maintain instead of 1</div>
        </div>
        <div class="problem-card" id="problemComplex">
          <div class="problem-icon">🔧</div>
          <h3>Operational Complexity</h3>
          <p>
            Running ZooKeeper requires its own <strong>JVM tuning</strong>, separate monitoring,
            different upgrade procedures, and careful capacity planning. ZK has different failure modes
            and scaling characteristics than Kafka itself.
          </p>
          <div class="problem-stat">~50% more ops overhead</div>
        </div>
        <div class="problem-card" id="problemDelay">
          <div class="problem-icon">🐌</div>
          <h3>Metadata Propagation Delay</h3>
          <p>
            Metadata changes flow through ZooKeeper via <strong>watches</strong>, then get propagated
            to the controller, which pushes updates to brokers. This indirect path creates
            <em>delay and inconsistency windows</em> during topology changes.
          </p>
          <div class="problem-stat">Seconds of stale metadata after changes</div>
        </div>
      </div>
    </section>

    <!-- Interactive Cluster Visualization -->
    <section class="cluster-section">
      <h2>🏗️ KRaft Cluster Architecture</h2>
      <p class="section-desc">Interactive cluster — click controllers and brokers to see how the system responds.</p>

      <div class="cluster-controls">
        <button id="createTopicBtn" class="action-btn primary-btn">📦 Create Topic</button>
        <button id="killControllerBtn" class="action-btn danger-btn">💀 Kill Active Controller</button>
        <button id="killBrokerBtn" class="action-btn warning-btn">⚠️ Kill Broker</button>
        <button id="resetClusterBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="cluster-viz-wrapper">
        <div class="cluster-viz" id="clusterViz">
          <!-- Controller Quorum -->
          <div class="quorum-area">
            <div class="quorum-label">Controller Quorum (Raft)</div>
            <div class="controllers" id="controllers"></div>
          </div>
          <!-- Arrow -->
          <div class="cluster-arrow">
            <div class="arrow-line"></div>
            <div class="arrow-label">Metadata Log</div>
            <div class="arrow-line"></div>
          </div>
          <!-- Brokers -->
          <div class="brokers-area">
            <div class="brokers-label">Broker Pool</div>
            <div class="brokers" id="brokers"></div>
          </div>
        </div>
      </div>

      <div class="cluster-log" id="clusterLog">
        <div class="log-entry info">Cluster initialized — 3 controllers, 4 brokers</div>
      </div>

      <div class="metadata-panel" id="metadataPanel">
        <h4>📋 Metadata Log (latest entries)</h4>
        <div class="metadata-entries" id="metadataEntries"></div>
      </div>
    </section>

    <!-- Controller Election Deep Dive -->
    <section class="election-section">
      <h2>🗳️ Controller Election</h2>
      <p class="section-desc">Step through a Raft-based leader election when the active controller fails.</p>

      <div class="election-controls">
        <button id="startElectionBtn" class="action-btn primary-btn">▶ Start Election</button>
        <button id="stepElectionBtn" class="action-btn step-btn" disabled>⏭ Next Step</button>
        <button id="resetElectionBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="election-viz" id="electionViz">
        <div class="election-node" id="electNode0" data-role="leader">
          <div class="election-node-label">Controller 0</div>
          <div class="election-node-role">Active Controller</div>
          <div class="election-node-term">Term: 1</div>
        </div>
        <div class="election-node" id="electNode1" data-role="follower">
          <div class="election-node-label">Controller 1</div>
          <div class="election-node-role">Follower</div>
          <div class="election-node-term">Term: 1</div>
        </div>
        <div class="election-node" id="electNode2" data-role="follower">
          <div class="election-node-label">Controller 2</div>
          <div class="election-node-role">Follower</div>
          <div class="election-node-term">Term: 1</div>
        </div>
      </div>

      <div class="election-timeline" id="electionTimeline"></div>
    </section>

    <!-- Metadata Log Section -->
    <section class="metalog-section">
      <h2>📜 The Metadata Log</h2>
      <p class="section-desc">Every cluster change is an event in a replicated log — just like Kafka's own commit log.</p>

      <div class="metalog-controls">
        <button id="addTopicEvt" class="action-btn primary-btn">📦 TopicCreated</button>
        <button id="addPartEvt" class="action-btn secondary-btn">📊 PartitionAssigned</button>
        <button id="addIsrEvt" class="action-btn warning-btn">🔄 ISRChange</button>
        <button id="addBrokerEvt" class="action-btn commit-btn">🖥️ BrokerRegistered</button>
        <button id="addFenceEvt" class="action-btn danger-btn">🚫 BrokerFenced</button>
        <button id="resetLogBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="metalog-viz" id="metalogViz">
        <div class="metalog-header">
          <span class="metalog-col">Offset</span>
          <span class="metalog-col">Type</span>
          <span class="metalog-col">Data</span>
          <span class="metalog-col">Epoch</span>
        </div>
        <div class="metalog-entries" id="metalogEntries"></div>
      </div>

      <div class="metalog-info">
        <strong>Key insight:</strong> Unlike ZooKeeper's tree-based state, KRaft stores metadata as a
        <em>log of events</em>. Brokers consume this log to build their local metadata cache — exactly
        like consumers reading a Kafka topic. Snapshots periodically compact the log.
      </div>
    </section>

    <!-- Broker Registration & Heartbeats -->
    <section class="heartbeat-section">
      <h2>💓 Broker Registration &amp; Heartbeats</h2>
      <p class="section-desc">Brokers register with the controller and send periodic heartbeats. Fencing tokens prevent zombie brokers.</p>

      <div class="heartbeat-controls">
        <button id="startHeartbeatBtn" class="action-btn primary-btn">▶ Start Simulation</button>
        <button id="fenceBrokerBtn" class="action-btn danger-btn">🚫 Fence Broker 2</button>
        <button id="resetHeartbeatBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="heartbeat-viz" id="heartbeatViz"></div>
      <div class="heartbeat-log" id="heartbeatLog"></div>

      <div class="fencing-explainer">
        <h4>🔑 Fencing Tokens</h4>
        <p>
          Each broker gets a <strong>monotonically increasing fencing token</strong> (broker epoch) upon registration.
          If a broker loses connectivity and re-registers, it gets a <em>new, higher epoch</em>.
          The old instance's writes are rejected because its epoch is stale — this prevents
          <strong>split-brain</strong> scenarios where two instances of the same broker could corrupt data.
        </p>
      </div>
    </section>

    <!-- ZK vs KRaft Comparison -->
    <section class="compare-section">
      <h2>⚔️ ZooKeeper vs KRaft — Side by Side</h2>
      <p class="section-desc">Toggle between architectures to see the structural differences.</p>

      <div class="compare-toggle">
        <button class="compare-btn active" data-mode="zk" id="zkBtn">ZooKeeper Mode</button>
        <button class="compare-btn" data-mode="kraft" id="kraftBtn">KRaft Mode</button>
        <button class="compare-btn" data-mode="split" id="splitBtn">Split View</button>
      </div>

      <div class="compare-viz" id="compareViz">
        <!-- Rendered by JS -->
      </div>

      <div class="compare-table">
        <div class="ct-row ct-header">
          <div class="ct-cell">Aspect</div>
          <div class="ct-cell zk-cell">ZooKeeper</div>
          <div class="ct-cell kraft-cell">KRaft</div>
        </div>
        <div class="ct-row">
          <div class="ct-cell">Metadata Store</div>
          <div class="ct-cell zk-cell">External ZK ensemble (znodes)</div>
          <div class="ct-cell kraft-cell">Internal event log (Raft)</div>
        </div>
        <div class="ct-row">
          <div class="ct-cell">Controller Election</div>
          <div class="ct-cell zk-cell">Ephemeral znode race</div>
          <div class="ct-cell kraft-cell">Raft leader election</div>
        </div>
        <div class="ct-row">
          <div class="ct-cell">Metadata Propagation</div>
          <div class="ct-cell zk-cell">ZK watches → controller → brokers</div>
          <div class="ct-cell kraft-cell">Direct log replication</div>
        </div>
        <div class="ct-row">
          <div class="ct-cell">Failover Time</div>
          <div class="ct-cell zk-cell">Seconds (ZK session timeout)</div>
          <div class="ct-cell kraft-cell">Milliseconds (Raft heartbeat)</div>
        </div>
        <div class="ct-row">
          <div class="ct-cell">Max Partitions</div>
          <div class="ct-cell zk-cell">~200K (ZK bottleneck)</div>
          <div class="ct-cell kraft-cell">Millions (log-based)</div>
        </div>
        <div class="ct-row">
          <div class="ct-cell">Ops Complexity</div>
          <div class="ct-cell zk-cell">2 distributed systems</div>
          <div class="ct-cell kraft-cell">1 system</div>
        </div>
      </div>
    </section>

    <!-- Migration Path -->
    <section class="migration-section">
      <h2>🛤️ Migration Path: ZK → KRaft</h2>
      <p class="section-desc">Step through the migration process from ZooKeeper mode to KRaft mode.</p>

      <div class="migration-steps" id="migrationSteps">
        <div class="mig-step" data-step="1">
          <div class="mig-step-num">1</div>
          <div class="mig-step-content">
            <h4>Upgrade to Bridge Release</h4>
            <p>Upgrade all brokers to a Kafka version that supports both ZK and KRaft (3.3+). The cluster continues running in ZK mode.</p>
          </div>
        </div>
        <div class="mig-step" data-step="2">
          <div class="mig-step-num">2</div>
          <div class="mig-step-content">
            <h4>Deploy Controller Quorum</h4>
            <p>Start KRaft controller nodes alongside existing ZK brokers. Controllers form a Raft quorum but don't manage metadata yet.</p>
          </div>
        </div>
        <div class="mig-step" data-step="3">
          <div class="mig-step-num">3</div>
          <div class="mig-step-content">
            <h4>Migrate Metadata</h4>
            <p>Run the migration tool to copy all metadata from ZooKeeper into the KRaft metadata log. Dual-write mode ensures consistency.</p>
          </div>
        </div>
        <div class="mig-step" data-step="4">
          <div class="mig-step-num">4</div>
          <div class="mig-step-content">
            <h4>Switch to KRaft</h4>
            <p>Flip the cluster to KRaft mode. Brokers now fetch metadata from the controller quorum. ZooKeeper is no longer the source of truth.</p>
          </div>
        </div>
        <div class="mig-step" data-step="5">
          <div class="mig-step-num">5</div>
          <div class="mig-step-content">
            <h4>Decommission ZooKeeper</h4>
            <p>Once stable, shut down the ZooKeeper ensemble. The cluster is fully KRaft-native. No going back!</p>
          </div>
        </div>
      </div>

      <div class="migration-controls">
        <button id="migAnimateBtn" class="action-btn primary-btn">▶ Animate Migration</button>
        <button id="migResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="migration-progress" id="migProgress">
        <div class="mig-progress-bar" id="migProgressBar"></div>
      </div>
      <div class="migration-status" id="migStatus">Click "Animate Migration" to walk through the process</div>
    </section>

    <!-- Explanations -->
    <section class="explain-section">
      <div class="explain-grid">
        <div class="explain-card highlight-card">
          <h3>💡 Why Raft?</h3>
          <p>
            Raft was chosen over ZooKeeper's ZAB protocol because it's <strong>simpler to reason about</strong>,
            well-studied, and fits naturally with Kafka's log-based architecture. The metadata log
            <em>is</em> a Raft log — same abstraction Kafka already uses for data.
          </p>
        </div>
        <div class="explain-card">
          <h3>⚡ Performance Gains</h3>
          <p>
            KRaft enables <strong>millions of partitions</strong> per cluster (vs ~200K with ZK),
            <em>faster controller failover</em> (ms vs seconds), and eliminates the metadata
            propagation delay from ZK watches. Startup time is also dramatically reduced.
          </p>
        </div>
        <div class="explain-card">
          <h3>🔄 Metadata Snapshots</h3>
          <p>
            Like Kafka's log compaction, the metadata log periodically creates <strong>snapshots</strong>.
            New brokers or restarting controllers load the latest snapshot and replay only recent events —
            no need to replay the entire log from the beginning.
          </p>
        </div>
        <div class="explain-card">
          <h3>🏗️ Combined vs Isolated Mode</h3>
          <p>
            Controllers can run on <strong>dedicated nodes</strong> (isolated, recommended for production)
            or <strong>co-located with brokers</strong> (combined, simpler for dev/small clusters).
            Use <code>process.roles=controller</code> or <code>process.roles=broker,controller</code>.
          </p>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://cwiki.apache.org/confluence/display/KAFKA/KIP-500%3A+Replace+ZooKeeper+with+a+Self-Managed+Metadata+Quorum" target="_blank">KIP-500: Replace ZooKeeper with a Self-Managed Metadata Quorum</a> and <a href="https://kafka.apache.org/documentation/#kraft" target="_blank">Apache Kafka KRaft Documentation</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20Kafka%20KRaft%20Visualizer%20—%20Replacing%20ZooKeeper&url=https://systeminternals.dev/kafka/kraft/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/kafka/kraft/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/kafka/kraft/&t=Interactive%20Kafka%20KRaft%20Visualizer" target="_blank" class="share-btn">🟧 HN</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container { max-width: 1100px; margin: 0 auto; }
  .viz-header { text-align: center; margin-bottom: 40px; }
  .viz-header h1 { font-size: 2.5rem; margin-bottom: 10px; background: linear-gradient(90deg, #f59e0b, #ef4444, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .subtitle { color: #888; font-size: 1.1rem; }
  h2 { font-size: 1.5rem; color: #fff; margin-bottom: 12px; }
  .section-desc { color: #888; margin-bottom: 24px; }

  .overview-section { margin-bottom: 50px; }
  .overview-card { background: linear-gradient(135deg, rgba(245,158,11,0.1), rgba(239,68,68,0.05)); border: 1px solid rgba(245,158,11,0.3); border-radius: 16px; padding: 24px 28px; font-size: 1.05rem; line-height: 1.8; color: #ccc; }
  .overview-card strong { color: #fff; }
  .overview-card em { color: #f59e0b; font-style: normal; font-weight: 500; }
  .overview-card code { background: rgba(0,0,0,0.3); padding: 2px 6px; border-radius: 4px; font-size: 0.9rem; color: #f59e0b; }

  .action-btn { padding: 10px 20px; border: none; border-radius: 10px; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .action-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .primary-btn { background: linear-gradient(135deg, #f59e0b, #d97706); color: white; }
  .primary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(245,158,11,0.4); }
  .secondary-btn { background: linear-gradient(135deg, #60a5fa, #3b82f6); color: white; }
  .secondary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(96,165,250,0.4); }
  .danger-btn { background: linear-gradient(135deg, #f87171, #ef4444); color: white; }
  .danger-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(239,68,68,0.4); }
  .warning-btn { background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #1a1a2e; }
  .warning-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(251,191,36,0.4); }
  .step-btn { background: linear-gradient(135deg, #60a5fa, #3b82f6); color: white; }
  .commit-btn { background: linear-gradient(135deg, #a78bfa, #7c3aed); color: white; }
  .reset-btn { background: rgba(255,255,255,0.1); color: #aaa; }
  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  /* Problems Section */
  .problems-section { margin-bottom: 50px; }
  .problems-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .problem-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 24px; transition: all 0.3s; }
  .problem-card:hover { border-color: rgba(239,68,68,0.4); transform: translateY(-3px); box-shadow: 0 8px 30px rgba(0,0,0,0.3); }
  .problem-icon { font-size: 2rem; margin-bottom: 12px; }
  .problem-card h3 { font-size: 1.05rem; color: #fff; margin-bottom: 10px; }
  .problem-card p { color: #aaa; font-size: 0.9rem; line-height: 1.6; margin-bottom: 12px; }
  .problem-card strong { color: #f87171; }
  .problem-card em { color: #fbbf24; font-style: normal; }
  .problem-stat { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); border-radius: 8px; padding: 8px 12px; font-size: 0.85rem; color: #fca5a5; text-align: center; font-weight: 600; }

  /* Cluster Section */
  .cluster-section { margin-bottom: 50px; }
  .cluster-controls { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 20px; }
  .cluster-viz-wrapper { background: rgba(0,0,0,0.2); border-radius: 14px; padding: 30px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 16px; }
  .cluster-viz { display: flex; flex-direction: column; align-items: center; gap: 20px; }
  .quorum-area, .brokers-area { width: 100%; }
  .quorum-label, .brokers-label { font-size: 0.85rem; font-weight: 700; color: #f59e0b; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; text-align: center; }
  .brokers-label { color: #60a5fa; }
  .controllers, .brokers { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; }

  .cluster-arrow { display: flex; align-items: center; gap: 12px; width: 100%; padding: 0 20px; }
  .arrow-line { flex: 1; height: 2px; background: linear-gradient(90deg, transparent, rgba(245,158,11,0.4), transparent); }
  .arrow-label { font-size: 0.8rem; color: #f59e0b; font-weight: 600; white-space: nowrap; }

  :global(.ctrl-node) { width: 120px; padding: 16px; border-radius: 12px; text-align: center; border: 2px solid rgba(245,158,11,0.3); background: rgba(245,158,11,0.08); transition: all 0.3s; cursor: default; }
  :global(.ctrl-node.leader) { border-color: #f59e0b; background: rgba(245,158,11,0.15); box-shadow: 0 0 20px rgba(245,158,11,0.2); }
  :global(.ctrl-node.dead) { border-color: rgba(239,68,68,0.4); background: rgba(239,68,68,0.08); opacity: 0.5; }
  :global(.ctrl-name) { font-weight: 700; font-size: 0.85rem; color: #fff; margin-bottom: 4px; }
  :global(.ctrl-role) { font-size: 0.75rem; color: #f59e0b; margin-bottom: 2px; }
  :global(.ctrl-epoch) { font-size: 0.7rem; color: #888; }

  :global(.broker-node) { width: 100px; padding: 14px; border-radius: 12px; text-align: center; border: 2px solid rgba(96,165,250,0.3); background: rgba(96,165,250,0.08); transition: all 0.3s; }
  :global(.broker-node.dead) { border-color: rgba(239,68,68,0.4); background: rgba(239,68,68,0.08); opacity: 0.5; }
  :global(.broker-node.registering) { animation: brokerPulse 1s ease-in-out infinite; }
  @keyframes brokerPulse { 0%,100% { box-shadow: 0 0 0 rgba(96,165,250,0); } 50% { box-shadow: 0 0 15px rgba(96,165,250,0.3); } }
  :global(.broker-name) { font-weight: 700; font-size: 0.85rem; color: #fff; margin-bottom: 4px; }
  :global(.broker-parts) { font-size: 0.7rem; color: #60a5fa; }

  .cluster-log { background: rgba(0,0,0,0.2); border-radius: 12px; padding: 16px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 16px; max-height: 200px; overflow-y: auto; font-size: 0.85rem; font-family: 'Monaco','Menlo',monospace; }
  :global(.log-entry) { padding: 4px 0; animation: fadeIn 0.3s ease-out; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
  :global(.log-entry.info) { color: #93c5fd; }
  :global(.log-entry.success) { color: #6ee7b7; }
  :global(.log-entry.error) { color: #fca5a5; }
  :global(.log-entry.warn) { color: #fde68a; }

  .metadata-panel { background: rgba(0,0,0,0.2); border-radius: 12px; padding: 16px; border: 1px solid rgba(255,255,255,0.1); }
  .metadata-panel h4 { font-size: 0.9rem; color: #fff; margin-bottom: 10px; }
  .metadata-entries { max-height: 150px; overflow-y: auto; }
  :global(.meta-entry) { display: flex; gap: 12px; padding: 4px 0; font-size: 0.8rem; font-family: 'Monaco','Menlo',monospace; animation: fadeIn 0.3s ease-out; }
  :global(.meta-offset) { color: #888; width: 40px; }
  :global(.meta-type) { color: #f59e0b; width: 140px; }
  :global(.meta-data) { color: #aaa; flex: 1; }

  /* Election Section */
