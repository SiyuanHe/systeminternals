  :global(.mlog-row) { display: flex; gap: 12px; padding: 6px 12px; border-radius: 6px; animation: fadeIn 0.3s ease-out; font-size: 0.85rem; font-family: 'Monaco','Menlo',monospace; }
  :global(.mlog-row:nth-child(even)) { background: rgba(255,255,255,0.02); }
  :global(.mlog-offset) { width: 60px; color: #888; }
  :global(.mlog-type) { width: 160px; font-weight: 600; }
  :global(.mlog-type.topic) { color: #34d399; }
