  .metalog-info { padding: 14px 18px; background: rgba(245,158,11,0.06); border: 1px solid rgba(245,158,11,0.2); border-radius: 10px; font-size: 0.9rem; color: #aaa; line-height: 1.6; }
  .metalog-info strong { color: #f59e0b; }
  .metalog-info em { color: #60a5fa; font-style: normal; }

  /* Heartbeat Section */
  .heartbeat-section { margin-bottom: 50px; }
  .heartbeat-controls { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 20px; }
  .heartbeat-viz { display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; margin-bottom: 16px; min-height: 100px; }
  :global(.hb-broker) { width: 140px; padding: 16px; border-radius: 12px; text-align: center; border: 2px solid rgba(96,165,250,0.3); background: rgba(96,165,250,0.08); transition: all 0.3s; }
  :global(.hb-broker.active) { border-color: #34d399; background: rgba(52,211,153,0.08); }
  :global(.hb-broker.fenced) { border-color: rgba(239,68,68,0.4); background: rgba(239,68,68,0.08); opacity: 0.6; }
  :global(.hb-broker.heartbeat) { animation: hbPulse 0.5s ease-out; }
  @keyframes hbPulse { 0% { box-shadow: 0 0 0 rgba(52,211,153,0); } 50% { box-shadow: 0 0 20px rgba(52,211,153,0.4); } 100% { box-shadow: 0 0 0 rgba(52,211,153,0); } }
  :global(.hb-name) { font-weight: 700; font-size: 0.9rem; color: #fff; margin-bottom: 4px; }
  :global(.hb-token) { font-size: 0.75rem; color: #f59e0b; margin-bottom: 4px; }
  :global(.hb-status) { font-size: 0.75rem; color: #888; }

  .heartbeat-log { background: rgba(0,0,0,0.2); border-radius: 12px; padding: 16px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 16px; max-height: 200px; overflow-y: auto; font-size: 0.85rem; font-family: 'Monaco','Menlo',monospace; }
  .fencing-explainer { padding: 20px 24px; background: linear-gradient(135deg, rgba(245,158,11,0.08), rgba(167,139,250,0.08)); border: 1px solid rgba(245,158,11,0.3); border-radius: 14px; }
  .fencing-explainer h4 { font-size: 1rem; color: #fff; margin-bottom: 8px; }
  .fencing-explainer p { color: #aaa; font-size: 0.9rem; line-height: 1.7; }
  .fencing-explainer strong { color: #f59e0b; }
  .fencing-explainer em { color: #a78bfa; font-style: normal; }

  /* Compare Section */
  .compare-section { margin-bottom: 50px; }
  .compare-toggle { display: flex; gap: 10px; margin-bottom: 20px; }
  .compare-btn { padding: 10px 20px; border: 1px solid rgba(255,255,255,0.15); border-radius: 10px; background: rgba(255,255,255,0.03); color: #ccc; font-size: 0.9rem; cursor: pointer; transition: all 0.2s; font-weight: 600; }
  .compare-btn.active { border-color: #f59e0b; background: rgba(245,158,11,0.15); color: #f59e0b; }
  .compare-viz { background: rgba(0,0,0,0.2); border-radius: 14px; padding: 30px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 24px; min-height: 200px; }

  :global(.arch-diagram) { display: flex; flex-direction: column; align-items: center; gap: 16px; }
  :global(.arch-row) { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; }
  :global(.arch-box) { padding: 12px 20px; border-radius: 10px; text-align: center; font-size: 0.85rem; font-weight: 600; min-width: 100px; }
  :global(.arch-box.zk) { background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; }
  :global(.arch-box.ctrl) { background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.3); color: #fde68a; }
  :global(.arch-box.broker-box) { background: rgba(96,165,250,0.12); border: 1px solid rgba(96,165,250,0.3); color: #93c5fd; }
  :global(.arch-box.producer-box) { background: rgba(52,211,153,0.12); border: 1px solid rgba(52,211,153,0.3); color: #6ee7b7; }
  :global(.arch-connector) { color: #666; font-size: 1.2rem; }
  :global(.arch-label) { font-size: 0.75rem; color: #888; margin-top: 4px; }

  :global(.split-view) { display: flex; gap: 30px; }
  :global(.split-col) { flex: 1; }
  :global(.split-title) { font-size: 0.9rem; font-weight: 700; text-align: center; margin-bottom: 16px; padding: 8px; border-radius: 8px; }
  :global(.split-title.zk-title) { color: #fca5a5; background: rgba(239,68,68,0.1); }
  :global(.split-title.kraft-title) { color: #fde68a; background: rgba(245,158,11,0.1); }

  .compare-table { border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); }
  .ct-row { display: flex; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .ct-row:last-child { border-bottom: none; }
  .ct-header { background: rgba(255,255,255,0.05); }
  .ct-header .ct-cell { font-weight: 700; color: #fff; font-size: 0.9rem; }
  .ct-cell { flex: 1; padding: 12px 16px; font-size: 0.85rem; color: #aaa; }
  .ct-cell:first-child { color: #ccc; font-weight: 600; }
  .zk-cell { background: rgba(239,68,68,0.03); }
  .kraft-cell { background: rgba(245,158,11,0.03); }

  /* Migration Section */
  .migration-section { margin-bottom: 50px; }
  .migration-steps { position: relative; padding-left: 40px; margin-bottom: 24px; }
  .migration-steps::before { content: ''; position: absolute; left: 18px; top: 0; bottom: 0; width: 2px; background: rgba(255,255,255,0.1); }
  .mig-step { display: flex; gap: 16px; margin-bottom: 24px; position: relative; opacity: 0.4; transition: all 0.5s; }
  .mig-step.active { opacity: 1; }
  .mig-step.done { opacity: 0.7; }
  .mig-step-num { width: 36px; height: 36px; border-radius: 50%; background: rgba(255,255,255,0.1); border: 2px solid rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; color: #888; flex-shrink: 0; position: absolute; left: -40px; transition: all 0.5s; z-index: 1; }
  .mig-step.active .mig-step-num { background: rgba(245,158,11,0.2); border-color: #f59e0b; color: #f59e0b; box-shadow: 0 0 15px rgba(245,158,11,0.3); }
  .mig-step.done .mig-step-num { background: rgba(52,211,153,0.2); border-color: #34d399; color: #34d399; }
  .mig-step-content h4 { font-size: 1rem; color: #fff; margin-bottom: 6px; }
  .mig-step-content p { font-size: 0.9rem; color: #aaa; line-height: 1.6; }
  .migration-controls { display: flex; gap: 12px; margin-bottom: 16px; }
  .migration-progress { height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px; overflow: hidden; margin-bottom: 8px; }
  .mig-progress-bar { height: 100%; width: 0%; background: linear-gradient(90deg, #f59e0b, #34d399); border-radius: 4px; transition: width 0.5s; }
  .migration-status { font-size: 0.9rem; color: #888; text-align: center; }

  /* Explain Section */
  .explain-section { margin-bottom: 50px; }
  .explain-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .explain-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 24px; }
  .explain-card h3 { font-size: 1rem; color: #fff; margin-bottom: 10px; }
  .explain-card p { color: #aaa; line-height: 1.6; font-size: 0.9rem; }
  .explain-card strong { color: #f59e0b; }
  .explain-card em { color: #60a5fa; font-style: normal; }
  .explain-card code { background: rgba(0,0,0,0.3); padding: 2px 6px; border-radius: 4px; font-size: 0.85rem; color: #f59e0b; }
  .highlight-card { background: linear-gradient(135deg, rgba(245,158,11,0.08), rgba(167,139,250,0.08)); border-color: rgba(245,158,11,0.3); }

  .viz-footer { text-align: center; color: #666; font-size: 0.9rem; padding: 20px 0; border-top: 1px solid rgba(255,255,255,0.1); margin-bottom: 30px; }
  .viz-footer a { color: #f59e0b; }
  .share-buttons { display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; }
  .share-buttons span { color: #666; }
  .share-btn { padding: 10px 20px; background: rgba(255,255,255,0.1); border-radius: 8px; color: #fff; font-size: 0.9rem; transition: background 0.2s; text-decoration: none; }
  .share-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  @media (max-width: 768px) {
    .viz-header h1 { font-size: 1.8rem; }
    .problems-grid { grid-template-columns: 1fr; }
    .explain-grid { grid-template-columns: 1fr; }
    .election-viz { flex-direction: column; align-items: center; }
    :global(.split-view) { flex-direction: column; }
    .compare-table { font-size: 0.8rem; }
    .ct-cell { padding: 8px 10px; }
  }
</style>

<script is:inline>
  // ========== CLUSTER STATE ==========
  var clusterState = {
    controllers: [
      { id: 0, role: 'leader', alive: true, epoch: 1 },
      { id: 1, role: 'follower', alive: true, epoch: 1 },
      { id: 2, role: 'follower', alive: true, epoch: 1 }
    ],
    brokers: [
      { id: 0, alive: true, partitions: 4, epoch: 1 },
      { id: 1, alive: true, partitions: 3, epoch: 1 },
      { id: 2, alive: true, partitions: 3, epoch: 1 },
      { id: 3, alive: true, partitions: 2, epoch: 1 }
    ],
    metadataOffset: 0,
    topicCount: 0
  };

  function addClusterLog(text, cls) {
    var log = document.getElementById('clusterLog');
    if (!log) return;
    var el = document.createElement('div');
    el.className = 'log-entry ' + cls;
    el.textContent = text;
    log.appendChild(el);
    log.scrollTop = log.scrollHeight;
  }

  function addMetadataEntry(type, data) {
    clusterState.metadataOffset++;
    var entries = document.getElementById('metadataEntries');
    if (!entries) return;
    var el = document.createElement('div');
    el.className = 'meta-entry';
    var typeCls = type.indexOf('Topic') >= 0 ? 'topic' : type.indexOf('Partition') >= 0 ? 'partition' : type.indexOf('ISR') >= 0 ? 'isr' : type.indexOf('Broker') >= 0 ? 'broker' : 'fence';
    el.innerHTML = '<span class="meta-offset">' + clusterState.metadataOffset + '</span>' +
      '<span class="meta-type">' + type + '</span>' +
      '<span class="meta-data">' + data + '</span>';
    entries.appendChild(el);
    entries.scrollTop = entries.scrollHeight;
  }

  function renderCluster() {
    var ctrlContainer = document.getElementById('controllers');
    var brokerContainer = document.getElementById('brokers');
    if (!ctrlContainer || !brokerContainer) return;

    ctrlContainer.innerHTML = '';
    clusterState.controllers.forEach(function(c) {
      var el = document.createElement('div');
      var classes = 'ctrl-node';
      if (c.role === 'leader' && c.alive) classes += ' leader';
      if (!c.alive) classes += ' dead';
      el.className = classes;
      el.innerHTML = '<div class="ctrl-name">Controller ' + c.id + '</div>' +
        '<div class="ctrl-role">' + (c.alive ? (c.role === 'leader' ? '⭐ Active' : '👥 Follower') : '💀 Dead') + '</div>' +
        '<div class="ctrl-epoch">Epoch: ' + c.epoch + '</div>';
      ctrlContainer.appendChild(el);
    });

    brokerContainer.innerHTML = '';
    clusterState.brokers.forEach(function(b) {
      var el = document.createElement('div');
      el.className = 'broker-node' + (b.alive ? '' : ' dead');
      el.innerHTML = '<div class="broker-name">Broker ' + b.id + '</div>' +
        '<div class="broker-parts">' + (b.alive ? b.partitions + ' partitions' : '💀 Dead') + '</div>';
      brokerContainer.appendChild(el);
    });
  }

  // Create Topic
  var createTopicBtn = document.getElementById('createTopicBtn');
  if (createTopicBtn) {
    createTopicBtn.addEventListener('click', function() {
      clusterState.topicCount++;
      var topicName = 'topic-' + String.fromCharCode(96 + clusterState.topicCount);
      addClusterLog('📦 Creating topic "' + topicName + '" with 3 partitions...', 'info');

      setTimeout(function() {
        addMetadataEntry('TopicCreated', topicName + ' (3 partitions, RF=3)');
        addClusterLog('✅ Topic "' + topicName + '" created — metadata propagated to all brokers', 'success');

        // distribute partitions
        var alive = clusterState.brokers.filter(function(b) { return b.alive; });
        alive.forEach(function(b) { b.partitions += 1; });
        renderCluster();

        setTimeout(function() {
          addMetadataEntry('PartitionAssigned', topicName + '-0 → Broker ' + (alive[0] ? alive[0].id : 0));
          addMetadataEntry('PartitionAssigned', topicName + '-1 → Broker ' + (alive[1] ? alive[1].id : 0));
          addMetadataEntry('PartitionAssigned', topicName + '-2 → Broker ' + (alive[2] ? alive[2].id : 0));
        }, 300);
      }, 500);
    });
  }

  // Kill Active Controller
  var killControllerBtn = document.getElementById('killControllerBtn');
  if (killControllerBtn) {
    killControllerBtn.addEventListener('click', function() {
      var leader = null;
      clusterState.controllers.forEach(function(c) {
        if (c.role === 'leader' && c.alive) leader = c;
      });
      if (!leader) {
        addClusterLog('⚠️ No active controller to kill', 'warn');
        return;
      }

      leader.alive = false;
      leader.role = 'dead';
      renderCluster();
      addClusterLog('💀 Controller ' + leader.id + ' killed! Leader is gone...', 'error');

      setTimeout(function() {
        addClusterLog('🗳️ Raft election triggered — followers increment term...', 'warn');
        var followers = clusterState.controllers.filter(function(c) { return c.alive && c.role === 'follower'; });

        setTimeout(function() {
          if (followers.length > 0) {
            var newLeader = followers[0];
            newLeader.role = 'leader';
            newLeader.epoch++;
            clusterState.controllers.forEach(function(c) { if (c.alive) c.epoch = newLeader.epoch; });
            renderCluster();
            addClusterLog('⭐ Controller ' + newLeader.id + ' elected as new active controller (epoch ' + newLeader.epoch + ')', 'success');
            addMetadataEntry('LeaderChange', 'Controller ' + newLeader.id + ' (epoch ' + newLeader.epoch + ')');
          }
        }, 800);
      }, 600);
    });
  }

  // Kill Broker
  var killBrokerBtn = document.getElementById('killBrokerBtn');
  if (killBrokerBtn) {
    killBrokerBtn.addEventListener('click', function() {
      var aliveBrokers = clusterState.brokers.filter(function(b) { return b.alive; });
      if (aliveBrokers.length === 0) {
        addClusterLog('⚠️ No alive brokers to kill', 'warn');
        return;
      }
      var victim = aliveBrokers[aliveBrokers.length - 1];
      victim.alive = false;
      var lostParts = victim.partitions;
      victim.partitions = 0;
      renderCluster();
      addClusterLog('💀 Broker ' + victim.id + ' killed! ' + lostParts + ' partitions need reassignment', 'error');
      addMetadataEntry('BrokerFenced', 'Broker ' + victim.id + ' (epoch ' + victim.epoch + ')');

      setTimeout(function() {
        var remaining = clusterState.brokers.filter(function(b) { return b.alive; });
        if (remaining.length > 0) {
          var perBroker = Math.ceil(lostParts / remaining.length);
          remaining.forEach(function(b) { b.partitions += perBroker; });
          renderCluster();
          addClusterLog('🔄 Partitions redistributed to remaining brokers', 'success');
          addMetadataEntry('PartitionReassign', lostParts + ' partitions moved from Broker ' + victim.id);
        }
      }, 800);
    });
  }

  // Reset Cluster
  var resetClusterBtn = document.getElementById('resetClusterBtn');
  if (resetClusterBtn) {
    resetClusterBtn.addEventListener('click', function() {
      clusterState.controllers = [
        { id: 0, role: 'leader', alive: true, epoch: 1 },
        { id: 1, role: 'follower', alive: true, epoch: 1 },
        { id: 2, role: 'follower', alive: true, epoch: 1 }
      ];
      clusterState.brokers = [
        { id: 0, alive: true, partitions: 4, epoch: 1 },
        { id: 1, alive: true, partitions: 3, epoch: 1 },
        { id: 2, alive: true, partitions: 3, epoch: 1 },
        { id: 3, alive: true, partitions: 2, epoch: 1 }
      ];
      clusterState.metadataOffset = 0;
      clusterState.topicCount = 0;
      renderCluster();
      document.getElementById('clusterLog').innerHTML = '<div class="log-entry info">Cluster reset — 3 controllers, 4 brokers</div>';
      document.getElementById('metadataEntries').innerHTML = '';
    });
  }

  // ========== ELECTION ANIMATION ==========
  var electionSteps = [];
  var electionStepIdx = 0;

  function buildElectionSteps() {
    electionSteps = [
      { cls: 'error', text: '💀 Controller 0 (active) crashes — no heartbeats received', nodes: [{id:0,role:'dead',term:1},{id:1,role:'follower',term:1},{id:2,role:'follower',term:1}] },
      { cls: 'info', text: '⏱️ Election timeout expires on Controller 1 — no leader heartbeat received', nodes: [{id:0,role:'dead',term:1},{id:1,role:'follower',term:1},{id:2,role:'follower',term:1}] },
      { cls: 'vote', text: '🗳️ Controller 1 increments term to 2, transitions to Candidate, votes for itself', nodes: [{id:0,role:'dead',term:1},{id:1,role:'candidate',term:2},{id:2,role:'follower',term:1}] },
      { cls: 'vote', text: '📨 Controller 1 sends RequestVote(term=2) to Controller 2', nodes: [{id:0,role:'dead',term:1},{id:1,role:'candidate',term:2},{id:2,role:'follower',term:2}] },
      { cls: 'vote', text: '✅ Controller 2 grants vote — Controller 1 has majority (2/3)', nodes: [{id:0,role:'dead',term:1},{id:1,role:'candidate',term:2},{id:2,role:'follower',term:2}] },
      { cls: 'success', text: '⭐ Controller 1 becomes Active Controller (term 2) — sends first AppendEntries', nodes: [{id:0,role:'dead',term:2},{id:1,role:'leader',term:2},{id:2,role:'follower',term:2}] },
      { cls: 'success', text: '📋 New leader loads metadata snapshot + replays uncommitted log entries', nodes: [{id:0,role:'dead',term:2},{id:1,role:'leader',term:2},{id:2,role:'follower',term:2}] },
      { cls: 'info', text: '🔔 Brokers notified of new active controller — metadata operations resume', nodes: [{id:0,role:'dead',term:2},{id:1,role:'leader',term:2},{id:2,role:'follower',term:2}] }
    ];
  }

  function renderElectionStep() {
    var step = electionSteps[electionStepIdx];
    // Update nodes
    step.nodes.forEach(function(n) {
      var node = document.getElementById('electNode' + n.id);
      if (!node) return;
      node.setAttribute('data-role', n.role);
      var roleText = n.role === 'leader' ? '⭐ Active Controller' :
                     n.role === 'candidate' ? '🗳️ Candidate' :
                     n.role === 'dead' ? '💀 Dead' : '👥 Follower';
      node.querySelector('.election-node-role').textContent = roleText;
      node.querySelector('.election-node-term').textContent = 'Term: ' + n.term;
    });
    // Add timeline entry
    var timeline = document.getElementById('electionTimeline');
    var el = document.createElement('div');
    el.className = 'elect-step ' + step.cls;
    el.textContent = step.text;
    timeline.appendChild(el);
    timeline.scrollTop = timeline.scrollHeight;
  }

  var startElectionBtn = document.getElementById('startElectionBtn');
  if (startElectionBtn) {
    startElectionBtn.addEventListener('click', function() {
      document.getElementById('electionTimeline').innerHTML = '';
      buildElectionSteps();
      electionStepIdx = 0;
      renderElectionStep();
      document.getElementById('stepElectionBtn').disabled = false;
    });
  }

  var stepElectionBtn = document.getElementById('stepElectionBtn');
  if (stepElectionBtn) {
    stepElectionBtn.addEventListener('click', function() {
      if (electionStepIdx < electionSteps.length - 1) {
        electionStepIdx++;
        renderElectionStep();
        if (electionStepIdx >= electionSteps.length - 1) {
          document.getElementById('stepElectionBtn').disabled = true;
        }
      }
    });
  }

  var resetElectionBtn = document.getElementById('resetElectionBtn');
  if (resetElectionBtn) {
    resetElectionBtn.addEventListener('click', function() {
      document.getElementById('electionTimeline').innerHTML = '';
      document.getElementById('stepElectionBtn').disabled = true;
      [{id:0,role:'leader',term:1},{id:1,role:'follower',term:1},{id:2,role:'follower',term:1}].forEach(function(n) {
        var node = document.getElementById('electNode' + n.id);
        if (!node) return;
        node.setAttribute('data-role', n.role);
        var roleText = n.role === 'leader' ? '⭐ Active Controller' : '👥 Follower';
        node.querySelector('.election-node-role').textContent = roleText;
        node.querySelector('.election-node-term').textContent = 'Term: 1';
      });
    });
  }

  // ========== METADATA LOG INTERACTIVE ==========
  var metalogOffset = 0;
  var metalogEpoch = 1;
  var topicNames = ['orders', 'payments', 'users', 'events', 'metrics', 'logs', 'clicks', 'sessions'];
  var topicIdx = 0;

  function addMetalogEntry(type, data, typeCls) {
    metalogOffset++;
    var entries = document.getElementById('metalogEntries');
    if (!entries) return;
    var el = document.createElement('div');
    el.className = 'mlog-row';
    el.innerHTML = '<span class="mlog-offset">' + metalogOffset + '</span>' +
      '<span class="mlog-type ' + typeCls + '">' + type + '</span>' +
      '<span class="mlog-data">' + data + '</span>' +
      '<span class="mlog-epoch">' + metalogEpoch + '</span>';
    entries.appendChild(el);
    entries.scrollTop = entries.scrollHeight;
  }

  var addTopicEvt = document.getElementById('addTopicEvt');
  if (addTopicEvt) {
    addTopicEvt.addEventListener('click', function() {
      var name = topicNames[topicIdx % topicNames.length];
      topicIdx++;
      addMetalogEntry('TopicRecord', 'name=' + name + ', id=t' + topicIdx + ', partitions=6', 'topic');
    });
  }
  var addPartEvt = document.getElementById('addPartEvt');
  if (addPartEvt) {
    addPartEvt.addEventListener('click', function() {
      var p = Math.floor(Math.random() * 6);
      var b = Math.floor(Math.random() * 4);
      addMetalogEntry('PartitionRecord', 'topic=orders, partition=' + p + ', leader=Broker ' + b + ', replicas=[' + b + ',' + ((b+1)%4) + ',' + ((b+2)%4) + ']', 'partition');
    });
  }
  var addIsrEvt = document.getElementById('addIsrEvt');
  if (addIsrEvt) {
    addIsrEvt.addEventListener('click', function() {
      var p = Math.floor(Math.random() * 6);
      var b = Math.floor(Math.random() * 4);
      addMetalogEntry('ISRChangeRecord', 'topic=orders, partition=' + p + ', isr=[' + b + ',' + ((b+1)%4) + '] (removed Broker ' + ((b+2)%4) + ')', 'isr');
    });
  }
  var addBrokerEvt = document.getElementById('addBrokerEvt');
  if (addBrokerEvt) {
    addBrokerEvt.addEventListener('click', function() {
      var b = Math.floor(Math.random() * 4);
      addMetalogEntry('RegisterBrokerRecord', 'broker=' + b + ', host=kafka-' + b + ':9092, epoch=' + metalogEpoch, 'broker');
    });
  }
  var addFenceEvt = document.getElementById('addFenceEvt');
  if (addFenceEvt) {
    addFenceEvt.addEventListener('click', function() {
      var b = Math.floor(Math.random() * 4);
      addMetalogEntry('FenceBrokerRecord', 'broker=' + b + ', epoch=' + metalogEpoch + ' → FENCED', 'fence');
    });
  }
  var resetLogBtn = document.getElementById('resetLogBtn');
  if (resetLogBtn) {
    resetLogBtn.addEventListener('click', function() {
      metalogOffset = 0;
      topicIdx = 0;
      var entries = document.getElementById('metalogEntries');
      if (entries) entries.innerHTML = '';
    });
  }

  // ========== HEARTBEAT SIMULATION ==========
  var hbInterval = null;
  var hbBrokers = [
    { id: 0, epoch: 1, status: 'active', missedHb: 0 },
    { id: 1, epoch: 1, status: 'active', missedHb: 0 },
    { id: 2, epoch: 1, status: 'active', missedHb: 0 },
    { id: 3, epoch: 1, status: 'active', missedHb: 0 }
  ];

  function renderHeartbeats() {
    var viz = document.getElementById('heartbeatViz');
    if (!viz) return;
    viz.innerHTML = '';
    hbBrokers.forEach(function(b) {
      var el = document.createElement('div');
      el.className = 'hb-broker ' + b.status;
      el.innerHTML = '<div class="hb-name">Broker ' + b.id + '</div>' +
        '<div class="hb-token">epoch: ' + b.epoch + '</div>' +
        '<div class="hb-status">' +
        (b.status === 'active' ? '💚 Active' : b.status === 'fenced' ? '🚫 Fenced' : '💓 Heartbeat') +
        '</div>';
      viz.appendChild(el);
    });
  }

  function addHbLog(text, cls) {
    var log = document.getElementById('heartbeatLog');
    if (!log) return;
    var el = document.createElement('div');
    el.className = 'log-entry ' + cls;
    el.textContent = text;
    log.appendChild(el);
    log.scrollTop = log.scrollHeight;
  }

  var startHeartbeatBtn = document.getElementById('startHeartbeatBtn');
  if (startHeartbeatBtn) {
    startHeartbeatBtn.addEventListener('click', function() {
      if (hbInterval) return;
      addHbLog('Starting heartbeat simulation...', 'info');
      var tick = 0;
      hbInterval = setInterval(function() {
        tick++;
        hbBrokers.forEach(function(b) {
          if (b.status === 'fenced') return;
          // briefly show heartbeat animation
          b.status = 'heartbeat';
          renderHeartbeats();
          setTimeout(function() {
            if (b.status !== 'fenced') b.status = 'active';
            renderHeartbeats();
          }, 300);
        });
        var activeBrokers = hbBrokers.filter(function(b) { return b.status !== 'fenced'; });
        if (activeBrokers.length > 0) {
          addHbLog('💓 Heartbeat #' + tick + ' — ' + activeBrokers.length + ' brokers responded', 'success');
        }
      }, 2000);
    });
  }

  var fenceBrokerBtn = document.getElementById('fenceBrokerBtn');
  if (fenceBrokerBtn) {
    fenceBrokerBtn.addEventListener('click', function() {
      var b = hbBrokers[2];
      if (b.status === 'fenced') {
        // Re-register with new epoch
        b.epoch++;
        b.status = 'active';
        addHbLog('🔄 Broker 2 re-registered with new epoch ' + b.epoch + ' — old instance fenced by epoch check', 'warn');
      } else {
        b.status = 'fenced';
        addHbLog('🚫 Broker 2 fenced! Epoch ' + b.epoch + ' is now invalid. Must re-register with new epoch.', 'error');
      }
      renderHeartbeats();
    });
  }

  var resetHeartbeatBtn = document.getElementById('resetHeartbeatBtn');
  if (resetHeartbeatBtn) {
    resetHeartbeatBtn.addEventListener('click', function() {
      if (hbInterval) { clearInterval(hbInterval); hbInterval = null; }
      hbBrokers = [
        { id: 0, epoch: 1, status: 'active', missedHb: 0 },
        { id: 1, epoch: 1, status: 'active', missedHb: 0 },
        { id: 2, epoch: 1, status: 'active', missedHb: 0 },
        { id: 3, epoch: 1, status: 'active', missedHb: 0 }
      ];
      renderHeartbeats();
      var log = document.getElementById('heartbeatLog');
      if (log) log.innerHTML = '';
    });
  }

  // ========== ZK vs KRAFT COMPARISON ==========
  var compareMode = 'zk';

  function renderZKArch() {
    return '<div class="arch-diagram">' +
      '<div class="arch-row"><div class="arch-box producer-box">Producers</div><div class="arch-box producer-box">Consumers</div></div>' +
      '<div class="arch-connector">↕</div>' +
      '<div class="arch-row"><div class="arch-box broker-box">Broker 0</div><div class="arch-box broker-box">Broker 1</div><div class="arch-box broker-box">Broker 2</div></div>' +
      '<div class="arch-connector">↕ ZK Watches</div>' +
      '<div class="arch-row"><div class="arch-box zk">ZK Node 1</div><div class="arch-box zk">ZK Node 2</div><div class="arch-box zk">ZK Node 3</div></div>' +
      '<div class="arch-label">External ZooKeeper Ensemble — separate JVMs, separate monitoring</div>' +
      '</div>';
  }

  function renderKRaftArch() {
    return '<div class="arch-diagram">' +
      '<div class="arch-row"><div class="arch-box producer-box">Producers</div><div class="arch-box producer-box">Consumers</div></div>' +
      '<div class="arch-connector">↕</div>' +
      '<div class="arch-row"><div class="arch-box broker-box">Broker 0</div><div class="arch-box broker-box">Broker 1</div><div class="arch-box broker-box">Broker 2</div></div>' +
      '<div class="arch-connector">↕ Metadata Log (Raft)</div>' +
      '<div class="arch-row"><div class="arch-box ctrl">Controller 0 ⭐</div><div class="arch-box ctrl">Controller 1</div><div class="arch-box ctrl">Controller 2</div></div>' +
      '<div class="arch-label">Internal Controller Quorum — same Kafka process, unified ops</div>' +
      '</div>';
  }

  function renderCompare() {
    var viz = document.getElementById('compareViz');
    if (!viz) return;
    if (compareMode === 'zk') {
      viz.innerHTML = renderZKArch();
    } else if (compareMode === 'kraft') {
      viz.innerHTML = renderKRaftArch();
    } else {
      viz.innerHTML = '<div class="split-view">' +
        '<div class="split-col"><div class="split-title zk-title">ZooKeeper Mode</div>' + renderZKArch() + '</div>' +
        '<div class="split-col"><div class="split-title kraft-title">KRaft Mode</div>' + renderKRaftArch() + '</div>' +
        '</div>';
    }
  }

  document.querySelectorAll('.compare-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.compare-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      compareMode = btn.getAttribute('data-mode');
      renderCompare();
    });
  });

  // ========== MIGRATION ANIMATION ==========
  var migAnimating = false;

  var migAnimateBtn = document.getElementById('migAnimateBtn');
  if (migAnimateBtn) {
    migAnimateBtn.addEventListener('click', function() {
      if (migAnimating) return;
      migAnimating = true;
      var steps = document.querySelectorAll('.mig-step');
      var bar = document.getElementById('migProgressBar');
      var status = document.getElementById('migStatus');
      var messages = [
        'Upgrading all brokers to bridge release (3.3+)...',
        'Deploying controller quorum alongside ZK...',
        'Migrating metadata from ZooKeeper to KRaft log...',
        'Switching cluster to KRaft mode...',
        'Decommissioning ZooKeeper — migration complete! 🎉'
      ];

      steps.forEach(function(s) { s.classList.remove('active', 'done'); });
      var idx = 0;

      function nextStep() {
        if (idx > 0) steps[idx - 1].classList.remove('active');
        if (idx > 0) steps[idx - 1].classList.add('done');
        if (idx >= steps.length) {
          bar.style.width = '100%';
          status.textContent = '✅ Migration complete — cluster is fully KRaft-native!';
          migAnimating = false;
          return;
        }
        steps[idx].classList.add('active');
        bar.style.width = ((idx + 1) / steps.length * 100) + '%';
        status.textContent = messages[idx];
        idx++;
        setTimeout(nextStep, 1800);
      }
      nextStep();
    });
  }

  var migResetBtn = document.getElementById('migResetBtn');
  if (migResetBtn) {
    migResetBtn.addEventListener('click', function() {
      migAnimating = false;
      document.querySelectorAll('.mig-step').forEach(function(s) { s.classList.remove('active', 'done'); });
      document.getElementById('migProgressBar').style.width = '0%';
      document.getElementById('migStatus').textContent = 'Click "Animate Migration" to walk through the process';
    });
  }

  // ========== INIT ==========
  renderCluster();
  renderHeartbeats();
  renderCompare();
</script>
</BaseLayout>
