  :global(.elect-step) { padding: 8px 12px; margin-bottom: 8px; border-radius: 8px; font-size: 0.9rem; animation: fadeIn 0.4s ease-out; }
  :global(.elect-step.info) { background: rgba(96,165,250,0.1); color: #93c5fd; border-left: 3px solid #60a5fa; }
