  .metalog-header { display: flex; gap: 12px; padding: 8px 12px; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 8px; }
  .metalog-col { font-size: 0.8rem; font-weight: 700; color: #f59e0b; text-transform: uppercase; }
  .metalog-col:nth-child(1) { width: 60px; }
