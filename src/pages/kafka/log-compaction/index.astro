  .highlight-card { background: linear-gradient(135deg, rgba(52,211,153,0.08), rgba(96,165,250,0.08)); border-color: rgba(52,211,153,0.3); }

  .viz-footer { text-align: center; color: #666; font-size: 0.9rem; padding: 20px 0; border-top: 1px solid rgba(255,255,255,0.1); margin-bottom: 30px; }
  .viz-footer a { color: #34d399; }
  .share-buttons { display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; }
  .share-buttons span { color: #666; }
  .share-btn { padding: 10px 20px; background: rgba(255,255,255,0.1); border-radius: 8px; color: #fff; font-size: 0.9rem; transition: background 0.2s; }
  .share-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  @media (max-width: 768px) {
    .viz-header h1 { font-size: 1.8rem; }
    .explain-grid { grid-template-columns: 1fr; }
    .config-grid { grid-template-columns: 1fr; }
    .before-after-viz { flex-direction: column; }
    .ba-arrow { align-self: center; transform: rotate(90deg); }
    .compaction-viz-wrapper { flex-direction: column; }
    .usecase-viz-wrapper { flex-direction: column; }
  }
</style>

<script is:inline>
  // ========== CONSTANTS ==========
  var KEY_COLORS = {
    'key-A': { cls: 'key-a', color: '#60a5fa', label: 'key-A' },
    'key-B': { cls: 'key-b', color: '#34d399', label: 'key-B' },
    'key-C': { cls: 'key-c', color: '#ef4444', label: 'key-C' }
  };
  var KEYS = ['key-A', 'key-B', 'key-C'];

  // ========== RETENTION VS COMPACTION ==========
  var retMode = 'delete';
  var retSegments = [];
  var retTime = 0;

  function initRetention() {
    retTime = 0;
    retSegments = [
      { id: 0, keys: {'key-A': 'v1', 'key-B': 'v1'}, age: 5, status: 'retained' },
      { id: 1, keys: {'key-A': 'v2', 'key-C': 'v1'}, age: 3, status: 'retained' },
      { id: 2, keys: {'key-B': 'v2', 'key-C': 'v2'}, age: 1, status: 'retained' },
      { id: 3, keys: {'key-A': 'v3'}, age: 0, status: 'active' }
    ];
  }

  function renderRetention() {
    var timeline = document.getElementById('retentionTimeline');
    timeline.innerHTML = '';
    retSegments.forEach(function(seg) {
      var el = document.createElement('div');
      el.className = 'ret-segment ' + seg.status;
      var keyStr = Object.keys(seg.keys).map(function(k) { return k + '=' + seg.keys[k]; }).join(', ');
      el.innerHTML = 'Seg ' + seg.id + '<br><span style="font-size:0.65rem;opacity:0.7">age:' + seg.age + ' | ' + keyStr + '</span>';
      timeline.appendChild(el);
    });
  }

  function advanceRetention() {
    retTime++;
    retSegments.forEach(function(seg) {
      if (seg.status !== 'expired') seg.age++;
    });

    // Make active segment close and create new one
    var activeSeg = retSegments.find(function(s) { return s.status === 'active'; });
    if (activeSeg) {
      activeSeg.status = 'retained';
      var newKeys = {};
      var rk = KEYS[Math.floor(Math.random() * KEYS.length)];
      newKeys[rk] = 'v' + (retTime + 3);
      retSegments.push({ id: retSegments.length, keys: newKeys, age: 0, status: 'active' });
    }

    if (retMode === 'delete') {
      // Delete segments older than 6
      retSegments.forEach(function(seg) {
        if (seg.age > 6 && seg.status === 'retained') seg.status = 'expired';
      });
    } else if (retMode === 'compact') {
      // Compact: keep only latest per key in non-active segments
      var latestKeys = {};
      for (var i = retSegments.length - 1; i >= 0; i--) {
        var seg = retSegments[i];
        if (seg.status === 'expired') continue;
        var newK = {};
        Object.keys(seg.keys).forEach(function(k) {
          if (!latestKeys[k]) {
            latestKeys[k] = true;
            newK[k] = seg.keys[k];
          }
        });
        if (Object.keys(newK).length === 0 && seg.status !== 'active') {
          seg.status = 'expired';
        } else {
          seg.keys = Object.keys(newK).length > 0 ? newK : seg.keys;
          if (seg.status !== 'active') seg.status = 'compacted';
        }
      }
    } else {
      // compact,delete: compact + delete very old
      var latestKeys2 = {};
      for (var j = retSegments.length - 1; j >= 0; j--) {
        var seg2 = retSegments[j];
        if (seg2.status === 'expired') continue;
        if (seg2.age > 8) { seg2.status = 'expired'; continue; }
        var newK2 = {};
        Object.keys(seg2.keys).forEach(function(k) {
          if (!latestKeys2[k]) {
            latestKeys2[k] = true;
            newK2[k] = seg2.keys[k];
          }
        });
        if (Object.keys(newK2).length === 0 && seg2.status !== 'active') {
          seg2.status = 'expired';
        } else {
          seg2.keys = Object.keys(newK2).length > 0 ? newK2 : seg2.keys;
          if (seg2.status !== 'active') seg2.status = 'compacted';
        }
      }
    }

    renderRetention();
  }

  var modeDescs = {
    'delete': '<strong>Delete mode:</strong> Old segments are removed when they exceed retention.ms or retention.bytes. Data is lost after expiry — no way to recover old keys.',
    'compact': '<strong>Compact mode:</strong> The Log Cleaner keeps only the latest value per key. Old duplicates are removed, but every key\'s latest value is preserved forever.',
    'compact-delete': '<strong>Compact + Delete:</strong> Compaction removes duplicate keys, AND very old segments are deleted by time. Useful when you want latest-per-key but don\'t need infinite history.'
  };

  document.querySelectorAll('.mode-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.mode-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      retMode = btn.getAttribute('data-mode');
      document.getElementById('retentionInfo').innerHTML = modeDescs[retMode];
      initRetention();
      renderRetention();
    });
  });

  document.getElementById('retentionAdvanceBtn').addEventListener('click', advanceRetention);
  document.getElementById('retentionResetBtn').addEventListener('click', function() {
    initRetention();
    renderRetention();
  });

  // ========== HOW COMPACTION WORKS ==========
  var compactionEntries = [
    { offset: 0, key: 'key-A', value: 'v1' },
    { offset: 1, key: 'key-B', value: 'v1' },
    { offset: 2, key: 'key-A', value: 'v2' },
    { offset: 3, key: 'key-C', value: 'v1' },
    { offset: 4, key: 'key-B', value: 'v2' },
    { offset: 5, key: 'key-A', value: 'v3' },
    { offset: 6, key: 'key-C', value: 'v2' },
    { offset: 7, key: 'key-B', value: 'v3' }
  ];
  var compStepIdx = 0;
  var compSteps = [];

  function getKeyCls(key) {
    if (key === 'key-A') return 'key-a';
    if (key === 'key-B') return 'key-b';
    if (key === 'key-C') return 'key-c';
    return '';
  }

  function renderCompactionLog(entries, removedOffsets, keptOffsets) {
    var container = document.getElementById('compactionLog');
    container.innerHTML = '';
    entries.forEach(function(e) {
      var el = document.createElement('div');
      var cls = 'log-entry ' + getKeyCls(e.key);
      if (removedOffsets && removedOffsets.indexOf(e.offset) !== -1) cls += ' removing';
      if (keptOffsets && keptOffsets.indexOf(e.offset) !== -1) cls += ' kept';
      el.className = cls;
      el.innerHTML = '<span class="offset-num">' + e.offset + '</span>' +
        '<span class="entry-key">' + e.key + '</span>' +
        '<span class="entry-val">= ' + e.value + '</span>';
      container.appendChild(el);
    });
  }

  function buildCompSteps() {
    compSteps = [
      {
        label: 'Dirty Log (before compaction)',
        badge: 'Scanning', badgeCls: 'scanning',
        text: 'Log Cleaner thread starts scanning dirty segments...',
        removed: [], kept: [], showMap: false
      },
      {
        label: 'Building Offset Map',
        badge: 'Scanning', badgeCls: 'scanning',
        text: 'Scanning entries to build offset map: key → latest offset',
        removed: [], kept: [], showMap: true,
        map: { 'key-A': 5, 'key-B': 7, 'key-C': 6 }
      },
      {
        label: 'Marking duplicates for removal',
        badge: 'Compacting', badgeCls: 'compacting',
        text: 'Entries with older offsets for the same key are marked for removal',
        removed: [0, 1, 2, 3, 4], kept: [5, 6, 7], showMap: true,
        map: { 'key-A': 5, 'key-B': 7, 'key-C': 6 }
      },
      {
        label: 'Rewriting compacted segment',
        badge: 'Compacting', badgeCls: 'compacting',
        text: 'Cleaner rewrites segment keeping only latest value per key',
        removed: [0, 1, 2, 3, 4], kept: [5, 6, 7], showMap: true,
        map: { 'key-A': 5, 'key-B': 7, 'key-C': 6 },
        compact: true
      },
      {
        label: 'Compaction complete!',
        badge: 'Done', badgeCls: 'done',
        text: 'Log reduced from 8 entries to 3. Every key\'s latest value preserved.',
        removed: [], kept: [5, 6, 7], showMap: false,
        compact: true
      }
    ];
  }

  function renderCompStep() {
    var step = compSteps[compStepIdx];
    document.getElementById('stageLabel').textContent = step.label;

    var badge = document.querySelector('.compaction-status .status-badge');
    badge.className = 'status-badge ' + step.badgeCls;
    badge.textContent = step.badge;
    document.getElementById('compactionStatusText').textContent = step.text;

    var entries = step.compact ? compactionEntries.filter(function(e) {
      return step.kept.indexOf(e.offset) !== -1;
    }) : compactionEntries;

    renderCompactionLog(entries, step.removed, step.kept);

    var mapPanel = document.getElementById('offsetMapPanel');
    if (step.showMap) {
      mapPanel.style.display = 'block';
      var mc = document.getElementById('offsetMapContent');
      mc.innerHTML = '';
      Object.keys(step.map).forEach(function(k) {
        var el = document.createElement('div');
        el.className = 'omap-entry' + (step.kept.indexOf(step.map[k]) !== -1 ? ' highlight' : '');
        el.textContent = k + ' → offset ' + step.map[k];
        mc.appendChild(el);
      });
    } else {
      mapPanel.style.display = 'none';
    }
  }

  document.getElementById('startCompactionBtn').addEventListener('click', function() {
    buildCompSteps();
    compStepIdx = 0;
    renderCompStep();
    document.getElementById('stepCompactionBtn').disabled = false;
  });

  document.getElementById('stepCompactionBtn').addEventListener('click', function() {
    if (compStepIdx < compSteps.length - 1) {
      compStepIdx++;
      renderCompStep();
      if (compStepIdx >= compSteps.length - 1) {
        document.getElementById('stepCompactionBtn').disabled = true;
      }
    }
  });

  document.getElementById('resetCompactionBtn').addEventListener('click', function() {
    compStepIdx = 0;
    document.getElementById('stageLabel').textContent = 'Dirty Log (before compaction)';
    var badge = document.querySelector('.compaction-status .status-badge');
    badge.className = 'status-badge idle';
    badge.textContent = 'Ready';
    document.getElementById('compactionStatusText').textContent = 'Click "Start Compaction" to begin';
    document.getElementById('offsetMapPanel').style.display = 'none';
    document.getElementById('stepCompactionBtn').disabled = true;
    renderCompactionLog(compactionEntries, [], []);
  });

  // ========== COMPACTION VISUALIZER ==========
  var vizEntries = [];
  var vizOffset = 0;
  var vizCompacted = [];

  function randomKey() {
    return KEYS[Math.floor(Math.random() * KEYS.length)];
  }

  function renderVizLog(entries, container) {
    var el = document.getElementById(container);
    el.innerHTML = '';
    entries.forEach(function(e) {
      var div = document.createElement('div');
      div.className = 'log-entry ' + getKeyCls(e.key);
      div.innerHTML = '<span class="offset-num">' + e.offset + '</span>' +
        '<span class="entry-key">' + e.key + '</span>' +
        '<span class="entry-val">= ' + e.value + '</span>';
      el.appendChild(div);
    });
  }

  function updateVizSizes() {
    document.getElementById('beforeSize').textContent = vizEntries.length + ' entries';
    document.getElementById('afterSize').textContent = vizCompacted.length + ' entries';
  }

  document.getElementById('produceBtn').addEventListener('click', function() {
    var key = randomKey();
    var valNum = vizEntries.filter(function(e) { return e.key === key; }).length + 1;
    vizEntries.push({ offset: vizOffset++, key: key, value: 'v' + valNum });
    renderVizLog(vizEntries, 'beforeLog');
    updateVizSizes();
  });

  document.getElementById('produceBatchBtn').addEventListener('click', function() {
    for (var i = 0; i < 5; i++) {
      var key = randomKey();
      var valNum = vizEntries.filter(function(e) { return e.key === key; }).length + 1;
      vizEntries.push({ offset: vizOffset++, key: key, value: 'v' + valNum });
    }
    renderVizLog(vizEntries, 'beforeLog');
    updateVizSizes();
  });

  document.getElementById('runCompactionBtn').addEventListener('click', function() {
    // Keep only latest per key
    var latest = {};
    vizEntries.forEach(function(e) {
      latest[e.key] = e;
    });
    vizCompacted = Object.keys(latest).map(function(k) { return latest[k]; });
    vizCompacted.sort(function(a, b) { return a.offset - b.offset; });
    renderVizLog(vizCompacted, 'afterLog');
    updateVizSizes();
  });

  document.getElementById('resetVisualizerBtn').addEventListener('click', function() {
    vizEntries = [];
    vizCompacted = [];
    vizOffset = 0;
    document.getElementById('beforeLog').innerHTML = '';
    document.getElementById('afterLog').innerHTML = '';
    updateVizSizes();
  });

  // ========== TOMBSTONES ==========
  var tsEntries = [];
  var tsOffset = 0;
  var tsTimers = [];

  function renderTombstones() {
    var viz = document.getElementById('tombstoneViz');
    viz.innerHTML = '';
    tsEntries.forEach(function(e) {
      var div = document.createElement('div');
      div.className = 'ts-entry ' + e.status;
      div.setAttribute('data-offset', e.offset);
      var val = e.value === null ? '🪦 null (tombstone)' : e.value;
      var ttl = '';
      if (e.status === 'tombstone' && e.ttl !== undefined) {
        ttl = '<span class="ts-ttl">TTL: ' + (e.ttl / 1000).toFixed(1) + 's</span>';
      }
      div.innerHTML = 'offset ' + e.offset + ' | ' + e.key + ' = ' + val + ttl;
      viz.appendChild(div);
    });
  }

  function addTsLog(text, cls) {
    var log = document.getElementById('tombstoneLog');
    var el = document.createElement('div');
    el.className = 'ts-log-entry ' + cls;
    el.textContent = text;
    log.appendChild(el);
    log.scrollTop = log.scrollHeight;
  }

  document.getElementById('deleteRetentionSlider').addEventListener('input', function(e) {
    document.getElementById('deleteRetentionLabel').textContent = e.target.value;
  });

  document.getElementById('produceNormalBtn').addEventListener('click', function() {
    tsEntries.push({ offset: tsOffset++, key: 'key-A', value: '"v' + tsOffset + '"', status: 'normal' });
    renderTombstones();
    addTsLog('Produced key-A = "v' + tsOffset + '" at offset ' + (tsOffset - 1), 'info');
  });

  document.getElementById('produceTombstoneBtn').addEventListener('click', function() {
    var deleteRetention = parseInt(document.getElementById('deleteRetentionSlider').value);
    var entry = { offset: tsOffset++, key: 'key-A', value: null, status: 'tombstone', ttl: deleteRetention };
    tsEntries.push(entry);
    renderTombstones();
    addTsLog('🪦 Produced tombstone for key-A at offset ' + (tsOffset - 1) + '. TTL: ' + (deleteRetention / 1000) + 's', 'warn');

    // Start countdown
    var entryOffset = entry.offset;
    var remaining = deleteRetention;
    var interval = setInterval(function() {
      remaining -= 500;
      var found = tsEntries.find(function(e) { return e.offset === entryOffset; });
      if (found) {
        found.ttl = Math.max(0, remaining);
        if (remaining <= 0) {
          found.status = 'expired';
          clearInterval(interval);
          addTsLog('💀 Tombstone at offset ' + entryOffset + ' expired — key-A fully removed!', 'error');
          setTimeout(function() { renderTombstones(); }, 100);
        }
        renderTombstones();
      } else {
        clearInterval(interval);
      }
    }, 500);
    tsTimers.push(interval);
  });

  document.getElementById('resetTombstoneBtn').addEventListener('click', function() {
    tsTimers.forEach(function(t) { clearInterval(t); });
    tsTimers = [];
    tsEntries = [];
    tsOffset = 0;
    document.getElementById('tombstoneViz').innerHTML = '';
    document.getElementById('tombstoneLog').innerHTML = '';
  });

  // ========== CONFIGURATION ==========
  document.getElementById('dirtyRatioSlider').addEventListener('input', function(e) {
    var val = parseInt(e.target.value) / 100;
    document.getElementById('dirtyRatioValue').textContent = val.toFixed(2);
    var cleanPct = (1 - val) * 100;
    var dirtyPct = val * 100;
    document.getElementById('meterClean').style.width = cleanPct + '%';
    document.getElementById('meterDirty').style.width = dirtyPct + '%';
    if (dirtyPct >= parseInt(e.target.value)) {
      document.getElementById('dirtyRatioStatus').textContent = 'Ratio ' + val.toFixed(2) + ' = threshold → compaction triggers ✅';
    } else {
      document.getElementById('dirtyRatioStatus').textContent = 'Dirty ratio below threshold → compaction skipped';
    }
    updateConfigTimeline();
  });

  document.getElementById('minLagSlider').addEventListener('input', function(e) {
    var val = parseInt(e.target.value);
    if (val === 0) {
      document.getElementById('minLagValue').textContent = '0';
    } else if (val < 3600000) {
      document.getElementById('minLagValue').textContent = (val / 60000).toFixed(0) + ' min';
    } else {
      document.getElementById('minLagValue').textContent = (val / 3600000).toFixed(0) + ' hr';
    }
    updateConfigTimeline();
  });

  document.getElementById('maxLagSlider').addEventListener('input', function(e) {
    var val = parseInt(e.target.value);
    if (val >= 604800000) {
      document.getElementById('maxLagValue').textContent = '∞';
    } else if (val < 86400000) {
      document.getElementById('maxLagValue').textContent = (val / 3600000).toFixed(0) + ' hr';
    } else {
      document.getElementById('maxLagValue').textContent = (val / 86400000).toFixed(1) + ' days';
    }
    updateConfigTimeline();
  });

  var segmentLabels = ['256MB / 1d', '512MB / 3d', '1GB / 7d', '2GB / 14d', '4GB / 30d'];
  document.getElementById('segmentSlider').addEventListener('input', function(e) {
    document.getElementById('segmentValue').textContent = segmentLabels[parseInt(e.target.value) - 1];
    updateConfigTimeline();
  });

  function updateConfigTimeline() {
    var bar = document.getElementById('configTimelineBar');
    bar.innerHTML = '';
    var minLag = parseInt(document.getElementById('minLagSlider').value);
    var maxLag = parseInt(document.getElementById('maxLagSlider').value);
    var totalBlocks = 24; // 24 hours

    for (var i = 0; i < totalBlocks; i++) {
      var block = document.createElement('div');
      block.className = 'ct-block';
      var hourMs = i * 3600000;

      if (i === totalBlocks - 1) {
        block.className += ' active-seg';
        block.textContent = 'Active';
      } else if (hourMs < minLag) {
        block.className += ' safe';
        block.textContent = i + 'h';
      } else if (maxLag < 604800000 && hourMs >= maxLag) {
        block.className += ' forced';
        block.textContent = i + 'h';
      } else {
        block.className += ' eligible';
        block.textContent = i + 'h';
      }
      bar.appendChild(block);
    }
  }

  // ========== USE CASES ==========
  var ucMode = 'cdc';
  var ucStream = [];
  var ucOffset = 0;
  var ucState = {};

  var ucData = {
    cdc: {
      desc: '<strong>CDC (Change Data Capture):</strong> Tools like Debezium capture database changes as Kafka messages keyed by primary key. Compaction ensures the topic always contains the latest row state — a full database snapshot consumers can replay from offset 0.',
      keys: ['user:101', 'user:102', 'user:103', 'order:501', 'order:502'],
      values: function(key) {
        var names = { 'user:101': 'Alice', 'user:102': 'Bob', 'user:103': 'Charlie', 'order:501': '$99.00', 'order:502': '$45.50' };
        var updates = ['email updated', 'status: active', 'addr changed', 'shipped', 'refunded'];
        return names[key] + ' — ' + updates[Math.floor(Math.random() * updates.length)];
      }
    },
    ktable: {
      desc: '<strong>KTable Materialization:</strong> Kafka Streams rebuilds KTables by reading the changelog topic from offset 0. Compaction keeps the topic small — only latest value per key — so rebuilds are fast. Without compaction, restoring a KTable would mean replaying the entire history.',
      keys: ['balance:alice', 'balance:bob', 'balance:carol', 'count:logins', 'count:orders'],
      values: function(key) {
        if (key.indexOf('balance') === 0) return '$' + (Math.floor(Math.random() * 10000) / 100).toFixed(2);
        return String(Math.floor(Math.random() * 1000));
      }
    },
    snapshot: {
      desc: '<strong>State Store Snapshots:</strong> Application state (configs, feature flags, session data) can be stored in a compacted topic. On restart, read the entire topic to restore state. Each key is a config/session entry — compaction ensures the snapshot stays minimal.',
      keys: ['config:theme', 'config:lang', 'config:tz', 'flag:dark-mode', 'flag:beta'],
      values: function(key) {
        var vals = {
          'config:theme': ['light', 'dark', 'auto'],
          'config:lang': ['en', 'fr', 'de', 'ja'],
          'config:tz': ['UTC', 'PST', 'EST', 'CET'],
          'flag:dark-mode': ['true', 'false'],
          'flag:beta': ['enabled', 'disabled']
        };
        var options = vals[key];
        return options[Math.floor(Math.random() * options.length)];
      }
    }
  };

  function renderUcStream() {
    var container = document.getElementById('usecaseStream');
    container.innerHTML = '';
    ucStream.forEach(function(e) {
      var div = document.createElement('div');
      div.className = 'log-entry ' + getKeyCls(e.key);
      // Use generic coloring for non key-A/B/C keys
      if (!getKeyCls(e.key)) {
        div.style.background = 'rgba(167,139,250,0.15)';
        div.style.borderLeft = '3px solid #a78bfa';
        div.style.color = '#c4b5fd';
      }
      div.innerHTML = '<span class="offset-num">' + e.offset + '</span>' +
        '<span class="entry-key">' + e.key + '</span>' +
        '<span class="entry-val">= ' + e.value + '</span>';
      container.appendChild(div);
    });
    container.scrollTop = container.scrollHeight;
  }

  function renderUcState() {
    var table = document.getElementById('stateTable');
    table.innerHTML = '';
    Object.keys(ucState).forEach(function(k) {
      var row = document.createElement('div');
      row.className = 'state-row' + (ucState[k].updated ? ' updated' : '');
      row.innerHTML = '<span class="state-key">' + k + '</span><span>' + ucState[k].value + '</span>';
      table.appendChild(row);
    });
    // Clear updated flag after render
    setTimeout(function() {
      Object.keys(ucState).forEach(function(k) { ucState[k].updated = false; });
    }, 600);
  }

  document.querySelectorAll('.usecase-tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.usecase-tab').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      ucMode = btn.getAttribute('data-uc');
      ucStream = [];
      ucOffset = 0;
      ucState = {};
      document.getElementById('usecaseDesc').innerHTML = ucData[ucMode].desc;
      renderUcStream();
      renderUcState();
    });
  });

  document.getElementById('ucProduceBtn').addEventListener('click', function() {
    var data = ucData[ucMode];
    var key = data.keys[Math.floor(Math.random() * data.keys.length)];
    var value = data.values(key);
    ucStream.push({ offset: ucOffset++, key: key, value: value });
    ucState[key] = { value: value, updated: true };
    renderUcStream();
    renderUcState();
  });

  document.getElementById('ucCompactBtn').addEventListener('click', function() {
    // Keep only latest per key
    var latest = {};
    ucStream.forEach(function(e) { latest[e.key] = e; });
    ucStream = Object.keys(latest).map(function(k) { return latest[k]; });
    ucStream.sort(function(a, b) { return a.offset - b.offset; });
    renderUcStream();
  });

  document.getElementById('ucResetBtn').addEventListener('click', function() {
    ucStream = [];
    ucOffset = 0;
    ucState = {};
    renderUcStream();
    renderUcState();
  });

  // ========== INIT ==========
  initRetention();
  renderRetention();
  renderCompactionLog(compactionEntries, [], []);
  updateVizSizes();
  updateConfigTimeline();
</script>
</BaseLayout>
