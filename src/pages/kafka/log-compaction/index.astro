  .usecase-tab.active { border-color: #34d399; background: rgba(52,211,153,0.15); color: #34d399; font-weight: 600; }

  .usecase-viz-wrapper { display: flex; gap: 20px; margin-bottom: 16px; flex-wrap: wrap; }
  .usecase-stream { flex: 1; background: rgba(0,0,0,0.2); border-radius: 14px; padding: 20px; border: 1px solid rgba(255,255,255,0.1); min-width: 280px; min-height: 80px; display: flex; flex-direction: column; gap: 4px; max-height: 300px; overflow-y: auto; }
  .usecase-state { flex: 1; background: rgba(0,0,0,0.2); border-radius: 14px; padding: 20px; border: 1px solid rgba(255,255,255,0.1); min-width: 280px; }
  .state-label { font-size: 0.85rem; font-weight: 700; color: #fff; margin-bottom: 12px; }

  :global(.state-row) { display: flex; justify-content: space-between; padding: 8px 12px; border-radius: 6px; margin-bottom: 4px; font-size: 0.8rem; font-family: 'Monaco','Menlo',monospace; background: rgba(255,255,255,0.03); color: #aaa; transition: all 0.3s; }
  :global(.state-row.updated) { background: rgba(52,211,153,0.15); color: #6ee7b7; }
  :global(.state-row .state-key) { font-weight: 700; }

  .usecase-controls { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 16px; }
  .usecase-desc { padding: 14px 18px; background: rgba(52,211,153,0.06); border: 1px solid rgba(52,211,153,0.2); border-radius: 10px; font-size: 0.9rem; color: #aaa; line-height: 1.6; }
  .usecase-desc strong { color: #34d399; }

  /* Explain Section */
  .explain-section { margin-bottom: 50px; }
  .explain-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
