---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "gRPC Internals", description: "HTTP/2 multiplexing, Protobuf encoding, streaming types, and connection management", href: "/grpc/internals/", status: "live" },
  { title: "Load Balancing", description: "Client-side vs proxy-based: pick_first, round_robin, xDS, and gRPC-LB", href: "#", status: "coming" },
  { title: "Interceptors & Middleware", description: "Unary and stream interceptor chains, logging, auth, and retry patterns", href: "#", status: "coming" },
  { title: "Deadlines & Cancellation", description: "Deadline propagation across services, context cancellation, and timeout budgets", href: "#", status: "coming" },
  { title: "Service Mesh Integration", description: "gRPC with Envoy, Istio, and Linkerd — mTLS, retries, circuit breaking", href: "#", status: "coming" },
  { title: "Health Checking", description: "gRPC health checking protocol, readiness vs liveness, and watch mode", href: "#", status: "coming" },
  { title: "Reflection & gRPCurl", description: "Server reflection, dynamic clients, and debugging with grpcurl", href: "#", status: "coming" },
  { title: "Performance Tuning", description: "Keep-alive, flow control, max message size, compression, and connection pooling", href: "#", status: "coming" },
];
---

<BaseLayout 
  title="gRPC Internals" 
  description="Interactive visualizations for understanding gRPC architecture, HTTP/2 transport, Protobuf encoding, and streaming patterns"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "gRPC", href: "/grpc/" }]}
>
  <section class="section-header">
    <h1>⚡ gRPC Internals</h1>
    <p>
      gRPC is a high-performance RPC framework built on HTTP/2 and Protocol Buffers.
      These interactive visualizations help you understand how gRPC works under the hood —
      from binary encoding to bidirectional streaming.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(0, 212, 255, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
