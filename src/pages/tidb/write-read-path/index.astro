---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Write Path & Read Path: End-to-End" 
  description="Interactive visualization of TiDB's end-to-end write and read paths — from SQL parsing to RocksDB storage engine"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "TiDB", href: "/tidb/" },
    { label: "Write & Read Path", href: "/tidb/write-read-path/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🛤️ Write Path & Read Path</h1>
      <p class="subtitle">End-to-End: From SQL to RocksDB and Back</p>
    </header>

    <!-- Overview -->
    <section class="overview-section">
      <div class="overview-card">
        <p>
          Every SQL statement in TiDB travels through multiple layers: the <strong>SQL layer</strong> 
          parses and plans, the <strong>transaction layer</strong> manages MVCC and timestamps, 
          <strong>2PC</strong> coordinates distributed commits, <strong>Raft</strong> replicates for 
          durability, and <strong>RocksDB</strong> persists data on disk. Understanding this full 
          path — for both <em>writes</em> and <em>reads</em> — is key to diagnosing latency and 
          tuning performance.
        </p>
      </div>
    </section>

    <!-- View Mode Toggle -->
    <section class="view-toggle-section">
      <div class="view-toggle">
        <button id="simpleViewBtn" class="toggle-btn active">📋 Simple View</button>
        <button id="detailedViewBtn" class="toggle-btn">🔬 Detailed View</button>
      </div>
    </section>

    <!-- ==================== WRITE PATH ==================== -->
    <section class="flow-section">
      <h2>✏️ Write Path</h2>
      <p class="section-desc">Trace an INSERT/UPDATE from SQL text to durable storage</p>

      <div class="flow-controls">
        <button id="startWriteBtn" class="action-btn primary-btn">▶ Start Write</button>
        <button id="stepWriteBtn" class="action-btn step-btn" disabled>⏭ Next Step</button>
        <button id="autoWriteBtn" class="action-btn auto-btn" disabled>⚡ Auto-Play</button>
        <button id="resetWriteBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="flow-status" id="writeFlowStatus">
        <span class="status-badge idle">Ready</span>
        <span class="status-text" id="writeStatusText">Click "Start Write" to begin</span>
      </div>

      <div class="pipeline-container" id="writePipeline">
        <div class="pipeline-stages">
          <div class="stage" id="ws-sql">
            <div class="stage-icon">📝</div>
            <div class="stage-label">SQL Layer</div>
          </div>
          <div class="stage-arrow">→</div>
          <div class="stage" id="ws-txn">
            <div class="stage-icon">🔄</div>
            <div class="stage-label">Transaction</div>
          </div>
          <div class="stage-arrow">→</div>
          <div class="stage" id="ws-2pc">
            <div class="stage-icon">🤝</div>
            <div class="stage-label">2PC</div>
          </div>
          <div class="stage-arrow">→</div>
          <div class="stage" id="ws-raft">
            <div class="stage-icon">📡</div>
            <div class="stage-label">Raft</div>
          </div>
          <div class="stage-arrow">→</div>
          <div class="stage" id="ws-engine">
            <div class="stage-icon">💾</div>
            <div class="stage-label">RocksDB</div>
          </div>
        </div>

        <div class="step-detail-box" id="writeDetailBox">
          <div class="detail-placeholder">Follow the write as it flows through each layer</div>
        </div>
      </div>
    </section>

    <!-- ==================== READ PATH ==================== -->
    <section class="flow-section">
      <h2>🔍 Read Path</h2>
      <p class="section-desc">Trace a SELECT from SQL text to data retrieval</p>

      <div class="flow-controls">
        <button id="startReadBtn" class="action-btn primary-btn">▶ Start Read</button>
        <button id="stepReadBtn" class="action-btn step-btn" disabled>⏭ Next Step</button>
        <button id="autoReadBtn" class="action-btn auto-btn" disabled>⚡ Auto-Play</button>
        <button id="resetReadBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="flow-status" id="readFlowStatus">
        <span class="status-badge idle">Ready</span>
        <span class="status-text" id="readStatusText">Click "Start Read" to begin</span>
      </div>

      <div class="pipeline-container" id="readPipeline">
        <div class="pipeline-stages">
          <div class="stage" id="rs-sql">
            <div class="stage-icon">📝</div>
            <div class="stage-label">SQL Layer</div>
          </div>
          <div class="stage-arrow">→</div>
          <div class="stage" id="rs-cop">
            <div class="stage-icon">⬇️</div>
            <div class="stage-label">Coprocessor</div>
          </div>
          <div class="stage-arrow">→</div>
          <div class="stage" id="rs-tikv">
            <div class="stage-icon">📦</div>
            <div class="stage-label">TiKV Read</div>
          </div>
          <div class="stage-arrow">→</div>
          <div class="stage" id="rs-mvcc">
            <div class="stage-icon">⏳</div>
            <div class="stage-label">MVCC</div>
          </div>
          <div class="stage-arrow">→</div>
          <div class="stage" id="rs-engine">
            <div class="stage-icon">💾</div>
            <div class="stage-label">RocksDB</div>
          </div>
        </div>

        <div class="step-detail-box" id="readDetailBox">
          <div class="detail-placeholder">Follow the read as it flows through each layer</div>
        </div>
      </div>
    </section>

    <!-- ==================== LATENCY BREAKDOWN ==================== -->
    <section class="latency-section">
      <h2>📊 Latency Breakdown</h2>
      <p class="section-desc">Adjust parameters to see how they affect end-to-end latency</p>

      <div class="latency-controls">
        <div class="latency-slider">
          <label>Network RTT: <strong id="rttValue">1</strong> ms</label>
          <input type="range" id="rttSlider" min="0" max="50" value="1" step="0.5">
        </div>
        <div class="latency-slider">
          <label>Disk Latency: <strong id="diskValue">0.1</strong> ms</label>
          <input type="range" id="diskSlider" min="0.05" max="5" value="0.1" step="0.05">
        </div>
        <div class="latency-slider">
          <label>Raft Replication: <strong id="raftValue">1</strong> ms</label>
          <input type="range" id="raftSlider" min="0" max="20" value="1" step="0.5">
        </div>
      </div>

      <div class="latency-path-tabs">
        <button id="latWriteTab" class="tab-btn active">✏️ Write Latency</button>
        <button id="latReadTab" class="tab-btn">🔍 Read Latency</button>
      </div>

      <div class="latency-bars" id="latencyBars"></div>

      <div class="latency-total">
        Total: <span id="latencyTotal">0</span> ms
      </div>
    </section>

    <!-- ==================== POINT LOOKUP vs RANGE SCAN ==================== -->
    <section class="comparison-section">
      <h2>🎯 Point Lookup vs Range Scan</h2>
      <p class="section-desc">How the read path differs for different query patterns</p>

      <div class="comparison-grid">
        <div class="comparison-card point-card">
          <div class="comparison-header">
            <h3>🎯 Point Lookup</h3>
            <code>SELECT * FROM t WHERE id = 42</code>
          </div>
          <div class="comparison-body">
            <div class="comp-step">
              <span class="comp-num">1</span>
              <div class="comp-text">
                <strong>Encode key</strong>
                <span class="detail-text">tablecodec → single key <code>t/42</code></span>
              </div>
            </div>
            <div class="comp-step">
              <span class="comp-num">2</span>
              <div class="comp-text">
                <strong>Locate region</strong>
                <span class="detail-text">PD cache → one region, one RPC</span>
              </div>
            </div>
            <div class="comp-step">
              <span class="comp-num">3</span>
              <div class="comp-text">
                <strong>Bloom filter</strong>
                <span class="detail-text">Check if key exists → skip SST if absent</span>
              </div>
            </div>
            <div class="comp-step">
              <span class="comp-num">4</span>
              <div class="comp-text">
                <strong>MemTable → Cache → SST</strong>
                <span class="detail-text">Single <code>Get()</code> call</span>
              </div>
            </div>
          </div>
          <div class="comparison-perf">
            <div class="perf-label">Typical</div>
            <div class="perf-bar point-bar" style="width: 25%"></div>
            <div class="perf-value">~1-2 ms</div>
          </div>
        </div>

        <div class="comparison-card range-card">
          <div class="comparison-header">
            <h3>📑 Range Scan</h3>
            <code>SELECT * FROM t WHERE id BETWEEN 1 AND 1000</code>
          </div>
          <div class="comparison-body">
            <div class="comp-step">
              <span class="comp-num">1</span>
              <div class="comp-text">
                <strong>Encode range</strong>
                <span class="detail-text">tablecodec → [<code>t/1</code>, <code>t/1000</code>]</span>
              </div>
            </div>
            <div class="comp-step">
              <span class="comp-num">2</span>
              <div class="comp-text">
                <strong>Scatter to regions</strong>
                <span class="detail-text">May span multiple regions → parallel RPCs</span>
              </div>
            </div>
            <div class="comp-step">
              <span class="comp-num">3</span>
              <div class="comp-text">
                <strong>No bloom filter</strong>
                <span class="detail-text">Bloom filters only help point lookups</span>
              </div>
            </div>
            <div class="comp-step">
              <span class="comp-num">4</span>
              <div class="comp-text">
                <strong>Iterator merge</strong>
                <span class="detail-text">Merge MemTable + L0..Lmax iterators</span>
              </div>
            </div>
          </div>
          <div class="comparison-perf">
            <div class="perf-label">Typical</div>
            <div class="perf-bar range-bar" style="width: 80%"></div>
            <div class="perf-value">~5-50 ms+</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Explanation Cards -->
    <section class="explain-section">
      <div class="explain-grid">
        <div class="explain-card">
          <h3>📦 TableCodec: SQL → KV</h3>
          <p>
            TiDB encodes every row as a key-value pair. The key format is 
            <code>t&#123;tableID&#125;_r&#123;rowID&#125;</code> for row data and 
            <code>t&#123;tableID&#125;_i&#123;indexID&#125;_&#123;indexValues&#125;</code> for indexes. 
            This encoding means <strong>range scans map directly to sorted key ranges</strong> 
            in TiKV — no secondary lookups needed.
          </p>
        </div>
        <div class="explain-card">
          <h3>⚡ Coprocessor Push-down</h3>
          <p>
            Instead of pulling all rows to TiDB and filtering there, predicates like 
            <code>WHERE age > 30</code> and aggregations like <code>COUNT(*)</code> are 
            <strong>pushed down to TiKV</strong>. Each region processes its chunk locally, 
            sending only matching/aggregated results back. Huge bandwidth savings.
          </p>
        </div>
      </div>
    </section>

    <section class="explain-section">
      <div class="explain-card highlight-card">
        <h3>💡 LSM-Tree: Why Writes Are Fast, Reads Are Complex</h3>
        <p>
          RocksDB uses an <strong>LSM-Tree</strong> (Log-Structured Merge Tree). Writes go to the 
          WAL (sequential I/O — fast!) then to the MemTable (in-memory). Reads must check the 
          MemTable, then the block cache, then search through multiple SST file levels. 
          <em>Compaction</em> merges levels to keep read amplification bounded. This is the 
          fundamental write-optimized vs read-cost tradeoff in TiKV.
        </p>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://docs.pingcap.com/tidb/stable/tidb-architecture" target="_blank">TiDB Architecture Documentation</a> and <a href="https://github.com/facebook/rocksdb/wiki" target="_blank">RocksDB Wiki</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share this visualization:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20visualization%20of%20TiDB%20Write%20%26%20Read%20Paths&url=https://systeminternals.dev/tidb/write-read-path/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/tidb/write-read-path/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/tidb/write-read-path/&t=Interactive%20TiDB%20Write%20%26%20Read%20Path%20Visualizer" target="_blank" class="share-btn">🟧 Hacker News</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .viz-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #f472b6, #a78bfa, #60a5fa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #888;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 12px;
  }

  .section-desc {
    color: #888;
    margin-bottom: 24px;
    font-size: 1rem;
  }

  /* Overview */
  .overview-section {
    margin-bottom: 50px;
  }

  .overview-card {
    background: linear-gradient(135deg, rgba(167, 139, 250, 0.1), rgba(96, 165, 250, 0.05));
    border: 1px solid rgba(167, 139, 250, 0.3);
    border-radius: 16px;
    padding: 24px 28px;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #ccc;
  }

  .overview-card strong { color: #fff; }
  .overview-card em { color: #a78bfa; font-style: normal; font-weight: 500; }
  .overview-card a { color: #60a5fa; }

  /* View Toggle */
  .view-toggle-section {
    margin-bottom: 40px;
    text-align: center;
  }

  .view-toggle {
    display: inline-flex;
    gap: 4px;
    background: rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 4px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .toggle-btn {
    padding: 10px 24px;
    border: none;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    background: transparent;
    color: #888;
    transition: all 0.2s;
  }

  .toggle-btn.active {
    background: linear-gradient(135deg, #a78bfa, #7c3aed);
    color: white;
  }

  .toggle-btn:hover:not(.active) {
    color: #ccc;
    background: rgba(255,255,255,0.05);
  }

  /* Action Buttons */
  .action-btn {
    padding: 10px 20px;
    border: none;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .action-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .primary-btn {
    background: linear-gradient(135deg, #a78bfa, #7c3aed);
    color: white;
  }

  .primary-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(124, 58, 237, 0.4);
  }

  .step-btn {
    background: linear-gradient(135deg, #60a5fa, #3b82f6);
    color: white;
  }

  .auto-btn {
    background: linear-gradient(135deg, #f472b6, #ec4899);
    color: white;
  }

  .reset-btn {
    background: rgba(255,255,255,0.1);
    color: #aaa;
  }

  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  /* Flow Section */
  .flow-section {
    margin-bottom: 50px;
  }

  .flow-controls {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .flow-status {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    padding: 12px 16px;
    background: rgba(255,255,255,0.03);
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .status-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .status-badge.idle { background: rgba(107, 114, 128, 0.3); color: #9ca3af; }
  .status-badge.sql { background: rgba(167, 139, 250, 0.2); color: #a78bfa; }
  .status-badge.txn { background: rgba(251, 191, 36, 0.2); color: #fbbf24; }
  .status-badge.twopc { background: rgba(244, 114, 182, 0.2); color: #f472b6; }
  .status-badge.raft { background: rgba(96, 165, 250, 0.2); color: #60a5fa; }
  .status-badge.engine { background: rgba(34, 197, 94, 0.2); color: #22c55e; }
  .status-badge.cop { background: rgba(251, 146, 60, 0.2); color: #fb923c; }
  .status-badge.mvcc { background: rgba(244, 114, 182, 0.2); color: #f472b6; }
  .status-badge.done { background: rgba(34, 197, 94, 0.2); color: #22c55e; }

  .status-text {
    color: #aaa;
    font-size: 0.95rem;
  }

  /* Pipeline */
  .pipeline-container {
    background: rgba(0,0,0,0.2);
    border-radius: 16px;
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .pipeline-stages {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 14px 18px;
    border-radius: 12px;
    border: 2px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.02);
    transition: all 0.4s ease;
    min-width: 90px;
  }

  .stage.active {
    border-color: #a78bfa;
    background: rgba(167, 139, 250, 0.15);
    box-shadow: 0 0 20px rgba(167, 139, 250, 0.3);
    transform: scale(1.05);
  }

  .stage.completed {
    border-color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
  }

  .stage-icon {
    font-size: 1.8rem;
  }

  .stage-label {
    font-size: 0.75rem;
    color: #888;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .stage.active .stage-label { color: #a78bfa; }
  .stage.completed .stage-label { color: #4ade80; }

  .stage-arrow {
    color: #555;
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .step-detail-box {
    min-height: 120px;
    padding: 20px;
    border-radius: 12px;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.08);
  }

  .detail-placeholder {
    color: #555;
    text-align: center;
    font-style: italic;
    padding-top: 30px;
  }

  :global(.step-detail) {
    animation: detailAppear 0.4s ease-out;
  }

  :global(.step-title) {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }

  :global(.step-desc) {
    color: #aaa;
    line-height: 1.7;
    font-size: 0.95rem;
    margin-bottom: 12px;
  }

  :global(.step-desc strong) { color: #00d4ff; }
  :global(.step-desc code) {
    background: rgba(0,0,0,0.3);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.85rem;
    color: #22c55e;
  }

  :global(.step-kv-box) {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 12px;
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 0.8rem;
    color: #ccc;
    overflow-x: auto;
  }

  :global(.step-kv-box .kv-line) {
    padding: 3px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  :global(.step-kv-box .kv-line:last-child) { border-bottom: none; }

  :global(.kv-key) { color: #f472b6; }
  :global(.kv-val) { color: #4ade80; }
  :global(.kv-arrow) { color: #666; }

  @keyframes detailAppear {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Latency Section */
  .latency-section {
    margin-bottom: 50px;
  }

  .latency-controls {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .latency-slider {
    flex: 1;
    min-width: 180px;
  }

  .latency-slider label {
    display: block;
    color: #ccc;
    margin-bottom: 10px;
    font-size: 0.95rem;
  }

  .latency-slider strong {
    color: #a78bfa;
  }

  .latency-slider input[type="range"] {
    width: 100%;
    height: 8px;
    -webkit-appearance: none;
    background: rgba(255,255,255,0.15);
    border-radius: 4px;
    cursor: pointer;
  }

  .latency-slider input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #a78bfa;
    cursor: pointer;
  }

  .latency-path-tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 20px;
  }

  .tab-btn {
    padding: 8px 20px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    background: rgba(255,255,255,0.03);
    color: #888;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .tab-btn.active {
    background: rgba(167, 139, 250, 0.15);
    border-color: rgba(167, 139, 250, 0.5);
    color: #a78bfa;
  }

  .latency-bars {
    background: rgba(0,0,0,0.2);
    border-radius: 12px;
    padding: 20px;
    border: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 16px;
  }

  :global(.latency-row) {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  :global(.latency-label) {
    width: 200px;
    font-size: 0.85rem;
    color: #aaa;
    text-align: right;
    flex-shrink: 0;
  }

  :global(.latency-bar-track) {
    flex: 1;
    height: 24px;
    background: rgba(255,255,255,0.05);
    border-radius: 6px;
