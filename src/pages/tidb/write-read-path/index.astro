<script>
  // ========== VIEW MODE ==========
  let detailedView = false;

  document.getElementById('simpleViewBtn')?.addEventListener('click', () => {
    detailedView = false;
    document.getElementById('simpleViewBtn')!.classList.add('active');
    document.getElementById('detailedViewBtn')!.classList.remove('active');
  });

  document.getElementById('detailedViewBtn')?.addEventListener('click', () => {
    detailedView = true;
    document.getElementById('detailedViewBtn')!.classList.add('active');
    document.getElementById('simpleViewBtn')!.classList.remove('active');
  });

  // ========== WRITE PATH STEPS ==========
  interface PathStep {
    badge: string;
    badgeClass: string;
    text: string;
    stageId: string;
    title: string;
    descSimple: string;
    descDetailed: string;
    kv?: string;
  }

  const writeSteps: PathStep[] = [
    {
      badge: 'SQL', badgeClass: 'sql', stageId: 'ws-sql',
      text: 'Parse SQL → Build execution plan → Extract KV pairs',
      title: '📝 SQL Layer: Parse & Plan',
      descSimple: 'The SQL statement is parsed into an AST, optimized into an execution plan, and <strong>tablecodec</strong> converts rows into KV pairs.',
      descDetailed: 'The parser tokenizes the SQL and builds an Abstract Syntax Tree. The optimizer (both rule-based and cost-based) produces a physical plan. For <code>INSERT INTO users VALUES (1, "alice", 25)</code>, tablecodec encodes the row into a key-value pair using the table and row ID.',
      kv: '<div class="kv-line"><span class="kv-key">t80_r1</span> <span class="kv-arrow">→</span> <span class="kv-val">{name: "alice", age: 25}</span></div><div class="kv-line"><span class="kv-key">t80_i1_alice</span> <span class="kv-arrow">→</span> <span class="kv-val">rowID=1</span> (index entry)</div>'
    },
    {
      badge: 'TXN', badgeClass: 'txn', stageId: 'ws-txn',
      text: 'Begin transaction → Get TSO (start_ts=415) from PD → Buffer writes',
      title: '🔄 Transaction Layer: Begin & Buffer',
      descSimple: 'A new transaction begins by fetching a <strong>globally unique timestamp</strong> (TSO) from PD. All writes are buffered in memory — nothing touches TiKV yet.',
      descDetailed: 'The TSO allocator on PD provides a monotonically increasing timestamp via a batched, pipelined protocol (~1 RTT). The TiDB node keeps a local mutation buffer (membuf). Writes accumulate here until COMMIT. The start_ts provides the <strong>snapshot isolation</strong> read boundary.',
      kv: '<div class="kv-line">start_ts = <span class="kv-val">415</span> (from PD TSO)</div><div class="kv-line">membuf: [<span class="kv-key">t80_r1</span> <span class="kv-arrow">→</span> <span class="kv-val">{...}</span>]</div>'
    },
    {
      badge: '2PC', badgeClass: 'twopc', stageId: 'ws-2pc',
      text: 'Prewrite: lock keys on TiKV regions → Commit primary → Async secondaries',
      title: '🤝 Two-Phase Commit',
      descSimple: '<strong>Prewrite</strong> sends mutations to TiKV, acquiring locks on each key. Once all prewrites succeed, <strong>Commit</strong> writes the commit record for the primary key. Secondaries commit asynchronously.',
      descDetailed: 'Phase 1 (Prewrite): For each key, TiKV writes a Lock CF entry and the data to Default CF at start_ts. If any key is already locked → WriteConflict. Phase 2 (Commit): Get commit_ts from PD, remove primary lock, write to Write CF. The commit_ts makes the data visible. Secondary cleanup is async — safe because any reader can resolve by checking the primary.',
      kv: '<div class="kv-line">Lock CF: <span class="kv-key">t80_r1</span> <span class="kv-arrow">→</span> <span class="kv-val">lock(ts=415, primary)</span></div><div class="kv-line">Default CF: <span class="kv-key">t80_r1@415</span> <span class="kv-arrow">→</span> <span class="kv-val">{name:"alice"}</span></div><div class="kv-line">Write CF: <span class="kv-key">t80_r1@420</span> <span class="kv-arrow">→</span> <span class="kv-val">start_ts=415 ✅</span></div>'
    },
    {
      badge: 'RAFT', badgeClass: 'raft', stageId: 'ws-raft',
      text: 'Propose to Raft group → Leader replicates to followers → Apply to state machine',
      title: '📡 Raft Consensus',
      descSimple: 'Every write to a TiKV region goes through <strong>Raft</strong>. The leader proposes the entry, replicates it to a majority of followers, then applies it to the local state machine.',
      descDetailed: 'TiKV uses Multi-Raft — each Region (~96MB) has its own Raft group (typically 3 replicas). The leader appends the proposal to its Raft log, sends AppendEntries RPCs to followers. Once a <strong>quorum</strong> (2/3) acknowledges, the entry is committed and applied. Raft guarantees linearizable writes even if one node fails. The apply step triggers the actual RocksDB write.',
    },
    {
      badge: 'ENGINE', badgeClass: 'engine', stageId: 'ws-engine',
      text: 'Write-Ahead Log → MemTable → Flush to SST → Compaction (L0→Lmax)',
      title: '💾 RocksDB Storage Engine',
      descSimple: 'Data is written to the <strong>WAL</strong> (crash safety), then inserted into the <strong>MemTable</strong> (in-memory sorted structure). When the MemTable is full, it flushes to an <strong>SST file</strong> on disk. Background compaction merges levels.',
      descDetailed: 'The write path in RocksDB: (1) Append to Write-Ahead Log — sequential disk I/O, very fast. (2) Insert into MemTable (skiplist). (3) When MemTable reaches threshold (~64MB), it becomes immutable and a new one is created. (4) Immutable MemTable flushes to L0 SST. (5) Background compaction merges L0→L1→...→Lmax, removing tombstones and old MVCC versions. TiKV uses <strong>3 Column Families</strong>: Lock, Default (data), Write — each is a separate RocksDB instance.',
      kv: '<div class="kv-line">WAL: <span class="kv-val">append(seq=1042, put t80_r1@415)</span></div><div class="kv-line">MemTable: <span class="kv-key">t80_r1@415</span> <span class="kv-arrow">→</span> <span class="kv-val">{...}</span> (skiplist)</div><div class="kv-line">SST L0: <span class="kv-val">[t80_r1@415, t80_r5@410, ...]</span></div>'
    },
  ];

  const readSteps: PathStep[] = [
    {
      badge: 'SQL', badgeClass: 'sql', stageId: 'rs-sql',
      text: 'Parse SQL → Build plan → Determine key ranges',
      title: '📝 SQL Layer: Parse & Plan',
      descSimple: 'The SELECT is parsed and the optimizer determines whether to do a <strong>point lookup</strong> or <strong>range scan</strong>, and which key ranges to request from TiKV.',
      descDetailed: 'For <code>SELECT * FROM users WHERE id = 1</code>, the optimizer recognizes a primary key access → PointGet plan (single key). For <code>WHERE age > 30</code>, it may choose an IndexScan + TableLookup or a full TableScan, depending on statistics. The plan determines the TiKV key ranges and whether to use the Coprocessor.',
      kv: '<div class="kv-line">PointGet: key = <span class="kv-key">t80_r1</span></div><div class="kv-line">RangeScan: [<span class="kv-key">t80_r1</span>, <span class="kv-key">t80_r∞</span>) with filter age > 30</div>'
    },
    {
      badge: 'COP', badgeClass: 'cop', stageId: 'rs-cop',
      text: 'Push predicates and aggregations down to TiKV coprocessor',
      title: '⬇️ Coprocessor Push-down',
      descSimple: 'Instead of pulling all data to TiDB, <strong>filter conditions</strong> and <strong>aggregations</strong> are sent to TiKV. Each region processes its slice locally.',
      descDetailed: 'The DistSQL layer in TiDB splits the key range by Region boundaries and sends parallel Coprocessor requests. Each TiKV node runs a local executor that understands Selection (WHERE), Aggregation (GROUP BY, COUNT), TopN, and Limit. Only matching rows or partial aggregates travel back over the network. For simple PointGet plans, the coprocessor is bypassed entirely.',
    },
    {
      badge: 'TIKV', badgeClass: 'raft', stageId: 'rs-tikv',
      text: 'Region leader handles read at snapshot_ts',
      title: '📦 TiKV Region Read',
      descSimple: 'The <strong>Region leader</strong> handles the read request. It creates a consistent snapshot at the requested <strong>snapshot_ts</strong> so readers never block writers.',
      descDetailed: 'The Region leader verifies it still holds the lease (Raft lease read — no extra Raft round trip needed). It creates a RocksDB snapshot at the requested timestamp. With <strong>Follower Read</strong> (enabled optionally), stale reads can go to followers with a resolved-ts check, reducing leader load. Stale read requests use a <code>max_ts</code> guaranteed to be safe.',
    },
    {
      badge: 'MVCC', badgeClass: 'mvcc', stageId: 'rs-mvcc',
      text: 'Find correct version, resolve any encountered locks',
      title: '⏳ MVCC Version Resolution',
      descSimple: 'The MVCC layer finds the <strong>latest committed version</strong> with commit_ts ≤ snapshot_ts. If it encounters a lock from an in-progress transaction, it must <strong>resolve</strong> it first.',
      descDetailed: 'Scan Write CF for the key, descending from snapshot_ts. The first Write record with commit_ts ≤ snapshot_ts gives us the start_ts of the visible version. Then read Default CF at that start_ts to get the actual data. If a Lock CF entry is found for the key, check if the lock\'s transaction has committed (check primary key) — if yes, resolve the lock by writing the commit record; if expired/rolled-back, clean it up. This is how TiDB achieves <strong>lock-free reads</strong>.',
      kv: '<div class="kv-line">Write CF scan: <span class="kv-key">t80_r1@420</span> <span class="kv-arrow">→</span> <span class="kv-val">start_ts=415</span> (commit_ts=420 ≤ snap=425 ✅)</div><div class="kv-line">Default CF get: <span class="kv-key">t80_r1@415</span> <span class="kv-arrow">→</span> <span class="kv-val">{name:"alice", age:25}</span></div>'
    },
    {
      badge: 'ENGINE', badgeClass: 'engine', stageId: 'rs-engine',
      text: 'MemTable → Block Cache → SST files (bloom filter → index → data block)',
      title: '💾 RocksDB Read Path',
      descSimple: 'RocksDB checks the <strong>MemTable</strong> first (fastest), then the <strong>block cache</strong> (in-memory SST blocks), then searches SST files on disk using <strong>bloom filters</strong> to skip irrelevant files.',
      descDetailed: 'Read order: (1) Active MemTable (2) Immutable MemTables (3) Block cache — LRU cache of SST data blocks and index blocks. (4) SST files: for point lookups, check the <strong>bloom filter</strong> first — if it says "not present", skip the file entirely (saves I/O). Otherwise: binary search the index block → locate the data block → decompress → find the key. For range scans, create a MergingIterator across all levels — bloom filters don\'t help here, so reads touch more files.',
      kv: '<div class="kv-line">① MemTable: <span class="kv-val">MISS</span></div><div class="kv-line">② Block Cache: <span class="kv-val">MISS</span></div><div class="kv-line">③ SST L0 bloom: <span class="kv-val">NEGATIVE → skip</span></div><div class="kv-line">④ SST L1 bloom: <span class="kv-val">POSITIVE → index → data block</span></div><div class="kv-line">⑤ Result: <span class="kv-key">t80_r1@415</span> <span class="kv-arrow">→</span> <span class="kv-val">{name:"alice"}</span></div>'
    },
  ];

  // ========== GENERIC FLOW ENGINE ==========
  function createFlowEngine(prefix: string, steps: PathStep[], stageIds: string[]) {
    let step = -1;
    let playing = false;

    const startBtn = document.getElementById(`start${prefix}Btn`) as HTMLButtonElement;
    const stepBtn = document.getElementById(`step${prefix}Btn`) as HTMLButtonElement;
    const autoBtn = document.getElementById(`auto${prefix}Btn`) as HTMLButtonElement;
    const resetBtn = document.getElementById(`reset${prefix}Btn`) as HTMLButtonElement;
    const statusEl = document.getElementById(`${prefix.toLowerCase()}FlowStatus`)!;
    const statusText = document.getElementById(`${prefix.toLowerCase()}StatusText`)!;
    const detailBox = document.getElementById(`${prefix.toLowerCase()}DetailBox`)!;

    function renderStep() {
      const s = steps[step];
      const badge = statusEl.querySelector('.status-badge')!;
      badge.className = `status-badge ${s.badgeClass}`;
      badge.textContent = s.badge;
      statusText.textContent = s.text;

      // Update stage highlights
      stageIds.forEach((id, idx) => {
        const el = document.getElementById(id)!;
        el.classList.remove('active', 'completed');
        if (idx < step) el.classList.add('completed');
        else if (idx === step) el.classList.add('active');
      });

      // Render detail
      const desc = detailedView ? s.descDetailed : s.descSimple;
      let html = `<div class="step-detail">
        <div class="step-title">${s.title}</div>
        <div class="step-desc">${desc}</div>`;
      if (s.kv && detailedView) {
        html += `<div class="step-kv-box">${s.kv}</div>`;
      }
      html += '</div>';
      detailBox.innerHTML = html;

      if (step >= steps.length - 1) {
        stepBtn.disabled = true;
        autoBtn.disabled = true;
        const b2 = statusEl.querySelector('.status-badge')!;
        b2.className = 'status-badge done';
        b2.textContent = 'Done';
      }
    }

    function reset() {
      step = -1;
      playing = false;
      const badge = statusEl.querySelector('.status-badge')!;
      badge.className = 'status-badge idle';
      badge.textContent = 'Ready';
      statusText.textContent = `Click "Start ${prefix}" to begin`;
      detailBox.innerHTML = '<div class="detail-placeholder">Follow the ' + prefix.toLowerCase() + ' as it flows through each layer</div>';
      stageIds.forEach(id => {
        document.getElementById(id)!.classList.remove('active', 'completed');
      });
      stepBtn.disabled = true;
      autoBtn.disabled = true;
    }

    startBtn?.addEventListener('click', () => {
      reset();
      step = 0;
      renderStep();
      stepBtn.disabled = false;
      autoBtn.disabled = false;
    });

    stepBtn?.addEventListener('click', () => {
      if (step < steps.length - 1) {
        step++;
        renderStep();
      }
    });

    autoBtn?.addEventListener('click', async () => {
      if (playing) return;
      playing = true;
      autoBtn.disabled = true;
      stepBtn.disabled = true;
      while (step < steps.length - 1) {
        await new Promise(r => setTimeout(r, 1500));
        if (!playing) break;
        step++;
        renderStep();
      }
      playing = false;
    });

    resetBtn?.addEventListener('click', reset);
  }

  createFlowEngine('Write', writeSteps, ['ws-sql', 'ws-txn', 'ws-2pc', 'ws-raft', 'ws-engine']);
  createFlowEngine('Read', readSteps, ['rs-sql', 'rs-cop', 'rs-tikv', 'rs-mvcc', 'rs-engine']);

  // ========== LATENCY BREAKDOWN ==========
  const rttSlider = document.getElementById('rttSlider') as HTMLInputElement;
  const diskSlider = document.getElementById('diskSlider') as HTMLInputElement;
  const raftSlider = document.getElementById('raftSlider') as HTMLInputElement;
  const latWriteTab = document.getElementById('latWriteTab') as HTMLButtonElement;
  const latReadTab = document.getElementById('latReadTab') as HTMLButtonElement;

  let latencyMode: 'write' | 'read' = 'write';

  latWriteTab?.addEventListener('click', () => {
    latencyMode = 'write';
    latWriteTab.classList.add('active');
    latReadTab.classList.remove('active');
    renderLatency();
  });

  latReadTab?.addEventListener('click', () => {
    latencyMode = 'read';
    latReadTab.classList.add('active');
    latWriteTab.classList.remove('active');
    renderLatency();
  });

  function renderLatency() {
    const rtt = parseFloat(rttSlider.value);
    const disk = parseFloat(diskSlider.value);
    const raft = parseFloat(raftSlider.value);

    document.getElementById('rttValue')!.textContent = rtt.toString();
    document.getElementById('diskValue')!.textContent = disk.toString();
    document.getElementById('raftValue')!.textContent = raft.toString();

    let rows: Array<{label: string; ms: number; bar: string}>;

    if (latencyMode === 'write') {
      rows = [
        { label: 'SQL Parse & Plan', ms: 0.1, bar: 'bar-sql' },
        { label: 'Get start_ts (PD)', ms: rtt, bar: 'bar-tso' },
        { label: 'Prewrite RPCs', ms: rtt, bar: 'bar-prewrite' },
        { label: 'Raft replication', ms: raft, bar: 'bar-raft' },
        { label: 'RocksDB WAL + MemTable', ms: disk, bar: 'bar-engine' },
        { label: 'Get commit_ts (PD)', ms: rtt, bar: 'bar-tso' },
        { label: 'Commit primary RPC', ms: rtt, bar: 'bar-prewrite' },
      ];
    } else {
      rows = [
        { label: 'SQL Parse & Plan', ms: 0.1, bar: 'bar-sql' },
        { label: 'Coprocessor RPC', ms: rtt, bar: 'bar-cop' },
        { label: 'MVCC version lookup', ms: 0.05, bar: 'bar-mvcc' },
        { label: 'RocksDB read (cache hit)', ms: 0.02, bar: 'bar-engine' },
        { label: 'RocksDB read (cache miss)', ms: disk, bar: 'bar-engine' },
        { label: 'Network response', ms: rtt, bar: 'bar-cop' },
      ];
    }

    const maxMs = Math.max(...rows.map(r => r.ms), 0.5);
    const container = document.getElementById('latencyBars')!;
    container.innerHTML = '';

    let total = 0;
    rows.forEach(r => {
      total += r.ms;
      const pct = Math.max((r.ms / maxMs) * 100, 3);
      const row = document.createElement('div');
      row.className = 'latency-row';
      row.innerHTML = `
        <div class="latency-label">${r.label}</div>
        <div class="latency-bar-track">
          <div class="latency-bar-fill ${r.bar}" style="width: ${pct}%"></div>
        </div>
        <div class="latency-time">${r.ms < 0.1 ? r.ms.toFixed(2) : r.ms.toFixed(1)} ms</div>
      `;
      container.appendChild(row);
    });

    document.getElementById('latencyTotal')!.textContent = total.toFixed(1);
  }

  rttSlider?.addEventListener('input', renderLatency);
  diskSlider?.addEventListener('input', renderLatency);
  raftSlider?.addEventListener('input', renderLatency);

  // Initial render
  renderLatency();
</script>
