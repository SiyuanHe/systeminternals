---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="LSM-Tree & Compaction: The Write-Optimized Engine" 
  description="Interactive visualization showing how LSM-trees store data, manage write amplification, and perform compaction in TiKV/RocksDB"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "TiDB", href: "/tidb/" },
    { label: "LSM-Tree & Compaction", href: "/tidb/lsm-tree/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🗂️ LSM-Tree & Compaction</h1>
      <p class="subtitle">The Write-Optimized Storage Engine Behind TiKV</p>
    </header>

    <!-- Controls -->
    <section class="controls-section">
      <div class="control-group">
        <button id="writeBtn" class="action-btn write-btn">
          ✏️ Write Key-Value
        </button>
        <button id="write10Btn" class="action-btn write-btn-secondary">
          ⚡ Write 10 KVs
        </button>
        <button id="readBtn" class="action-btn read-btn">
          🔍 Read Random Key
        </button>
        <button id="resetBtn" class="action-btn reset-btn">
          🔄 Reset
        </button>
      </div>
      <div class="stats-row">
        <div class="stat">
          <span class="stat-label">Writes</span>
          <span class="stat-value" id="writeCount">0</span>
        </div>
        <div class="stat">
          <span class="stat-label">Compactions</span>
          <span class="stat-value" id="compactionCount">0</span>
        </div>
        <div class="stat">
          <span class="stat-label">Write Amp</span>
          <span class="stat-value" id="writeAmp">1.0x</span>
        </div>
        <div class="stat">
          <span class="stat-label">Read Amp</span>
          <span class="stat-value" id="readAmp">1</span>
        </div>
      </div>
    </section>

    <!-- Main Visualization -->
    <section class="lsm-viz">
      <!-- MemTable -->
      <div class="component memtable">
        <div class="component-header">
          <h3>📝 MemTable (RAM)</h3>
          <span class="component-info">Sorted in-memory buffer</span>
        </div>
        <div class="memtable-bar">
          <div class="memtable-fill" id="memtableFill"></div>
          <span class="memtable-label" id="memtableLabel">0 / 4 keys</span>
        </div>
        <div class="memtable-keys" id="memtableKeys"></div>
      </div>

      <!-- Flush Arrow -->
      <div class="arrow-container" id="flushArrow">
        <div class="arrow">↓</div>
        <span class="arrow-label">Flush to L0</span>
      </div>

      <!-- SST Levels -->
      <div class="levels-container">
        <div class="level level-0" id="level0">
          <div class="level-header">
            <h3>L0</h3>
            <span class="level-info">Unsorted SSTs (fast writes)</span>
          </div>
          <div class="sst-container" id="l0-ssts"></div>
        </div>

        <div class="compact-arrow" id="compact01">
          <div class="arrow">↓</div>
          <span class="arrow-label">Compact</span>
        </div>

        <div class="level level-1" id="level1">
          <div class="level-header">
            <h3>L1</h3>
            <span class="level-info">Sorted, non-overlapping</span>
          </div>
          <div class="sst-container" id="l1-ssts"></div>
        </div>

        <div class="compact-arrow" id="compact12">
          <div class="arrow">↓</div>
          <span class="arrow-label">Compact</span>
        </div>

        <div class="level level-2" id="level2">
          <div class="level-header">
            <h3>L2</h3>
            <span class="level-info">10x larger, sorted</span>
          </div>
          <div class="sst-container" id="l2-ssts"></div>
        </div>
      </div>
    </section>

    <!-- Activity Log -->
    <section class="log-section">
      <h3>📜 Activity Log</h3>
      <div class="log-container" id="activityLog">
        <div class="log-entry">System ready. Click "Write Key-Value" to begin.</div>
      </div>
    </section>

    <!-- Explanation Cards -->
    <section class="explanation-section">
      <div class="explain-card">
        <h3>💡 Why LSM-Trees?</h3>
        <p>
          Traditional B-trees update data in-place, requiring random disk I/O for every write.
          LSM-trees batch writes in memory, then flush sequentially — turning random writes into 
          sequential writes. This makes writes <strong>10-100x faster</strong> on SSDs and HDDs.
        </p>
      </div>

      <div class="explain-card">
        <h3>⚖️ The Write Amplification Tradeoff</h3>
        <p>
          The catch: data gets rewritten multiple times as it compacts through levels.
          A single key might be written to L0, then compacted to L1, then to L2...
          <strong>Write amplification</strong> is the ratio of bytes written to disk vs. bytes written by the app.
          Typical values: 10-30x for RocksDB.
        </p>
      </div>

      <div class="explain-card">
        <h3>🔍 Read Amplification</h3>
        <p>
          To read a key, we might check: MemTable → L0 (multiple SSTs!) → L1 → L2.
          Bloom filters help skip SSTs that definitely don't contain the key.
          In the worst case, reads check every level — this is <strong>read amplification</strong>.
        </p>
      </div>
    </section>

    <!-- Tuning Section -->
    <section class="tuning-section">
      <h2>🎛️ Tuning Knobs</h2>
      <div class="tuning-grid">
        <div class="tuning-card">
          <h4>MemTable Size</h4>
          <p>Larger = fewer flushes, but more memory and longer recovery</p>
          <code>write-buffer-size = 128MB</code>
        </div>
        <div class="tuning-card">
          <h4>L0 Trigger</h4>
          <p>Compact to L1 when L0 has this many SSTs</p>
          <code>level0-file-num-compaction-trigger = 4</code>
        </div>
        <div class="tuning-card">
          <h4>Level Ratio</h4>
          <p>Each level is Nx larger than the previous</p>
          <code>max-bytes-for-level-multiplier = 10</code>
        </div>
        <div class="tuning-card">
          <h4>Compression</h4>
          <p>Balance CPU vs disk space per level</p>
          <code>compression-per-level = [no, no, lz4, lz4, lz4, zstd, zstd]</code>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://docs.pingcap.com/tidb/stable/rocksdb-overview" target="_blank">TiKV's RocksDB implementation</a> and the <a href="https://www.cs.umb.edu/~pon} O'Neil et al. LSM-tree paper</a></p>
    </footer>

    <!-- Share buttons -->
    <div class="share-buttons">
      <span>Share this visualization:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20LSM-Tree%20visualization%20-%20see%20how%20RocksDB%20compaction%20works&url=https://systeminternals.dev/tidb/lsm-tree/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/tidb/lsm-tree/" target="_blank" class="share-btn">in LinkedIn</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .viz-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #f59e0b, #22c55e, #3b82f6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #888;
    font-size: 1.1rem;
  }

  /* Controls */
  .controls-section {
    background: rgba(255,255,255,0.03);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 30px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .control-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 20px;
  }

  .action-btn {
    padding: 12px 24px;
    border: none;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .write-btn {
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: white;
  }

  .write-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(34, 197, 94, 0.4);
  }

  .write-btn-secondary {
    background: linear-gradient(135deg, #16a34a, #15803d);
    color: white;
  }

  .read-btn {
    background: linear-gradient(135deg, #3b82f6, #2563eb);
    color: white;
  }

  .read-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(59, 130, 246, 0.4);
  }

  .reset-btn {
    background: rgba(255,255,255,0.1);
    color: #aaa;
  }

  .reset-btn:hover {
    background: rgba(255,255,255,0.2);
    color: #fff;
  }

  .stats-row {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .stat {
    text-align: center;
  }

  .stat-label {
    display: block;
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 4px;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
  }

  /* LSM Visualization */
  .lsm-viz {
    background: rgba(255,255,255,0.02);
    border-radius: 20px;
    padding: 30px;
    border: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 30px;
  }

  .component {
    margin-bottom: 20px;
  }

  .component-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 12px;
  }

  .component-header h3 {
    font-size: 1.1rem;
    color: #fff;
  }

  .component-info {
    font-size: 0.85rem;
    color: #666;
  }

  /* MemTable */
  .memtable {
    background: linear-gradient(135deg, rgba(251, 191, 36, 0.1), rgba(245, 158, 11, 0.05));
    border-radius: 12px;
    padding: 20px;
    border: 1px solid rgba(251, 191, 36, 0.3);
  }

  .memtable-bar {
    height: 24px;
    background: rgba(0,0,0,0.3);
    border-radius: 12px;
    position: relative;
    overflow: hidden;
    margin-bottom: 12px;
  }

  .memtable-fill {
    height: 100%;
    background: linear-gradient(90deg, #fbbf24, #f59e0b);
    border-radius: 12px;
    transition: width 0.3s;
    width: 0%;
  }

  .memtable-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 0.8rem;
    color: #fff;
    font-weight: 500;
  }

  .memtable-keys {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    min-height: 32px;
  }

  :global(.key-badge) {
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    color: #000;
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    animation: keyAppear 0.3s ease-out;
  }

  @keyframes keyAppear {
    from { transform: scale(0); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  /* Arrows */
  .arrow-container, .compact-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 10px 0;
    opacity: 0.3;
    transition: opacity 0.3s;
  }

  :global(.arrow-container.active), :global(.compact-arrow.active) {
    opacity: 1;
  }

  .arrow {
    font-size: 1.5rem;
    color: #00d4ff;
    animation: none;
  }

  :global(.arrow-container.active .arrow), :global(.compact-arrow.active .arrow) {
    animation: arrowPulse 0.5s ease-in-out;
  }

  @keyframes arrowPulse {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(5px); }
  }

  .arrow-label {
    font-size: 0.75rem;
    color: #666;
  }

  /* Levels */
  .levels-container {
    margin-top: 10px;
  }

  .level {
    background: rgba(255,255,255,0.03);
    border-radius: 12px;
    padding: 16px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .level-0 {
    border-color: rgba(239, 68, 68, 0.3);
    background: rgba(239, 68, 68, 0.05);
  }

  .level-1 {
    border-color: rgba(59, 130, 246, 0.3);
    background: rgba(59, 130, 246, 0.05);
  }

  .level-2 {
    border-color: rgba(34, 197, 94, 0.3);
    background: rgba(34, 197, 94, 0.05);
  }

  .level-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 12px;
  }

  .level-header h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
  }

  .level-info {
    font-size: 0.8rem;
    color: #666;
  }

  .sst-container {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    min-height: 50px;
    align-items: flex-start;
  }

  :global(.sst-file) {
    background: rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 8px 12px;
    border: 1px solid rgba(255,255,255,0.2);
    animation: sstAppear 0.4s ease-out;
  }

  :global(.sst-file.l0) {
    background: rgba(239, 68, 68, 0.2);
    border-color: rgba(239, 68, 68, 0.4);
  }

  :global(.sst-file.l1) {
    background: rgba(59, 130, 246, 0.2);
    border-color: rgba(59, 130, 246, 0.4);
  }

  :global(.sst-file.l2) {
    background: rgba(34, 197, 94, 0.2);
    border-color: rgba(34, 197, 94, 0.4);
  }

  :global(.sst-file.compacting) {
    animation: compactPulse 0.5s ease-in-out infinite;
  }

  @keyframes sstAppear {
    from { transform: scale(0.8); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  @keyframes compactPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  :global(.sst-keys) {
    font-size: 0.75rem;
    color: #aaa;
    white-space: nowrap;
  }

  /* Log */
  .log-section {
    background: rgba(0,0,0,0.3);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 30px;
  }

  .log-section h3 {
    font-size: 1rem;
    margin-bottom: 12px;
    color: #888;
  }

  .log-container {
    max-height: 150px;
    overflow-y: auto;
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 0.85rem;
  }

  :global(.log-entry) {
    padding: 4px 0;
    color: #888;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  :global(.log-entry.write) { color: #22c55e; }
  :global(.log-entry.flush) { color: #fbbf24; }
  :global(.log-entry.compact) { color: #f472b6; }
  :global(.log-entry.read) { color: #3b82f6; }

  /* Explanation */
  .explanation-section {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }

  .explain-card {
    background: rgba(255,255,255,0.03);
    border-radius: 12px;
    padding: 20px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .explain-card h3 {
    font-size: 1rem;
    margin-bottom: 12px;
    color: #fff;
  }

  .explain-card p {
    font-size: 0.9rem;
    color: #888;
    line-height: 1.6;
  }

  .explain-card strong {
    color: #00d4ff;
  }

  /* Tuning */
  .tuning-section {
    margin-bottom: 40px;
  }

  .tuning-section h2 {
    font-size: 1.3rem;
    margin-bottom: 20px;
    color: #fff;
  }

  .tuning-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }

  .tuning-card {
    background: rgba(255,255,255,0.03);
    border-radius: 10px;
    padding: 16px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .tuning-card h4 {
    font-size: 0.95rem;
    margin-bottom: 8px;
    color: #fff;
  }

  .tuning-card p {
    font-size: 0.85rem;
    color: #888;
    margin-bottom: 12px;
    line-height: 1.5;
  }

  .tuning-card code {
    display: block;
    background: rgba(0,0,0,0.3);
    padding: 8px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    color: #22c55e;
    overflow-x: auto;
  }

  /* Footer */
  .viz-footer {
    text-align: center;
    color: #666;
    font-size: 0.9rem;
    padding: 20px 0;
    border-top: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 30px;
  }

  .viz-footer a {
    color: #00d4ff;
  }

  /* Share buttons */
  .share-buttons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .share-buttons span {
    color: #666;
  }

  .share-btn {
    padding: 10px 20px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: #fff;
    font-size: 0.9rem;
    transition: background 0.2s;
  }

  .share-btn:hover {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  @media (max-width: 768px) {
    .viz-header h1 {
      font-size: 1.8rem;
    }

    .stats-row {
      gap: 20px;
    }

    .stat-value {
      font-size: 1.2rem;
    }
  }
</style>

<script>
  // State
  let memtable: string[] = [];
  let l0: string[][] = [];
  let l1: string[] = [];
  let l2: string[] = [];
  let writeCount = 0;
  let compactionCount = 0;
  let totalBytesWritten = 0;
  let keyCounter = 0;

  const MEMTABLE_SIZE = 4;
  const L0_COMPACT_TRIGGER = 4;
  const L1_COMPACT_TRIGGER = 8;

  // DOM Elements
  const memtableFill = document.getElementById('memtableFill')!;
  const memtableLabel = document.getElementById('memtableLabel')!;
  const memtableKeys = document.getElementById('memtableKeys')!;
  const l0Container = document.getElementById('l0-ssts')!;
  const l1Container = document.getElementById('l1-ssts')!;
  const l2Container = document.getElementById('l2-ssts')!;
  const activityLog = document.getElementById('activityLog')!;
  const writeCountEl = document.getElementById('writeCount')!;
  const compactionCountEl = document.getElementById('compactionCount')!;
  const writeAmpEl = document.getElementById('writeAmp')!;
  const readAmpEl = document.getElementById('readAmp')!;
  const flushArrow = document.getElementById('flushArrow')!;
  const compact01 = document.getElementById('compact01')!;
  const compact12 = document.getElementById('compact12')!;

  function log(msg: string, type: string = '') {
    const entry = document.createElement('div');
    entry.className = 'log-entry ' + type;
    entry.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
    activityLog.insertBefore(entry, activityLog.firstChild);
    if (activityLog.children.length > 20) {
      activityLog.removeChild(activityLog.lastChild!);
    }
  }

  function generateKey(): string {
    return `k${String(keyCounter++).padStart(3, '0')}`;
  }

  function updateStats() {
    writeCountEl.textContent = String(writeCount);
    compactionCountEl.textContent = String(compactionCount);
    
    const amp = writeCount > 0 ? (totalBytesWritten / writeCount).toFixed(1) : '1.0';
    writeAmpEl.textContent = amp + 'x';
    
    // Read amp = levels that need to be checked
    const readLevels = 1 + l0.length + (l1.length > 0 ? 1 : 0) + (l2.length > 0 ? 1 : 0);
    readAmpEl.textContent = String(readLevels);
  }

  function renderMemtable() {
    memtableFill.style.width = (memtable.length / MEMTABLE_SIZE * 100) + '%';
    memtableLabel.textContent = `${memtable.length} / ${MEMTABLE_SIZE} keys`;
    
    memtableKeys.innerHTML = '';
    memtable.forEach(key => {
      const badge = document.createElement('span');
      badge.className = 'key-badge';
      badge.textContent = key;
      memtableKeys.appendChild(badge);
    });
  }

  function renderSST(container: HTMLElement, ssts: string[][], levelClass: string) {
    container.innerHTML = '';
    ssts.forEach((sst, i) => {
      const sstEl = document.createElement('div');
      sstEl.className = `sst-file ${levelClass}`;
      const keysText = sst.length <= 3 ? sst.join(', ') : `${sst[0]}...${sst[sst.length-1]}`;
      sstEl.innerHTML = `<div class="sst-keys">${keysText}</div>`;
      container.appendChild(sstEl);
    });
  }

  function renderL1L2(container: HTMLElement, keys: string[], levelClass: string) {
    container.innerHTML = '';
    if (keys.length === 0) return;
    
    const sstEl = document.createElement('div');
    sstEl.className = `sst-file ${levelClass}`;
    const keysText = keys.length <= 4 ? keys.join(', ') : `${keys[0]}...${keys[keys.length-1]} (${keys.length} keys)`;
    sstEl.innerHTML = `<div class="sst-keys">${keysText}</div>`;
    container.appendChild(sstEl);
  }

  function render() {
    renderMemtable();
    renderSST(l0Container, l0, 'l0');
    renderL1L2(l1Container, l1, 'l1');
    renderL1L2(l2Container, l2, 'l2');
    updateStats();
  }

  async function animateArrow(el: HTMLElement) {
    el.classList.add('active');
    await new Promise(r => setTimeout(r, 500));
    el.classList.remove('active');
  }

  async function flush() {
    if (memtable.length === 0) return;
    
    log(`Flushing memtable to L0 (${memtable.length} keys)`, 'flush');
    await animateArrow(flushArrow);
    
    // Add to L0
    l0.push([...memtable]);
    totalBytesWritten += memtable.length; // Count as bytes written
    memtable = [];
    render();
    
    // Check if L0 needs compaction
    if (l0.length >= L0_COMPACT_TRIGGER) {
      await compactL0toL1();
    }
  }

  async function compactL0toL1() {
    log(`Compacting L0 → L1 (merging ${l0.length} SSTs)`, 'compact');
    compactionCount++;
    await animateArrow(compact01);
    
    // Merge all L0 SSTs into L1
    const allKeys = l0.flat().concat(l1);
    const uniqueKeys = [...new Set(allKeys)].sort();
    
    totalBytesWritten += uniqueKeys.length; // Rewriting to L1
    
    l1 = uniqueKeys;
    l0 = [];
    render();
    
    // Check if L1 needs compaction
    if (l1.length >= L1_COMPACT_TRIGGER) {
      await compactL1toL2();
    }
  }

  async function compactL1toL2() {
    log(`Compacting L1 → L2 (${l1.length} keys)`, 'compact');
    compactionCount++;
    await animateArrow(compact12);
    
    // Merge L1 into L2
    const allKeys = l1.concat(l2);
    const uniqueKeys = [...new Set(allKeys)].sort();
    
    totalBytesWritten += uniqueKeys.length; // Rewriting to L2
    
    l2 = uniqueKeys;
    l1 = [];
    render();
  }

  async function write() {
    const key = generateKey();
    writeCount++;
    totalBytesWritten++;
    
    log(`Write: ${key}`, 'write');
    memtable.push(key);
    memtable.sort();
    render();
    
    if (memtable.length >= MEMTABLE_SIZE) {
      await flush();
    }
  }

  async function write10() {
    for (let i = 0; i < 10; i++) {
      await write();
      await new Promise(r => setTimeout(r, 150));
    }
  }

  function read() {
    // Pick a random key that exists
    const allKeys = [...memtable, ...l0.flat(), ...l1, ...l2];
    if (allKeys.length === 0) {
      log('Read: No keys in storage', 'read');
      return;
    }
    
    const key = allKeys[Math.floor(Math.random() * allKeys.length)];
    let found = '';
    let checks = 0;
    
    if (memtable.includes(key)) {
      found = 'MemTable';
      checks = 1;
    } else {
      checks = 1; // MemTable checked
      for (let i = 0; i < l0.length; i++) {
        checks++;
        if (l0[i].includes(key)) {
          found = `L0[${i}]`;
          break;
        }
      }
      if (!found && l1.includes(key)) {
        checks++;
        found = 'L1';
      }
      if (!found && l2.includes(key)) {
        checks++;
        found = 'L2';
      }
    }
    
    log(`Read: ${key} → found in ${found} (checked ${checks} locations)`, 'read');
  }

  function reset() {
    memtable = [];
    l0 = [];
    l1 = [];
    l2 = [];
    writeCount = 0;
    compactionCount = 0;
    totalBytesWritten = 0;
    keyCounter = 0;
    render();
    activityLog.innerHTML = '<div class="log-entry">System reset. Ready.</div>';
  }

  // Event listeners
  document.getElementById('writeBtn')?.addEventListener('click', write);
  document.getElementById('write10Btn')?.addEventListener('click', write10);
  document.getElementById('readBtn')?.addEventListener('click', read);
  document.getElementById('resetBtn')?.addEventListener('click', reset);

  // Initial render
  render();
</script>
