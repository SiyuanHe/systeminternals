---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "Objects, Trees & Commits", description: "SHA-1 content addressing, blob/tree/commit/tag objects, and the object store", href: "/git/object-model/", status: "live" },
  { title: "Merge vs Rebase", description: "3-way merge, fast-forward, interactive rebase, conflict resolution step-by-step", href: "/git/merge-rebase/", status: "live" },
];
---

<BaseLayout 
  title="Git Internals" 
  description="Interactive visualizations for understanding Git's object model, merge algorithms, and internal data structures"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Git", href: "/git/" }]}
>
  <section class="section-header">
    <h1>🔀 Git Internals</h1>
    <p>
      Git is a content-addressable filesystem with a VCS built on top. Understanding its object model — blobs, trees, 
      commits, and tags — reveals why Git is so fast and how operations like merge and rebase actually work.
      These visualizations let you build and inspect Git's internal structures interactively.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(245, 158, 11, 0.4);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
