---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Vitess Sharding: Horizontal Scaling for MySQL" 
  description="Interactive visualization of Vitess sharding — keyspaces, VSchema, vindexes, query routing, and zero-downtime resharding"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "Vitess", href: "/vitess/" },
    { label: "Sharding", href: "/vitess/sharding/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🐬 Vitess Sharding</h1>
      <p class="subtitle">Horizontal Scaling for MySQL — Born at YouTube</p>
    </header>

    <!-- Overview -->
    <section class="overview-section">
      <div class="overview-card">
        <p>
          Vitess sits between your application and MySQL, transparently <strong>sharding</strong> data 
          across many MySQL instances. Your app talks to <em>vtgate</em> (a proxy), which routes queries 
          to the right <em>vttablet</em> (one per MySQL). The magic: your app thinks it's talking to a 
          single database. Vitess handles the rest — including <strong>resharding with zero downtime</strong>.
        </p>
      </div>
    </section>

    <!-- Architecture -->
    <section class="arch-section">
      <h2>🏗️ Architecture</h2>
      <p class="section-desc">Click on components to learn more</p>

      <div class="arch-diagram" id="archDiagram">
        <div class="arch-layer app-layer">
          <div class="arch-label">Application Layer</div>
          <div class="arch-nodes">
            <div class="arch-node app-node" data-comp="app">📱 App</div>
            <div class="arch-node app-node" data-comp="app">📱 App</div>
            <div class="arch-node app-node" data-comp="app">📱 App</div>
          </div>
        </div>
        <div class="arch-arrow">▼ MySQL Protocol</div>
        <div class="arch-layer gate-layer">
          <div class="arch-label">Proxy Layer</div>
          <div class="arch-nodes">
            <div class="arch-node gate-node" data-comp="vtgate">⚡ vtgate</div>
            <div class="arch-node gate-node" data-comp="vtgate">⚡ vtgate</div>
          </div>
        </div>
        <div class="arch-arrow">▼ gRPC</div>
        <div class="arch-layer tablet-layer">
          <div class="arch-label">Tablet Layer</div>
          <div class="arch-nodes">
            <div class="arch-node tablet-node" data-comp="vttablet">📦 vttablet<br><small>primary</small></div>
            <div class="arch-node tablet-node" data-comp="vttablet">📦 vttablet<br><small>primary</small></div>
            <div class="arch-node tablet-node replica" data-comp="replica">📦 vttablet<br><small>replica</small></div>
          </div>
        </div>
        <div class="arch-arrow">▼ SQL</div>
        <div class="arch-layer mysql-layer">
          <div class="arch-label">Storage Layer</div>
          <div class="arch-nodes">
            <div class="arch-node mysql-node" data-comp="mysql">🐬 MySQL</div>
            <div class="arch-node mysql-node" data-comp="mysql">🐬 MySQL</div>
            <div class="arch-node mysql-node" data-comp="mysql">🐬 MySQL</div>
          </div>
        </div>
        <div class="arch-side topo-side">
          <div class="arch-node topo-node" data-comp="topo">🗺️ Topology<br><small>etcd / ZooKeeper</small></div>
          <div class="arch-node vtctld-node" data-comp="vtctld">🎛️ vtctld<br><small>control plane</small></div>
        </div>
      </div>

      <div class="arch-info" id="archInfo">
        <div class="info-title" id="archInfoTitle">Click a component</div>
        <div class="info-body" id="archInfoBody">Select any component in the diagram above to see what it does.</div>
      </div>
    </section>

    <!-- VSchema & Keyspace -->
    <section class="vschema-section">
      <h2>📋 VSchema: Defining Your Sharding Strategy</h2>
      <p class="section-desc">The VSchema tells Vitess how to distribute data across shards</p>

      <div class="vschema-demo">
        <div class="vschema-editor">
          <div class="editor-header">
            <span>VSchema — commerce keyspace</span>
            <div class="editor-tabs">
              <button class="editor-tab active" data-tab="hash">Hash Vindex</button>
              <button class="editor-tab" data-tab="region">Region Vindex</button>
              <button class="editor-tab" data-tab="lookup">Lookup Vindex</button>
            </div>
          </div>
          <pre class="editor-code" id="vschemaCode"></pre>
        </div>
        <div class="vschema-explain" id="vschemaExplain"></div>
      </div>
    </section>

    <!-- Interactive Keyspace Visualizer -->
    <section class="keyspace-section">
      <h2>🗄️ Interactive Keyspace</h2>
      <p class="section-desc">Watch how data distributes across shards based on the sharding key</p>

      <div class="keyspace-controls">
        <div class="insert-form">
          <label>Insert row with user_id:</label>
          <input type="number" id="insertUserId" value="42" min="1" max="999">
          <button class="action-btn primary-btn" id="insertBtn">➕ Insert</button>
          <button class="action-btn primary-btn" id="insertBatchBtn">📦 Insert 20 Random</button>
          <button class="action-btn reset-btn" id="resetKeyspaceBtn">🔄 Reset</button>
        </div>
      </div>

      <div class="keyspace-viz" id="keyspaceViz">
        <div class="keyspace-ring" id="keyspaceRing">
          <div class="ring-center">
            <div class="ring-label">Keyspace</div>
            <div class="ring-sublabel">commerce</div>
          </div>
        </div>
        <div class="shard-panels" id="shardPanels"></div>
      </div>

      <div class="vindex-calc" id="vindexCalc"></div>
    </section>

    <!-- Query Routing -->
    <section class="routing-section">
      <h2>📡 Query Routing</h2>
      <p class="section-desc">See how vtgate routes different queries to shards</p>

      <div class="query-controls">
        <div class="query-presets">
          <button class="query-btn" data-query="SELECT * FROM users WHERE user_id = 42">Single-shard lookup</button>
          <button class="query-btn" data-query="SELECT * FROM users WHERE name = 'Alice'">Scatter-gather</button>
          <button class="query-btn" data-query="SELECT * FROM users WHERE user_id IN (42, 137, 256)">Multi-shard IN</button>
          <button class="query-btn" data-query="INSERT INTO users (user_id, name) VALUES (99, 'Bob')">Insert (routed)</button>
          <button class="query-btn" data-query="SELECT count(*) FROM users">Aggregate scatter</button>
        </div>
        <div class="query-input-row">
          <input type="text" id="queryInput" class="query-input" placeholder="Or type a query...">
          <button class="action-btn primary-btn" id="runQueryBtn">▶ Route</button>
        </div>
      </div>

      <div class="routing-viz" id="routingViz">
        <div class="routing-stage" id="routingStage">
          <div class="route-app">📱 Application</div>
          <div class="route-arrow" id="routeArrow1"></div>
          <div class="route-gate" id="routeGate">⚡ vtgate</div>
          <div class="route-arrows" id="routeArrows"></div>
          <div class="route-shards" id="routeShards"></div>
        </div>
        <div class="routing-log" id="routingLog"></div>
      </div>
    </section>

    <!-- Resharding -->
    <section class="reshard-section">
      <h2>🔀 Zero-Downtime Resharding</h2>
      <p class="section-desc">Watch data migrate from 2 shards to 4 shards with no downtime</p>

      <div class="reshard-controls">
        <button class="action-btn primary-btn" id="startReshardBtn">▶ Start Reshard (2→4)</button>
        <button class="action-btn step-btn" id="reshardStepBtn" disabled>⏭ Next Phase</button>
        <button class="action-btn auto-btn" id="reshardAutoBtn" disabled>⚡ Auto-Play</button>
        <button class="action-btn reset-btn" id="resetReshardBtn">🔄 Reset</button>
      </div>

      <div class="reshard-status" id="reshardStatus">
        <span class="status-badge idle">Ready</span>
        <span class="status-text" id="reshardStatusText">Click "Start Reshard" to begin the migration</span>
      </div>

      <div class="reshard-viz">
        <div class="reshard-side">
          <h4>Source Shards (2)</h4>
          <div class="reshard-shards" id="sourceShards">
            <div class="reshard-shard source-shard" id="src-80">
              <div class="shard-header">-80</div>
              <div class="shard-rows" id="src-80-rows"></div>
            </div>
            <div class="reshard-shard source-shard" id="src80-">
              <div class="shard-header">80-</div>
              <div class="shard-rows" id="src80--rows"></div>
            </div>
          </div>
        </div>
        <div class="reshard-middle">
          <div class="reshard-flow" id="reshardFlow"></div>
        </div>
        <div class="reshard-side">
          <h4>Target Shards (4)</h4>
          <div class="reshard-shards" id="targetShards">
            <div class="reshard-shard target-shard" id="tgt-40">
              <div class="shard-header">-40</div>
              <div class="shard-rows" id="tgt-40-rows"></div>
            </div>
            <div class="reshard-shard target-shard" id="tgt40-80">
              <div class="shard-header">40-80</div>
              <div class="shard-rows" id="tgt40-80-rows"></div>
            </div>
            <div class="reshard-shard target-shard" id="tgt80-c0">
              <div class="shard-header">80-c0</div>
              <div class="shard-rows" id="tgt80-c0-rows"></div>
            </div>
            <div class="reshard-shard target-shard" id="tgtc0-">
              <div class="shard-header">c0-</div>
              <div class="shard-rows" id="tgtc0--rows"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="reshard-timeline" id="reshardTimeline"></div>
    </section>

    <!-- Explain: Resharding Phases -->
    <section class="explain-section">
      <div class="explain-grid">
        <div class="explain-card">
          <h3>📋 Phase 1: Copy</h3>
          <p>
            VReplication creates a <strong>snapshot</strong> of existing data and streams it to 
            the new target shards. The source shards continue serving all traffic. 
            No downtime, no impact on reads or writes.
          </p>
        </div>
        <div class="explain-card">
          <h3>🔄 Phase 2: Catch-up</h3>
          <p>
            After the bulk copy, VReplication enters <strong>streaming mode</strong> — 
            replicating the binlog in real-time. Target shards converge to match the source. 
            The lag drops to near-zero.
          </p>
        </div>
        <div class="explain-card">
          <h3>👀 Phase 3: SwitchReads</h3>
          <p>
            vtgate starts sending <strong>read queries</strong> to the new target shards. 
            Writes still go to source. This is safe because target is caught up. 
            Validate data integrity before proceeding.
          </p>
        </div>
        <div class="explain-card">
          <h3>✅ Phase 4: SwitchWrites</h3>
          <p>
            The critical moment: vtgate switches <strong>writes</strong> to target shards. 
            There's a brief pause (seconds) to ensure the final binlog events replicate. 
            After this, source shards are idle and can be removed.
          </p>
        </div>
      </div>
    </section>

    <!-- VReplication Animation -->
    <section class="vrepl-section">
      <h2>🔄 VReplication: The Engine Behind Resharding</h2>
      <p class="section-desc">Stream-based data movement — the backbone of all Vitess data operations</p>

      <div class="vrepl-controls">
        <button class="action-btn primary-btn" id="startVreplBtn">▶ Start Stream</button>
        <button class="action-btn reset-btn" id="resetVreplBtn">🔄 Reset</button>
      </div>

      <div class="vrepl-viz">
        <div class="vrepl-source">
          <h4>Source MySQL (binlog)</h4>
          <div class="binlog-stream" id="binlogStream"></div>
        </div>
        <div class="vrepl-pipe">
          <div class="pipe-label">VStream gRPC</div>
          <div class="pipe-particles" id="pipeParticles"></div>
        </div>
        <div class="vrepl-target">
          <h4>Target vttablet</h4>
          <div class="vrepl-stages">
            <div class="vrepl-stage" id="vreplFilter">🔍 Filter</div>
            <div class="vrepl-stage" id="vreplTransform">🔄 Transform</div>
            <div class="vrepl-stage" id="vreplApply">💾 Apply</div>
          </div>
          <div class="applied-rows" id="appliedRows"></div>
        </div>
      </div>
    </section>

    <!-- Vindex Lookup Animation -->
    <section class="vindex-section">
      <h2>🔑 Vindex: How Vitess Finds Your Data</h2>
      <p class="section-desc">Vindexes map column values to keyspace IDs, determining which shard owns a row</p>

      <div class="vindex-controls">
        <label>Lookup user_id:</label>
        <input type="number" id="vindexInput" value="42" min="1" max="999">
        <button class="action-btn primary-btn" id="vindexLookupBtn">🔍 Resolve Vindex</button>
      </div>

      <div class="vindex-viz" id="vindexViz">
        <div class="vindex-step" id="vindexStep1">
          <div class="vindex-step-num">1</div>
          <div class="vindex-step-content">
            <div class="vindex-step-title">Input Value</div>
            <div class="vindex-step-value" id="vindexInputVal">user_id = 42</div>
          </div>
        </div>
        <div class="vindex-arrow-down">▼</div>
        <div class="vindex-step" id="vindexStep2">
          <div class="vindex-step-num">2</div>
          <div class="vindex-step-content">
            <div class="vindex-step-title">Hash Function (xxHash64)</div>
            <div class="vindex-step-value" id="vindexHashVal">computing...</div>
          </div>
        </div>
        <div class="vindex-arrow-down">▼</div>
        <div class="vindex-step" id="vindexStep3">
          <div class="vindex-step-num">3</div>
          <div class="vindex-step-content">
            <div class="vindex-step-title">Keyspace ID</div>
            <div class="vindex-step-value" id="vindexKsid">0x...</div>
          </div>
        </div>
        <div class="vindex-arrow-down">▼</div>
        <div class="vindex-step" id="vindexStep4">
          <div class="vindex-step-num">4</div>
          <div class="vindex-step-content">
            <div class="vindex-step-title">Shard Match</div>
            <div class="vindex-step-value" id="vindexShard">shard -80</div>
          </div>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://vitess.io/docs/" target="_blank">Vitess Documentation</a> and <a href="https://www.youtube.com/watch?v=OCS45iy5v1M" target="_blank">Vitess: Sharding MySQL at Scale (YouTube)</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share this visualization:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20visualization%20of%20Vitess%20Sharding%20—%20MySQL%20horizontal%20scaling&url=https://systeminternals.dev/vitess/sharding/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/vitess/sharding/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/vitess/sharding/&t=Interactive%20Vitess%20Sharding%20Visualizer" target="_blank" class="share-btn">🟧 Hacker News</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .viz-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #56db3a, #3b82f6, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #888;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 12px;
  }

  .section-desc {
    color: #888;
    margin-bottom: 24px;
    font-size: 1rem;
  }

  /* Overview */
  .overview-section {
    margin-bottom: 50px;
  }

  .overview-card {
    background: linear-gradient(135deg, rgba(86, 219, 58, 0.1), rgba(59, 130, 246, 0.05));
    border: 1px solid rgba(86, 219, 58, 0.3);
    border-radius: 16px;
    padding: 24px 28px;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #ccc;
  }

  .overview-card strong { color: #fff; }
  .overview-card em { color: #56db3a; font-style: normal; font-weight: 500; }
  .overview-card a { color: #60a5fa; }

  /* Action Buttons */
  .action-btn {
    padding: 10px 20px;
    border: none;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .action-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .primary-btn {
    background: linear-gradient(135deg, #56db3a, #22a83a);
    color: white;
  }

  .primary-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(86, 219, 58, 0.4);
  }

  .step-btn {
    background: linear-gradient(135deg, #60a5fa, #3b82f6);
    color: white;
  }

  .auto-btn {
    background: linear-gradient(135deg, #f472b6, #ec4899);
    color: white;
  }

  .reset-btn {
    background: rgba(255,255,255,0.1);
    color: #aaa;
  }

  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  /* Architecture */
  .arch-section {
    margin-bottom: 50px;
  }

  .arch-diagram {
    background: rgba(0,0,0,0.2);
    border-radius: 16px;
    padding: 30px;
    border: 1px solid rgba(255,255,255,0.1);
    position: relative;
    margin-bottom: 16px;
  }

  .arch-layer {
    margin-bottom: 8px;
  }

  .arch-label {
    font-size: 0.75rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }

  .arch-nodes {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .arch-node {
    padding: 12px 20px;
    border-radius: 10px;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
    border: 1px solid transparent;
  }

  .arch-node:hover {
    transform: translateY(-2px);
  }

  .arch-node small {
    font-size: 0.7rem;
    opacity: 0.7;
  }

  .app-node { background: rgba(167, 139, 250, 0.15); border-color: rgba(167, 139, 250, 0.3); color: #c4b5fd; }
  .gate-node { background: rgba(251, 191, 36, 0.15); border-color: rgba(251, 191, 36, 0.3); color: #fcd34d; }
  .tablet-node { background: rgba(86, 219, 58, 0.15); border-color: rgba(86, 219, 58, 0.3); color: #86efac; }
  .tablet-node.replica { opacity: 0.7; }
  .mysql-node { background: rgba(59, 130, 246, 0.15); border-color: rgba(59, 130, 246, 0.3); color: #93c5fd; }
  .topo-node { background: rgba(244, 114, 182, 0.15); border-color: rgba(244, 114, 182, 0.3); color: #f9a8d4; }
  .vtctld-node { background: rgba(239, 68, 68, 0.15); border-color: rgba(239, 68, 68, 0.3); color: #fca5a5; }

  .arch-node.selected {
    box-shadow: 0 0 20px rgba(86, 219, 58, 0.4);
    transform: translateY(-3px);
  }

  .arch-arrow {
    text-align: center;
    color: #555;
    font-size: 0.8rem;
    padding: 6px 0;
  }

  .arch-side {
    position: absolute;
    right: 20px;
    top: 30px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .arch-info {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 16px 20px;
  }

  .info-title {
    font-weight: 600;
    color: #fff;
    margin-bottom: 8px;
    font-size: 1rem;
  }

  .info-body {
    color: #aaa;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* VSchema */
  .vschema-section {
    margin-bottom: 50px;
  }

  .vschema-demo {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 20px;
  }

  .vschema-editor {
    background: rgba(0,0,0,0.3);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .editor-header {
    padding: 12px 16px;
    background: rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 0.85rem;
    color: #aaa;
  }

  .editor-tabs {
    display: flex;
    gap: 6px;
  }

  .editor-tab {
    padding: 4px 12px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    background: transparent;
    color: #888;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .editor-tab.active {
    background: rgba(86, 219, 58, 0.2);
    border-color: rgba(86, 219, 58, 0.4);
    color: #56db3a;
  }

  .editor-code {
    padding: 16px;
    margin: 0;
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 0.82rem;
    line-height: 1.6;
    color: #ccc;
    overflow-x: auto;
    min-height: 200px;
  }

  .vschema-explain {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 20px;
    font-size: 0.9rem;
    color: #aaa;
    line-height: 1.7;
  }

  /* Keyspace Visualizer */
  .keyspace-section {
    margin-bottom: 50px;
  }

  .keyspace-controls {
    margin-bottom: 20px;
  }

  .insert-form {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .insert-form label {
    color: #ccc;
    font-size: 0.95rem;
  }

  .insert-form input {
    padding: 8px 14px;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 8px;
    color: #fff;
    font-size: 0.95rem;
    width: 80px;
  }

  .keyspace-viz {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 24px;
    margin-bottom: 16px;
  }

  .keyspace-ring {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    border: 3px solid rgba(86, 219, 58, 0.3);
    position: relative;
    display: flex;
