<script is:inline>
  // ========== UTILITY: Simple hash for vindex simulation ==========
  function simpleHash(val) {
    var h = 0x811c9dc5;
    var s = String(val);
    for (var i = 0; i < s.length; i++) {
      h ^= s.charCodeAt(i);
      h = Math.imul(h, 0x01000193);
    }
    return h >>> 0;
  }

  function toKeyspaceId(userId) {
    var h = simpleHash(userId);
    return ((h & 0xFF) << 24 | (h >> 8 & 0xFF) << 16 | (h >> 16 & 0xFF) << 8 | (h >> 24 & 0xFF)) >>> 0;
  }

  function ksidHex(userId) {
    return '0x' + toKeyspaceId(userId).toString(16).padStart(8, '0');
  }

  function getShardFor2(userId) {
    var ksid = toKeyspaceId(userId);
    return ksid < 0x80000000 ? '-80' : '80-';
  }

  function getShardFor4(userId) {
    var ksid = toKeyspaceId(userId);
    if (ksid < 0x40000000) return '-40';
    if (ksid < 0x80000000) return '40-80';
    if (ksid < 0xC0000000) return '80-c0';
    return 'c0-';
  }

  // ========== ARCHITECTURE COMPONENT INFO ==========
  var compInfo = {
    app: { title: '📱 Application', body: 'Your application connects to vtgate using the standard MySQL protocol. No code changes needed — vtgate looks like a regular MySQL server. Connection pools, ORMs, and existing queries all work as-is.' },
    vtgate: { title: '⚡ vtgate (Proxy)', body: 'The stateless query router. Parses SQL, consults the VSchema to determine which shard(s) to target, sends sub-queries to vttablets, and merges results. Multiple vtgates run behind a load balancer for HA.' },
    vttablet: { title: '📦 vttablet (Tablet Manager)', body: 'One vttablet per MySQL instance. It manages the MySQL lifecycle, handles connection pooling (reducing MySQL connections 10-100×), enforces query timeouts, and runs health checks. Each tablet is either primary or replica.' },
    replica: { title: '📦 vttablet (Replica)', body: 'Replica tablets serve read-only queries (SELECT). vtgate can route reads to replicas to spread load. During resharding, replicas are promoted to serve the new shard topology.' },
    mysql: { title: '🐬 MySQL', body: 'Standard MySQL (or Percona/MariaDB). Vitess treats MySQL as a "dumb" storage engine — all intelligence lives in vttablet and vtgate. Each MySQL instance stores one shard\'s data.' },
    topo: { title: '🗺️ Topology Service', body: 'A distributed lock server (etcd, ZooKeeper, or Consul) that stores the cluster metadata: which shards exist, where tablets are, who is primary. The single source of truth for cluster state.' },
    vtctld: { title: '🎛️ vtctld (Control Plane)', body: 'The admin server. Exposes APIs and a web UI for managing the cluster: initiating resharding, running schema changes, performing failovers, and monitoring health. You interact with it via vtctlclient CLI.' }
  };

  document.querySelectorAll('.arch-node').forEach(function(node) {
    node.addEventListener('click', function() {
      var comp = this.getAttribute('data-comp');
      var info = compInfo[comp];
      if (!info) return;
      document.querySelectorAll('.arch-node').forEach(function(n) { n.classList.remove('selected'); });
      this.classList.add('selected');
      document.getElementById('archInfoTitle').textContent = info.title;
      document.getElementById('archInfoBody').textContent = info.body;
    });
  });

  // ========== VSCHEMA TABS ==========
  var vschemaData = {
    hash: {
      code: '{\n  "sharded": true,\n  "vindexes": {\n    "hash": {\n      "type": "hash"\n    }\n  },\n  "tables": {\n    "users": {\n      "column_vindexes": [\n        {\n          "column": "user_id",\n          "name": "hash"\n        }\n      ]\n    }\n  }\n}',
      explain: '<strong style="color:#fff">Hash Vindex</strong><br><br>The most common vindex type. Takes the sharding column value (user_id), hashes it, and produces a <span style="color:#56db3a">keyspace ID</span>.<br><br>✅ <strong style="color:#56db3a">Even distribution</strong> — hash spreads data uniformly<br>✅ <strong style="color:#56db3a">Single-shard lookups</strong> — WHERE user_id = ? hits one shard<br>❌ No range queries on user_id (hash destroys ordering)<br><br>Best for: primary keys, user IDs, UUIDs'
    },
    region: {
      code: '{\n  "sharded": true,\n  "vindexes": {\n    "region_vdx": {\n      "type": "region_experimental",\n      "params": {\n        "region_bytes": "1"\n      }\n    }\n  },\n  "tables": {\n    "orders": {\n      "column_vindexes": [\n        {\n          "columns": ["region", "order_id"],\n          "name": "region_vdx"\n        }\n      ]\n    }\n  }\n}',
      explain: '<strong style="color:#fff">Region Vindex</strong><br><br>Prefixes the keyspace ID with a <span style="color:#56db3a">region byte</span>, guaranteeing all rows from the same region land on the same shard (or adjacent shards).<br><br>✅ <strong style="color:#56db3a">Data locality</strong> — same-region queries stay single-shard<br>✅ <strong style="color:#56db3a">Compliance</strong> — keep EU data in EU shards<br>❌ Risk of hotspots if one region is much larger<br><br>Best for: multi-region deployments, data sovereignty'
    },
    lookup: {
      code: '{\n  "sharded": true,\n  "vindexes": {\n    "hash": { "type": "hash" },\n    "email_lookup": {\n      "type": "consistent_lookup",\n      "params": {\n        "table": "email_user_idx",\n        "from": "email",\n        "to": "user_id"\n      },\n      "owner": "users"\n    }\n  },\n  "tables": {\n    "users": {\n      "column_vindexes": [\n        { "column": "user_id", "name": "hash" },\n        { "column": "email", "name": "email_lookup" }\n      ]\n    }\n  }\n}',
      explain: '<strong style="color:#fff">Lookup Vindex</strong><br><br>A secondary index stored as a <span style="color:#56db3a">separate Vitess table</span>. Maps a non-sharding column (email) back to the sharding key (user_id).<br><br>✅ <strong style="color:#56db3a">Single-shard lookup by email</strong> — no scatter!<br>✅ Automatically maintained by Vitess on INSERT/UPDATE<br>❌ Extra write per insert (to maintain the lookup table)<br>❌ Slightly higher read latency (two-hop lookup)<br><br>Best for: unique secondary keys (email, username, SSN)'
    }
  };

  function showVschemaTab(tab) {
    document.querySelectorAll('.editor-tab').forEach(function(t) { t.classList.remove('active'); });
    document.querySelector('.editor-tab[data-tab="' + tab + '"]').classList.add('active');
    document.getElementById('vschemaCode').textContent = vschemaData[tab].code;
    document.getElementById('vschemaExplain').innerHTML = vschemaData[tab].explain;
  }

  document.querySelectorAll('.editor-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      showVschemaTab(this.getAttribute('data-tab'));
    });
  });
  showVschemaTab('hash');

  // ========== KEYSPACE VISUALIZER ==========
  var shardData = { '-80': [], '80-': [] };

  function renderKeyspace() {
    var panels = document.getElementById('shardPanels');
    panels.innerHTML = '';
    var shardNames = Object.keys(shardData);
    shardNames.forEach(function(name) {
      var panel = document.createElement('div');
      panel.className = 'shard-panel';
      var rows = shardData[name];
      panel.innerHTML = '<div class="shard-panel-header"><span>Shard ' + name + '</span><span>' + rows.length + ' rows</span></div>' +
        '<div class="shard-panel-body">' +
        (rows.length === 0 ? '<span style="color:#555">Empty</span>' :
          rows.map(function(r) { return '<div class="shard-row">user_id=' + r.id + ' ksid=' + r.ksid + '</div>'; }).join('')) +
        '</div>';
      panels.appendChild(panel);
    });
  }

  function insertUser(userId, highlight) {
    var shard = getShardFor2(userId);
    var hex = ksidHex(userId);
    shardData[shard].push({ id: userId, ksid: hex });
    renderKeyspace();
    document.getElementById('vindexCalc').textContent = 'user_id=' + userId + ' → hash → ksid=' + hex + ' → shard ' + shard;
    if (highlight) {
      var panels = document.getElementById('shardPanels');
      var allRows = panels.querySelectorAll('.shard-row');
      var last = allRows[allRows.length - 1];
      if (last) last.classList.add('highlight');
    }
  }

  document.getElementById('insertBtn').addEventListener('click', function() {
    var val = parseInt(document.getElementById('insertUserId').value) || 1;
    insertUser(val, true);
  });

  document.getElementById('insertBatchBtn').addEventListener('click', function() {
    for (var i = 0; i < 20; i++) {
      var uid = Math.floor(Math.random() * 999) + 1;
      var shard = getShardFor2(uid);
      shardData[shard].push({ id: uid, ksid: ksidHex(uid) });
    }
    renderKeyspace();
    document.getElementById('vindexCalc').textContent = 'Inserted 20 random users across shards';
  });

  document.getElementById('resetKeyspaceBtn').addEventListener('click', function() {
    shardData = { '-80': [], '80-': [] };
    renderKeyspace();
    document.getElementById('vindexCalc').textContent = '';
  });

  renderKeyspace();

  // ========== QUERY ROUTING ==========
  var shardNames2 = ['-80', '80-'];

  function routeQuery(sql) {
    var gate = document.getElementById('routeGate');
    var shards = document.getElementById('routeShards');
    var arrows = document.getElementById('routeArrows');
    var log = document.getElementById('routingLog');
    var arrow1 = document.getElementById('routeArrow1');

    arrow1.textContent = '→';
    gate.classList.add('active');

    shards.innerHTML = '';
    shardNames2.forEach(function(s) {
      var el = document.createElement('div');
      el.className = 'route-shard';
      el.textContent = s;
      el.setAttribute('data-shard', s);
      shards.appendChild(el);
    });

    var targeted = [];
    var plan = '';
    var routeType = '';

    var lowerSql = sql.toLowerCase();

    if (lowerSql.match(/where\s+user_id\s*=\s*(\d+)/)) {
      var uid = parseInt(lowerSql.match(/where\s+user_id\s*=\s*(\d+)/)[1]);
      var shard = getShardFor2(uid);
      targeted = [shard];
      plan = 'Equal unique vindex: user_id=' + uid + ' → ksid=' + ksidHex(uid) + ' → shard ' + shard;
      routeType = 'Single Shard';
    } else if (lowerSql.match(/user_id\s+in\s*\(/)) {
      var ids = lowerSql.match(/\(([^)]+)\)/);
      if (ids) {
        var nums = ids[1].split(',').map(function(x) { return parseInt(x.trim()); });
        var shardSet = {};
        nums.forEach(function(n) { shardSet[getShardFor2(n)] = true; });
        targeted = Object.keys(shardSet);
        plan = 'IN clause: resolving ' + nums.length + ' vindex lookups → ' + targeted.length + ' shard(s): ' + targeted.join(', ');
        routeType = targeted.length > 1 ? 'Scatter (subset)' : 'Single Shard';
      }
    } else if (lowerSql.match(/insert\s+into/)) {
      var valMatch = lowerSql.match(/values\s*\(\s*(\d+)/);
      if (valMatch) {
        var iuid = parseInt(valMatch[1]);
        var ishard = getShardFor2(iuid);
        targeted = [ishard];
        plan = 'INSERT routed by primary vindex: user_id=' + iuid + ' → shard ' + ishard;
        routeType = 'Single Shard';
      }
    }

    if (targeted.length === 0) {
      targeted = shardNames2.slice();
      plan = 'No vindex match — scatter query to ALL shards, merge results at vtgate';
      routeType = 'Scatter-Gather';
    }

    arrows.textContent = targeted.length > 1 ? '⇉' : '→';

    setTimeout(function() {
      targeted.forEach(function(s) {
        var el = shards.querySelector('[data-shard="' + s + '"]');
        if (el) el.classList.add('targeted');
      });

      var color = routeType === 'Scatter-Gather' ? 'log-scatter' : 'log-route';
      log.innerHTML = '<div class="log-line"><span class="' + color + '">[' + routeType + ']</span> ' + plan + '</div>' +
        '<div class="log-line"><span class="log-info">[SQL]</span> ' + sql + '</div>';
    }, 300);

    setTimeout(function() {
      gate.classList.remove('active');
    }, 1500);
  }

  document.querySelectorAll('.query-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var q = this.getAttribute('data-query');
      document.getElementById('queryInput').value = q;
      routeQuery(q);
    });
  });

  document.getElementById('runQueryBtn').addEventListener('click', function() {
    var q = document.getElementById('queryInput').value.trim();
    if (q) routeQuery(q);
  });

  document.getElementById('queryInput').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      var q = this.value.trim();
      if (q) routeQuery(q);
    }
  });

  // ========== RESHARDING ==========
  var reshardStep = 0;
  var reshardAutoPlaying = false;
  var sourceRows = [];

  // Generate initial data
  (function() {
    for (var i = 0; i < 16; i++) {
      var uid = Math.floor(Math.random() * 999) + 1;
      sourceRows.push({ id: uid, ksid: toKeyspaceId(uid) });
    }
  })();

  function renderSourceShards() {
    var s80 = document.getElementById('src-80-rows');
    var s80p = document.getElementById('src80--rows');
    s80.innerHTML = '';
    s80p.innerHTML = '';
    sourceRows.forEach(function(r) {
      var el = document.createElement('div');
      el.className = 'shard-data-row';
      el.textContent = 'uid=' + r.id;
      if (r.ksid < 0x80000000) {
        s80.appendChild(el);
      } else {
        s80p.appendChild(el);
      }
    });
  }

  function clearTargetShards() {
    ['tgt-40-rows', 'tgt40-80-rows', 'tgt80-c0-rows', 'tgtc0--rows'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.innerHTML = '';
    });
  }

  function renderTargetShards() {
    clearTargetShards();
    sourceRows.forEach(function(r) {
      var shard = getShardFor4(r.id);
      var targetId;
      if (shard === '-40') targetId = 'tgt-40-rows';
      else if (shard === '40-80') targetId = 'tgt40-80-rows';
      else if (shard === '80-c0') targetId = 'tgt80-c0-rows';
      else targetId = 'tgtc0--rows';
      var el = document.createElement('div');
      el.className = 'shard-data-row';
      el.textContent = 'uid=' + r.id;
      var container = document.getElementById(targetId);
      if (container) container.appendChild(el);
    });
  }

  var reshardPhases = [
    {
      badge: 'copy', badgeText: 'Copy',
      text: 'Phase 1: VReplication copying snapshot from source → target shards',
      action: function() {
        document.getElementById('reshardFlow').innerHTML = '📋<br>Copying...';
        document.getElementById('reshardFlow').className = 'reshard-flow streaming';
        document.querySelectorAll('.target-shard').forEach(function(s) { s.classList.add('active'); s.classList.remove('inactive'); });
        renderTargetShards();
        addReshardEvent('copy-ev', 'COPY', 'Snapshot copy started — streaming existing rows to target shards');
      }
    },
    {
      badge: 'catchup', badgeText: 'Catch-up',
      text: 'Phase 2: Streaming binlog events — target shards catching up to source',
      action: function() {
        document.getElementById('reshardFlow').innerHTML = '🔄<br>Streaming';
        addReshardEvent('catchup-ev', 'CATCH-UP', 'VReplication streaming binlog — replication lag < 1s');
      }
    },
    {
      badge: 'switchreads', badgeText: 'SwitchReads',
      text: 'Phase 3: SwitchReads — reads now served by target shards',
      action: function() {
        document.getElementById('reshardFlow').innerHTML = '👀<br>Reads →';
        addReshardEvent('switch-ev', 'SWITCH_READS', 'vtgate now routing SELECT queries to target shards');
      }
    },
    {
      badge: 'switchwrite', badgeText: 'SwitchWrites',
      text: 'Phase 4: SwitchWrites — brief pause, then writes go to target shards',
      action: function() {
        document.getElementById('reshardFlow').innerHTML = '✅<br>Writes →';
        document.querySelectorAll('.source-shard').forEach(function(s) { s.classList.add('dimmed'); });
        addReshardEvent('switch-ev', 'SWITCH_WRITES', 'Traffic fully cut over — target shards are now primary');
      }
    },
    {
      badge: 'done', badgeText: 'Complete',
      text: 'Resharding complete! Source shards can be decommissioned 🎉',
      action: function() {
        document.getElementById('reshardFlow').innerHTML = '🎉<br>Done!';
        addReshardEvent('done-ev', 'COMPLETE', 'Reshard 2→4 finished. Source shards idle, safe to remove.');
      }
    }
  ];

  function addReshardEvent(cls, phase, text) {
    var tl = document.getElementById('reshardTimeline');
    var ev = document.createElement('div');
    ev.className = 'reshard-event ' + cls;
    ev.innerHTML = '<span class="ev-phase">[' + phase + ']</span> ' + text;
    tl.appendChild(ev);
    tl.scrollTop = tl.scrollHeight;
  }

  function updateReshardStatus(badge, text) {
    var statusBadge = document.querySelector('.reshard-status .status-badge');
    statusBadge.className = 'status-badge ' + badge;
    statusBadge.textContent = reshardPhases[reshardStep] ? reshardPhases[reshardStep].badgeText : 'Done';
    document.getElementById('reshardStatusText').textContent = text;
  }

  function executeReshardStep() {
    var phase = reshardPhases[reshardStep];
    if (!phase) return;
    updateReshardStatus(phase.badge, phase.text);
    phase.action();
  }

  document.getElementById('startReshardBtn').addEventListener('click', function() {
    reshardStep = 0;
    document.getElementById('reshardTimeline').innerHTML = '';
    document.querySelectorAll('.source-shard').forEach(function(s) { s.classList.remove('dimmed'); });
    document.querySelectorAll('.target-shard').forEach(function(s) { s.classList.add('inactive'); s.classList.remove('active'); });
    clearTargetShards();
    document.getElementById('reshardFlow').innerHTML = '⏸<br>Ready';
    document.getElementById('reshardFlow').className = 'reshard-flow';
    renderSourceShards();
    executeReshardStep();
    document.getElementById('reshardStepBtn').disabled = false;
    document.getElementById('reshardAutoBtn').disabled = false;
  });

  document.getElementById('reshardStepBtn').addEventListener('click', function() {
    if (reshardStep < reshardPhases.length - 1) {
      reshardStep++;
      executeReshardStep();
      if (reshardStep >= reshardPhases.length - 1) {
        document.getElementById('reshardStepBtn').disabled = true;
        document.getElementById('reshardAutoBtn').disabled = true;
      }
    }
  });

  document.getElementById('reshardAutoBtn').addEventListener('click', function() {
    if (reshardAutoPlaying) return;
    reshardAutoPlaying = true;
    document.getElementById('reshardAutoBtn').disabled = true;
    document.getElementById('reshardStepBtn').disabled = true;

    function nextStep() {
      if (reshardStep < reshardPhases.length - 1) {
        reshardStep++;
        executeReshardStep();
        setTimeout(nextStep, 1500);
      } else {
        reshardAutoPlaying = false;
      }
    }
    setTimeout(nextStep, 1500);
  });

  document.getElementById('resetReshardBtn').addEventListener('click', function() {
    reshardStep = 0;
    reshardAutoPlaying = false;
    document.getElementById('reshardTimeline').innerHTML = '';
    var statusBadge = document.querySelector('.reshard-status .status-badge');
    statusBadge.className = 'status-badge idle';
    statusBadge.textContent = 'Ready';
    document.getElementById('reshardStatusText').textContent = 'Click "Start Reshard" to begin the migration';
    document.getElementById('reshardFlow').innerHTML = '';
    document.getElementById('reshardFlow').className = 'reshard-flow';
    document.querySelectorAll('.source-shard').forEach(function(s) { s.classList.remove('dimmed'); });
    document.querySelectorAll('.target-shard').forEach(function(s) { s.classList.remove('active'); s.classList.add('inactive'); });
    clearTargetShards();
    renderSourceShards();
    document.getElementById('reshardStepBtn').disabled = true;
    document.getElementById('reshardAutoBtn').disabled = true;
  });

  renderSourceShards();
  document.querySelectorAll('.target-shard').forEach(function(s) { s.classList.add('inactive'); });

  // ========== VREPLICATION ANIMATION ==========
  var vreplRunning = false;
  var vreplInterval = null;
  var vreplCount = 0;

  var binlogOps = ['INSERT', 'UPDATE', 'DELETE', 'INSERT', 'INSERT', 'UPDATE'];
  var binlogTables = ['users', 'orders', 'products', 'users', 'orders', 'users'];

  document.getElementById('startVreplBtn').addEventListener('click', function() {
    if (vreplRunning) {
      vreplRunning = false;
      clearInterval(vreplInterval);
      this.textContent = '▶ Start Stream';
      document.getElementById('pipeParticles').classList.remove('active');
      document.getElementById('pipeParticles').innerHTML = '';
      document.querySelectorAll('.vrepl-stage').forEach(function(s) { s.classList.remove('active'); });
      return;
    }

    vreplRunning = true;
    this.textContent = '⏹ Stop Stream';
    document.getElementById('pipeParticles').classList.add('active');

    var dot = document.createElement('div');
    dot.className = 'pipe-dot';
    document.getElementById('pipeParticles').appendChild(dot);

    var stages = ['vreplFilter', 'vreplTransform', 'vreplApply'];

    vreplInterval = setInterval(function() {
      vreplCount++;
      var opIdx = vreplCount % binlogOps.length;
      var op = binlogOps[opIdx];
      var table = binlogTables[opIdx];
      var uid = Math.floor(Math.random() * 999) + 1;

      // Add binlog entry
      var binlog = document.getElementById('binlogStream');
      var cls = op === 'INSERT' ? 'insert-entry' : op === 'UPDATE' ? 'update-entry' : 'delete-entry';
      var entry = document.createElement('div');
      entry.className = 'binlog-entry ' + cls;
      entry.innerHTML = '<span class="be-type">' + op + '</span> ' + table + ' uid=' + uid;
      binlog.appendChild(entry);
      binlog.scrollTop = binlog.scrollHeight;

      // Animate stages
      var stageIdx = 0;
      function lightStage() {
        if (stageIdx > 0) document.getElementById(stages[stageIdx - 1]).classList.remove('active');
        if (stageIdx < stages.length) {
          document.getElementById(stages[stageIdx]).classList.add('active');
          stageIdx++;
          setTimeout(lightStage, 200);
        } else {
          setTimeout(function() {
            document.getElementById(stages[stages.length - 1]).classList.remove('active');
          }, 200);

          // Add applied row
          if (op !== 'DELETE') {
            var applied = document.getElementById('appliedRows');
            var row = document.createElement('div');
            row.className = 'applied-row';
            row.textContent = '✓ ' + op + ' ' + table + ' uid=' + uid;
            applied.appendChild(row);
            applied.scrollTop = applied.scrollHeight;
          }
        }
      }
      lightStage();
    }, 1200);
  });

  document.getElementById('resetVreplBtn').addEventListener('click', function() {
    vreplRunning = false;
    clearInterval(vreplInterval);
    vreplCount = 0;
    document.getElementById('startVreplBtn').textContent = '▶ Start Stream';
    document.getElementById('binlogStream').innerHTML = '';
    document.getElementById('appliedRows').innerHTML = '';
    document.getElementById('pipeParticles').classList.remove('active');
    document.getElementById('pipeParticles').innerHTML = '';
    document.querySelectorAll('.vrepl-stage').forEach(function(s) { s.classList.remove('active'); });
  });

  // ========== VINDEX LOOKUP ANIMATION ==========
  document.getElementById('vindexLookupBtn').addEventListener('click', function() {
    var userId = parseInt(document.getElementById('vindexInput').value) || 1;
    var hex = ksidHex(userId);
    var shard = getShardFor2(userId);

    var steps = document.querySelectorAll('.vindex-step');
    steps.forEach(function(s) { s.classList.remove('active'); });

    document.getElementById('vindexInputVal').textContent = 'user_id = ' + userId;
    document.getElementById('vindexHashVal').textContent = 'computing...';
    document.getElementById('vindexKsid').textContent = '0x...';
    document.getElementById('vindexShard').textContent = '...';

    // Animate step by step
    setTimeout(function() {
      steps[0].classList.add('active');
    }, 100);

    setTimeout(function() {
      steps[1].classList.add('active');
      document.getElementById('vindexHashVal').textContent = 'xxHash64(' + userId + ') = ' + hex;
    }, 600);

    setTimeout(function() {
      steps[2].classList.add('active');
      document.getElementById('vindexKsid').textContent = hex;
    }, 1200);

    setTimeout(function() {
      steps[3].classList.add('active');
      var firstByte = parseInt(hex.substring(2, 4), 16);
      var rangeExplain = firstByte < 0x80 ? hex + ' < 0x80... → shard -80' : hex + ' >= 0x80... → shard 80-';
      document.getElementById('vindexShard').textContent = shard + ' (' + rangeExplain + ')';
    }, 1800);
  });

  // Initial vindex lookup
  document.getElementById('vindexLookupBtn').click();
</script>
