---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "Sharding & Resharding", description: "VSchema, vindexes, keyspaces, and zero-downtime resharding", href: "/vitess/sharding/", status: "live" },
  { title: "Query Routing", description: "How vtgate routes queries: scatter-gather vs single-shard", href: "#", status: "coming" },
  { title: "VReplication", description: "Stream-based data movement for resharding and materialization", href: "#", status: "coming" },
  { title: "Topology & Service Discovery", description: "How Vitess tracks shards, tablets, and health across cells", href: "#", status: "coming" },
  { title: "Schema Management", description: "Online DDL with gh-ost and pt-osc across sharded keyspaces", href: "#", status: "coming" },
  { title: "Connection Pooling", description: "How vttablet pools MySQL connections and manages transactions", href: "#", status: "coming" },
  { title: "Backup & Restore", description: "Tablet snapshots, point-in-time recovery, and shard cloning", href: "#", status: "coming" },
  { title: "MoveTables & Migrations", description: "Migrating workloads between keyspaces with zero downtime", href: "#", status: "coming" },
];
---

<BaseLayout 
  title="Vitess Internals" 
  description="Interactive visualizations for understanding Vitess architecture, sharding, and MySQL horizontal scaling"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Vitess", href: "/vitess/" }]}
>
  <section class="section-header">
    <h1>🐬 Vitess Internals</h1>
    <p>
      Vitess is a database clustering system for horizontal scaling of MySQL. Born at YouTube to handle 
      massive traffic, it transparently shards your data while preserving MySQL compatibility. 
      These visualizations help you understand how it works under the hood.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(86, 219, 58, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
