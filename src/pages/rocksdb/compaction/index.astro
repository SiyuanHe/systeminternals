---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="RocksDB Compaction Strategies Deep Dive" 
  description="Interactive visualization of Leveled, Universal, and FIFO compaction in RocksDB with write/read/space amplification tradeoffs"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "RocksDB", href: "/rocksdb/" },
    { label: "Compaction Strategies", href: "/rocksdb/compaction/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🗜️ RocksDB Compaction Strategies</h1>
      <p class="subtitle">Leveled, Universal &amp; FIFO — See the Tradeoffs in Action</p>
    </header>

    <!-- Strategy Selector -->
    <section class="strategy-selector">
      <div class="strategy-tabs">
        <button class="strategy-tab active" data-strategy="leveled">
          <span class="tab-icon">📊</span>
          <span class="tab-label">Leveled</span>
          <span class="tab-desc">Default — balanced</span>
        </button>
        <button class="strategy-tab" data-strategy="universal">
          <span class="tab-icon">🌊</span>
          <span class="tab-label">Universal</span>
          <span class="tab-desc">Write-optimized</span>
        </button>
        <button class="strategy-tab" data-strategy="fifo">
          <span class="tab-icon">⏳</span>
          <span class="tab-label">FIFO</span>
          <span class="tab-desc">TTL data</span>
        </button>
      </div>
      <div class="strategy-description" id="strategyDesc">
        Leveled compaction: each level is 10x larger. Files with overlapping key ranges are merged into the next level. Best balance of read/write/space amplification.
      </div>
    </section>

    <!-- Controls -->
    <section class="controls-section">
      <div class="control-group">
        <button id="writeBtn" class="action-btn write-btn">✏️ Write KV</button>
        <button id="write10Btn" class="action-btn write-btn-secondary">⚡ Write 10</button>
        <button id="write50Btn" class="action-btn write-btn-tertiary">🔥 Write 50</button>
        <button id="readBtn" class="action-btn read-btn">🔍 Read Key</button>
        <button id="resetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>
    </section>

    <!-- Amplification Meters -->
    <section class="amp-meters">
      <div class="meter">
        <div class="meter-header">
          <span class="meter-label">Write Amplification</span>
          <span class="meter-value" id="writeAmpVal">1.0x</span>
        </div>
        <div class="meter-bar">
          <div class="meter-fill write-amp-fill" id="writeAmpBar" style="width: 5%"></div>
        </div>
        <span class="meter-hint">Bytes written to disk / bytes from app</span>
      </div>
      <div class="meter">
        <div class="meter-header">
          <span class="meter-label">Read Amplification</span>
          <span class="meter-value" id="readAmpVal">1</span>
        </div>
        <div class="meter-bar">
          <div class="meter-fill read-amp-fill" id="readAmpBar" style="width: 5%"></div>
        </div>
        <span class="meter-hint">Locations checked per read</span>
      </div>
      <div class="meter">
        <div class="meter-header">
          <span class="meter-label">Space Amplification</span>
          <span class="meter-value" id="spaceAmpVal">1.0x</span>
        </div>
        <div class="meter-bar">
          <div class="meter-fill space-amp-fill" id="spaceAmpBar" style="width: 5%"></div>
        </div>
        <span class="meter-hint">Disk used / actual data size</span>
      </div>
    </section>

    <!-- Stats Row -->
    <section class="stats-row">
      <div class="stat">
        <span class="stat-label">Writes</span>
        <span class="stat-value" id="writeCount">0</span>
      </div>
      <div class="stat">
        <span class="stat-label">Flushes</span>
        <span class="stat-value" id="flushCount">0</span>
      </div>
      <div class="stat">
        <span class="stat-label">Compactions</span>
        <span class="stat-value" id="compactionCount">0</span>
      </div>
      <div class="stat">
        <span class="stat-label">Unique Keys</span>
        <span class="stat-value" id="uniqueKeyCount">0</span>
      </div>
      <div class="stat">
        <span class="stat-label">Total SSTs</span>
        <span class="stat-value" id="totalSstCount">0</span>
      </div>
    </section>

    <!-- Main LSM Visualization -->
    <section class="lsm-viz">
      <!-- WAL -->
      <div class="component wal-component">
        <div class="component-header">
          <h3>📋 WAL (Write-Ahead Log)</h3>
          <span class="component-info">Append-only for crash recovery</span>
        </div>
        <div class="wal-bar" id="walBar">
          <div class="wal-entries" id="walEntries"></div>
        </div>
      </div>

      <!-- MemTable -->
      <div class="component memtable-component">
        <div class="component-header">
          <h3>📝 MemTable (RAM)</h3>
          <span class="component-info">Sorted skip-list — fast inserts</span>
        </div>
        <div class="memtable-bar">
          <div class="memtable-fill" id="memtableFill"></div>
          <span class="memtable-label" id="memtableLabel">0 / 6 keys</span>
        </div>
        <div class="memtable-keys" id="memtableKeys"></div>
      </div>

      <!-- Flush Arrow -->
      <div class="arrow-container" id="flushArrow">
        <div class="arrow">↓</div>
        <span class="arrow-label">Flush to L0 (sequential write)</span>
      </div>

      <!-- Levels -->
      <div class="levels-container" id="levelsContainer">
        <!-- Levels are rendered dynamically -->
      </div>
    </section>

    <!-- Activity Log -->
    <section class="log-section">
      <h3>📜 Activity Log</h3>
      <div class="log-container" id="activityLog">
        <div class="log-entry">System ready. Select a compaction strategy and start writing.</div>
      </div>
    </section>

    <!-- Column Families -->
    <section class="cf-section">
      <h2>🗃️ Column Families</h2>
      <p class="section-desc">Each column family has its own LSM-tree but shares a single WAL. This lets you tune compaction and compression per data type.</p>
      <div class="cf-diagram">
        <div class="cf-wal-shared">
          <div class="cf-wal-label">Shared WAL</div>
        </div>
        <div class="cf-trees">
          <div class="cf-tree">
            <div class="cf-name">default</div>
            <div class="cf-levels">
              <span class="cf-level">Mem</span>
              <span class="cf-level">L0</span>
              <span class="cf-level">L1</span>
              <span class="cf-level">L2</span>
            </div>
            <div class="cf-note">General data</div>
          </div>
          <div class="cf-tree">
            <div class="cf-name">write</div>
            <div class="cf-levels">
              <span class="cf-level">Mem</span>
              <span class="cf-level">L0</span>
              <span class="cf-level">L1</span>
              <span class="cf-level">L2</span>
            </div>
            <div class="cf-note">MVCC locks &amp; writes</div>
          </div>
          <div class="cf-tree">
            <div class="cf-name">lock</div>
            <div class="cf-levels">
              <span class="cf-level">Mem</span>
              <span class="cf-level">L0</span>
              <span class="cf-level">L1</span>
            </div>
            <div class="cf-note">Transaction locks (small)</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Bloom Filter Calculator -->
    <section class="bloom-section">
      <h2>🌸 Bloom Filter Calculator</h2>
      <p class="section-desc">Bloom filters let RocksDB skip SST files that definitely don't contain a key. More bits per key = fewer false positives = fewer wasted reads.</p>
      <div class="bloom-calc">
        <div class="bloom-input-group">
          <label for="bloomBits">Bits per key:</label>
          <input type="range" id="bloomBits" min="1" max="20" value="10" />
          <span id="bloomBitsVal">10</span>
        </div>
        <div class="bloom-input-group">
          <label for="bloomKeys">Keys in SST:</label>
          <input type="range" id="bloomKeys" min="100" max="100000" value="10000" step="100" />
          <span id="bloomKeysVal">10,000</span>
        </div>
        <div class="bloom-results">
          <div class="bloom-result">
            <span class="bloom-result-label">False positive rate</span>
            <span class="bloom-result-value" id="bloomFPR">0.82%</span>
          </div>
          <div class="bloom-result">
            <span class="bloom-result-label">Filter size</span>
            <span class="bloom-result-value" id="bloomSize">12.2 KB</span>
          </div>
          <div class="bloom-result">
            <span class="bloom-result-label">Reads saved per miss</span>
            <span class="bloom-result-value" id="bloomSaved">~99.2%</span>
          </div>
        </div>
        <div class="bloom-visual" id="bloomVisual"></div>
      </div>
    </section>

    <!-- Block Cache -->
    <section class="cache-section">
      <h2>💾 Block Cache</h2>
      <p class="section-desc">RocksDB caches hot data blocks in memory. Choose between LRU (simple, predictable) and Clock (lower lock contention, better for multi-threaded reads).</p>
      <div class="cache-comparison">
        <div class="cache-card">
          <h4>LRU Cache</h4>
          <div class="cache-detail">Mutex-protected doubly linked list</div>
          <div class="cache-pros">
            <div class="pro">✓ Predictable eviction</div>
            <div class="pro">✓ Well understood</div>
            <div class="pro">✓ Strict LRU ordering</div>
          </div>
          <div class="cache-cons">
            <div class="con">✗ Lock contention at high QPS</div>
            <div class="con">✗ Per-shard mutex</div>
          </div>
          <code>block_cache = NewLRUCache(8 &lt;&lt; 30);</code>
        </div>
        <div class="cache-card">
          <h4>Clock Cache</h4>
          <div class="cache-detail">Lock-free clock eviction algorithm</div>
          <div class="cache-pros">
            <div class="pro">✓ Better multi-thread scaling</div>
            <div class="pro">✓ Lower tail latency</div>
            <div class="pro">✓ Less lock contention</div>
          </div>
          <div class="cache-cons">
            <div class="con">✗ Approximate LRU</div>
            <div class="con">✗ Slightly more memory</div>
          </div>
          <code>block_cache = NewClockCache(8 &lt;&lt; 30);</code>
        </div>
      </div>
    </section>

    <!-- Explanation Cards -->
    <section class="explanation-section">
      <div class="explain-card">
        <h3>📊 Leveled Compaction (Default)</h3>
        <p>
          Each level is <strong>10x larger</strong> than the previous. When L(n) fills up, 
          RocksDB picks a file and merges it with overlapping files in L(n+1).
          Files within each level (except L0) have <strong>non-overlapping key ranges</strong>.
          Best for read-heavy workloads: point lookups only need to check one file per level.
        </p>
      </div>
      <div class="explain-card">
        <h3>🌊 Universal Compaction</h3>
        <p>
          All SSTs can have <strong>overlapping key ranges</strong>. Compaction picks sorted runs
          based on size ratio. Fewer compactions means <strong>lower write amplification</strong>
          (often 2-3x less than leveled), but reads may need to check more files.
          Ideal for write-heavy workloads where write throughput matters most.
        </p>
      </div>
      <div class="explain-card">
        <h3>⏳ FIFO Compaction</h3>
        <p>
          The simplest strategy: when total data exceeds a size limit, the
          <strong>oldest SST files are dropped</strong>. No merging, no rewriting.
          Zero write amplification beyond the initial flush. Perfect for
          <strong>time-series / TTL data</strong> where old data can be discarded.
        </p>
      </div>
    </section>

    <!-- Tradeoffs Table -->
    <section class="tradeoffs-section">
      <h2>⚖️ Amplification Tradeoffs</h2>
      <div class="tradeoffs-cards">
        <div class="tradeoff-card">
          <div class="tradeoff-header leveled-header">Leveled</div>
          <div class="tradeoff-row">
            <span>Write Amp</span>
            <div class="tradeoff-bar-container">
              <div class="tradeoff-bar high-bar" style="width:80%"></div>
            </div>
            <span class="tradeoff-rating">High (10-30x)</span>
          </div>
          <div class="tradeoff-row">
            <span>Read Amp</span>
            <div class="tradeoff-bar-container">
              <div class="tradeoff-bar low-bar" style="width:25%"></div>
            </div>
            <span class="tradeoff-rating">Low</span>
          </div>
          <div class="tradeoff-row">
            <span>Space Amp</span>
            <div class="tradeoff-bar-container">
              <div class="tradeoff-bar low-bar" style="width:20%"></div>
            </div>
            <span class="tradeoff-rating">Low (1.1x)</span>
          </div>
        </div>
        <div class="tradeoff-card">
          <div class="tradeoff-header universal-header">Universal</div>
          <div class="tradeoff-row">
            <span>Write Amp</span>
            <div class="tradeoff-bar-container">
              <div class="tradeoff-bar low-bar" style="width:30%"></div>
            </div>
            <span class="tradeoff-rating">Low</span>
          </div>
          <div class="tradeoff-row">
            <span>Read Amp</span>
            <div class="tradeoff-bar-container">
              <div class="tradeoff-bar medium-bar" style="width:55%"></div>
            </div>
            <span class="tradeoff-rating">Medium</span>
          </div>
          <div class="tradeoff-row">
            <span>Space Amp</span>
            <div class="tradeoff-bar-container">
              <div class="tradeoff-bar high-bar" style="width:70%"></div>
            </div>
            <span class="tradeoff-rating">High (2x)</span>
          </div>
        </div>
        <div class="tradeoff-card">
          <div class="tradeoff-header fifo-header">FIFO</div>
          <div class="tradeoff-row">
            <span>Write Amp</span>
            <div class="tradeoff-bar-container">
              <div class="tradeoff-bar lowest-bar" style="width:10%"></div>
            </div>
            <span class="tradeoff-rating">Minimal (1x)</span>
          </div>
          <div class="tradeoff-row">
            <span>Read Amp</span>
            <div class="tradeoff-bar-container">
              <div class="tradeoff-bar high-bar" style="width:85%"></div>
            </div>
            <span class="tradeoff-rating">High</span>
          </div>
          <div class="tradeoff-row">
            <span>Space Amp</span>
            <div class="tradeoff-bar-container">
              <div class="tradeoff-bar medium-bar" style="width:50%"></div>
            </div>
            <span class="tradeoff-rating">Medium</span>
          </div>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on the <a href="https://github.com/facebook/rocksdb/wiki/Compaction" target="_blank">RocksDB Wiki</a> and <a href="https://arxiv.org/abs/2202.04522" target="_blank">LSM-tree compaction research</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share this visualization:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20RocksDB%20compaction%20visualization%20-%20Leveled%20vs%20Universal%20vs%20FIFO&url=https://systeminternals.dev/rocksdb/compaction/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/rocksdb/compaction/" target="_blank" class="share-btn">in LinkedIn</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .viz-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #f59e0b, #ef4444, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #888;
    font-size: 1.1rem;
  }

  /* Strategy Selector */
  .strategy-selector {
    margin-bottom: 30px;
  }

  .strategy-tabs {
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .strategy-tab {
    flex: 1;
    min-width: 140px;
    padding: 16px;
    background: rgba(255,255,255,0.03);
    border: 2px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s;
    text-align: center;
    color: #888;
  }

  .strategy-tab:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.2);
  }

  .strategy-tab.active {
    border-color: #f59e0b;
    background: rgba(245, 158, 11, 0.1);
    color: #fff;
  }

  .strategy-tab.active[data-strategy="universal"] {
    border-color: #3b82f6;
    background: rgba(59, 130, 246, 0.1);
  }

  .strategy-tab.active[data-strategy="fifo"] {
    border-color: #8b5cf6;
    background: rgba(139, 92, 246, 0.1);
  }

  .tab-icon {
    display: block;
    font-size: 1.5rem;
    margin-bottom: 4px;
  }

  .tab-label {
    display: block;
    font-weight: 700;
    font-size: 1rem;
    color: inherit;
  }

  .tab-desc {
    display: block;
    font-size: 0.75rem;
    color: #666;
    margin-top: 2px;
  }

  .strategy-description {
    background: rgba(255,255,255,0.03);
    padding: 16px 20px;
    border-radius: 10px;
    font-size: 0.9rem;
    color: #aaa;
    line-height: 1.6;
    border: 1px solid rgba(255,255,255,0.08);
  }

  /* Controls */
  .controls-section {
    background: rgba(255,255,255,0.03);
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 24px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .control-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .action-btn {
    padding: 12px 24px;
    border: none;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .write-btn {
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: white;
  }
  .write-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(34, 197, 94, 0.4);
  }
  .write-btn-secondary {
    background: linear-gradient(135deg, #16a34a, #15803d);
    color: white;
  }
  .write-btn-tertiary {
    background: linear-gradient(135deg, #15803d, #166534);
    color: white;
  }
  .read-btn {
    background: linear-gradient(135deg, #3b82f6, #2563eb);
    color: white;
  }
  .read-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(59, 130, 246, 0.4);
  }
  .reset-btn {
    background: rgba(255,255,255,0.1);
    color: #aaa;
  }
  .reset-btn:hover {
    background: rgba(255,255,255,0.2);
    color: #fff;
  }

  /* Amplification Meters */
  .amp-meters {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }

  .meter {
    background: rgba(255,255,255,0.03);
    border-radius: 12px;
    padding: 16px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .meter-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 8px;
  }

  .meter-label {
    font-size: 0.85rem;
    color: #888;
    font-weight: 600;
  }

  .meter-value {
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
  }

  .meter-bar {
    height: 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 6px;
  }

  .meter-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.5s ease;
  }

  .write-amp-fill { background: linear-gradient(90deg, #22c55e, #f59e0b, #ef4444); }
  .read-amp-fill { background: linear-gradient(90deg, #3b82f6, #8b5cf6, #ef4444); }
  .space-amp-fill { background: linear-gradient(90deg, #06b6d4, #f59e0b, #ef4444); }

  .meter-hint {
    font-size: 0.7rem;
    color: #555;
  }

  /* Stats Row */
  .stats-row {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
    margin-bottom: 24px;
    padding: 16px;
    background: rgba(255,255,255,0.02);
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.06);
  }

  .stat { text-align: center; }
  .stat-label { display: block; font-size: 0.8rem; color: #666; margin-bottom: 2px; }
  .stat-value { font-size: 1.4rem; font-weight: 700; color: #fff; }

  /* LSM Visualization */
  .lsm-viz {
    background: rgba(255,255,255,0.02);
    border-radius: 20px;
    padding: 30px;
    border: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 30px;
  }

  .component { margin-bottom: 16px; }
  .component-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 10px;
  }
  .component-header h3 { font-size: 1.05rem; color: #fff; }
  .component-info { font-size: 0.8rem; color: #666; }

  /* WAL */
  .wal-component {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(139, 92, 246, 0.03));
    border-radius: 12px;
    padding: 16px;
    border: 1px solid rgba(139, 92, 246, 0.3);
  }

  .wal-bar {
    height: 28px;
    background: rgba(0,0,0,0.2);
    border-radius: 8px;
    display: flex;
    gap: 2px;
    padding: 3px;
    overflow: hidden;
  }

  .memtable-component {
    background: linear-gradient(135deg, rgba(251, 191, 36, 0.1), rgba(245, 158, 11, 0.05));
    border-radius: 12px;
    padding: 16px;
    border: 1px solid rgba(251, 191, 36, 0.3);
  }

  .memtable-bar {
    height: 24px;
    background: rgba(0,0,0,0.3);
    border-radius: 12px;
    position: relative;
    overflow: hidden;
    margin-bottom: 10px;
  }

  .memtable-fill {
    height: 100%;
    background: linear-gradient(90deg, #fbbf24, #f59e0b);
    border-radius: 12px;
    transition: width 0.3s;
    width: 0%;
  }

  .memtable-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 0.8rem;
    color: #fff;
    font-weight: 500;
  }

  .memtable-keys {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    min-height: 28px;
  }

  .arrow-container, .compact-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 0;
    opacity: 0.3;
    transition: opacity 0.3s;
