</style>

<script is:inline>
  (function() {
    // === State ===
    var strategy = 'leveled';
    var memtable = [];
    var levels = [[], [], [], []]; // L0=array of SSTs, L1-L3=array of SSTs
    var writeCount = 0;
    var flushCountVal = 0;
    var compactionCountVal = 0;
    var totalBytesWritten = 0;
    var keyCounter = 0;
    var allKeysEver = {};
    var isProcessing = false;

    var MEMTABLE_SIZE = 6;
    var L0_TRIGGER = { leveled: 4, universal: 6, fifo: 999 };
    var LEVEL_MAX = { leveled: [4, 6, 20], universal: [6, 10, 30], fifo: [999, 999, 999] };

    var STRATEGY_DESCS = {
      leveled: 'Leveled compaction: each level is 10x larger. Files with overlapping key ranges are merged into the next level. Best balance of read/write/space amplification.',
      universal: 'Universal compaction: sorted runs are merged based on size ratio. Fewer, larger compactions reduce write amplification at the cost of more space and read overhead.',
      fifo: 'FIFO compaction: oldest SST files are simply dropped when space is needed. No merge overhead. Ideal for TTL / time-series data that expires naturally.'
    };

    // === DOM ===
    var memtableFillEl = document.getElementById('memtableFill');
    var memtableLabelEl = document.getElementById('memtableLabel');
    var memtableKeysEl = document.getElementById('memtableKeys');
    var walEntriesEl = document.getElementById('walEntries');
    var levelsContainerEl = document.getElementById('levelsContainer');
    var activityLogEl = document.getElementById('activityLog');
    var flushArrowEl = document.getElementById('flushArrow');
    var strategyDescEl = document.getElementById('strategyDesc');

    function $(id) { return document.getElementById(id); }

    function log(msg, type) {
      var entry = document.createElement('div');
      entry.className = 'log-entry' + (type ? ' ' + type : '');
      var now = new Date();
      entry.textContent = '[' + now.toLocaleTimeString() + '] ' + msg;
      activityLogEl.insertBefore(entry, activityLogEl.firstChild);
      while (activityLogEl.children.length > 30) {
        activityLogEl.removeChild(activityLogEl.lastChild);
      }
    }

    function generateKey() {
      var k = 'k' + String(keyCounter).padStart(3, '0');
      keyCounter++;
      return k;
    }

    function uniqueKeyCount() {
      return Object.keys(allKeysEver).length;
    }

    function totalSSTFiles() {
      var count = 0;
      for (var i = 0; i < levels.length; i++) {
        count += levels[i].length;
      }
      return count;
    }

    function totalKeysOnDisk() {
      var count = 0;
      for (var i = 0; i < levels.length; i++) {
        for (var j = 0; j < levels[i].length; j++) {
          count += levels[i][j].length;
        }
      }
      return count;
    }

    function updateStats() {
      $('writeCount').textContent = writeCount;
      $('flushCount').textContent = flushCountVal;
      $('compactionCount').textContent = compactionCountVal;
      $('uniqueKeyCount').textContent = uniqueKeyCount();
      $('totalSstCount').textContent = totalSSTFiles();

      // Write amp
      var wAmp = writeCount > 0 ? (totalBytesWritten / writeCount) : 1;
      $('writeAmpVal').textContent = wAmp.toFixed(1) + 'x';
      var wPct = Math.min(100, (wAmp / 30) * 100);
      $('writeAmpBar').style.width = Math.max(5, wPct) + '%';

      // Read amp (worst case: memtable + all SSTs in L0 + 1 per L1+)
      var rAmp = 1 + levels[0].length;
      for (var i = 1; i < levels.length; i++) {
        if (levels[i].length > 0) rAmp++;
      }
      $('readAmpVal').textContent = rAmp;
      var rPct = Math.min(100, (rAmp / 15) * 100);
      $('readAmpBar').style.width = Math.max(5, rPct) + '%';

      // Space amp
      var actual = uniqueKeyCount();
      var disk = totalKeysOnDisk() + memtable.length;
      var sAmp = actual > 0 ? (disk / actual) : 1;
      $('spaceAmpVal').textContent = sAmp.toFixed(1) + 'x';
      var sPct = Math.min(100, (sAmp / 5) * 100);
      $('spaceAmpBar').style.width = Math.max(5, sPct) + '%';
    }

    function renderWAL() {
      walEntriesEl.innerHTML = '';
      var show = memtable.slice(-20);
      for (var i = 0; i < show.length; i++) {
        var el = document.createElement('div');
        el.style.cssText = 'display:inline-block;background:rgba(139,92,246,0.3);border-radius:3px;padding:2px 6px;font-size:0.7rem;color:#c4b5fd;';
        el.textContent = show[i];
        walEntriesEl.appendChild(el);
      }
    }

    function renderMemtable() {
      var pct = (memtable.length / MEMTABLE_SIZE) * 100;
      memtableFillEl.style.width = pct + '%';
      memtableLabelEl.textContent = memtable.length + ' / ' + MEMTABLE_SIZE + ' keys';

      memtableKeysEl.innerHTML = '';
      var sorted = memtable.slice().sort();
      for (var i = 0; i < sorted.length; i++) {
        var badge = document.createElement('span');
        badge.style.cssText = 'display:inline-block;background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#000;padding:3px 10px;border-radius:6px;font-size:0.8rem;font-weight:600;animation:keyAppear 0.3s ease-out;';
        badge.textContent = sorted[i];
        memtableKeysEl.appendChild(badge);
      }
    }

    var LEVEL_COLORS = [
      { bg: 'rgba(239,68,68,0.05)', border: 'rgba(239,68,68,0.3)', sst: 'rgba(239,68,68,0.2)', sstBorder: 'rgba(239,68,68,0.4)', label: 'Unsorted SSTs (overlapping)' },
      { bg: 'rgba(59,130,246,0.05)', border: 'rgba(59,130,246,0.3)', sst: 'rgba(59,130,246,0.2)', sstBorder: 'rgba(59,130,246,0.4)', label: 'Sorted, non-overlapping' },
      { bg: 'rgba(34,197,94,0.05)', border: 'rgba(34,197,94,0.3)', sst: 'rgba(34,197,94,0.2)', sstBorder: 'rgba(34,197,94,0.4)', label: '10x larger, sorted' },
      { bg: 'rgba(139,92,246,0.05)', border: 'rgba(139,92,246,0.3)', sst: 'rgba(139,92,246,0.2)', sstBorder: 'rgba(139,92,246,0.4)', label: '100x larger (cold data)' }
    ];

    function renderLevels() {
      levelsContainerEl.innerHTML = '';
      var numLevels = strategy === 'fifo' ? 1 : (strategy === 'universal' ? 3 : 4);

      for (var lvl = 0; lvl < numLevels; lvl++) {
        // Compact arrow
        if (lvl > 0) {
          var arrowDiv = document.createElement('div');
          arrowDiv.className = 'compact-arrow';
          arrowDiv.id = 'compact' + (lvl - 1) + '' + lvl;
          arrowDiv.innerHTML = '<div class="arrow">\u2193</div><span class="arrow-label">' +
            (strategy === 'fifo' ? 'Drop oldest' : 'Compact') + '</span>';
          levelsContainerEl.appendChild(arrowDiv);
        }

        var c = LEVEL_COLORS[lvl] || LEVEL_COLORS[3];
        var levelDiv = document.createElement('div');
        levelDiv.style.cssText = 'background:' + c.bg + ';border-radius:12px;padding:16px;border:1px solid ' + c.border + ';margin-bottom:4px;';

        var header = document.createElement('div');
        header.style.cssText = 'display:flex;align-items:baseline;gap:12px;margin-bottom:10px;';

        var info = lvl === 0 ? c.label : c.label;
        if (strategy === 'universal') {
          info = lvl === 0 ? 'Sorted runs (may overlap)' : 'Merged runs (size-tiered)';
        }
        if (strategy === 'fifo') {
          info = 'SSTs dropped when oldest expires';
        }

        header.innerHTML = '<h3 style="font-size:1rem;font-weight:700;color:#fff;">L' + lvl + '</h3>' +
          '<span style="font-size:0.8rem;color:#666;">' + info + '</span>' +
          '<span style="font-size:0.75rem;color:#555;margin-left:auto;">' + levels[lvl].length + ' / ' + LEVEL_MAX[strategy][lvl] + ' SSTs</span>';

        levelDiv.appendChild(header);

        var sstArea = document.createElement('div');
        sstArea.style.cssText = 'display:flex;gap:8px;flex-wrap:wrap;min-height:40px;align-items:flex-start;';

        if (levels[lvl].length === 0) {
          var empty = document.createElement('span');
          empty.style.cssText = 'font-size:0.75rem;color:#444;font-style:italic;';
          empty.textContent = 'empty';
          sstArea.appendChild(empty);
        } else {
          for (var s = 0; s < levels[lvl].length; s++) {
            var sst = levels[lvl][s];
            var sstEl = document.createElement('div');
            sstEl.style.cssText = 'background:' + c.sst + ';border:1px solid ' + c.sstBorder + ';border-radius:8px;padding:6px 10px;';

            var keysText = '';
            if (sst.length <= 3) {
              keysText = sst.join(', ');
            } else {
              keysText = sst[0] + '..' + sst[sst.length - 1] + ' (' + sst.length + ')';
            }

            var keysSpan = document.createElement('div');
            keysSpan.style.cssText = 'font-size:0.7rem;color:#aaa;white-space:nowrap;';
            keysSpan.textContent = keysText;
            sstEl.appendChild(keysSpan);
            sstArea.appendChild(sstEl);
          }
        }

        levelDiv.appendChild(sstArea);
        levelsContainerEl.appendChild(levelDiv);
      }
    }

    function render() {
      renderWAL();
      renderMemtable();
      renderLevels();
      updateStats();
    }

    function sleep(ms) {
      return new Promise(function(resolve) { setTimeout(resolve, ms); });
    }

    function animateArrow(id) {
      var el = document.getElementById(id);
      if (!el) return sleep(100);
      el.style.opacity = '1';
      return sleep(400).then(function() { el.style.opacity = '0.3'; });
    }

    function mergeAndDedupe(arrays) {
      var all = [];
      for (var i = 0; i < arrays.length; i++) {
        for (var j = 0; j < arrays[i].length; j++) {
          all.push(arrays[i][j]);
        }
      }
      var unique = [];
      var seen = {};
      all.sort();
      for (var k = 0; k < all.length; k++) {
        if (!seen[all[k]]) {
          seen[all[k]] = true;
          unique.push(all[k]);
        }
      }
      return unique;
    }

    function chunkArray(arr, size) {
      var chunks = [];
      for (var i = 0; i < arr.length; i += size) {
        chunks.push(arr.slice(i, i + size));
      }
      return chunks;
    }

    function doFlush() {
      if (memtable.length === 0) return Promise.resolve();
      var sorted = memtable.slice().sort();
      flushCountVal++;
      totalBytesWritten += sorted.length;
      log('Flush: memtable (' + sorted.length + ' keys) \u2192 L0', 'flush');

      levels[0].push(sorted);
      memtable = [];
      render();

      return animateArrow('flushArrow').then(function() {
        return checkCompaction(0);
      });
    }

    function checkCompaction(fromLevel) {
      var trigger = fromLevel === 0 ? L0_TRIGGER[strategy] : LEVEL_MAX[strategy][fromLevel];
      if (levels[fromLevel].length < trigger) return Promise.resolve();

      if (strategy === 'fifo') {
        // FIFO: just drop oldest
        var dropped = levels[0].shift();
        log('FIFO: dropped oldest SST (' + dropped.length + ' keys expired)', 'compact');
        compactionCountVal++;
        render();
        return Promise.resolve();
      }

      var nextLevel = fromLevel + 1;
      if (nextLevel >= levels.length) return Promise.resolve();

      compactionCountVal++;

      if (strategy === 'leveled') {
        // Merge all SSTs from fromLevel into nextLevel
        var allFrom = levels[fromLevel];
        var allNext = levels[nextLevel];
        var merged = mergeAndDedupe(allFrom.concat(allNext));
        totalBytesWritten += merged.length;

        log('Leveled compact: L' + fromLevel + ' (' + allFrom.length + ' SSTs) \u2192 L' + nextLevel, 'compact');
        levels[fromLevel] = [];
        levels[nextLevel] = chunkArray(merged, Math.max(4, Math.floor(merged.length / 3)));
        render();

        return animateArrow('compact' + fromLevel + '' + nextLevel).then(function() {
          return checkCompaction(nextLevel);
        });
      }

      if (strategy === 'universal') {
        // Merge adjacent runs by size ratio
        var runs = levels[fromLevel];
        if (runs.length < 2) return Promise.resolve();
        var merged2 = mergeAndDedupe(runs);
        totalBytesWritten += merged2.length;

        log('Universal compact: merge ' + runs.length + ' runs in L' + fromLevel + ' (' + merged2.length + ' keys)', 'compact');

        // If too big, push merged to next level
        if (merged2.length > LEVEL_MAX[strategy][fromLevel] * 4 && nextLevel < levels.length) {
          levels[fromLevel] = [];
          levels[nextLevel].push(merged2);
          render();
          return animateArrow('compact' + fromLevel + '' + nextLevel).then(function() {
            return checkCompaction(nextLevel);
          });
        } else {
          levels[fromLevel] = [merged2];
          render();
          return Promise.resolve();
        }
      }

      return Promise.resolve();
    }

    function doWrite() {
      var key = generateKey();
      writeCount++;
      totalBytesWritten++;
      allKeysEver[key] = true;
      memtable.push(key);
      log('Write: ' + key + ' \u2192 MemTable', 'write');
      render();

      if (memtable.length >= MEMTABLE_SIZE) {
        return doFlush();
      }
      return Promise.resolve();
    }

    function doWriteN(n) {
      if (isProcessing) return;
      isProcessing = true;
      var i = 0;
      function next() {
        if (i >= n) { isProcessing = false; return; }
        i++;
        doWrite().then(function() {
          return sleep(80);
        }).then(next);
      }
      next();
    }

    function doRead() {
      // Collect all keys
      var allKeys = memtable.slice();
      for (var i = 0; i < levels.length; i++) {
        for (var j = 0; j < levels[i].length; j++) {
          for (var k = 0; k < levels[i][j].length; k++) {
            allKeys.push(levels[i][j][k]);
          }
        }
      }
      if (allKeys.length === 0) {
        log('Read: no keys in storage', 'read');
        return;
      }

      var key = allKeys[Math.floor(Math.random() * allKeys.length)];
      var checks = 0;
      var found = '';

      // Check memtable
      checks++;
      if (memtable.indexOf(key) !== -1) {
        found = 'MemTable';
      }

      if (!found) {
        // Check L0 (each SST)
        for (var li = 0; li < levels[0].length && !found; li++) {
          checks++;
          if (levels[0][li].indexOf(key) !== -1) {
            found = 'L0[' + li + ']';
          }
        }
      }

      // Check L1+
      for (var lv = 1; lv < levels.length && !found; lv++) {
        if (levels[lv].length > 0) {
          checks++;
          for (var si = 0; si < levels[lv].length; si++) {
            if (levels[lv][si].indexOf(key) !== -1) {
              found = 'L' + lv;
              break;
            }
          }
        }
      }

      log('Read: ' + key + ' \u2192 found in ' + found + ' (checked ' + checks + ' locations)', 'read');
    }

    function doReset() {
      memtable = [];
      levels = [[], [], [], []];
      writeCount = 0;
      flushCountVal = 0;
      compactionCountVal = 0;
      totalBytesWritten = 0;
      keyCounter = 0;
      allKeysEver = {};
      isProcessing = false;
      render();
      activityLogEl.innerHTML = '<div class="log-entry">System reset. Ready.</div>';
    }

    // === Bloom Filter Calculator ===
    function updateBloom() {
      var bits = parseInt(document.getElementById('bloomBits').value);
      var keys = parseInt(document.getElementById('bloomKeys').value);

      document.getElementById('bloomBitsVal').textContent = bits;
      document.getElementById('bloomKeysVal').textContent = keys.toLocaleString();

      // FPR formula: (1 - e^(-k*n/m))^k where k = bits * ln(2), m = bits * n
      var k = Math.round(bits * 0.6931); // ln(2) ≈ 0.6931
      if (k < 1) k = 1;
      var m = bits * keys;
      var fpr = Math.pow(1 - Math.exp(-k * keys / m), k);
      var fprPct = (fpr * 100);

      document.getElementById('bloomFPR').textContent = fprPct < 0.01 ? fprPct.toExponential(1) + '%' : fprPct.toFixed(2) + '%';
      document.getElementById('bloomSize').textContent = ((bits * keys) / 8 / 1024).toFixed(1) + ' KB';
      document.getElementById('bloomSaved').textContent = '~' + ((1 - fpr) * 100).toFixed(1) + '%';

      // Visual: 100 cells showing FP rate
      var visual = document.getElementById('bloomVisual');
      visual.innerHTML = '';
      var numFP = Math.round(fpr * 100);
      for (var i = 0; i < 100; i++) {
        var cell = document.createElement('div');
        var isFP = i < numFP;
        cell.style.cssText = 'display:inline-block;width:8px;height:8px;border-radius:2px;margin:1px;background:' +
          (isFP ? '#ef4444' : 'rgba(34,197,94,0.4)') + ';';
        cell.title = isFP ? 'False positive' : 'Correct negative';
        visual.appendChild(cell);
      }
    }

    // === Event Listeners ===
    document.getElementById('writeBtn').addEventListener('click', function() {
      if (!isProcessing) {
        isProcessing = true;
        doWrite().then(function() { isProcessing = false; });
      }
    });

    document.getElementById('write10Btn').addEventListener('click', function() {
      doWriteN(10);
    });

    document.getElementById('write50Btn').addEventListener('click', function() {
      doWriteN(50);
    });

    document.getElementById('readBtn').addEventListener('click', doRead);
    document.getElementById('resetBtn').addEventListener('click', doReset);

    // Strategy tabs
    var tabs = document.querySelectorAll('.strategy-tab');
    for (var t = 0; t < tabs.length; t++) {
      tabs[t].addEventListener('click', function() {
        var newStrategy = this.getAttribute('data-strategy');
        if (newStrategy === strategy) return;
        strategy = newStrategy;
        for (var i = 0; i < tabs.length; i++) {
          tabs[i].classList.remove('active');
        }
        this.classList.add('active');
        strategyDescEl.textContent = STRATEGY_DESCS[strategy];
        doReset();
        log('Switched to ' + strategy + ' compaction', '');
      });
    }

    // Bloom filter
    document.getElementById('bloomBits').addEventListener('input', updateBloom);
    document.getElementById('bloomKeys').addEventListener('input', updateBloom);

    // Init
    render();
    updateBloom();
  })();
</script>
</BaseLayout>
