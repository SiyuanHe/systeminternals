---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "MergeTree Engine", description: "Parts, merges, sparse indexes, and column-oriented storage", href: "/clickhouse/mergetree/", status: "live" },
  { title: "Distributed Tables", description: "Sharding, replication, and cross-shard queries", href: "#", status: "coming" },
  { title: "Materialized Views", description: "Real-time aggregation pipelines and projection chains", href: "#", status: "coming" },
  { title: "Query Execution Pipeline", description: "Vectorized execution, parallel processing, and pipeline stages", href: "#", status: "coming" },
  { title: "Data Compression", description: "Codec stacking, per-column compression, and storage efficiency", href: "#", status: "coming" },
  { title: "Joins & Dictionaries", description: "Hash joins, external dictionaries, and lookup strategies", href: "#", status: "coming" },
  { title: "Buffer & Kafka Engines", description: "Streaming ingestion and buffered writes", href: "#", status: "coming" },
  { title: "ReplicatedMergeTree", description: "ZooKeeper coordination, insert deduplication, and quorum writes", href: "#", status: "coming" },
  { title: "Mutations & ALTER", description: "Lazy column mutations, lightweight deletes, and TTL", href: "#", status: "coming" },
  { title: "Performance Tuning", description: "Profiling queries, system tables, and optimization patterns", href: "#", status: "coming" },
];
---

<BaseLayout 
  title="ClickHouse Internals" 
  description="Interactive visualizations for understanding ClickHouse architecture, MergeTree engine, and OLAP performance"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "ClickHouse", href: "/clickhouse/" }]}
>
  <section class="section-header">
    <h1>🏠 ClickHouse Internals</h1>
    <p>
      ClickHouse is a column-oriented OLAP database designed for blazing-fast analytical queries.
      These visualizations help you understand how MergeTree stores data, how merges work, and how to tune for your workload.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 215, 0, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
