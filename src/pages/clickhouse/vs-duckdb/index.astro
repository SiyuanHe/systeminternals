</style>

<script>
  // ===== Storage Canvas Visualization =====
  const storageCanvas = document.getElementById('storageCanvas');
  const ctx = storageCanvas.getContext('2d');
  const storageExplanation = document.getElementById('storageExplanation');
  
  function drawClickHouseStorage() {
    ctx.clearRect(0, 0, 800, 400);
    ctx.fillStyle = '#0f172a';
    ctx.fillRect(0, 0, 800, 400);
    
    // Title
    ctx.fillStyle = '#eab308';
    ctx.font = 'bold 16px system-ui';
    ctx.fillText('ClickHouse MergeTree Storage', 20, 30);
    
    // Draw parts
    const parts = [
      { x: 40, w: 150, label: 'Part 2024-03_1', rows: '8192 rows' },
      { x: 220, w: 150, label: 'Part 2024-03_2', rows: '8192 rows' },
      { x: 400, w: 200, label: 'Part 2024-03_3 (merged)', rows: '16384 rows' },
      { x: 630, w: 140, label: 'Part 2024-03_4', rows: '4096 rows' },
    ];
    
    parts.forEach((p, i) => {
      const y = 60;
      const h = 120;
      // Part container
      ctx.strokeStyle = '#eab308';
      ctx.lineWidth = 2;
      ctx.strokeRect(p.x, y, p.w, h);
      ctx.fillStyle = '#1e293b';
      ctx.fillRect(p.x + 1, y + 1, p.w - 2, h - 2);
      
      // Label
      ctx.fillStyle = '#fcd34d';
      ctx.font = 'bold 11px system-ui';
      ctx.fillText(p.label, p.x + 8, y + 20);
      ctx.fillStyle = '#64748b';
      ctx.font = '10px system-ui';
      ctx.fillText(p.rows, p.x + 8, y + 36);
      
      // Column files
      const cols = ['date.bin', 'url.bin', 'count.bin'];
      cols.forEach((col, ci) => {
        const cy = y + 48 + ci * 22;
        ctx.fillStyle = ['#3b82f6', '#10b981', '#8b5cf6'][ci];
        ctx.fillRect(p.x + 8, cy, p.w - 16, 16);
        ctx.fillStyle = '#fff';
        ctx.font = '10px monospace';
        ctx.fillText(col, p.x + 14, cy + 12);
      });
    });
    
    // Sparse index
    ctx.fillStyle = '#94a3b8';
    ctx.font = '12px system-ui';
    ctx.fillText('Sparse Index (primary.idx) — one entry per 8192 rows', 40, 210);
    
    const marks = ['2024-03-01', '2024-03-01', '2024-03-02', '2024-03-02', '2024-03-03'];
    marks.forEach((m, i) => {
      const x = 40 + i * 140;
      ctx.fillStyle = '#334155';
      ctx.fillRect(x, 220, 120, 28);
      ctx.fillStyle = '#7dd3fc';
      ctx.font = '11px monospace';
      ctx.fillText(m, x + 8, 238);
    });
    
    // Merge arrow
    ctx.fillStyle = '#94a3b8';
    ctx.font = '12px system-ui';
    ctx.fillText('Background merge combines parts → fewer, larger parts → better compression & query speed', 40, 280);
    
    // Disk layout
    ctx.fillStyle = '#64748b';
    ctx.font = '11px system-ui';
    ctx.fillText('On disk: /var/lib/clickhouse/data/db/table/', 40, 310);
    ctx.fillText('├── 2024-03_1_1_0/  (part directory)', 40, 328);
    ctx.fillText('│   ├── date.bin, url.bin, count.bin  (column files)', 40, 346);
    ctx.fillText('│   ├── primary.idx  (sparse index)', 40, 364);
    ctx.fillText('│   └── checksums.txt', 40, 382);
    
    storageExplanation.innerHTML = '<strong>ClickHouse MergeTree:</strong> Each INSERT creates a new <em>part</em> — a directory of column files. Background threads merge small parts into larger ones (like an LSM-tree). Each column is stored in a separate file with specialized compression. The sparse index stores one key per granule (8192 rows), keeping the index tiny even for billions of rows.';
  }
  
  function drawDuckDBStorage() {
    ctx.clearRect(0, 0, 800, 400);
    ctx.fillStyle = '#0f172a';
    ctx.fillRect(0, 0, 800, 400);
    
    // Title
    ctx.fillStyle = '#f97316';
    ctx.font = 'bold 16px system-ui';
    ctx.fillText('DuckDB Storage Layout', 20, 30);
    
    // Single file
    ctx.strokeStyle = '#f97316';
    ctx.lineWidth = 2;
    ctx.strokeRect(40, 50, 720, 300);
    ctx.fillStyle = '#1e293b';
    ctx.fillRect(41, 51, 718, 298);
    
    ctx.fillStyle = '#fdba74';
    ctx.font = 'bold 12px system-ui';
    ctx.fillText('my_database.duckdb  (single file)', 50, 72);
    
    // Row groups
    const rgs = [
      { x: 60, label: 'Row Group 0', rows: '122,880 rows' },
      { x: 250, label: 'Row Group 1', rows: '122,880 rows' },
      { x: 440, label: 'Row Group 2', rows: '122,880 rows' },
      { x: 630, label: 'Row Group 3', rows: '81,024 rows' },
    ];
    
    rgs.forEach(rg => {
      const y = 85;
      ctx.strokeStyle = '#f97316';
      ctx.lineWidth = 1;
      ctx.strokeRect(rg.x, y, 170, 120);
      
      ctx.fillStyle = '#fb923c';
      ctx.font = 'bold 11px system-ui';
      ctx.fillText(rg.label, rg.x + 8, y + 18);
      ctx.fillStyle = '#64748b';
      ctx.font = '10px system-ui';
      ctx.fillText(rg.rows, rg.x + 8, y + 34);
      
      // Column segments
      const cols = ['date', 'url', 'count'];
      cols.forEach((col, ci) => {
        const cy = y + 44 + ci * 22;
        ctx.fillStyle = ['#3b82f6', '#10b981', '#8b5cf6'][ci];
        ctx.fillRect(rg.x + 8, cy, 154, 16);
        ctx.fillStyle = '#fff';
        ctx.font = '10px monospace';
        ctx.fillText(col + ' segment (compressed)', rg.x + 14, cy + 12);
      });
    });
    
    // Buffer manager
    ctx.fillStyle = '#94a3b8';
    ctx.font = '12px system-ui';
    ctx.fillText('Buffer Manager — pages loaded on demand, spills to disk when memory is full', 60, 230);
    
    // Metadata
    ctx.fillStyle = '#64748b';
    ctx.font = '11px system-ui';
    ctx.fillText('Metadata block: table schemas, column stats (min/max/null count per row group)', 60, 260);
    ctx.fillText('Checkpoint: WAL flushed to main storage (ACID durable)', 60, 280);
    ctx.fillText('MVCC: readers see snapshot, writer appends new row groups', 60, 300);
    
    // Key difference
    ctx.fillStyle = '#f97316';
    ctx.font = 'bold 12px system-ui';
    ctx.fillText('Key: Everything in one file. No background merges. No separate index files.', 60, 330);
    
    storageExplanation.innerHTML = '<strong>DuckDB Storage:</strong> Data lives in a single file, organized into <em>row groups</em> (~122K rows each). Within each row group, columns are stored as compressed segments. The buffer manager loads pages into memory on demand — if data exceeds RAM, it spills to disk. MVCC provides snapshot isolation: readers never block writers. No background maintenance needed — it\'s designed for simplicity, like SQLite.';
  }
  
  // Init
  drawClickHouseStorage();
  
  document.getElementById('showChStorage').addEventListener('click', function() {
    this.classList.add('active-toggle');
    document.getElementById('showDkStorage').classList.remove('active-toggle');
    drawClickHouseStorage();
  });
  
  document.getElementById('showDkStorage').addEventListener('click', function() {
    this.classList.add('active-toggle');
    document.getElementById('showChStorage').classList.remove('active-toggle');
    drawDuckDBStorage();
  });

  // ===== Query Race Animation =====
  let raceRunning = false;
  
  document.getElementById('runRaceBtn').addEventListener('click', function() {
    if (raceRunning) return;
    raceRunning = true;
    
    const chStages = document.querySelectorAll('#chPipeline .pipe-stage');
    const dkStages = document.querySelectorAll('#dkPipeline .pipe-stage');
    const chProgress = document.getElementById('chProgress');
    const dkProgress = document.getElementById('dkProgress');
    const chStats = document.getElementById('chStats');
    const dkStats = document.getElementById('dkStats');
    
    // Reset
    chStages.forEach(s => s.className = 'pipe-stage');
    dkStages.forEach(s => s.className = 'pipe-stage');
    chProgress.style.width = '0%';
    dkProgress.style.width = '0%';
    
    // ClickHouse animation (push-based, slightly faster for this scenario)
    const chTimings = [200, 150, 300, 250, 100]; // ms per stage
    const dkTimings = [250, 150, 350, 150, 100]; // ms per stage
    
    let chTotal = 0;
    chTimings.forEach((t, i) => {
      setTimeout(() => {
        chStages[i].classList.add('active');
        chProgress.style.width = ((i + 1) / chStages.length * 100) + '%';
        if (i > 0) chStages[i - 1].classList.remove('active');
        if (i > 0) chStages[i - 1].classList.add('done');
      }, chTotal);
      chTotal += t;
    });
    setTimeout(() => {
      chStages[chStages.length - 1].classList.remove('active');
      chStages[chStages.length - 1].classList.add('done');
      chStats.textContent = '✅ 42ms — Push pipeline: all stages run simultaneously, data flows through';
    }, chTotal);
    
    let dkTotal = 0;
    dkTimings.forEach((t, i) => {
      setTimeout(() => {
        dkStages[i].classList.add('active');
        dkProgress.style.width = ((i + 1) / dkStages.length * 100) + '%';
        if (i > 0) dkStages[i - 1].classList.remove('active');
        if (i > 0) dkStages[i - 1].classList.add('done');
      }, dkTotal);
      dkTotal += t;
    });
    setTimeout(() => {
      dkStages[dkStages.length - 1].classList.remove('active');
      dkStages[dkStages.length - 1].classList.add('done');
      dkStats.textContent = '✅ 48ms — Pull model: consumer requests next batch from producer (morsel-driven)';
      raceRunning = false;
    }, dkTotal);
  });
  
  document.getElementById('resetRaceBtn').addEventListener('click', function() {
    document.querySelectorAll('#chPipeline .pipe-stage, #dkPipeline .pipe-stage').forEach(s => s.className = 'pipe-stage');
    document.getElementById('chProgress').style.width = '0%';
    document.getElementById('dkProgress').style.width = '0%';
    document.getElementById('chStats').textContent = 'Waiting...';
    document.getElementById('dkStats').textContent = 'Waiting...';
    raceRunning = false;
  });

  // ===== Benchmark Simulator =====
  document.getElementById('runBenchBtn').addEventListener('click', function() {
    const size = document.getElementById('benchDataSize').value;
    const conc = parseInt(document.getElementById('benchConcurrency').value);
    const qtype = document.getElementById('benchQueryType').value;
    
    // Simulated results based on real-world benchmarks
    const results = {
      // [chMs, dkMs, verdict]
      'small-1-scan': [120, 80, 'DuckDB wins on small data — zero overhead, in-process speed.'],
      'small-1-agg': [95, 65, 'DuckDB wins — for small data, embedded beats client-server overhead.'],
      'small-1-join': [150, 90, 'DuckDB wins — optimized hash joins on small datasets.'],
      'small-1-point': [5, 3, 'Both fast. DuckDB slight edge from no network hop.'],
      'small-10-scan': [130, 400, 'ClickHouse handles concurrency natively. DuckDB serializes writers.'],
      'small-10-agg': [105, 350, 'ClickHouse designed for concurrent dashboards.'],
      'small-10-join': [160, 450, 'Multi-user? ClickHouse wins hands down.'],
      'small-10-point': [8, 15, 'ClickHouse query pipeline handles concurrent point lookups.'],
      'small-100-scan': [180, 4000, 'DuckDB not designed for 100 concurrent users.'],
      'small-100-agg': [150, 3500, '🟡 ClickHouse — built for this exact scenario.'],
      'small-100-join': [220, 4500, '🟡 ClickHouse — production dashboard workload.'],
      'small-100-point': [12, 3000, '🟡 ClickHouse — concurrent access is its bread and butter.'],
      'medium-1-scan': [800, 2400, 'ClickHouse parallel part scanning beats single-file reads.'],
      'medium-1-agg': [450, 1200, 'ClickHouse SIMD-optimized aggregation shines at scale.'],
      'medium-1-join': [1200, 3500, 'ClickHouse hash join across parts is highly parallelized.'],
      'medium-1-point': [8, 500, 'ClickHouse sparse index → instant lookups even on 100GB.'],
      'medium-10-scan': [900, 12000, '🟡 ClickHouse — no contest at 100GB with concurrent users.'],
      'medium-10-agg': [500, 6000, '🟡 ClickHouse — this is what it was built for.'],
      'medium-10-join': [1400, 15000, '🟡 ClickHouse dominates multi-user analytical workloads.'],
      'medium-10-point': [10, 2500, '🟡 ClickHouse point lookups stay fast regardless of concurrency.'],
      'medium-100-scan': [1200, 0, '🟡 ClickHouse. DuckDB would OOM or timeout at this scale + concurrency.'],
      'medium-100-agg': [700, 0, '🟡 ClickHouse only. DuckDB not viable here.'],
      'medium-100-join': [2000, 0, '🟡 ClickHouse only. DuckDB single-writer limitation.'],
      'medium-100-point': [15, 0, '🟡 ClickHouse. DuckDB can\'t serve 100 concurrent queries on 100GB.'],
      'large-1-scan': [3200, 0, '🟡 ClickHouse only. 1TB exceeds DuckDB\'s single-node design.'],
      'large-1-agg': [1800, 0, '🟡 ClickHouse. DuckDB can\'t handle TB-scale efficiently.'],
      'large-1-join': [5000, 0, '🟡 ClickHouse only. Distributed joins across shards.'],
      'large-1-point': [10, 0, '🟡 ClickHouse. Sparse index means constant-time lookups at any scale.'],
      'large-10-scan': [3500, 0, '🟡 ClickHouse. TB+ data is ClickHouse territory.'],
      'large-10-agg': [2000, 0, '🟡 ClickHouse. Sharded aggregation.'],
      'large-10-join': [5500, 0, '🟡 ClickHouse. Distributed queries across the cluster.'],
      'large-10-point': [12, 0, '🟡 ClickHouse.'],
      'large-100-scan': [4000, 0, '🟡 ClickHouse only viable option.'],
      'large-100-agg': [2500, 0, '🟡 ClickHouse.'],
      'large-100-join': [6500, 0, '🟡 ClickHouse.'],
      'large-100-point': [15, 0, '🟡 ClickHouse.'],
      'xlarge-1-scan': [8000, 0, '🟡 ClickHouse sharding across nodes.'],
      'xlarge-1-agg': [4000, 0, '🟡 ClickHouse. Petabyte-scale analytics.'],
      'xlarge-1-join': [12000, 0, '🟡 ClickHouse. Distributed engine.'],
      'xlarge-1-point': [12, 0, '🟡 ClickHouse. O(1) lookups at any scale.'],
      'xlarge-10-scan': [8500, 0, '🟡 ClickHouse.'],
      'xlarge-10-agg': [4500, 0, '🟡 ClickHouse.'],
      'xlarge-10-join': [13000, 0, '🟡 ClickHouse.'],
      'xlarge-10-point': [14, 0, '🟡 ClickHouse.'],
      'xlarge-100-scan': [9500, 0, '🟡 ClickHouse.'],
      'xlarge-100-agg': [5000, 0, '🟡 ClickHouse.'],
      'xlarge-100-join': [15000, 0, '🟡 ClickHouse.'],
      'xlarge-100-point': [18, 0, '🟡 ClickHouse.'],
    };
    
    const key = `${size}-${conc}-${qtype}`;
    const [chMs, dkMs, verdict] = results[key] || [500, 500, 'Comparable performance.'];
    
    const chBar = document.getElementById('chBenchBar');
    const dkBar = document.getElementById('dkBenchBar');
    const chTime = document.getElementById('chBenchTime');
    const dkTime = document.getElementById('dkBenchTime');
    const vDiv = document.getElementById('benchVerdict');
    
    const maxMs = Math.max(chMs, dkMs || 1);
    
    setTimeout(() => {
      chBar.style.width = (chMs / maxMs * 100) + '%';
      chTime.textContent = chMs + 'ms';
      
      if (dkMs > 0) {
        dkBar.style.width = (dkMs / maxMs * 100) + '%';
        dkTime.textContent = dkMs + 'ms';
      } else {
        dkBar.style.width = '0%';
        dkTime.textContent = 'N/A';
      }
      
      vDiv.textContent = verdict;
    }, 100);
  });

  // ===== Feature Matrix Toggle =====
  document.querySelectorAll('.cat-header').forEach(header => {
    header.addEventListener('click', function() {
      const body = this.nextElementSibling;
      const toggle = this.querySelector('.cat-toggle');
      if (body.style.display === 'none') {
        body.style.display = 'block';
        toggle.classList.add('open');
      } else {
        body.style.display = 'none';
        toggle.classList.remove('open');
      }
    });
  });

  // ===== Decision Tree =====
  const dtState = { step: 0, answers: [] };
  const dtQuestions = [
    { q: 'What\'s your data volume?', opts: [
      { label: 'Under 10 GB', val: 'small' },
      { label: '10 GB – 1 TB', val: 'medium' },
      { label: 'Over 1 TB', val: 'large' },
    ]},
    { q: 'How many concurrent users?', opts: [
      { label: 'Just me (1)', val: 'single' },
      { label: 'Small team (2-10)', val: 'team' },
      { label: 'Production app (10+)', val: 'prod' },
    ]},
    { q: 'What\'s your deployment model?', opts: [
      { label: 'Embedded (in Python/R/app)', val: 'embedded' },
      { label: 'Standalone server', val: 'server' },
      { label: 'Cloud managed', val: 'cloud' },
    ]},
  ];
  
  function renderDTStep() {
    const dtQ = document.getElementById('dtQuestion');
    const dtO = document.getElementById('dtOptions');
    const dtR = document.getElementById('dtResult');
    const dtP = document.getElementById('dtPath');
    
    if (dtState.step >= dtQuestions.length) {
      // Show result
      dtO.innerHTML = '';
      const a = dtState.answers;
      let rec, cls;
      
      if (a[0] === 'large' || a[1] === 'prod') {
        rec = '🟡 <strong>ClickHouse</strong> — Your workload needs a distributed OLAP server. ClickHouse handles TB+ data, 100s of concurrent users, and real-time ingestion. Consider ClickHouse Cloud for managed experience.';
        cls = 'ch-rec';
      } else if (a[0] === 'small' && a[1] === 'single' && a[2] === 'embedded') {
        rec = '🦆 <strong>DuckDB</strong> — Perfect fit! Small data, single user, embedded. DuckDB gives you blazing fast analytics with zero ops overhead. Just pip install duckdb and go.';
        cls = 'dk-rec';
      } else if (a[0] === 'small' && a[2] === 'embedded') {
        rec = '🦆 <strong>DuckDB</strong> — Embedded analytics on small data. For team read access, DuckDB\'s MVCC handles concurrent readers well.';
        cls = 'dk-rec';
      } else if (a[0] === 'medium' && a[1] === 'single') {
        rec = '🤝 <strong>Either works!</strong> — At 10-1000 GB with one user, both perform well. DuckDB for simplicity; ClickHouse if you need streaming ingestion or materialized views.';
        cls = 'both-rec';
      } else if (a[2] === 'server' || a[2] === 'cloud') {
        rec = '🟡 <strong>ClickHouse</strong> — Server deployment with team access? ClickHouse is the natural choice. Try ClickHouse Cloud or self-host with ReplicatedMergeTree.';
        cls = 'ch-rec';
      } else {
        rec = '🤝 <strong>Consider both!</strong> — Use DuckDB for exploration and prototyping, ClickHouse for production serving. They complement each other well.';
        cls = 'both-rec';
      }
      
      dtQ.textContent = 'Our recommendation:';
      dtR.innerHTML = rec;
      dtR.className = 'dt-result show ' + cls;
      
      // Add restart button
      dtO.innerHTML = '<button class="dt-btn" id="dtRestart">🔄 Start Over</button>';
      document.getElementById('dtRestart').addEventListener('click', function() {
        dtState.step = 0;
        dtState.answers = [];
        document.getElementById('dtPath').textContent = '';
        document.getElementById('dtResult').className = 'dt-result';
        renderDTStep();
      });
      return;
    }
    
    const step = dtQuestions[dtState.step];
    dtQ.textContent = step.q;
    dtO.innerHTML = '';
    
    step.opts.forEach(opt => {
      const btn = document.createElement('button');
      btn.className = 'dt-btn';
      btn.textContent = opt.label;
      btn.addEventListener('click', function() {
        dtState.answers.push(opt.val);
        dtP.textContent = (dtP.textContent ? dtP.textContent + ' → ' : '') + opt.label;
        dtState.step++;
        renderDTStep();
      });
      dtO.appendChild(btn);
    });
  }
  
  renderDTStep();
</script>
</BaseLayout>
