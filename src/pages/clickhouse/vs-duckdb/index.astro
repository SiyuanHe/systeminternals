---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="ClickHouse vs DuckDB: Architecture, Performance & When to Use Each" 
  description="Interactive comparison of ClickHouse and DuckDB internals: storage engines, query execution, concurrency models, and benchmarks. Learn which columnar database fits your workload."
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "ClickHouse", href: "/clickhouse/" },
    { label: "ClickHouse vs DuckDB", href: "/clickhouse/vs-duckdb/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>⚔️ ClickHouse vs DuckDB</h1>
      <p class="subtitle">Two Columnar Engines, Very Different Philosophies — Interactive Deep Dive</p>
    </header>

    <!-- ===== Section 1: Overview Comparison ===== -->
    <section class="demo-section">
      <h2>🏗️ Architecture at a Glance</h2>
      <p class="section-desc">ClickHouse is a distributed OLAP server. DuckDB is an embedded analytical engine. Click each card to explore.</p>
      <div class="arch-compare" id="archCompare">
        <div class="arch-card ch-card" data-system="clickhouse">
          <div class="arch-header">
            <span class="arch-icon">🟡</span>
            <h3>ClickHouse</h3>
          </div>
          <ul class="arch-props">
            <li><strong>Model:</strong> Client-server (standalone process)</li>
            <li><strong>Storage:</strong> MergeTree on disk (LSM-tree inspired)</li>
            <li><strong>Concurrency:</strong> Multi-user, 100s of concurrent queries</li>
            <li><strong>Scale:</strong> Petabytes, distributed across shards</li>
            <li><strong>Best for:</strong> Real-time analytics dashboards, log/event stores</li>
          </ul>
        </div>
        <div class="arch-card dk-card" data-system="duckdb">
          <div class="arch-header">
            <span class="arch-icon">🦆</span>
            <h3>DuckDB</h3>
          </div>
          <ul class="arch-props">
            <li><strong>Model:</strong> In-process (like SQLite for analytics)</li>
            <li><strong>Storage:</strong> Buffer manager + row groups in single file</li>
            <li><strong>Concurrency:</strong> Single-writer, MVCC for reads</li>
            <li><strong>Scale:</strong> Single-node, fits-in-memory + spill</li>
            <li><strong>Best for:</strong> Local data science, ETL, embedded analytics</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ===== Section 2: Storage Engine Comparison ===== -->
    <section class="demo-section">
      <h2>💾 Storage Engine Internals</h2>
      <p class="section-desc">Both are columnar, but the storage architectures diverge significantly. Toggle between them to compare.</p>
      <div class="controls-section">
        <div class="control-group">
          <button id="showChStorage" class="action-btn insert-btn active-toggle">🟡 ClickHouse Storage</button>
          <button id="showDkStorage" class="action-btn insert-btn-secondary">🦆 DuckDB Storage</button>
        </div>
      </div>
      <div class="storage-viz" id="storageViz">
        <canvas id="storageCanvas" width="800" height="400"></canvas>
      </div>
      <div class="storage-explanation" id="storageExplanation">
        <p>Click a button above to visualize the storage architecture.</p>
      </div>
    </section>

    <!-- ===== Section 3: Query Execution Models ===== -->
    <section class="demo-section">
      <h2>⚡ Query Execution: Push vs Pull</h2>
      <p class="section-desc">ClickHouse uses a <strong>push-based pipeline</strong> (producers push data). DuckDB uses a <strong>pull-based vectorized</strong> model (consumers pull batches). Watch them process the same query.</p>
      <div class="controls-section">
        <div class="control-group">
          <button id="runRaceBtn" class="action-btn search-btn">▶️ Run Query Race</button>
          <button id="resetRaceBtn" class="action-btn reset-btn">↺ Reset</button>
        </div>
        <div class="query-display">
          <code>SELECT country, count(*), avg(amount) FROM events WHERE year = 2025 GROUP BY country ORDER BY count(*) DESC LIMIT 10</code>
        </div>
      </div>
      <div class="race-viz">
        <div class="race-lane">
          <h4>🟡 ClickHouse (Push Pipeline)</h4>
          <div class="pipeline-flow" id="chPipeline">
            <div class="pipe-stage" data-idx="0">Read Parts</div>
            <div class="pipe-arrow">→</div>
            <div class="pipe-stage" data-idx="1">Filter</div>
            <div class="pipe-arrow">→</div>
            <div class="pipe-stage" data-idx="2">Partial Agg</div>
            <div class="pipe-arrow">→</div>
            <div class="pipe-stage" data-idx="3">Merge Agg</div>
            <div class="pipe-arrow">→</div>
            <div class="pipe-stage" data-idx="4">Sort + Limit</div>
          </div>
          <div class="progress-bar"><div class="progress-fill ch-fill" id="chProgress"></div></div>
          <div class="race-stats" id="chStats">Waiting...</div>
        </div>
        <div class="race-lane">
          <h4>🦆 DuckDB (Pull Vectorized)</h4>
          <div class="pipeline-flow" id="dkPipeline">
            <div class="pipe-stage" data-idx="0">Scan Chunks</div>
            <div class="pipe-arrow">→</div>
            <div class="pipe-stage" data-idx="1">Filter</div>
            <div class="pipe-arrow">→</div>
            <div class="pipe-stage" data-idx="2">Hash Agg</div>
            <div class="pipe-arrow">→</div>
            <div class="pipe-stage" data-idx="3">Top-N</div>
            <div class="pipe-arrow">→</div>
            <div class="pipe-stage" data-idx="4">Result</div>
          </div>
          <div class="progress-bar"><div class="progress-fill dk-fill" id="dkProgress"></div></div>
          <div class="race-stats" id="dkStats">Waiting...</div>
        </div>
      </div>
    </section>

    <!-- ===== Section 4: Interactive Benchmark ===== -->
    <section class="demo-section">
      <h2>📊 Benchmark Simulator</h2>
      <p class="section-desc">Adjust workload parameters to see how each engine performs under different conditions. Based on published ClickBench and academic benchmarks.</p>
      <div class="controls-section">
        <div class="control-group" style="flex-wrap: wrap; gap: 12px;">
          <label class="bench-label">
            Data Size
            <select id="benchDataSize" class="codec-select">
              <option value="small">1 GB</option>
              <option value="medium" selected>100 GB</option>
              <option value="large">1 TB</option>
              <option value="xlarge">10 TB+</option>
            </select>
          </label>
          <label class="bench-label">
            Concurrency
            <select id="benchConcurrency" class="codec-select">
              <option value="1" selected>1 user</option>
              <option value="10">10 users</option>
              <option value="100">100 users</option>
            </select>
          </label>
          <label class="bench-label">
            Query Type
            <select id="benchQueryType" class="codec-select">
              <option value="scan">Full Scan</option>
              <option value="agg" selected>Aggregation</option>
              <option value="join">JOIN</option>
              <option value="point">Point Lookup</option>
            </select>
          </label>
          <button id="runBenchBtn" class="action-btn compress-btn">📊 Run Benchmark</button>
        </div>
      </div>
      <div class="bench-results" id="benchResults">
        <div class="bench-bar-group">
          <div class="bench-bar-label">🟡 ClickHouse</div>
          <div class="bench-bar-track"><div class="bench-bar ch-bar" id="chBenchBar"></div></div>
          <span class="bench-time" id="chBenchTime">—</span>
        </div>
        <div class="bench-bar-group">
          <div class="bench-bar-label">🦆 DuckDB</div>
          <div class="bench-bar-track"><div class="bench-bar dk-bar" id="dkBenchBar"></div></div>
          <span class="bench-time" id="dkBenchTime">—</span>
        </div>
        <div class="bench-verdict" id="benchVerdict"></div>
      </div>
    </section>

    <!-- ===== Section 5: Feature Matrix ===== -->
    <section class="demo-section">
      <h2>🗂️ Feature Comparison</h2>
      <p class="section-desc">Click a category to expand. Green = strong support, yellow = partial, red = not supported.</p>
      <div class="feature-matrix" id="featureMatrix">
        <div class="feature-category" data-cat="deployment">
          <div class="cat-header">
            <span class="cat-toggle">▶</span>
            <h4>Deployment & Operations</h4>
          </div>
          <div class="cat-body" style="display:none;">
            <div class="feature-row"><span class="feat-name">Embedded (in-process)</span><span class="feat-ch red">✗</span><span class="feat-dk green">✓ Core design</span></div>
            <div class="feature-row"><span class="feat-name">Standalone server</span><span class="feat-ch green">✓ Primary mode</span><span class="feat-dk yellow">~ Experimental</span></div>
            <div class="feature-row"><span class="feat-name">Distributed queries</span><span class="feat-ch green">✓ Native sharding</span><span class="feat-dk red">✗ Single node</span></div>
            <div class="feature-row"><span class="feat-name">Replication</span><span class="feat-ch green">✓ ReplicatedMergeTree</span><span class="feat-dk red">✗</span></div>
            <div class="feature-row"><span class="feat-name">Zero-config setup</span><span class="feat-ch yellow">~ Docker/binary</span><span class="feat-dk green">✓ pip install duckdb</span></div>
            <div class="feature-row"><span class="feat-name">Language bindings</span><span class="feat-ch yellow">~ HTTP/Native protocol</span><span class="feat-dk green">✓ Python, R, JS, Java, etc.</span></div>
          </div>
        </div>
        <div class="feature-category" data-cat="sql">
          <div class="cat-header">
            <span class="cat-toggle">▶</span>
            <h4>SQL & Query Features</h4>
          </div>
          <div class="cat-body" style="display:none;">
            <div class="feature-row"><span class="feat-name">Window functions</span><span class="feat-ch green">✓</span><span class="feat-dk green">✓</span></div>
            <div class="feature-row"><span class="feat-name">CTEs (WITH)</span><span class="feat-ch green">✓</span><span class="feat-dk green">✓</span></div>
            <div class="feature-row"><span class="feat-name">Correlated subqueries</span><span class="feat-ch yellow">~ Limited</span><span class="feat-dk green">✓ Full support</span></div>
            <div class="feature-row"><span class="feat-name">ACID transactions</span><span class="feat-ch red">✗ Eventual</span><span class="feat-dk green">✓ Full MVCC</span></div>
            <div class="feature-row"><span class="feat-name">UPDATE/DELETE</span><span class="feat-ch yellow">~ Async mutations</span><span class="feat-dk green">✓ Standard DML</span></div>
            <div class="feature-row"><span class="feat-name">JOINs (large tables)</span><span class="feat-ch green">✓ Hash/Sort merge</span><span class="feat-dk green">✓ Adaptive</span></div>
          </div>
        </div>
        <div class="feature-category" data-cat="data">
          <div class="cat-header">
            <span class="cat-toggle">▶</span>
            <h4>Data Ingestion & Formats</h4>
          </div>
          <div class="cat-body" style="display:none;">
            <div class="feature-row"><span class="feat-name">Read Parquet</span><span class="feat-ch green">✓</span><span class="feat-dk green">✓ First-class</span></div>
            <div class="feature-row"><span class="feat-name">Read CSV</span><span class="feat-ch green">✓</span><span class="feat-dk green">✓ Parallel sniffer</span></div>
            <div class="feature-row"><span class="feat-name">Read JSON</span><span class="feat-ch green">✓</span><span class="feat-dk green">✓</span></div>
            <div class="feature-row"><span class="feat-name">S3/GCS/Azure direct</span><span class="feat-ch green">✓</span><span class="feat-dk green">✓ httpfs extension</span></div>
            <div class="feature-row"><span class="feat-name">Kafka ingestion</span><span class="feat-ch green">✓ Native engine</span><span class="feat-dk red">✗</span></div>
            <div class="feature-row"><span class="feat-name">Real-time streaming</span><span class="feat-ch green">✓ Materialized views</span><span class="feat-dk red">✗ Batch only</span></div>
          </div>
        </div>
        <div class="feature-category" data-cat="perf">
          <div class="cat-header">
            <span class="cat-toggle">▶</span>
            <h4>Performance & Optimization</h4>
          </div>
          <div class="cat-body" style="display:none;">
            <div class="feature-row"><span class="feat-name">Vectorized execution</span><span class="feat-ch green">✓ SIMD-optimized</span><span class="feat-dk green">✓ Vector volcano</span></div>
            <div class="feature-row"><span class="feat-name">Compression</span><span class="feat-ch green">✓ LZ4/ZSTD + codecs</span><span class="feat-dk green">✓ Per-segment</span></div>
            <div class="feature-row"><span class="feat-name">Parallel execution</span><span class="feat-ch green">✓ Per-part parallelism</span><span class="feat-dk green">✓ Morsel-driven</span></div>
            <div class="feature-row"><span class="feat-name">Query cache</span><span class="feat-ch green">✓</span><span class="feat-dk yellow">~ Planned</span></div>
            <div class="feature-row"><span class="feat-name">Materialized views</span><span class="feat-ch green">✓ Real-time</span><span class="feat-dk red">✗</span></div>
            <div class="feature-row"><span class="feat-name">Approximate functions</span><span class="feat-ch green">✓ HyperLogLog, quantiles</span><span class="feat-dk green">✓ HLL, approx_quantile</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Section 6: Decision Tree ===== -->
    <section class="demo-section">
      <h2>🧭 Which Should You Choose?</h2>
      <p class="section-desc">Answer a few questions to get a recommendation. Click to start.</p>
      <div class="decision-tree" id="decisionTree">
        <div class="dt-question" id="dtQuestion">What's your data volume?</div>
        <div class="dt-options" id="dtOptions">
          <button class="dt-btn" data-answer="small">Under 10 GB</button>
          <button class="dt-btn" data-answer="medium">10 GB – 1 TB</button>
          <button class="dt-btn" data-answer="large">Over 1 TB</button>
        </div>
        <div class="dt-path" id="dtPath"></div>
        <div class="dt-result" id="dtResult"></div>
      </div>
    </section>

    <!-- ===== Section 7: Can You Combine Them? ===== -->
    <section class="demo-section">
      <h2>🤝 Using Both Together</h2>
      <p class="section-desc">They're not mutually exclusive! Many teams use DuckDB for local exploration and ClickHouse for production dashboards.</p>
      <div class="combo-viz" id="comboViz">
        <div class="combo-flow">
          <div class="combo-node source-node">
            <div class="combo-icon">📂</div>
            <div>Raw Data<br/><small>S3 / Parquet</small></div>
          </div>
          <div class="combo-arrow">→</div>
          <div class="combo-node dk-node">
            <div class="combo-icon">🦆</div>
            <div>DuckDB<br/><small>Explore & Transform</small></div>
          </div>
          <div class="combo-arrow">→</div>
          <div class="combo-node ch-node">
            <div class="combo-icon">🟡</div>
            <div>ClickHouse<br/><small>Serve Dashboards</small></div>
          </div>
          <div class="combo-arrow">→</div>
          <div class="combo-node app-node">
            <div class="combo-icon">📊</div>
            <div>Grafana / App<br/><small>End Users</small></div>
          </div>
        </div>
        <div class="combo-scenarios">
          <div class="combo-card">
            <h4>🔬 Data Science Workflow</h4>
            <p>Use DuckDB in Jupyter to explore Parquet files on S3. Once you know the schema and transformations, load into ClickHouse for production queries.</p>
          </div>
          <div class="combo-card">
            <h4>🧪 CI/CD Testing</h4>
            <p>Run analytical tests with DuckDB in CI (no server needed). Deploy to ClickHouse in staging/prod for multi-user dashboards.</p>
          </div>
          <div class="combo-card">
            <h4>🏠 Local → Cloud</h4>
            <p>Prototype queries on your laptop with DuckDB. When data grows beyond single-node, migrate to ClickHouse Cloud or self-hosted cluster.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Related Pages -->
    <section class="demo-section">
      <h2>📚 Related Pages</h2>
      <div class="family-grid">
        <a href="/clickhouse/mergetree/" class="family-card" style="text-decoration:none;">
          <h4>🌲 MergeTree Engine</h4>
          <p>Deep dive into ClickHouse's core storage engine — parts, merges, sparse indexes.</p>
        </a>
        <a href="/clickhouse/query-execution/" class="family-card accent-blue" style="text-decoration:none;">
          <h4>⚡ Query Execution</h4>
          <p>How ClickHouse processes queries from SQL to result with parallel pipelines.</p>
        </a>
        <a href="/clickhouse/distributed-tables/" class="family-card accent-green" style="text-decoration:none;">
          <h4>🌐 Distributed Tables</h4>
          <p>Sharding, routing, and distributed query execution across ClickHouse nodes.</p>
        </a>
        <a href="/clickhouse/materialized-views/" class="family-card accent-purple" style="text-decoration:none;">
          <h4>📐 Materialized Views</h4>
          <p>Real-time aggregation pipelines — a feature DuckDB doesn't have.</p>
        </a>
      </div>
    </section>
  </div>

<style>
  /* ===== Base styles (match site theme) ===== */
  .viz-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px 60px;
  }
  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .viz-header h1 {
    font-size: 2.2rem;
    margin-bottom: 8px;
  }
  .subtitle {
    color: #94a3b8;
    font-size: 1.1rem;
  }
  .demo-section {
    background: #1e293b;
    border-radius: 12px;
    padding: 28px;
    margin-bottom: 28px;
    border: 1px solid #334155;
  }
  .demo-section h2 {
    margin-top: 0;
    font-size: 1.4rem;
    margin-bottom: 8px;
  }
  .section-desc {
    color: #94a3b8;
    margin-bottom: 20px;
    line-height: 1.6;
  }
  .controls-section {
    margin-bottom: 20px;
  }
  .control-group {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .action-btn {
    padding: 8px 16px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s;
  }
  .insert-btn { background: #3b82f6; color: white; }
  .insert-btn:hover { background: #2563eb; }
  .insert-btn-secondary { background: #1e40af; color: #93c5fd; }
  .insert-btn-secondary:hover { background: #1e3a8a; }
  .search-btn { background: #10b981; color: white; }
  .search-btn:hover { background: #059669; }
  .compress-btn { background: #8b5cf6; color: white; }
  .compress-btn:hover { background: #7c3aed; }
  .reset-btn { background: #475569; color: #cbd5e1; }
  .reset-btn:hover { background: #64748b; }
  .codec-select {
    background: #0f172a;
    color: #e2e8f0;
    border: 1px solid #334155;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 0.9rem;
  }
  .query-display {
    background: #0f172a;
    border: 1px solid #334155;
    border-radius: 8px;
    padding: 12px 16px;
    margin-top: 12px;
    overflow-x: auto;
  }
  .query-display code {
    color: #7dd3fc;
    font-size: 0.85rem;
  }
  .active-toggle {
    box-shadow: 0 0 0 2px #3b82f6;
  }

  /* ===== Architecture Cards ===== */
  .arch-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .arch-card {
    background: #0f172a;
    border-radius: 10px;
    padding: 20px;
    border: 2px solid #334155;
    cursor: pointer;
    transition: all 0.2s;
  }
  .arch-card:hover { border-color: #64748b; transform: translateY(-2px); }
  .ch-card:hover { border-color: #eab308; }
  .dk-card:hover { border-color: #f97316; }
  .arch-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .arch-icon { font-size: 1.8rem; }
  .arch-header h3 { margin: 0; }
  .arch-props {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .arch-props li {
    padding: 6px 0;
    border-bottom: 1px solid #1e293b;
    font-size: 0.9rem;
    color: #cbd5e1;
  }
  .arch-props li:last-child { border-bottom: none; }

  /* ===== Storage Canvas ===== */
  .storage-viz {
    background: #0f172a;
    border-radius: 10px;
    padding: 16px;
    text-align: center;
  }
  #storageCanvas { max-width: 100%; height: auto; }
  .storage-explanation {
    margin-top: 12px;
    padding: 12px;
    background: #0f172a;
    border-radius: 8px;
    color: #94a3b8;
    line-height: 1.6;
  }

  /* ===== Race Visualization ===== */
  .race-viz {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 16px;
  }
  .race-lane {
    background: #0f172a;
    border-radius: 10px;
    padding: 16px;
    border: 1px solid #334155;
  }
  .race-lane h4 { margin: 0 0 12px; }
  .pipeline-flow {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .pipe-stage {
    background: #1e293b;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 0.8rem;
    color: #94a3b8;
    transition: all 0.3s;
  }
  .pipe-stage.active { background: #3b82f6; color: white; }
  .pipe-stage.done { background: #10b981; color: white; }
  .pipe-arrow { color: #475569; font-size: 0.8rem; }
  .progress-bar {
    height: 8px;
    background: #1e293b;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .progress-fill {
    height: 100%;
    border-radius: 4px;
    width: 0%;
    transition: width 0.3s ease;
  }
  .ch-fill { background: linear-gradient(90deg, #eab308, #f59e0b); }
  .dk-fill { background: linear-gradient(90deg, #f97316, #fb923c); }
  .race-stats { font-size: 0.85rem; color: #94a3b8; }

  /* ===== Benchmark ===== */
  .bench-label {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 0.85rem;
    color: #94a3b8;
  }
  .bench-results {
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .bench-bar-group {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .bench-bar-label { width: 120px; font-size: 0.9rem; flex-shrink: 0; }
  .bench-bar-track {
    flex: 1;
    height: 32px;
    background: #0f172a;
    border-radius: 6px;
    overflow: hidden;
  }
  .bench-bar {
    height: 100%;
    border-radius: 6px;
    width: 0%;
    transition: width 0.8s ease;
    display: flex;
    align-items: center;
    padding-left: 8px;
    font-size: 0.8rem;
    color: white;
    font-weight: 600;
  }
  .ch-bar { background: linear-gradient(90deg, #eab308, #ca8a04); }
  .dk-bar { background: linear-gradient(90deg, #f97316, #ea580c); }
  .bench-time { font-size: 0.9rem; color: #e2e8f0; width: 80px; text-align: right; }
  .bench-verdict {
    margin-top: 12px;
