---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="MergeTree Engine: Column Storage, Parts & Merges" 
  description="Interactive visualization of ClickHouse MergeTree engine internals: column-oriented storage, parts, background merges, sparse indexes, and data skipping"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "ClickHouse", href: "/clickhouse/" },
    { label: "MergeTree Engine", href: "/clickhouse/mergetree/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🌲 MergeTree Engine</h1>
      <p class="subtitle">Column Storage, Parts & Background Merges — The Heart of ClickHouse</p>
    </header>

    <!-- ===== Section 1: Column vs Row Storage ===== -->
    <section class="demo-section">
      <h2>📊 Column vs Row Storage</h2>
      <p class="section-desc">Click a column header to see how column-oriented storage reads only what it needs.</p>
      <div class="storage-compare">
        <div class="storage-panel">
          <h3>Row-Oriented (PostgreSQL-style)</h3>
          <div class="row-table" id="rowTable"></div>
          <div class="read-indicator" id="rowReadInfo">Click a column above to compare</div>
        </div>
        <div class="storage-panel">
          <h3>Column-Oriented (ClickHouse)</h3>
          <div class="col-table" id="colTable"></div>
          <div class="read-indicator" id="colReadInfo">Click a column above to compare</div>
        </div>
      </div>
      <div class="storage-stats" id="storageStats"></div>
    </section>

    <!-- ===== Section 2: Insert → Parts → Merge ===== -->
    <section class="demo-section">
      <h2>📦 Parts &amp; Background Merges</h2>
      <p class="section-desc">Each INSERT creates a new "part" on disk. Background merges combine parts for efficiency.</p>
      <div class="controls-section">
        <div class="control-group">
          <button id="insertBtn" class="action-btn insert-btn">✏️ INSERT Batch</button>
          <button id="insert5Btn" class="action-btn insert-btn-secondary">⚡ INSERT ×5</button>
          <button id="mergeBtn" class="action-btn merge-action-btn">🔄 Force Merge</button>
          <button id="resetPartsBtn" class="action-btn reset-btn">↺ Reset</button>
        </div>
        <div class="stats-row">
          <div class="stat">
            <span class="stat-label">Parts</span>
            <span class="stat-value" id="partCount">0</span>
          </div>
          <div class="stat">
            <span class="stat-label">Total Rows</span>
            <span class="stat-value" id="totalRows">0</span>
          </div>
          <div class="stat">
            <span class="stat-label">Merges</span>
            <span class="stat-value" id="mergeCount">0</span>
          </div>
          <div class="stat">
            <span class="stat-label">Inserts</span>
            <span class="stat-value" id="insertCount">0</span>
          </div>
        </div>
      </div>

      <div class="parts-viz" id="partsViz">
        <div class="parts-container" id="partsContainer"></div>
      </div>

      <div class="log-section">
        <h3>📜 Activity Log</h3>
        <div class="log-container" id="partsLog">
          <div class="log-entry">System ready. Click "INSERT Batch" to create parts.</div>
        </div>
      </div>
    </section>

    <!-- ===== Section 3: Sparse Index Lookup ===== -->
    <section class="demo-section">
      <h2>🔍 Sparse Index (Primary Key) Lookup</h2>
      <p class="section-desc">ClickHouse doesn't index every row — it indexes every <strong>granule</strong> (8192 rows). Enter a value to see how it skips granules.</p>
      <div class="controls-section">
        <div class="control-group">
          <input type="number" id="searchValue" min="1" max="100000" value="42000" class="search-input" placeholder="Search value..." />
          <button id="searchBtn" class="action-btn search-btn">🔍 Lookup</button>
        </div>
      </div>
      <div class="sparse-viz" id="sparseViz">
        <div class="granule-row" id="granuleRow"></div>
        <div class="mark-row" id="markRow"></div>
        <div class="search-result" id="searchResult"></div>
      </div>
    </section>

    <!-- ===== Section 4: Compression Demo ===== -->
    <section class="demo-section">
      <h2>🗜️ Compression Codecs</h2>
      <p class="section-desc">Column storage enables massive compression. Different codecs suit different data patterns.</p>
      <div class="controls-section">
        <div class="control-group">
          <select id="dataType" class="codec-select">
            <option value="timestamps">Timestamps (monotonic)</option>
            <option value="ids">User IDs (random integers)</option>
            <option value="status">HTTP Status Codes (low cardinality)</option>
            <option value="metrics">Float Metrics (slowly changing)</option>
          </select>
          <button id="compressBtn" class="action-btn compress-btn">🗜️ Compress</button>
        </div>
      </div>
      <div class="compression-results" id="compressionResults"></div>
    </section>

    <!-- ===== Section 5: Data Skipping Indexes ===== -->
    <section class="demo-section">
      <h2>⚡ Data Skipping Indexes</h2>
      <p class="section-desc">Beyond the primary index, MergeTree can skip granules using minmax, set, bloom_filter, and ngrambf indexes.</p>
      <div class="skip-index-viz">
        <div class="skip-index-card">
          <h4>minmax</h4>
          <p>Stores min/max per granule block. Best for: range queries on nearly-sorted data.</p>
          <div class="skip-example">
            <code>WHERE temperature BETWEEN 20 AND 25</code>
            <div class="skip-demo" id="skipMinmax"></div>
          </div>
        </div>
        <div class="skip-index-card">
          <h4>set(N)</h4>
          <p>Stores unique values (up to N) per block. Best for: equality on low-cardinality columns.</p>
          <div class="skip-example">
            <code>WHERE status = 404</code>
            <div class="skip-demo" id="skipSet"></div>
          </div>
        </div>
        <div class="skip-index-card">
          <h4>bloom_filter</h4>
          <p>Probabilistic membership test. Best for: equality checks on high-cardinality columns.</p>
          <div class="skip-example">
            <code>WHERE user_id = 'abc123'</code>
            <div class="skip-demo" id="skipBloom"></div>
          </div>
        </div>
        <div class="skip-index-card">
          <h4>ngrambf_v1</h4>
          <p>N-gram bloom filter for substring search. Best for: LIKE '%pattern%' queries.</p>
          <div class="skip-example">
            <code>WHERE url LIKE '%/api/v2%'</code>
            <div class="skip-demo" id="skipNgram"></div>
          </div>
        </div>
      </div>
      <button id="runSkipDemo" class="action-btn search-btn" style="margin-top: 16px;">▶️ Run Skip Demo</button>
    </section>

    <!-- ===== Section 6: MergeTree Family ===== -->
    <section class="demo-section">
      <h2>🌳 The MergeTree Family</h2>
      <div class="family-grid">
        <div class="family-card">
          <h4>MergeTree</h4>
          <p>Base engine. Stores all inserted rows. Use for append-only analytics and event logs.</p>
          <code>ENGINE = MergeTree()</code>
        </div>
        <div class="family-card accent-blue">
          <h4>ReplacingMergeTree</h4>
          <p>Deduplicates rows by sorting key during merges. Last version wins. Use for mutable dimension tables.</p>
          <code>ENGINE = ReplacingMergeTree(version)</code>
        </div>
        <div class="family-card accent-green">
          <h4>SummingMergeTree</h4>
          <p>Automatically sums numeric columns for rows with same sorting key during merges. Use for pre-aggregated counters.</p>
          <code>ENGINE = SummingMergeTree(columns)</code>
        </div>
        <div class="family-card accent-purple">
          <h4>AggregatingMergeTree</h4>
          <p>Stores partial aggregation states (AggregateFunction types). Use with materialized views for real-time rollups.</p>
          <code>ENGINE = AggregatingMergeTree()</code>
        </div>
        <div class="family-card accent-orange">
          <h4>CollapsingMergeTree</h4>
          <p>Uses a sign column (+1 / -1) to logically delete/update rows during merges. Use for mutable event streams.</p>
          <code>ENGINE = CollapsingMergeTree(sign)</code>
        </div>
      </div>
    </section>

    <!-- ===== Section 7: Partitioning ===== -->
    <section class="demo-section">
      <h2>📅 Partitioning</h2>
      <p class="section-desc">Partitions organize data into independent directories. Queries that filter on partition keys skip entire partitions.</p>
      <div class="partition-viz" id="partitionViz">
        <div class="partition-controls">
          <button id="queryAllBtn" class="action-btn query-btn">SELECT * (all partitions)</button>
          <button id="queryMonthBtn" class="action-btn query-btn">WHERE month = '2024-03'</button>
          <button id="queryRangeBtn" class="action-btn query-btn">WHERE month BETWEEN '2024-01' AND '2024-02'</button>
        </div>
        <div class="partitions-row" id="partitionsRow"></div>
        <div class="partition-result" id="partitionResult"></div>
      </div>
    </section>

    <!-- Tuning Section -->
    <section class="tuning-section">
      <h2>🎛️ Key MergeTree Settings</h2>
      <div class="tuning-grid">
        <div class="tuning-card">
          <h4>index_granularity</h4>
          <p>Rows per granule. Smaller = more precise skipping, larger index.</p>
          <code>index_granularity = 8192</code>
        </div>
        <div class="tuning-card">
          <h4>min_bytes_for_wide_part</h4>
          <p>Parts below this use compact format (single file). Above = wide format (file per column).</p>
          <code>min_bytes_for_wide_part = 10485760</code>
        </div>
        <div class="tuning-card">
          <h4>merge_with_ttl_timeout</h4>
          <p>Minimum delay between TTL-triggered merges</p>
          <code>merge_with_ttl_timeout = 14400</code>
        </div>
        <div class="tuning-card">
          <h4>max_parts_in_total</h4>
          <p>Too many parts = "too many parts" error. Keep under this limit.</p>
          <code>max_parts_in_total = 100000</code>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://clickhouse.com/docs/en/engines/table-engines/mergetree-family/mergetree" target="_blank">ClickHouse MergeTree documentation</a> and source code analysis</p>
    </footer>

    <div class="share-buttons">
      <span>Share this visualization:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20ClickHouse%20MergeTree%20visualization%20-%20see%20how%20parts%2C%20merges%2C%20and%20sparse%20indexes%20work&url=https://systeminternals.dev/clickhouse/mergetree/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/clickhouse/mergetree/" target="_blank" class="share-btn">in LinkedIn</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .viz-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #facc15, #f97316, #ef4444);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #888;
    font-size: 1.1rem;
  }

  /* Sections */
  .demo-section {
    background: rgba(255,255,255,0.02);
    border-radius: 20px;
    padding: 30px;
    border: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 30px;
  }

  .demo-section h2 {
    font-size: 1.4rem;
    color: #fff;
    margin-bottom: 8px;
  }

  .section-desc {
    color: #888;
    font-size: 0.95rem;
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .section-desc strong {
    color: #facc15;
  }

  /* Controls */
  .controls-section {
    background: rgba(255,255,255,0.03);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 20px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .control-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 20px;
  }

  .action-btn {
    padding: 12px 24px;
    border: none;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .insert-btn {
    background: linear-gradient(135deg, #f97316, #ea580c);
    color: white;
  }

  .insert-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(249, 115, 22, 0.4); }

  .insert-btn-secondary {
    background: linear-gradient(135deg, #ea580c, #c2410c);
    color: white;
  }

  .merge-action-btn {
    background: linear-gradient(135deg, #8b5cf6, #7c3aed);
    color: white;
  }

  .merge-action-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(139, 92, 246, 0.4); }

  .search-btn {
    background: linear-gradient(135deg, #3b82f6, #2563eb);
    color: white;
  }

  .search-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(59, 130, 246, 0.4); }

  .compress-btn {
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: white;
  }

  .compress-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(34, 197, 94, 0.4); }

  .query-btn {
    background: linear-gradient(135deg, #06b6d4, #0891b2);
    color: white;
    font-size: 0.85rem;
    padding: 10px 16px;
  }

  .reset-btn {
    background: rgba(255,255,255,0.1);
    color: #aaa;
  }

  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  .search-input {
    padding: 12px 20px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(0,0,0,0.3);
    color: #fff;
    font-size: 1rem;
    width: 180px;
  }

  .codec-select {
    padding: 12px 20px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(0,0,0,0.5);
    color: #fff;
    font-size: 0.95rem;
  }

  .stats-row {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .stat { text-align: center; }

  .stat-label {
    display: block;
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 4px;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
  }

  /* Column vs Row Storage */
  .storage-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 16px;
  }

  .storage-panel {
    background: rgba(0,0,0,0.2);
    border-radius: 12px;
    padding: 16px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .storage-panel h3 {
    font-size: 0.95rem;
    color: #aaa;
    margin-bottom: 12px;
    text-align: center;
  }

  :global(.storage-row) {
    display: flex;
    gap: 2px;
    margin-bottom: 2px;
  }

  :global(.storage-cell) {
    padding: 6px 8px;
    font-size: 0.7rem;
    border-radius: 4px;
    flex: 1;
    text-align: center;
    transition: all 0.3s;
    background: rgba(255,255,255,0.05);
    color: #888;
    cursor: pointer;
  }

  :global(.storage-cell.header) {
    background: rgba(255,255,255,0.1);
    color: #fff;
    font-weight: 600;
    cursor: pointer;
  }

  :global(.storage-cell.highlight) {
    background: rgba(59, 130, 246, 0.4);
    color: #fff;
  }

  :global(.storage-cell.dimmed) {
    opacity: 0.2;
  }

  .read-indicator {
    text-align: center;
    font-size: 0.85rem;
    color: #666;
    margin-top: 10px;
    min-height: 24px;
  }

  .storage-stats {
    text-align: center;
    font-size: 0.9rem;
    color: #888;
    min-height: 24px;
  }

  /* Parts viz */
  .parts-viz {
    margin-bottom: 20px;
    min-height: 100px;
  }

  .parts-container {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    min-height: 80px;
    align-items: flex-start;
  }

  :global(.part-block) {
    background: rgba(249, 115, 22, 0.15);
    border: 1px solid rgba(249, 115, 22, 0.4);
    border-radius: 10px;
    padding: 12px;
    min-width: 100px;
    animation: partAppear 0.4s ease-out;
    transition: all 0.3s;
  }

  :global(.part-block.merging) {
    animation: mergePulse 0.6s ease-in-out infinite;
    border-color: rgba(139, 92, 246, 0.6);
    background: rgba(139, 92, 246, 0.15);
  }

  :global(.part-block.merged) {
    background: rgba(34, 197, 94, 0.15);
    border-color: rgba(34, 197, 94, 0.4);
  }

  @keyframes partAppear {
    from { transform: scale(0.7) translateY(-10px); opacity: 0; }
    to { transform: scale(1) translateY(0); opacity: 1; }
  }

  @keyframes mergePulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.97); }
  }

  :global(.part-name) {
    font-size: 0.75rem;
    font-weight: 600;
    color: #f97316;
    margin-bottom: 4px;
  }

  :global(.part-block.merged .part-name) {
    color: #22c55e;
  }

  :global(.part-info) {
    font-size: 0.7rem;
    color: #888;
  }

  :global(.part-columns) {
    display: flex;
    gap: 3px;
    margin-top: 6px;
  }

  :global(.col-file) {
    width: 8px;
    height: 20px;
    border-radius: 2px;
    background: rgba(255,255,255,0.2);
  }

  :global(.col-file.id-col) { background: rgba(59, 130, 246, 0.5); }
  :global(.col-file.name-col) { background: rgba(34, 197, 94, 0.5); }
  :global(.col-file.val-col) { background: rgba(249, 115, 22, 0.5); }
  :global(.col-file.ts-col) { background: rgba(168, 85, 247, 0.5); }

  /* Sparse index */
  .sparse-viz {
    margin-top: 16px;
  }

  .granule-row {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }

  :global(.granule) {
    width: 48px;
    height: 36px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    color: #888;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    transition: all 0.3s;
  }

  :global(.granule.scanned) {
    background: rgba(59, 130, 246, 0.3);
    border-color: rgba(59, 130, 246, 0.6);
    color: #fff;
  }

  :global(.granule.skipped) {
    opacity: 0.2;
  }

  :global(.granule.found) {
    background: rgba(34, 197, 94, 0.4);
    border-color: rgba(34, 197, 94, 0.7);
    color: #fff;
  }

  .mark-row {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  :global(.mark) {
    width: 48px;
    text-align: center;
    font-size: 0.55rem;
    color: #555;
  }

  :global(.mark.active) {
    color: #facc15;
    font-weight: 600;
  }

  .search-result {
    font-size: 0.9rem;
    color: #888;
    min-height: 24px;
  }

  /* Compression */
  .compression-results {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
    min-height: 80px;
  }

  :global(.codec-card) {
    background: rgba(0,0,0,0.2);
    border-radius: 10px;
    padding: 16px;
    border: 1px solid rgba(255,255,255,0.1);
    animation: partAppear 0.3s ease-out;
  }

  :global(.codec-name) {
    font-size: 0.85rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }

  :global(.codec-bar-bg) {
    height: 12px;
    background: rgba(255,255,255,0.05);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 6px;
  }

  :global(.codec-bar-fill) {
    height: 100%;
    border-radius: 6px;
    transition: width 0.6s ease-out;
  }

  :global(.codec-ratio) {
    font-size: 0.8rem;
    color: #888;
  }

  :global(.codec-ratio strong) {
    color: #22c55e;
  }

  /* Skip indexes */
  .skip-index-viz {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }

  .skip-index-card {
    background: rgba(0,0,0,0.2);
    border-radius: 10px;
    padding: 16px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .skip-index-card h4 {
    font-size: 1rem;
    color: #facc15;
    margin-bottom: 8px;
  }

  .skip-index-card p {
    font-size: 0.85rem;
    color: #888;
    line-height: 1.5;
    margin-bottom: 10px;
  }

  .skip-example code {
    display: block;
    background: rgba(0,0,0,0.3);
    padding: 8px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    color: #22c55e;
    margin-bottom: 10px;
  }

  .skip-demo {
    display: flex;
    gap: 3px;
    min-height: 24px;
    flex-wrap: wrap;
  }

  :global(.skip-block) {
    width: 24px;
    height: 20px;
    border-radius: 4px;
    background: rgba(255,255,255,0.08);
    transition: all 0.3s;
  }

  :global(.skip-block.read) {
    background: rgba(59, 130, 246, 0.5);
  }

  :global(.skip-block.skipped) {
    background: rgba(255,255,255,0.03);
    opacity: 0.3;
  }

  /* Partitioning */
  .partition-controls {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .partitions-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  :global(.partition-block) {
    flex: 1;
    min-width: 120px;
    background: rgba(6, 182, 212, 0.1);
    border: 1px solid rgba(6, 182, 212, 0.3);
    border-radius: 10px;
    padding: 14px;
    text-align: center;
    transition: all 0.3s;
  }

  :global(.partition-block.active) {
    background: rgba(6, 182, 212, 0.25);
    border-color: rgba(6, 182, 212, 0.6);
