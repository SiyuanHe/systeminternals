<script is:inline>
  // ============================================================
  // Section 1: Column vs Row Storage
  // ============================================================
  (function() {
    var columns = ['id', 'name', 'city', 'revenue'];
    var data = [
      [1, 'Alice', 'NYC', 4500],
      [2, 'Bob', 'SF', 3200],
      [3, 'Carol', 'NYC', 7800],
      [4, 'Dave', 'LA', 2100],
      [5, 'Eve', 'SF', 5600],
      [6, 'Frank', 'NYC', 9100]
    ];

    var rowTable = document.getElementById('rowTable');
    var colTable = document.getElementById('colTable');
    var rowReadInfo = document.getElementById('rowReadInfo');
    var colReadInfo = document.getElementById('colReadInfo');
    var storageStats = document.getElementById('storageStats');

    // Build row-oriented table
    function buildRowTable() {
      var html = '<div class="storage-row">';
      for (var c = 0; c < columns.length; c++) {
        html += '<div class="storage-cell header" data-col="' + c + '">' + columns[c] + '</div>';
      }
      html += '</div>';
      for (var r = 0; r < data.length; r++) {
        html += '<div class="storage-row">';
        for (var c = 0; c < columns.length; c++) {
          html += '<div class="storage-cell" data-col="' + c + '" data-row="' + r + '">' + data[r][c] + '</div>';
        }
        html += '</div>';
      }
      rowTable.innerHTML = html;
    }

    // Build column-oriented table (transposed)
    function buildColTable() {
      var html = '';
      for (var c = 0; c < columns.length; c++) {
        html += '<div class="storage-row">';
        html += '<div class="storage-cell header" data-col="' + c + '">' + columns[c] + '</div>';
        for (var r = 0; r < data.length; r++) {
          html += '<div class="storage-cell" data-col="' + c + '" data-row="' + r + '">' + data[r][c] + '</div>';
        }
        html += '</div>';
      }
      colTable.innerHTML = html;
    }

    function highlightColumn(colIdx) {
      // Row table: highlight entire rows (must read all columns)
      var rowCells = rowTable.querySelectorAll('.storage-cell');
      for (var i = 0; i < rowCells.length; i++) {
        rowCells[i].classList.add('highlight');
      }
      rowReadInfo.textContent = 'Must read ALL ' + (data.length * columns.length) + ' cells (entire rows)';
      rowReadInfo.style.color = '#ef4444';

      // Col table: highlight only selected column
      var colCells = colTable.querySelectorAll('.storage-cell');
      for (var i = 0; i < colCells.length; i++) {
        var cellCol = parseInt(colCells[i].getAttribute('data-col'));
        if (cellCol === colIdx) {
          colCells[i].classList.add('highlight');
          colCells[i].classList.remove('dimmed');
        } else {
          colCells[i].classList.add('dimmed');
          colCells[i].classList.remove('highlight');
        }
      }
      colReadInfo.textContent = 'Read only ' + (data.length + 1) + ' cells (column "' + columns[colIdx] + '")';
      colReadInfo.style.color = '#22c55e';

      var savings = Math.round((1 - (data.length + 1) / (data.length * columns.length)) * 100);
      storageStats.innerHTML = '<strong style="color:#22c55e">' + savings + '% less data read</strong> — this is why column stores dominate analytics';
    }

    buildRowTable();
    buildColTable();

    // Attach click handlers to headers
    var allHeaders = document.querySelectorAll('.storage-cell.header');
    for (var i = 0; i < allHeaders.length; i++) {
      allHeaders[i].addEventListener('click', function() {
        var colIdx = parseInt(this.getAttribute('data-col'));
        highlightColumn(colIdx);
      });
    }
  })();

  // ============================================================
  // Section 2: Parts & Merges
  // ============================================================
  (function() {
    var parts = [];
    var partCounter = 0;
    var insertCounter = 0;
    var mergeCounter = 0;
    var totalRows = 0;
    var MERGE_TRIGGER = 4;

    var partsContainer = document.getElementById('partsContainer');
    var partsLog = document.getElementById('partsLog');
    var partCountEl = document.getElementById('partCount');
    var totalRowsEl = document.getElementById('totalRows');
    var mergeCountEl = document.getElementById('mergeCount');
    var insertCountEl = document.getElementById('insertCount');

    function pLog(msg, type) {
      var entry = document.createElement('div');
      entry.className = 'log-entry ' + (type || '');
      var now = new Date();
      entry.textContent = '[' + now.toLocaleTimeString() + '] ' + msg;
      partsLog.insertBefore(entry, partsLog.firstChild);
      if (partsLog.children.length > 20) {
        partsLog.removeChild(partsLog.lastChild);
      }
    }

    function renderParts() {
      partsContainer.innerHTML = '';
      for (var i = 0; i < parts.length; i++) {
        var p = parts[i];
        var div = document.createElement('div');
        div.className = 'part-block' + (p.merged ? ' merged' : '');
        div.innerHTML = '<div class="part-name">' + p.name + '</div>' +
          '<div class="part-info">' + p.rows + ' rows</div>' +
          '<div class="part-columns">' +
            '<div class="col-file id-col" title="id.bin"></div>' +
            '<div class="col-file name-col" title="name.bin"></div>' +
            '<div class="col-file val-col" title="value.bin"></div>' +
            '<div class="col-file ts-col" title="timestamp.bin"></div>' +
          '</div>';
        partsContainer.appendChild(div);
      }
      partCountEl.textContent = parts.length;
      totalRowsEl.textContent = totalRows;
      mergeCountEl.textContent = mergeCounter;
      insertCountEl.textContent = insertCounter;
    }

    function insertBatch() {
      var rows = Math.floor(Math.random() * 900) + 100;
      partCounter++;
      insertCounter++;
      totalRows += rows;
      var name = 'part_' + partCounter;
      parts.push({ name: name, rows: rows, merged: false });
      pLog('INSERT ' + rows + ' rows → created ' + name, 'insert');
      renderParts();

      if (parts.length >= MERGE_TRIGGER) {
        setTimeout(function() { autoMerge(); }, 600);
      }
    }

    function autoMerge() {
      if (parts.length < 2) return;
      // Merge smallest parts
      parts.sort(function(a, b) { return a.rows - b.rows; });
      var p1 = parts.shift();
      var p2 = parts.shift();
      mergeCounter++;
      partCounter++;
      var merged = {
        name: 'part_' + partCounter,
        rows: p1.rows + p2.rows,
        merged: true
      };
      parts.push(merged);
      pLog('MERGE ' + p1.name + ' + ' + p2.name + ' → ' + merged.name + ' (' + merged.rows + ' rows)', 'merge');
      renderParts();
    }

    function forceMerge() {
      if (parts.length < 2) {
        pLog('Need at least 2 parts to merge', 'info');
        return;
      }
      autoMerge();
    }

    function resetParts() {
      parts = [];
      partCounter = 0;
      insertCounter = 0;
      mergeCounter = 0;
      totalRows = 0;
      renderParts();
      partsLog.innerHTML = '<div class="log-entry">System reset. Ready.</div>';
    }

    document.getElementById('insertBtn').addEventListener('click', insertBatch);
    document.getElementById('insert5Btn').addEventListener('click', function() {
      var i = 0;
      function next() {
        if (i < 5) { insertBatch(); i++; setTimeout(next, 300); }
      }
      next();
    });
    document.getElementById('mergeBtn').addEventListener('click', forceMerge);
    document.getElementById('resetPartsBtn').addEventListener('click', resetParts);

    renderParts();
  })();

  // ============================================================
  // Section 3: Sparse Index Lookup
  // ============================================================
  (function() {
    var GRANULE_SIZE = 8192;
    var TOTAL_ROWS = 100000;
    var NUM_GRANULES = Math.ceil(TOTAL_ROWS / GRANULE_SIZE);
    var granuleRow = document.getElementById('granuleRow');
    var markRow = document.getElementById('markRow');
    var searchResult = document.getElementById('searchResult');

    function buildGranules() {
      granuleRow.innerHTML = '';
      markRow.innerHTML = '';
      for (var i = 0; i < NUM_GRANULES; i++) {
        var g = document.createElement('div');
        g.className = 'granule';
        g.setAttribute('data-idx', i);
        g.textContent = 'G' + i;
        granuleRow.appendChild(g);

        var m = document.createElement('div');
        m.className = 'mark';
        m.textContent = (i * GRANULE_SIZE).toLocaleString();
        markRow.appendChild(m);
      }
    }

    function lookup() {
      var val = parseInt(document.getElementById('searchValue').value);
      if (isNaN(val) || val < 1 || val > TOTAL_ROWS) {
        searchResult.textContent = 'Enter a value between 1 and ' + TOTAL_ROWS;
        return;
      }

      var targetGranule = Math.floor((val - 1) / GRANULE_SIZE);
      var granules = granuleRow.querySelectorAll('.granule');
      var marks = markRow.querySelectorAll('.mark');

      for (var i = 0; i < granules.length; i++) {
        granules[i].className = 'granule';
        marks[i].className = 'mark';
      }

      // Animate: binary search simulation
      var left = 0;
      var right = NUM_GRANULES - 1;
      var steps = [];

      while (left <= right) {
        var mid = Math.floor((left + right) / 2);
        var midStart = mid * GRANULE_SIZE + 1;
        var midEnd = Math.min((mid + 1) * GRANULE_SIZE, TOTAL_ROWS);
        steps.push({ idx: mid, type: 'scan' });
        if (val >= midStart && val <= midEnd) {
          steps.push({ idx: mid, type: 'found' });
          break;
        } else if (val < midStart) {
          right = mid - 1;
        } else {
          left = mid + 1;
        }
      }

      var step = 0;
      function animateStep() {
        if (step >= steps.length) {
          // Mark skipped
          for (var i = 0; i < granules.length; i++) {
            if (granules[i].className === 'granule') {
              granules[i].classList.add('skipped');
            }
          }
          searchResult.innerHTML = 'Found in <strong style="color:#22c55e">granule ' + targetGranule + '</strong> (rows ' +
            (targetGranule * GRANULE_SIZE + 1).toLocaleString() + '–' +
            Math.min((targetGranule + 1) * GRANULE_SIZE, TOTAL_ROWS).toLocaleString() + '). ' +
            'Checked <strong style="color:#facc15">' + steps.length + '</strong> marks out of ' + NUM_GRANULES + ' — <strong style="color:#22c55e">' +
            Math.round((1 - steps.length / NUM_GRANULES) * 100) + '% skipped</strong>';
          return;
        }
        var s = steps[step];
        if (s.type === 'found') {
          granules[s.idx].className = 'granule found';
          marks[s.idx].className = 'mark active';
        } else {
          granules[s.idx].className = 'granule scanned';
          marks[s.idx].className = 'mark active';
        }
        step++;
        setTimeout(animateStep, 250);
      }

      searchResult.textContent = 'Searching...';
      animateStep();
    }

    buildGranules();
    document.getElementById('searchBtn').addEventListener('click', lookup);
  })();

  // ============================================================
  // Section 4: Compression Demo
  // ============================================================
  (function() {
    var compressionData = {
      timestamps: {
        label: 'Timestamps',
        raw: 80000,
        codecs: [
          { name: 'LZ4', ratio: 3.2, color: '#3b82f6' },
          { name: 'ZSTD', ratio: 5.1, color: '#8b5cf6' },
          { name: 'Delta + LZ4', ratio: 12.5, color: '#22c55e' },
          { name: 'DoubleDelta + ZSTD', ratio: 28.0, color: '#facc15' }
        ]
      },
      ids: {
        label: 'Random User IDs',
        raw: 80000,
        codecs: [
          { name: 'LZ4', ratio: 1.8, color: '#3b82f6' },
          { name: 'ZSTD', ratio: 2.5, color: '#8b5cf6' },
          { name: 'Delta + LZ4', ratio: 1.9, color: '#22c55e' },
          { name: 'DoubleDelta + ZSTD', ratio: 2.2, color: '#facc15' }
        ]
      },
      status: {
        label: 'HTTP Status Codes',
        raw: 80000,
        codecs: [
          { name: 'LZ4', ratio: 15.0, color: '#3b82f6' },
          { name: 'ZSTD', ratio: 42.0, color: '#8b5cf6' },
          { name: 'LowCardinality + LZ4', ratio: 85.0, color: '#22c55e' },
          { name: 'LowCardinality + ZSTD', ratio: 120.0, color: '#facc15' }
        ]
      },
      metrics: {
        label: 'Float Metrics',
        raw: 80000,
        codecs: [
          { name: 'LZ4', ratio: 2.1, color: '#3b82f6' },
          { name: 'ZSTD', ratio: 3.8, color: '#8b5cf6' },
          { name: 'Gorilla + LZ4', ratio: 8.5, color: '#22c55e' },
          { name: 'Gorilla + ZSTD', ratio: 11.2, color: '#facc15' }
        ]
      }
    };

    var container = document.getElementById('compressionResults');

    function showCompression() {
      var type = document.getElementById('dataType').value;
      var d = compressionData[type];
      var maxRatio = 0;
      for (var i = 0; i < d.codecs.length; i++) {
        if (d.codecs[i].ratio > maxRatio) maxRatio = d.codecs[i].ratio;
      }

      container.innerHTML = '';
      for (var i = 0; i < d.codecs.length; i++) {
        var c = d.codecs[i];
        var pct = Math.round((c.ratio / maxRatio) * 100);
        var compressed = Math.round(d.raw / c.ratio);
        var card = document.createElement('div');
        card.className = 'codec-card';
        card.innerHTML = '<div class="codec-name">' + c.name + '</div>' +
          '<div class="codec-bar-bg"><div class="codec-bar-fill" style="width:0%;background:' + c.color + '"></div></div>' +
          '<div class="codec-ratio">' + (d.raw / 1000).toFixed(0) + 'KB → <strong>' + (compressed / 1000).toFixed(1) + 'KB</strong> (' + c.ratio + 'x)</div>';
        container.appendChild(card);
        // Animate bar
        (function(el, w) {
          setTimeout(function() { el.querySelector('.codec-bar-fill').style.width = w + '%'; }, 50);
        })(card, pct);
      }
    }

    document.getElementById('compressBtn').addEventListener('click', showCompression);
    showCompression();
  })();

  // ============================================================
  // Section 5: Data Skipping Indexes Demo
  // ============================================================
  (function() {
    var NUM_BLOCKS = 12;
    var containers = {
      minmax: document.getElementById('skipMinmax'),
      set: document.getElementById('skipSet'),
      bloom: document.getElementById('skipBloom'),
      ngram: document.getElementById('skipNgram')
    };

    function initBlocks() {
      var ids = ['skipMinmax', 'skipSet', 'skipBloom', 'skipNgram'];
      for (var k = 0; k < ids.length; k++) {
        var el = document.getElementById(ids[k]);
        el.innerHTML = '';
        for (var i = 0; i < NUM_BLOCKS; i++) {
          var b = document.createElement('div');
          b.className = 'skip-block';
          el.appendChild(b);
        }
      }
    }

    function animateSkip(containerId, readIndexes) {
      var el = document.getElementById(containerId);
      var blocks = el.querySelectorAll('.skip-block');
      var i = 0;
      function next() {
        if (i >= blocks.length) return;
        var isRead = readIndexes.indexOf(i) !== -1;
        blocks[i].className = 'skip-block ' + (isRead ? 'read' : 'skipped');
        i++;
        setTimeout(next, 80);
      }
      // Reset first
      for (var j = 0; j < blocks.length; j++) blocks[j].className = 'skip-block';
      next();
    }

    document.getElementById('runSkipDemo').addEventListener('click', function() {
      animateSkip('skipMinmax', [2, 3, 7]);
      setTimeout(function() { animateSkip('skipSet', [4]); }, 200);
      setTimeout(function() { animateSkip('skipBloom', [1, 9]); }, 400);
      setTimeout(function() { animateSkip('skipNgram', [0, 5, 6]); }, 600);
    });

    initBlocks();
  })();

  // ============================================================
  // Section 7: Partitioning
  // ============================================================
  (function() {
    var months = ['2024-01', '2024-02', '2024-03', '2024-04', '2024-05', '2024-06'];
    var partsPerMonth = [3, 2, 4, 2, 3, 1];
    var partitionsRow = document.getElementById('partitionsRow');
    var partitionResult = document.getElementById('partitionResult');

    function buildPartitions() {
      partitionsRow.innerHTML = '';
      for (var i = 0; i < months.length; i++) {
        var div = document.createElement('div');
        div.className = 'partition-block';
        div.setAttribute('data-month', months[i]);
        div.innerHTML = '<div class="partition-label">' + months[i] + '</div>' +
          '<div class="partition-parts">' + partsPerMonth[i] + ' parts</div>';
        partitionsRow.appendChild(div);
      }
    }

    function highlightPartitions(activeMonths, label) {
      var blocks = partitionsRow.querySelectorAll('.partition-block');
      var scanned = 0;
      var total = 0;
      for (var i = 0; i < blocks.length; i++) {
        total += partsPerMonth[i];
        var month = blocks[i].getAttribute('data-month');
        if (activeMonths.indexOf(month) !== -1) {
          blocks[i].className = 'partition-block active';
          scanned += partsPerMonth[i];
        } else {
          blocks[i].className = 'partition-block pruned';
        }
      }
      var pruned = months.length - activeMonths.length;
      partitionResult.innerHTML = label + ' — Scanned <strong style="color:#06b6d4">' + scanned +
        ' parts</strong> in ' + activeMonths.length + ' partitions, <strong style="color:#22c55e">pruned ' +
        pruned + ' partitions</strong>';
    }

    document.getElementById('queryAllBtn').addEventListener('click', function() {
      var blocks = partitionsRow.querySelectorAll('.partition-block');
      for (var i = 0; i < blocks.length; i++) blocks[i].className = 'partition-block active';
      partitionResult.innerHTML = 'Full scan — all ' + months.length + ' partitions read (no pruning)';
    });

    document.getElementById('queryMonthBtn').addEventListener('click', function() {
      highlightPartitions(['2024-03'], 'WHERE month = \'2024-03\'');
    });

    document.getElementById('queryRangeBtn').addEventListener('click', function() {
      highlightPartitions(['2024-01', '2024-02'], 'WHERE month BETWEEN \'2024-01\' AND \'2024-02\'');
    });

    buildPartitions();
  })();
</script>
