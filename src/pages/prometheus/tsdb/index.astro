</style>

<script is:inline>
  // ============================================================
  // Section 1: Time Series Data Model
  // ============================================================
  (function() {
    var samplesRow = document.getElementById('samplesRow');
    var modelInfo = document.getElementById('modelInfo');
    var sampleCount = 0;
    var baseTime = Date.now() - 60000;
    var value = 1000;

    function addSample() {
      sampleCount++;
      baseTime += 15000;
      value += Math.floor(Math.random() * 10) + 1;
      var t = new Date(baseTime);
      var timeStr = t.toLocaleTimeString();
      var el = document.createElement('div');
      el.className = 'sample-point';
      el.innerHTML = '<div class="ts">t=' + timeStr + '</div><div class="val">' + value + '</div>';
      samplesRow.appendChild(el);
      modelInfo.innerHTML = sampleCount + ' samples ingested. Each sample = (timestamp, float64 value) = <strong style="color:#3b82f6">16 bytes</strong> raw';
      if (samplesRow.children.length > 12) {
        samplesRow.removeChild(samplesRow.firstChild);
      }
    }

    document.getElementById('addSampleBtn').addEventListener('click', addSample);
    document.getElementById('resetModelBtn').addEventListener('click', function() {
      samplesRow.innerHTML = '';
      sampleCount = 0;
      value = 1000;
      baseTime = Date.now() - 60000;
      modelInfo.textContent = 'Click "Scrape Sample" to add timestamped data points';
    });
  })();

  // ============================================================
  // Section 2: Head Block & WAL
  // ============================================================
  (function() {
    var headSamplesCount = 0;
    var headSeriesCount = 0;
    var walSegCount = 0;
    var diskBlockCount = 0;
    var scrapeId = 0;
    var seriesNames = ['http_requests_total', 'process_cpu_seconds', 'go_goroutines', 'node_memory_bytes', 'up'];

    var headChunks = document.getElementById('headChunks');
    var walViz = document.getElementById('walSegments_viz');
    var diskViz = document.getElementById('diskBlocksViz');
    var headLog = document.getElementById('headLog');

    function hLog(msg, type) {
      var entry = document.createElement('div');
      entry.className = 'log-entry ' + (type || '');
      var now = new Date();
      entry.textContent = '[' + now.toLocaleTimeString() + '] ' + msg;
      headLog.insertBefore(entry, headLog.firstChild);
      if (headLog.children.length > 20) headLog.removeChild(headLog.lastChild);
    }

    function updateStats() {
      document.getElementById('headSamples').textContent = headSamplesCount;
      document.getElementById('headSeries').textContent = headSeriesCount;
      document.getElementById('walSegments').textContent = walSegCount;
      document.getElementById('diskBlocks').textContent = diskBlockCount;
    }

    function scrape() {
      scrapeId++;
      var newSamples = Math.floor(Math.random() * 50) + 20;
      var newSeries = Math.min(scrapeId <= 3 ? Math.floor(Math.random() * 3) + 1 : 0, 5 - headSeriesCount);
      if (headSeriesCount < 5) newSeries = Math.max(newSeries, 1);
      headSamplesCount += newSamples;
      headSeriesCount = Math.min(headSeriesCount + newSeries, seriesNames.length);

      // Add head chunk
      var chunk = document.createElement('div');
      chunk.className = 'head-chunk';
      var series = seriesNames[Math.floor(Math.random() * headSeriesCount)];
      chunk.innerHTML = series + '<div class="chunk-info">+' + newSamples + ' samples</div>';
      headChunks.appendChild(chunk);

      // WAL entry
      if (headSamplesCount % 80 < newSamples) {
        walSegCount++;
        var seg = document.createElement('div');
        seg.className = 'wal-seg';
        seg.textContent = 'seg_' + String(walSegCount).padStart(3, '0');
        walViz.appendChild(seg);
        hLog('WAL: new segment seg_' + String(walSegCount).padStart(3, '0'), 'wal');
      }

      hLog('Scrape #' + scrapeId + ': ' + newSamples + ' samples from ' + headSeriesCount + ' series', 'scrape');
      updateStats();
    }

    function compactHead() {
      if (headSamplesCount === 0) {
        hLog('Nothing to compact — head is empty', 'info');
        return;
      }
      diskBlockCount++;
      var blockId = 'block_' + String(diskBlockCount).padStart(2, '0');
      var block = document.createElement('div');
      block.className = 'disk-block';
      block.innerHTML = '<div class="block-name">' + blockId + '</div>' +
        '<div class="block-meta">' + headSamplesCount + ' samples, ' + headSeriesCount + ' series</div>' +
        '<div class="block-files">' +
          '<div class="block-file chunks-f" title="chunks/"></div>' +
          '<div class="block-file index-f" title="index"></div>' +
          '<div class="block-file meta-f" title="meta.json"></div>' +
          '<div class="block-file tombstones-f" title="tombstones"></div>' +
        '</div>';
      diskViz.appendChild(block);

      hLog('Compacted head → ' + blockId + ' (' + headSamplesCount + ' samples)', 'compact');

      headSamplesCount = 0;
      headChunks.innerHTML = '';
      walViz.innerHTML = '';
      walSegCount = 0;
      updateStats();
    }

    function resetHead() {
      headSamplesCount = 0;
      headSeriesCount = 0;
      walSegCount = 0;
      diskBlockCount = 0;
      scrapeId = 0;
      headChunks.innerHTML = '';
      walViz.innerHTML = '';
      diskViz.innerHTML = '';
      headLog.innerHTML = '<div class="log-entry">TSDB reset. Ready.</div>';
      updateStats();
    }

    document.getElementById('scrapeBtn').addEventListener('click', scrape);
    document.getElementById('scrape10Btn').addEventListener('click', function() {
      var i = 0;
      function next() {
        if (i < 10) { scrape(); i++; setTimeout(next, 200); }
      }
      next();
    });
    document.getElementById('compactHeadBtn').addEventListener('click', compactHead);
    document.getElementById('resetHeadBtn').addEventListener('click', resetHead);
    updateStats();
  })();

  // ============================================================
  // Section 3: XOR Double-Delta Compression
  // ============================================================
  (function() {
    var chart = document.getElementById('compressionChart');
    var stats = document.getElementById('compressionStats');
    var detail = document.getElementById('encodingDetail');

    function generateSamples(pattern) {
      var samples = [];
      var v = 0;
      for (var i = 0; i < 120; i++) {
        switch (pattern) {
          case 'constant': v = 42; break;
          case 'counter': v = i * 1.0; break;
          case 'spiky': v = 50 + Math.sin(i * 0.3) * 30 + (Math.random() < 0.05 ? Math.random() * 200 : 0); break;
          case 'random': v = Math.random() * 1000; break;
        }
        samples.push(v);
      }
      return samples;
    }

    function xorBits(a, b) {
      // Simulate: count significant bits in XOR
      if (a === b) return 0;
      var diff = Math.abs(a - b);
      if (diff === 0) return 1;
      return Math.max(1, Math.ceil(Math.log2(diff + 1)));
    }

    function runCompression() {
      var pattern = document.getElementById('compressionPattern').value;
      var samples = generateSamples(pattern);

      // Draw chart
      var maxVal = 0;
      for (var i = 0; i < samples.length; i++) {
        if (Math.abs(samples[i]) > maxVal) maxVal = Math.abs(samples[i]);
      }
      if (maxVal === 0) maxVal = 1;

      chart.innerHTML = '';
      for (var i = 0; i < samples.length; i++) {
        var bar = document.createElement('div');
        bar.className = 'chart-bar';
        var h = Math.max(2, (Math.abs(samples[i]) / maxVal) * 60);
        bar.style.height = h + 'px';
        chart.appendChild(bar);
      }

      // Calculate compression stats
      var rawBits = 120 * 128; // 16 bytes per sample (ts + val)
      var totalBits = 0;
      var xorBitsArr = [];

      // Timestamp: double-delta encoding
      var tsBits = 0;
      for (var i = 0; i < 120; i++) {
        if (i === 0) { tsBits += 64; }
        else if (i === 1) { tsBits += 14; }
        else { tsBits += 1; } // constant interval = 1 bit (0 = same delta)
      }
      totalBits += tsBits;

      // Value: XOR encoding
      var valBits = 0;
      var prev = 0;
      for (var i = 0; i < 120; i++) {
        if (i === 0) { valBits += 64; prev = samples[i]; }
        else {
          var bits = xorBits(samples[i], prev);
          xorBitsArr.push(bits);
          if (bits === 0) { valBits += 1; } // single 0 bit
          else { valBits += 2 + 5 + 6 + bits; } // control bits + leading + length + value
          prev = samples[i];
        }
      }
      totalBits += valBits;

      var bitsPerSample = (totalBits / 120).toFixed(2);
      var ratio = (rawBits / totalBits).toFixed(1);
      var compressed = (totalBits / 8 / 1024).toFixed(2);
      var raw = (rawBits / 8 / 1024).toFixed(2);

      stats.innerHTML = '';
      var statItems = [
        { label: 'Raw Size', value: raw + ' KB' },
        { label: 'Compressed', value: compressed + ' KB' },
        { label: 'Bits/Sample', value: bitsPerSample },
        { label: 'Ratio', value: ratio + 'x' }
      ];
      for (var i = 0; i < statItems.length; i++) {
        var card = document.createElement('div');
        card.className = 'comp-stat-card';
        card.innerHTML = '<div class="comp-stat-label">' + statItems[i].label + '</div>' +
          '<div class="comp-stat-value">' + statItems[i].value + '</div>';
        stats.appendChild(card);
      }

      // Encoding detail
      var detailHtml = '<span class="enc-dim">Timestamp encoding:</span> first=64b, delta-of-delta: ';
      detailHtml += '<span class="enc-highlight">1 bit per sample</span> (constant 15s interval)<br>';
      detailHtml += '<span class="enc-dim">Value encoding (XOR):</span> ';

      if (pattern === 'constant') {
        detailHtml += 'all XOR=0 → <span class="enc-highlight">1 bit per sample</span> (just a "same" flag)';
      } else if (pattern === 'counter') {
        detailHtml += 'XOR of sequential floats → <span class="enc-xor">~12-16 bits</span> per sample';
      } else if (pattern === 'spiky') {
        detailHtml += 'mostly small XOR, occasional spikes → <span class="enc-xor">variable 8-64 bits</span>';
      } else {
        detailHtml += 'random data → XOR gives no compression → <span class="enc-xor">~64 bits</span> per sample';
      }

      detail.innerHTML = detailHtml;
    }

    document.getElementById('runCompressionBtn').addEventListener('click', runCompression);
    runCompression();
  })();

  // ============================================================
  // Section 4: Inverted Index
  // ============================================================
  (function() {
    var index = {
      '__name__="http_requests_total"': [1, 2, 3, 4, 5, 6, 7, 8],
      'method="GET"': [1, 2, 5, 6, 7],
      'method="POST"': [3, 4, 8],
      'status="200"': [1, 3, 5, 6],
      'status="500"': [2, 4, 7, 8],
      'handler="/api"': [1, 2, 3, 4],
      'handler="/web"': [5, 6, 7, 8]
    };

    var queries = {
      method_get: { labels: ['method="GET"'], name: 'method="GET"' },
      status_500: { labels: ['status="500"'], name: 'status="500"' },
      handler_api: { labels: ['handler="/api"'], name: 'handler="/api"' },
      intersection: { labels: ['method="GET"', 'status="200"'], name: 'method="GET" AND status="200"' }
    };

    var postingLists = document.getElementById('postingLists');
    var indexResult = document.getElementById('indexResult');

    function renderIndex(highlightLabels, matchedIds) {
      postingLists.innerHTML = '';
      var labels = Object.keys(index);
      for (var i = 0; i < labels.length; i++) {
        var label = labels[i];
        var isHighlighted = highlightLabels && highlightLabels.indexOf(label) !== -1;
        var row = document.createElement('div');
        row.className = 'posting-row';

        var labelEl = document.createElement('div');
        labelEl.className = 'posting-label';
        labelEl.textContent = label;
        if (isHighlighted) labelEl.style.borderColor = 'rgba(250, 204, 21, 0.7)';

        var arrow = document.createElement('div');
        arrow.className = 'posting-arrow';
        arrow.textContent = '→';

        var idsEl = document.createElement('div');
        idsEl.className = 'posting-ids';

        var ids = index[label];
        for (var j = 0; j < ids.length; j++) {
          var idEl = document.createElement('div');
          idEl.className = 'posting-id';
          idEl.textContent = ids[j];
          if (matchedIds && matchedIds.indexOf(ids[j]) !== -1 && isHighlighted) {
            idEl.classList.add('matched');
          } else if (matchedIds && !isHighlighted) {
            idEl.classList.add('dimmed');
          }
          idsEl.appendChild(idEl);
        }

        row.appendChild(labelEl);
        row.appendChild(arrow);
        row.appendChild(idsEl);
        postingLists.appendChild(row);
      }
    }

    function lookup() {
      var queryKey = document.getElementById('labelQuery').value;
      var q = queries[queryKey];

      // Find matching IDs (intersection of all label posting lists)
      var sets = [];
      for (var i = 0; i < q.labels.length; i++) {
        sets.push(index[q.labels[i]] || []);
      }

      var result = sets[0].slice();
      for (var i = 1; i < sets.length; i++) {
        result = result.filter(function(id) { return sets[i].indexOf(id) !== -1; });
      }

      renderIndex(q.labels, result);
      indexResult.innerHTML = '<strong style="color:#facc15">' + q.name + '</strong> → matched series: <strong style="color:#22c55e">[' + result.join(', ') + ']</strong>' +
        (sets.length > 1 ? ' (intersection of ' + sets.length + ' posting lists)' : ' (' + result.length + ' of ' + index[q.labels[0]].length + ' series)');
    }

    document.getElementById('lookupBtn').addEventListener('click', lookup);
    renderIndex(null, null);
  })();

  // ============================================================
  // Section 5: Block Compaction
  // ============================================================
  (function() {
    var blocks = [];
    var blockId = 0;
    var baseHour = 0;

    var timeline = document.getElementById('compactionTimeline');
    var compInfo = document.getElementById('compactionInfo');

    function renderBlocks() {
      timeline.innerHTML = '';
      for (var i = 0; i < blocks.length; i++) {
        var b = blocks[i];
        var div = document.createElement('div');
        div.className = 'comp-block level-' + b.level;
        div.innerHTML = '<div class="comp-label">' + b.name + '</div>' +
          '<div class="comp-range">' + b.range + '</div>' +
          (b.tombstone ? '<div class="tombstone">🪦</div>' : '');
        timeline.appendChild(div);
      }
    }

    function addBlock() {
      blockId++;
      var startH = baseHour;
      baseHour += 2;
      blocks.push({
        name: 'blk_' + String(blockId).padStart(2, '0'),
        range: startH + 'h–' + (startH + 2) + 'h',
        startH: startH,
        endH: startH + 2,
        level: 0,
        tombstone: false,
        samples: Math.floor(Math.random() * 5000) + 2000
      });
      renderBlocks();
      compInfo.textContent = blocks.length + ' blocks on disk. ' + blocks.filter(function(b) { return b.level === 0; }).length + ' uncompacted.';
    }

    function compact() {
      // Find groups of consecutive level-0 blocks (3+)
      var level0 = [];
      for (var i = 0; i < blocks.length; i++) {
        if (blocks[i].level === 0) level0.push(i);
      }

      if (level0.length < 3) {
        // Try merging level-1 blocks
        var level1 = [];
        for (var i = 0; i < blocks.length; i++) {
          if (blocks[i].level === 1) level1.push(i);
        }
        if (level1.length < 2) {
          compInfo.textContent = 'Need at least 3 level-0 blocks (or 2 level-1) to compact.';
          return;
        }
        // Merge first two level-1
        var b1 = blocks[level1[0]];
        var b2 = blocks[level1[1]];
        blockId++;
        var merged = {
          name: 'blk_' + String(blockId).padStart(2, '0'),
          range: b1.startH + 'h–' + b2.endH + 'h',
          startH: b1.startH,
          endH: b2.endH,
          level: 2,
          tombstone: false,
          samples: b1.samples + b2.samples
        };
        blocks.splice(level1[1], 1);
        blocks.splice(level1[0], 1, merged);
        renderBlocks();
        compInfo.innerHTML = 'Compacted ' + b1.name + ' + ' + b2.name + ' → <strong style="color:#22c55e">' + merged.name + '</strong> (level 2, ' + merged.range + ')';
        return;
      }

      // Merge first 3 level-0 blocks
      var toMerge = level0.slice(0, 3);
      var first = blocks[toMerge[0]];
      var last = blocks[toMerge[2]];
      blockId++;
      var merged = {
        name: 'blk_' + String(blockId).padStart(2, '0'),
        range: first.startH + 'h–' + last.endH + 'h',
        startH: first.startH,
        endH: last.endH,
        level: 1,
        tombstone: false,
        samples: 0
      };
      for (var i = 0; i < 3; i++) {
        merged.samples += blocks[toMerge[i]].samples;
      }
      // Remove tombstoned series during compaction
      var hadTombstones = false;
      for (var i = 2; i >= 0; i--) {
        if (blocks[toMerge[i]].tombstone) hadTombstones = true;
        blocks.splice(toMerge[i], 1);
      }
      blocks.push(merged);
      blocks.sort(function(a, b) { return a.startH - b.startH; });
      renderBlocks();
      var msg = 'Compacted 3 blocks → <strong style="color:#8b5cf6">' + merged.name + '</strong> (level 1, ' + merged.range + ')';
      if (hadTombstones) msg += ' — <span style="color:#ef4444">tombstoned series removed</span>';
      compInfo.innerHTML = msg;
    }

    function deleteSeries() {
      if (blocks.length === 0) {
        compInfo.textContent = 'No blocks to mark for deletion.';
        return;
      }
      // Mark a random block with tombstone
      var idx = Math.floor(Math.random() * blocks.length);
      blocks[idx].tombstone = true;
      renderBlocks();
      compInfo.innerHTML = 'Marked tombstone on <strong style="color:#ef4444">' + blocks[idx].name + '</strong> — will be cleaned on next compaction';
    }

    function resetBlocks() {
      blocks = [];
      blockId = 0;
      baseHour = 0;
      timeline.innerHTML = '';
      compInfo.textContent = 'Add blocks to see the compaction timeline';
    }

    document.getElementById('addBlockBtn').addEventListener('click', addBlock);
    document.getElementById('add6BlockBtn').addEventListener('click', function() {
      var i = 0;
      function next() {
        if (i < 6) { addBlock(); i++; setTimeout(next, 200); }
      }
      next();
    });
    document.getElementById('compactBlocksBtn').addEventListener('click', compact);
    document.getElementById('deleteSeriesBtn').addEventListener('click', deleteSeries);
    document.getElementById('resetBlocksBtn').addEventListener('click', resetBlocks);
  })();

  // ============================================================
  // Section 6: PromQL Query Flow Animation
  // ============================================================
  (function() {
    var steps = document.querySelectorAll('.flow-step');
    var animating = false;

    function animateFlow() {
      if (animating) return;
      animating = true;
      // Reset
      for (var i = 0; i < steps.length; i++) {
        steps[i].classList.remove('active', 'done');
      }

      var current = 0;
      function nextStep() {
        if (current > 0) {
          steps[current - 1].classList.remove('active');
          steps[current - 1].classList.add('done');
        }
        if (current >= steps.length) {
          animating = false;
          return;
        }
        steps[current].classList.add('active');
        current++;
        setTimeout(nextStep, 800);
      }
      nextStep();
    }

    document.getElementById('animateQueryBtn').addEventListener('click', animateFlow);
  })();
</script>
