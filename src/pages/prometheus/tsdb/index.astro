---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Prometheus TSDB: Time Series Storage Engine" 
  description="Interactive visualization of Prometheus TSDB internals: head block, WAL, chunk encoding, inverted index, compaction, and PromQL evaluation"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "Prometheus", href: "/prometheus/" },
    { label: "TSDB Internals", href: "/prometheus/tsdb/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>📊 Prometheus TSDB</h1>
      <p class="subtitle">Head Block, WAL, Chunks &amp; Compaction — The Storage Engine Behind Prometheus</p>
    </header>

    <!-- ===== Section 1: Time Series Data Model ===== -->
    <section class="demo-section">
      <h2>🏷️ Time Series Data Model</h2>
      <p class="section-desc">Every time series is uniquely identified by its <strong>metric name</strong> + <strong>label set</strong>. Each series holds timestamped samples.</p>
      <div class="data-model-viz">
        <div class="metric-card" id="metricCard">
          <div class="metric-header">
            <span class="metric-name">http_requests_total</span>
            <span class="metric-labels">&#123;method="GET", handler="/api", status="200"&#125;</span>
          </div>
          <div class="series-id">Series ID: <strong>42</strong></div>
          <div class="samples-row" id="samplesRow"></div>
        </div>
        <div class="model-controls">
          <button id="addSampleBtn" class="action-btn scrape-btn">📥 Scrape Sample</button>
          <button id="resetModelBtn" class="action-btn reset-btn">↺ Reset</button>
        </div>
        <div class="model-info" id="modelInfo">Click "Scrape Sample" to add timestamped data points</div>
      </div>
    </section>

    <!-- ===== Section 2: Head Block & WAL ===== -->
    <section class="demo-section">
      <h2>🧠 Head Block &amp; Write-Ahead Log</h2>
      <p class="section-desc">New samples go into the in-memory <strong>head block</strong>. The WAL ensures crash recovery. Every 2 hours, the head is compacted to a persistent block.</p>
      <div class="controls-section">
        <div class="control-group">
          <button id="scrapeBtn" class="action-btn scrape-btn">📥 Scrape Metrics</button>
          <button id="scrape10Btn" class="action-btn scrape-btn-secondary">⚡ Scrape ×10</button>
          <button id="compactHeadBtn" class="action-btn compact-btn">📦 Compact to Block</button>
          <button id="resetHeadBtn" class="action-btn reset-btn">↺ Reset</button>
        </div>
        <div class="stats-row">
          <div class="stat">
            <span class="stat-label">Head Samples</span>
            <span class="stat-value" id="headSamples">0</span>
          </div>
          <div class="stat">
            <span class="stat-label">Head Series</span>
            <span class="stat-value" id="headSeries">0</span>
          </div>
          <div class="stat">
            <span class="stat-label">WAL Segments</span>
            <span class="stat-value" id="walSegments">0</span>
          </div>
          <div class="stat">
            <span class="stat-label">Disk Blocks</span>
            <span class="stat-value" id="diskBlocks">0</span>
          </div>
        </div>
      </div>

      <div class="head-viz">
        <div class="head-area">
          <h3>🧠 Head Block (in-memory)</h3>
          <div class="head-chunks" id="headChunks"></div>
        </div>
        <div class="wal-area">
          <h3>📜 WAL (Write-Ahead Log)</h3>
          <div class="wal-segments" id="walSegments_viz"></div>
        </div>
        <div class="blocks-area">
          <h3>💾 Disk Blocks</h3>
          <div class="disk-blocks" id="diskBlocksViz"></div>
        </div>
      </div>

      <div class="log-section">
        <h3>📜 Activity Log</h3>
        <div class="log-container" id="headLog">
          <div class="log-entry">TSDB ready. Click "Scrape Metrics" to ingest samples.</div>
        </div>
      </div>
    </section>

    <!-- ===== Section 3: XOR Chunk Encoding (Gorilla) ===== -->
    <section class="demo-section">
      <h2>🗜️ XOR Double-Delta Compression (Gorilla)</h2>
      <p class="section-desc">Prometheus uses Facebook's Gorilla paper: timestamps are double-delta encoded, values use XOR with the previous value. Nearly-constant metrics compress to ~1.37 bits/sample.</p>
      <div class="controls-section">
        <div class="control-group">
          <select id="compressionPattern" class="codec-select">
            <option value="constant">Constant value (gauge = 42)</option>
            <option value="counter">Monotonic counter (+1/s)</option>
            <option value="spiky">Spiky latency (p99)</option>
            <option value="random">Random noise</option>
          </select>
          <button id="runCompressionBtn" class="action-btn compress-btn">🗜️ Encode 120 Samples</button>
        </div>
      </div>
      <div class="compression-viz">
        <div class="compression-chart" id="compressionChart"></div>
        <div class="compression-stats" id="compressionStats"></div>
        <div class="encoding-detail" id="encodingDetail"></div>
      </div>
    </section>

    <!-- ===== Section 4: Inverted Index ===== -->
    <section class="demo-section">
      <h2>🔍 Inverted Index: Label Lookup</h2>
      <p class="section-desc">Prometheus builds an inverted index mapping each <strong>label pair</strong> to a sorted list of series IDs. Queries intersect posting lists.</p>
      <div class="controls-section">
        <div class="control-group">
          <select id="labelQuery" class="codec-select">
            <option value="method_get">method="GET"</option>
            <option value="status_500">status="500"</option>
            <option value="handler_api">handler="/api"</option>
            <option value="intersection">method="GET" AND status="200"</option>
          </select>
          <button id="lookupBtn" class="action-btn search-btn">🔍 Lookup</button>
        </div>
      </div>
      <div class="index-viz" id="indexViz">
        <div class="posting-lists" id="postingLists"></div>
        <div class="index-result" id="indexResult"></div>
      </div>
    </section>

    <!-- ===== Section 5: Block Compaction ===== -->
    <section class="demo-section">
      <h2>🔄 Block Compaction</h2>
      <p class="section-desc">Small 2-hour blocks are merged into larger blocks (up to 31.25% of retention). Tombstones from deletes are cleaned during compaction.</p>
      <div class="controls-section">
        <div class="control-group">
          <button id="addBlockBtn" class="action-btn scrape-btn">➕ Add 2h Block</button>
          <button id="add6BlockBtn" class="action-btn scrape-btn-secondary">⚡ Add ×6</button>
          <button id="compactBlocksBtn" class="action-btn compact-btn">🔄 Compact</button>
          <button id="deleteSeriesBtn" class="action-btn delete-btn">🪦 Delete Series</button>
          <button id="resetBlocksBtn" class="action-btn reset-btn">↺ Reset</button>
        </div>
      </div>
      <div class="compaction-viz">
        <div class="compaction-timeline" id="compactionTimeline"></div>
        <div class="compaction-info" id="compactionInfo">Add blocks to see the compaction timeline</div>
      </div>
    </section>

    <!-- ===== Section 6: PromQL Query Flow ===== -->
    <section class="demo-section">
      <h2>⚡ PromQL Range Query Flow</h2>
      <p class="section-desc">See how a range query scans through blocks and series to produce results.</p>
      <div class="query-flow-viz">
        <div class="query-box">
          <code>rate(http_requests_total&#123;status="200"&#125;[5m])</code>
        </div>
        <div class="flow-steps" id="flowSteps">
          <div class="flow-step" data-step="0">
            <div class="step-num">1</div>
            <div class="step-content">
              <h4>Parse PromQL</h4>
              <p>AST: rate(selector[5m])</p>
            </div>
          </div>
          <div class="flow-step" data-step="1">
            <div class="step-num">2</div>
            <div class="step-content">
              <h4>Resolve Label Matchers</h4>
              <p>Inverted index: status="200" → posting list</p>
            </div>
          </div>
          <div class="flow-step" data-step="2">
            <div class="step-num">3</div>
            <div class="step-content">
              <h4>Find Overlapping Blocks</h4>
              <p>Time range → which blocks to scan</p>
            </div>
          </div>
          <div class="flow-step" data-step="3">
            <div class="step-num">4</div>
            <div class="step-content">
              <h4>Read Chunks</h4>
              <p>Decode XOR-compressed samples from chunks</p>
            </div>
          </div>
          <div class="flow-step" data-step="4">
            <div class="step-num">5</div>
            <div class="step-content">
              <h4>Evaluate rate()</h4>
              <p>Compute per-second increase over 5m window</p>
            </div>
          </div>
        </div>
        <button id="animateQueryBtn" class="action-btn search-btn" style="margin-top: 16px;">▶️ Animate Query Flow</button>
      </div>
    </section>

    <!-- ===== Key Settings ===== -->
    <section class="tuning-section">
      <h2>🎛️ Key TSDB Settings</h2>
      <div class="tuning-grid">
        <div class="tuning-card">
          <h4>--storage.tsdb.retention.time</h4>
          <p>How long to keep data. Older blocks are deleted.</p>
          <code>--storage.tsdb.retention.time=15d</code>
        </div>
        <div class="tuning-card">
          <h4>--storage.tsdb.min-block-duration</h4>
          <p>Minimum block range. Head compacts after this period.</p>
          <code>--storage.tsdb.min-block-duration=2h</code>
        </div>
        <div class="tuning-card">
          <h4>--storage.tsdb.max-block-duration</h4>
          <p>Maximum block range after compaction. Defaults to 10% of retention.</p>
          <code>--storage.tsdb.max-block-duration=36h</code>
        </div>
        <div class="tuning-card">
          <h4>--storage.tsdb.wal-compression</h4>
          <p>Enable snappy compression for WAL segments to reduce disk I/O.</p>
          <code>--storage.tsdb.wal-compression</code>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://ganeshvernekar.com/blog/prometheus-tsdb-the-head-block/" target="_blank">Ganesh Vernekar's TSDB deep-dive</a>, the <a href="https://www.vldb.org/pvldb/vol8/p1816-teller.pdf" target="_blank">Gorilla paper</a>, and Prometheus source code</p>
    </footer>

    <div class="share-buttons">
      <span>Share this visualization:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20Prometheus%20TSDB%20visualization%20-%20see%20how%20head%20blocks%2C%20WAL%2C%20and%20compaction%20work&url=https://systeminternals.dev/prometheus/tsdb/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/prometheus/tsdb/" target="_blank" class="share-btn">in LinkedIn</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .viz-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #e65732, #f97316, #facc15);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #888;
    font-size: 1.1rem;
  }

  .demo-section {
    background: rgba(255,255,255,0.02);
    border-radius: 20px;
    padding: 30px;
    border: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 30px;
  }

  .demo-section h2 {
    font-size: 1.4rem;
    color: #fff;
    margin-bottom: 8px;
  }

  .section-desc {
    color: #888;
    font-size: 0.95rem;
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .section-desc strong {
    color: #f97316;
  }

  .controls-section {
    background: rgba(255,255,255,0.03);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 20px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .control-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 20px;
  }

  .action-btn {
    padding: 12px 24px;
    border: none;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .scrape-btn {
    background: linear-gradient(135deg, #e65732, #d94a28);
    color: white;
  }
  .scrape-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(230, 87, 50, 0.4); }

  .scrape-btn-secondary {
    background: linear-gradient(135deg, #d94a28, #c2410c);
    color: white;
  }

  .compact-btn {
    background: linear-gradient(135deg, #8b5cf6, #7c3aed);
    color: white;
  }
  .compact-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(139, 92, 246, 0.4); }

  .search-btn {
    background: linear-gradient(135deg, #3b82f6, #2563eb);
    color: white;
  }
  .search-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(59, 130, 246, 0.4); }

  .compress-btn {
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: white;
  }
  .compress-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(34, 197, 94, 0.4); }

  .delete-btn {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    color: white;
  }
  .delete-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(239, 68, 68, 0.4); }

  .reset-btn {
    background: rgba(255,255,255,0.1);
    color: #aaa;
  }
  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  .codec-select {
    padding: 12px 20px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(0,0,0,0.5);
    color: #fff;
    font-size: 0.95rem;
  }

  .stats-row {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .stat { text-align: center; }

  .stat-label {
    display: block;
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 4px;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
  }

  /* Data Model */
  .data-model-viz {
    text-align: center;
  }

  .metric-card {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(230, 87, 50, 0.3);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
    text-align: left;
  }

  .metric-header {
    margin-bottom: 8px;
  }

  .metric-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: #e65732;
  }

  .metric-labels {
    font-size: 0.85rem;
    color: #facc15;
    margin-left: 4px;
  }

  .series-id {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 12px;
  }

  .series-id strong {
    color: #3b82f6;
  }

  .samples-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    min-height: 40px;
  }

  :global(.sample-point) {
    background: rgba(59, 130, 246, 0.2);
    border: 1px solid rgba(59, 130, 246, 0.4);
    border-radius: 8px;
    padding: 6px 10px;
    font-size: 0.7rem;
    color: #aaa;
    animation: sampleAppear 0.3s ease-out;
  }

  :global(.sample-point .ts) {
    color: #666;
    font-size: 0.6rem;
  }

  :global(.sample-point .val) {
    color: #3b82f6;
    font-weight: 600;
  }

  @keyframes sampleAppear {
    from { transform: scale(0.7); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .model-controls {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-bottom: 12px;
  }

  .model-info {
    font-size: 0.85rem;
    color: #666;
    min-height: 20px;
  }

  /* Head & WAL */
  .head-viz {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 20px;
  }

  .head-area, .wal-area, .blocks-area {
    background: rgba(0,0,0,0.2);
    border-radius: 12px;
    padding: 16px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .blocks-area {
    grid-column: 1 / -1;
  }

  .head-area h3, .wal-area h3, .blocks-area h3 {
    font-size: 0.9rem;
    color: #aaa;
    margin-bottom: 12px;
  }

  .head-chunks, .wal-segments, .disk-blocks {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    min-height: 50px;
  }

  :global(.head-chunk) {
    background: rgba(230, 87, 50, 0.15);
    border: 1px solid rgba(230, 87, 50, 0.4);
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 0.75rem;
    color: #e65732;
    animation: sampleAppear 0.3s ease-out;
  }

  :global(.head-chunk .chunk-info) {
    font-size: 0.65rem;
    color: #888;
  }

  :global(.wal-seg) {
    background: rgba(250, 204, 21, 0.1);
    border: 1px solid rgba(250, 204, 21, 0.3);
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 0.75rem;
    color: #facc15;
    animation: sampleAppear 0.3s ease-out;
  }

  :global(.disk-block) {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 10px;
    padding: 12px 16px;
    animation: sampleAppear 0.4s ease-out;
  }

  :global(.disk-block .block-name) {
    font-size: 0.8rem;
    font-weight: 600;
    color: #22c55e;
    margin-bottom: 4px;
  }

  :global(.disk-block .block-meta) {
    font-size: 0.65rem;
    color: #888;
  }

  :global(.disk-block .block-files) {
    display: flex;
    gap: 4px;
    margin-top: 6px;
  }

  :global(.block-file) {
    width: 10px;
    height: 18px;
    border-radius: 2px;
  }

  :global(.block-file.chunks-f) { background: rgba(59, 130, 246, 0.5); }
  :global(.block-file.index-f) { background: rgba(250, 204, 21, 0.5); }
  :global(.block-file.meta-f) { background: rgba(168, 85, 247, 0.5); }
  :global(.block-file.tombstones-f) { background: rgba(239, 68, 68, 0.3); }

  /* Compression */
  .compression-viz {
    margin-top: 16px;
  }

  .compression-chart {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 80px;
    margin-bottom: 16px;
    background: rgba(0,0,0,0.2);
    border-radius: 8px;
    padding: 10px;
  }

  :global(.chart-bar) {
    flex: 1;
    background: rgba(59, 130, 246, 0.5);
    border-radius: 2px 2px 0 0;
    min-width: 2px;
    transition: height 0.3s, background 0.3s;
  }

  .compression-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
    margin-bottom: 16px;
  }

  :global(.comp-stat-card) {
    background: rgba(0,0,0,0.2);
    border-radius: 10px;
    padding: 14px;
    border: 1px solid rgba(255,255,255,0.1);
    text-align: center;
    animation: sampleAppear 0.3s ease-out;
  }

  :global(.comp-stat-label) {
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 4px;
  }

  :global(.comp-stat-value) {
    font-size: 1.2rem;
    font-weight: 700;
    color: #22c55e;
  }

  .encoding-detail {
    background: rgba(0,0,0,0.3);
    border-radius: 8px;
    padding: 16px;
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 0.8rem;
    color: #888;
    min-height: 40px;
    line-height: 1.6;
  }

  :global(.enc-highlight) { color: #22c55e; }
  :global(.enc-dim) { color: #555; }
  :global(.enc-xor) { color: #f97316; }

  /* Inverted Index */
  .index-viz {
    margin-top: 16px;
  }

  .posting-lists {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 16px;
  }

  :global(.posting-row) {
    display: flex;
    align-items: center;
    gap: 12px;
    animation: sampleAppear 0.3s ease-out;
  }

  :global(.posting-label) {
    min-width: 180px;
    background: rgba(250, 204, 21, 0.1);
    border: 1px solid rgba(250, 204, 21, 0.3);
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 0.8rem;
    font-weight: 600;
    color: #facc15;
    text-align: right;
  }

  :global(.posting-arrow) {
    color: #555;
    font-size: 1.2rem;
  }

  :global(.posting-ids) {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  :global(.posting-id) {
    background: rgba(59, 130, 246, 0.15);
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 0.8rem;
    color: #3b82f6;
    font-weight: 600;
    transition: all 0.3s;
  }

  :global(.posting-id.matched) {
    background: rgba(34, 197, 94, 0.25);
    border-color: rgba(34, 197, 94, 0.6);
    color: #22c55e;
    transform: scale(1.1);
  }

  :global(.posting-id.dimmed) {
    opacity: 0.2;
  }

  .index-result {
    font-size: 0.9rem;
    color: #888;
    min-height: 24px;
  }

  /* Compaction */
  .compaction-viz {
    margin-top: 16px;
  }

  .compaction-timeline {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    min-height: 70px;
    align-items: flex-end;
    margin-bottom: 12px;
  }

  :global(.comp-block) {
    border-radius: 8px;
    padding: 10px 14px;
    text-align: center;
    animation: sampleAppear 0.3s ease-out;
    transition: all 0.3s;
    position: relative;
  }

  :global(.comp-block.level-0) {
    background: rgba(230, 87, 50, 0.15);
    border: 1px solid rgba(230, 87, 50, 0.4);
    min-width: 70px;
  }

  :global(.comp-block.level-1) {
