---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "Partitioning & Adaptive Capacity", description: "Hash partitioning, auto-splits, burst capacity, and the end of hot partitions", href: "/dynamodb/partitioning/", status: "live" },
  { title: "On-Demand vs Provisioned", description: "Auto-scaling mechanics, when to use each, and cost trade-offs", href: "#", status: "coming" },
  { title: "Global & Local Secondary Indexes", description: "How GSIs are separate tables and LSIs share the partition", href: "#", status: "coming" },
  { title: "Single-Table Design", description: "Access pattern modeling, overloaded keys, and adjacency lists", href: "#", status: "coming" },
  { title: "Transactions & Conflict Resolution", description: "TransactWriteItems, idempotency tokens, and optimistic locking", href: "#", status: "coming" },
  { title: "Streams & Change Data Capture", description: "DynamoDB Streams, Lambda triggers, and cross-region replication", href: "#", status: "coming" },
  { title: "DAX & Caching", description: "DynamoDB Accelerator: write-through cache architecture", href: "#", status: "coming" },
  { title: "Global Tables", description: "Multi-region active-active replication and conflict resolution", href: "#", status: "coming" },
  { title: "Backup & Restore", description: "On-demand backups, PITR, and export to S3", href: "#", status: "coming" },
  { title: "Request Router & Storage Nodes", description: "How requests flow from SDK to storage node replicas", href: "#", status: "coming" },
];
---

<BaseLayout 
  title="DynamoDB Internals" 
  description="Interactive visualizations for understanding Amazon DynamoDB architecture, partitioning, and performance tuning"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "DynamoDB", href: "/dynamodb/" }]}
>
  <section class="section-header">
    <h1>⚡ DynamoDB Internals</h1>
    <p>
      Amazon DynamoDB is a fully managed NoSQL database that delivers single-digit millisecond performance at any scale.
      Under the hood, it uses hash partitioning, automatic partition splitting, and adaptive capacity to eliminate
      hot partition problems. These visualizations help you understand the internals.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(249, 115, 22, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #f97316;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
