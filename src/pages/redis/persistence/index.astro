---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Redis Persistence: RDB & AOF" 
  description="Interactive visualization of Redis persistence mechanisms — RDB snapshots, AOF logging, crash recovery, and hybrid persistence"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "Redis", href: "/redis/" },
    { label: "Persistence", href: "/redis/persistence/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🔴 Redis Persistence: RDB & AOF</h1>
      <p class="subtitle">How Redis Saves Data to Disk and Recovers From Crashes</p>
    </header>

    <!-- Overview -->
    <section class="overview-section">
      <div class="overview-card">
        <p>
          Redis is an in-memory database, but it needs <strong>persistence</strong> to survive restarts and crashes.
          Two mechanisms exist: <em>RDB snapshots</em> (periodic point-in-time dumps) and <em>AOF</em> (append-only log of every write).
          Each has different tradeoffs for <strong>durability</strong>, <strong>performance</strong>, and <strong>recovery speed</strong>.
          Redis 7+ introduces a <em>hybrid mode</em> that combines both for the best of each world.
        </p>
      </div>
    </section>

    <!-- RDB Snapshots: BGSAVE Visualization -->
    <section class="flow-section">
      <h2>📸 RDB Snapshots: BGSAVE with Fork &amp; Copy-on-Write</h2>
      <p class="section-desc">Watch Redis fork a child process to write a point-in-time snapshot while the parent keeps serving requests</p>

      <div class="flow-controls">
        <button id="bgsaveBtn" class="action-btn primary-btn">🚀 Trigger BGSAVE</button>
        <button id="saveBtn" class="action-btn step-btn">⏸ Trigger SAVE (blocking)</button>
        <button id="resetBgsaveBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="flow-status" id="bgsaveStatus">
        <span class="status-badge idle" id="bgsaveBadge">Ready</span>
        <span class="status-text" id="bgsaveStatusText">Click BGSAVE to see fork + copy-on-write in action</span>
      </div>

      <div class="memory-viz-container">
        <div class="mem-section">
          <h4 class="mem-title parent-title">Parent Process (serves clients)</h4>
          <div class="memory-grid" id="parentMemory"></div>
          <div class="mem-label" id="parentLabel">Redis Main Process — all memory pages</div>
        </div>
        <div class="fork-arrow" id="forkArrow" style="opacity:0;">
          <div class="fork-label">fork()</div>
          <div class="fork-line"></div>
          <div class="cow-label" id="cowLabel" style="opacity:0;">COW: only modified pages copied</div>
        </div>
        <div class="mem-section" id="childSection" style="opacity:0;">
          <h4 class="mem-title child-title">Child Process (writes .rdb)</h4>
          <div class="memory-grid" id="childMemory"></div>
          <div class="mem-label" id="childLabel">Snapshot frozen at fork time</div>
        </div>
      </div>

      <div class="rdb-disk" id="rdbDisk">
        <div class="disk-icon">💾</div>
        <div class="disk-file" id="diskFile">dump.rdb</div>
        <div class="disk-progress" id="diskProgress"></div>
      </div>

      <div class="rdb-timeline" id="bgsaveTimeline"></div>
    </section>

    <!-- RDB Config -->
    <section class="explain-section">
      <div class="explain-card highlight-card">
        <h3>⚙️ RDB Save Triggers</h3>
        <p>
          Redis can automatically trigger BGSAVE based on configurable thresholds:<br>
          <code>save 900 1</code> — snapshot if at least <strong>1 key</strong> changed in 900 seconds<br>
          <code>save 300 10</code> — snapshot if at least <strong>10 keys</strong> changed in 300 seconds<br>
          <code>save 60 10000</code> — snapshot if at least <strong>10,000 keys</strong> changed in 60 seconds<br><br>
          The <em>fork()</em> system call creates a child process that shares the parent's memory pages.
          Thanks to <strong>copy-on-write (COW)</strong>, only pages modified by the parent after forking
          are actually duplicated — making BGSAVE memory-efficient even for large datasets.
        </p>
      </div>
    </section>

    <!-- AOF: Append-Only File -->
    <section class="flow-section">
      <h2>📝 AOF: Append-Only File</h2>
      <p class="section-desc">Every write command is appended to a log. Watch commands flow in and trigger a rewrite to compact.</p>

      <div class="flow-controls">
        <div class="slider-group">
          <label>fsync mode:</label>
          <select id="fsyncSelect" class="fsync-select">
            <option value="always">always (every write)</option>
            <option value="everysec" selected>everysec (every second)</option>
            <option value="no">no (OS decides)</option>
          </select>
        </div>
        <button id="aofWriteBtn" class="action-btn primary-btn">✏️ Write Commands</button>
        <button id="aofRewriteBtn" class="action-btn step-btn" disabled>🗜️ AOF Rewrite</button>
        <button id="resetAofBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="aof-container">
        <div class="aof-input-panel">
          <h4>Redis Commands</h4>
          <div class="aof-commands" id="aofCommands"></div>
        </div>
        <div class="aof-arrow-col">
          <div class="aof-flow-arrow">→</div>
          <div class="fsync-indicator" id="fsyncIndicator">
            <div class="fsync-dot"></div>
            <span id="fsyncLabel">everysec</span>
          </div>
        </div>
        <div class="aof-file-panel">
          <h4>appendonly.aof <span class="aof-size" id="aofSize">0 bytes</span></h4>
          <div class="aof-log" id="aofLog"></div>
        </div>
      </div>

      <div class="latency-meters">
        <div class="latency-meter">
          <div class="meter-label">Write Latency</div>
          <div class="meter-bar-bg">
            <div class="meter-bar" id="latencyBar" style="width:10%;"></div>
          </div>
          <div class="meter-value" id="latencyValue">~0.1ms</div>
        </div>
        <div class="latency-meter">
          <div class="meter-label">Durability</div>
          <div class="meter-bar-bg">
            <div class="meter-bar durability-bar" id="durabilityBar" style="width:80%;"></div>
          </div>
          <div class="meter-value" id="durabilityValue">High</div>
        </div>
      </div>
    </section>

    <!-- AOF Rewrite Explainer -->
    <section class="explain-section">
      <div class="explain-grid">
        <div class="explain-card">
          <h3>🔄 AOF Rewrite</h3>
          <p>
            Over time, the AOF file grows with redundant commands (e.g., 100 INCRs on the same key).
            <strong>BGREWRITEAOF</strong> forks a child that replays the current dataset to generate a
            <em>minimal</em> command set — replacing 100 INCRs with a single <code>SET key 100</code>.
            The parent buffers new writes and appends them after the rewrite completes.
          </p>
        </div>
        <div class="explain-card">
          <h3>⚡ appendfsync Modes</h3>
          <p>
            <code>always</code> — fsync after every write. <strong>Safest</strong> but slowest (~1ms per write).<br>
            <code>everysec</code> — fsync once per second. <strong>Good balance</strong>. At most 1 second of data loss.<br>
            <code>no</code> — let the OS flush when it wants. <strong>Fastest</strong> but up to 30 seconds of data loss.
          </p>
        </div>
      </div>
    </section>

    <!-- RDB vs AOF Comparison -->
    <section class="flow-section">
      <h2>⚖️ RDB vs AOF: Crash Simulation</h2>
      <p class="section-desc">See what happens when Redis crashes — how much data does each mode lose?</p>

      <div class="flow-controls">
        <div class="slider-group">
          <label>Persistence mode:</label>
          <select id="modeSelect" class="fsync-select">
            <option value="rdb">RDB only</option>
            <option value="aof-always">AOF (always)</option>
            <option value="aof-everysec">AOF (everysec)</option>
            <option value="aof-no">AOF (no)</option>
            <option value="both" selected>RDB + AOF</option>
          </select>
        </div>
        <button id="crashBtn" class="action-btn kill-btn">💥 Crash After 5s</button>
        <button id="resetCrashBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="crash-viz">
        <div class="crash-timeline-bar" id="crashTimeline">
          <div class="crash-bar-bg">
            <div class="crash-bar-rdb" id="crashBarRdb"></div>
            <div class="crash-bar-aof" id="crashBarAof"></div>
            <div class="crash-marker" id="crashMarker" style="display:none;">💥</div>
          </div>
          <div class="crash-labels">
            <span>0s</span><span>1s</span><span>2s</span><span>3s</span><span>4s</span><span>5s</span>
          </div>
        </div>
        <div class="crash-results" id="crashResults"></div>
      </div>

      <div class="comparison-table" id="comparisonTable">
        <div class="comp-header">
          <div class="comp-cell"></div>
          <div class="comp-cell comp-h">RDB</div>
          <div class="comp-cell comp-h">AOF</div>
        </div>
        <div class="comp-row">
          <div class="comp-cell comp-label">Startup Speed</div>
          <div class="comp-cell comp-good">⚡ Fast (binary load)</div>
          <div class="comp-cell comp-warn">🐢 Slower (replay commands)</div>
        </div>
        <div class="comp-row">
          <div class="comp-cell comp-label">File Size</div>
          <div class="comp-cell comp-good">📦 Compact</div>
          <div class="comp-cell comp-warn">📄 Larger (command log)</div>
        </div>
        <div class="comp-row">
          <div class="comp-cell comp-label">Data Loss Window</div>
          <div class="comp-cell comp-warn">⚠️ Minutes (between saves)</div>
          <div class="comp-cell comp-good">✅ 0–1 second</div>
        </div>
        <div class="comp-row">
          <div class="comp-cell comp-label">CPU Impact</div>
          <div class="comp-cell comp-warn">🔥 Fork spike</div>
          <div class="comp-cell comp-good">📊 Steady (append)</div>
        </div>
        <div class="comp-row">
          <div class="comp-cell comp-label">Best For</div>
          <div class="comp-cell">Backups, replication</div>
          <div class="comp-cell">Durability-critical</div>
        </div>
      </div>
    </section>

    <!-- Hybrid Persistence -->
    <section class="flow-section">
      <h2>🔀 RDB+AOF Hybrid Persistence (Redis 7+)</h2>
      <p class="section-desc">The AOF file starts with an RDB preamble for fast loading, followed by an AOF tail for recent writes</p>

      <div class="flow-controls">
        <button id="hybridPlayBtn" class="action-btn primary-btn">▶ Play Timeline</button>
        <button id="resetHybridBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="hybrid-viz">
        <div class="hybrid-file" id="hybridFile">
          <div class="hybrid-segment rdb-segment" id="hybridRdb">
            <div class="seg-label">RDB Preamble</div>
            <div class="seg-desc">Binary snapshot — fast to load</div>
          </div>
          <div class="hybrid-segment aof-segment" id="hybridAof" style="flex:0;">
            <div class="seg-label">AOF Tail</div>
            <div class="seg-desc">Recent write commands</div>
          </div>
        </div>
        <div class="hybrid-timeline" id="hybridTimeline"></div>
      </div>

      <div class="hybrid-stats">
        <div class="hybrid-stat">
          <div class="stat-num" id="hybridStartup">~200ms</div>
          <div class="stat-label">Startup Time</div>
        </div>
        <div class="hybrid-stat">
          <div class="stat-num" id="hybridLoss">&lt;1s</div>
          <div class="stat-label">Max Data Loss</div>
        </div>
        <div class="hybrid-stat">
          <div class="stat-num" id="hybridSize">Compact</div>
          <div class="stat-label">File Size</div>
        </div>
      </div>
    </section>

    <!-- Hybrid Explainer -->
    <section class="explain-section">
      <div class="explain-card highlight-card">
        <h3>💡 Why Hybrid?</h3>
        <p>
          Pure RDB is fast to load but loses minutes of data. Pure AOF is durable but slow to replay on restart.
          <strong>Hybrid persistence</strong> (<code>aof-use-rdb-preamble yes</code>) writes the AOF file as:
          an <em>RDB binary preamble</em> (fast loading) followed by an <em>AOF command tail</em> (recent writes since the last rewrite).
          On restart, Redis loads the RDB portion instantly, then replays only the small AOF tail —
          giving you <strong>fast startup AND minimal data loss</strong>.
        </p>
      </div>
    </section>

    <!-- File Size Growth -->
    <section class="flow-section">
      <h2>📊 File Size Growth: RDB vs AOF</h2>
      <p class="section-desc">Watch how file sizes change over time with continuous writes</p>

      <div class="flow-controls">
        <button id="growthPlayBtn" class="action-btn primary-btn">▶ Simulate Writes</button>
        <button id="resetGrowthBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="growth-chart-container">
        <canvas id="growthCanvas" width="780" height="300"></canvas>
      </div>
      <div class="growth-legend">
        <span class="growth-legend-item"><span class="growth-swatch" style="background:#ef4444;"></span> RDB file size</span>
        <span class="growth-legend-item"><span class="growth-swatch" style="background:#3b82f6;"></span> AOF file size</span>
        <span class="growth-legend-item"><span class="growth-swatch" style="background:#22c55e;"></span> AOF after rewrite</span>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://redis.io/docs/management/persistence/" target="_blank">Redis Persistence Documentation</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share this visualization:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20visualization%20of%20Redis%20Persistence%20RDB%20%26%20AOF&url=https://systeminternals.dev/redis/persistence/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/redis/persistence/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/redis/persistence/&t=Interactive%20Redis%20Persistence%20RDB%20%26%20AOF%20Visualizer" target="_blank" class="share-btn">🟧 Hacker News</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .viz-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #ef4444, #f97316, #eab308);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #888;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 12px;
  }

  .section-desc {
    color: #888;
    margin-bottom: 24px;
    font-size: 1rem;
  }

  /* Overview */
  .overview-section {
    margin-bottom: 50px;
  }

  .overview-card {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(249, 115, 22, 0.05));
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 16px;
    padding: 24px 28px;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #ccc;
  }

  .overview-card strong { color: #fff; }
  .overview-card em { color: #f97316; font-style: normal; font-weight: 500; }

  /* Action Buttons */
  .action-btn {
    padding: 10px 20px;
    border: none;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .action-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .primary-btn {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    color: white;
  }

  .primary-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(239, 68, 68, 0.4);
  }

  .step-btn {
    background: linear-gradient(135deg, #60a5fa, #3b82f6);
    color: white;
  }

  .kill-btn {
    background: linear-gradient(135deg, #ef4444, #b91c1c);
    color: white;
  }

  .kill-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(239, 68, 68, 0.5);
  }

  .reset-btn {
    background: rgba(255,255,255,0.1);
    color: #aaa;
  }

  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  /* Flow Section */
  .flow-section {
    margin-bottom: 50px;
  }

  .flow-controls {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 20px;
    align-items: center;
  }

  .flow-status {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    padding: 12px 16px;
    background: rgba(255,255,255,0.03);
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .status-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .status-badge.idle { background: rgba(107, 114, 128, 0.3); color: #9ca3af; }
  .status-badge.forking { background: rgba(251, 191, 36, 0.2); color: #fbbf24; }
  .status-badge.writing { background: rgba(96, 165, 250, 0.2); color: #60a5fa; }
  .status-badge.done { background: rgba(34, 197, 94, 0.2); color: #22c55e; }
  .status-badge.blocking { background: rgba(239, 68, 68, 0.2); color: #ef4444; }

  .status-text {
    color: #aaa;
    font-size: 0.95rem;
  }

  /* Memory Visualization */
  .memory-viz-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 16px;
    align-items: start;
    margin-bottom: 20px;
  }

  .mem-section {
    background: rgba(0,0,0,0.2);
    border-radius: 12px;
    padding: 16px;
    border: 1px solid rgba(255,255,255,0.1);
    transition: opacity 0.5s;
  }

  .mem-title {
    font-size: 0.9rem;
    margin-bottom: 12px;
    font-weight: 600;
  }

  .parent-title { color: #f97316; }
  .child-title { color: #60a5fa; }

  .memory-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 4px;
    margin-bottom: 8px;
  }

  :global(.mem-page) {
    aspect-ratio: 1;
    border-radius: 4px;
    transition: all 0.3s;
    position: relative;
  }

  :global(.mem-page.shared) {
    background: rgba(34, 197, 94, 0.4);
    border: 1px solid rgba(34, 197, 94, 0.6);
  }

  :global(.mem-page.modified) {
    background: rgba(249, 115, 22, 0.5);
    border: 1px solid rgba(249, 115, 22, 0.8);
    animation: pageModify 0.4s ease-out;
  }

  :global(.mem-page.cow-copied) {
    background: rgba(239, 68, 68, 0.4);
    border: 1px solid rgba(239, 68, 68, 0.7);
    animation: pageCopy 0.4s ease-out;
  }

  :global(.mem-page.frozen) {
    background: rgba(96, 165, 250, 0.3);
    border: 1px solid rgba(96, 165, 250, 0.5);
  }

  :global(.mem-page.written) {
    background: rgba(34, 197, 94, 0.5);
    border: 1px solid rgba(34, 197, 94, 0.8);
    animation: pageWrite 0.3s ease-out;
  }

  @keyframes pageModify {
    0% { transform: scale(1); }
    50% { transform: scale(1.2); }
    100% { transform: scale(1); }
  }

  @keyframes pageCopy {
    0% { opacity: 0; transform: scale(0.5); }
    100% { opacity: 1; transform: scale(1); }
  }

  @keyframes pageWrite {
    0% { opacity: 0.5; }
    100% { opacity: 1; }
  }

  .mem-label {
    font-size: 0.8rem;
    color: #666;
    text-align: center;
  }

  .fork-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding-top: 40px;
    transition: opacity 0.5s;
  }

  .fork-label {
    color: #fbbf24;
    font-weight: 700;
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 0.9rem;
  }

  .fork-line {
    width: 3px;
    height: 60px;
    background: rgba(251, 191, 36, 0.4);
    border-radius: 2px;
  }

  .cow-label {
    color: #ef4444;
    font-size: 0.75rem;
    text-align: center;
    max-width: 100px;
    transition: opacity 0.5s;
  }

  /* RDB Disk */
  .rdb-disk {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    background: rgba(0,0,0,0.2);
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 16px;
  }

  .disk-icon { font-size: 1.5rem; }

  .disk-file {
    font-family: 'Monaco', 'Menlo', monospace;
    color: #fff;
    font-weight: 600;
  }

  .disk-progress {
    flex: 1;
    height: 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 4px;
    overflow: hidden;
  }

  :global(.disk-progress-fill) {
    height: 100%;
    background: linear-gradient(90deg, #22c55e, #4ade80);
    border-radius: 4px;
    transition: width 0.3s;
  }

  .rdb-timeline {
    background: rgba(0,0,0,0.2);
    border-radius: 12px;
    padding: 16px;
    min-height: 40px;
    border: 1px solid rgba(255,255,255,0.1);
    max-height: 200px;
    overflow-y: auto;
  }

  :global(.rdb-event) {
    padding: 6px 10px;
    margin-bottom: 6px;
    border-radius: 6px;
    font-size: 0.85rem;
    animation: eventAppear 0.4s ease-out;
  }

  :global(.rdb-event.fork-event) { background: rgba(251, 191, 36, 0.1); color: #fde68a; border-left: 3px solid #fbbf24; }
  :global(.rdb-event.write-event) { background: rgba(96, 165, 250, 0.1); color: #93c5fd; border-left: 3px solid #60a5fa; }
  :global(.rdb-event.cow-event) { background: rgba(239, 68, 68, 0.1); color: #fca5a5; border-left: 3px solid #ef4444; }
  :global(.rdb-event.done-event) { background: rgba(34, 197, 94, 0.1); color: #86efac; border-left: 3px solid #22c55e; }
  :global(.rdb-event.block-event) { background: rgba(239, 68, 68, 0.15); color: #fca5a5; border-left: 3px solid #ef4444; }

  @keyframes eventAppear {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* AOF */
