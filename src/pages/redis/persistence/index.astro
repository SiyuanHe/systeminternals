<script is:inline>
  // ========== BGSAVE VISUALIZATION ==========
  var NUM_PAGES = 32;
  var parentPages = [];
  var childPages = [];
  var bgsaveRunning = false;

  var parentMemory = document.getElementById('parentMemory');
  var childMemory = document.getElementById('childMemory');
  var childSection = document.getElementById('childSection');
  var forkArrow = document.getElementById('forkArrow');
  var cowLabel = document.getElementById('cowLabel');
  var bgsaveBadge = document.getElementById('bgsaveBadge');
  var bgsaveStatusText = document.getElementById('bgsaveStatusText');
  var bgsaveTimeline = document.getElementById('bgsaveTimeline');
  var diskProgress = document.getElementById('diskProgress');

  function initPages() {
    parentPages = [];
    childPages = [];
    for (var i = 0; i < NUM_PAGES; i++) {
      parentPages.push('shared');
      childPages.push('frozen');
    }
  }

  function renderPages(container, pages, prefix) {
    container.innerHTML = '';
    for (var i = 0; i < pages.length; i++) {
      var div = document.createElement('div');
      div.className = 'mem-page ' + pages[i];
      div.title = prefix + ' page ' + i + ' (' + pages[i] + ')';
      container.appendChild(div);
    }
  }

  function addBgsaveEvent(text, cls) {
    var el = document.createElement('div');
    el.className = 'rdb-event ' + cls;
    el.textContent = text;
    bgsaveTimeline.appendChild(el);
    bgsaveTimeline.scrollTop = bgsaveTimeline.scrollHeight;
  }

  function setBgsaveStatus(badge, badgeText, statusText) {
    bgsaveBadge.className = 'status-badge ' + badge;
    bgsaveBadge.textContent = badgeText;
    bgsaveStatusText.textContent = statusText;
  }

  function sleep(ms) {
    return new Promise(function(resolve) { setTimeout(resolve, ms); });
  }

  initPages();
  renderPages(parentMemory, parentPages, 'Parent');

  // disk progress bar
  diskProgress.innerHTML = '<div class="disk-progress-fill" style="width:0%"></div>';

  document.getElementById('bgsaveBtn').addEventListener('click', function() {
    if (bgsaveRunning) return;
    bgsaveRunning = true;
    runBgsave();
  });

  document.getElementById('saveBtn').addEventListener('click', function() {
    if (bgsaveRunning) return;
    bgsaveRunning = true;
    runSave();
  });

  document.getElementById('resetBgsaveBtn').addEventListener('click', function() {
    bgsaveRunning = false;
    initPages();
    renderPages(parentMemory, parentPages, 'Parent');
    childSection.style.opacity = '0';
    forkArrow.style.opacity = '0';
    cowLabel.style.opacity = '0';
    setBgsaveStatus('idle', 'Ready', 'Click BGSAVE to see fork + copy-on-write in action');
    bgsaveTimeline.innerHTML = '';
    diskProgress.innerHTML = '<div class="disk-progress-fill" style="width:0%"></div>';
    document.getElementById('parentLabel').textContent = 'Redis Main Process \u2014 all memory pages';
  });

  async function runBgsave() {
    initPages();
    bgsaveTimeline.innerHTML = '';
    diskProgress.innerHTML = '<div class="disk-progress-fill" style="width:0%"></div>';

    // Step 1: Fork
    setBgsaveStatus('forking', 'FORKING', 'Calling fork() to create child process...');
    addBgsaveEvent('\uD83D\uDD00 BGSAVE started \u2014 calling fork()', 'fork-event');
    renderPages(parentMemory, parentPages, 'Parent');
    await sleep(800);

    // Show child
    forkArrow.style.opacity = '1';
    childSection.style.opacity = '1';
    renderPages(childMemory, childPages, 'Child');
    addBgsaveEvent('\uD83D\uDC76 Child process created \u2014 shares all memory pages via COW', 'fork-event');
    await sleep(600);

    // Step 2: Child writes to disk while parent serves
    setBgsaveStatus('writing', 'WRITING', 'Child writing .rdb to disk, parent still serving clients...');
    addBgsaveEvent('\uD83D\uDCBE Child begins serializing dataset to dump.rdb', 'write-event');

    var progressFill = diskProgress.querySelector('.disk-progress-fill');
    var totalSteps = NUM_PAGES;
    var cowPages = [3, 7, 12, 19, 25]; // pages parent modifies during BGSAVE

    for (var step = 0; step < totalSteps; step++) {
      if (!bgsaveRunning) return;

      // Child writes a page to disk
      childPages[step] = 'written';
      renderPages(childMemory, childPages, 'Child');
      var pct = Math.round(((step + 1) / totalSteps) * 100);
      progressFill.style.width = pct + '%';

      // Parent modifies a page (COW)
      if (cowPages.indexOf(step) !== -1) {
        parentPages[step] = 'modified';
        childPages[step] = 'written';
        cowLabel.style.opacity = '1';
        addBgsaveEvent('\u270F\uFE0F Parent modified page ' + step + ' \u2014 COW: page duplicated', 'cow-event');
        renderPages(parentMemory, parentPages, 'Parent');
      }

      await sleep(200);
    }

    // Done
    setBgsaveStatus('done', 'COMPLETE', 'BGSAVE complete! dump.rdb written to disk.');
    addBgsaveEvent('\u2705 dump.rdb saved successfully \u2014 child process exits', 'done-event');
    document.getElementById('parentLabel').textContent = 'Parent served clients throughout \u2014 ' + cowPages.length + ' COW pages duplicated';
    bgsaveRunning = false;
  }

  async function runSave() {
    initPages();
    bgsaveTimeline.innerHTML = '';
    diskProgress.innerHTML = '<div class="disk-progress-fill" style="width:0%"></div>';
    childSection.style.opacity = '0';
    forkArrow.style.opacity = '0';

    setBgsaveStatus('blocking', '\u26D4 BLOCKING', 'SAVE command \u2014 Redis is FROZEN, no client requests served!');
    addBgsaveEvent('\u26A0\uFE0F SAVE called \u2014 Redis blocks ALL operations!', 'block-event');
    document.getElementById('parentLabel').textContent = '\u26D4 BLOCKED \u2014 cannot serve any client requests';

    var progressFill = diskProgress.querySelector('.disk-progress-fill');

    for (var step = 0; step < NUM_PAGES; step++) {
      if (!bgsaveRunning) return;
      parentPages[step] = 'written';
      renderPages(parentMemory, parentPages, 'Parent');
      var pct = Math.round(((step + 1) / NUM_PAGES) * 100);
      progressFill.style.width = pct + '%';
      await sleep(150);
    }

    setBgsaveStatus('done', 'COMPLETE', 'SAVE complete. Redis resumes serving clients.');
    addBgsaveEvent('\u2705 dump.rdb saved \u2014 Redis unblocked', 'done-event');
    document.getElementById('parentLabel').textContent = 'Redis Main Process \u2014 SAVE complete, clients can connect again';
    bgsaveRunning = false;
  }

  // ========== AOF VISUALIZATION ==========
  var aofCommands = document.getElementById('aofCommands');
  var aofLog = document.getElementById('aofLog');
  var aofSizeEl = document.getElementById('aofSize');
  var latencyBar = document.getElementById('latencyBar');
  var latencyValue = document.getElementById('latencyValue');
  var durabilityBar = document.getElementById('durabilityBar');
  var durabilityValue = document.getElementById('durabilityValue');
  var fsyncSelect = document.getElementById('fsyncSelect');
  var aofWriteBtn = document.getElementById('aofWriteBtn');
  var aofRewriteBtn = document.getElementById('aofRewriteBtn');

  var aofEntries = [];
  var aofRunning = false;
  var aofByteSize = 0;

  var sampleCommands = [
    'SET user:1 "Alice"',
    'INCR pageviews',
    'SET user:2 "Bob"',
    'INCR pageviews',
    'HSET session:abc token xyz',
    'SET user:1 "Alice Smith"',
    'INCR pageviews',
    'DEL session:abc',
    'INCR pageviews',
    'SET counter 0',
    'INCR counter',
    'INCR counter',
    'INCR counter',
    'INCR counter',
    'SET user:3 "Charlie"',
    'LPUSH queue "job1"',
    'LPUSH queue "job2"',
    'RPOP queue',
    'INCR pageviews',
    'SET user:1 "Alice Johnson"'
  ];

  function updateFsyncMeters() {
    var mode = fsyncSelect.value;
    if (mode === 'always') {
      latencyBar.style.width = '80%';
      latencyValue.textContent = '~1ms per write';
      durabilityBar.style.width = '100%';
      durabilityValue.textContent = 'Maximum — zero data loss';
    } else if (mode === 'everysec') {
      latencyBar.style.width = '30%';
      latencyValue.textContent = '~0.1ms per write';
      durabilityBar.style.width = '80%';
      durabilityValue.textContent = 'High — up to 1s data loss';
    } else {
      latencyBar.style.width = '10%';
      latencyValue.textContent = '~0.05ms per write';
      durabilityBar.style.width = '30%';
      durabilityValue.textContent = 'Low — up to 30s data loss';
    }
    document.getElementById('fsyncLabel').textContent = mode;
  }

  fsyncSelect.addEventListener('change', updateFsyncMeters);
  updateFsyncMeters();

  aofWriteBtn.addEventListener('click', function() {
    if (aofRunning) return;
    aofRunning = true;
    runAofWrites();
  });

  aofRewriteBtn.addEventListener('click', function() {
    runAofRewrite();
  });

  document.getElementById('resetAofBtn').addEventListener('click', function() {
    aofRunning = false;
    aofEntries = [];
    aofByteSize = 0;
    aofCommands.innerHTML = '';
    aofLog.innerHTML = '';
    aofSizeEl.textContent = '0 bytes';
    aofRewriteBtn.disabled = true;
  });

  async function runAofWrites() {
    for (var i = 0; i < sampleCommands.length; i++) {
      if (!aofRunning) return;
      var cmd = sampleCommands[i];

      // Show command
      var cmdEl = document.createElement('div');
      cmdEl.className = 'aof-cmd';
      cmdEl.textContent = '> ' + cmd;
      aofCommands.appendChild(cmdEl);
      aofCommands.scrollTop = aofCommands.scrollHeight;

      // Add to AOF log
      aofEntries.push(cmd);
      var entry = document.createElement('div');
      entry.className = 'aof-entry';
      entry.textContent = cmd;
      aofLog.appendChild(entry);
      aofLog.scrollTop = aofLog.scrollHeight;

      aofByteSize += cmd.length + 20; // approximate RESP overhead
      aofSizeEl.textContent = aofByteSize + ' bytes';

      // Pulse fsync dot
      var dot = document.querySelector('.fsync-dot');
      dot.classList.remove('syncing');
      void dot.offsetWidth;
      dot.classList.add('syncing');

      if (aofEntries.length >= 5) {
        aofRewriteBtn.disabled = false;
      }

      await sleep(400);
    }
    aofRunning = false;
  }

  async function runAofRewrite() {
    aofRewriteBtn.disabled = true;

    // Compact: group by final state
    var finalState = {};
    for (var i = 0; i < aofEntries.length; i++) {
      var parts = aofEntries[i].split(' ');
      var op = parts[0];
      var key = parts[1];
      if (op === 'INCR') {
        var cur = finalState[key] || 0;
        if (typeof cur === 'number') {
          finalState[key] = cur + 1;
        } else {
          finalState[key] = 1;
        }
      } else if (op === 'SET' || op === 'HSET') {
        finalState[key] = aofEntries[i];
      } else if (op === 'DEL') {
        delete finalState[key];
      } else {
        finalState[key + ':' + i] = aofEntries[i];
      }
    }

    // Generate compact commands
    var compacted = [];
    var keys = Object.keys(finalState);
    for (var k = 0; k < keys.length; k++) {
      var key = keys[k];
      var val = finalState[key];
      if (typeof val === 'number') {
        compacted.push('SET ' + key + ' ' + val);
      } else {
        compacted.push(val);
      }
    }

    // Animate rewrite
    aofLog.innerHTML = '';
    var oldSize = aofByteSize;
    aofByteSize = 0;
    aofEntries = compacted;

    for (var j = 0; j < compacted.length; j++) {
      var entry = document.createElement('div');
      entry.className = 'aof-entry rewritten';
      entry.textContent = compacted[j];
      aofLog.appendChild(entry);
      aofByteSize += compacted[j].length + 20;
      await sleep(150);
    }

    aofSizeEl.textContent = aofByteSize + ' bytes (was ' + oldSize + ')';
  }

  // ========== CRASH SIMULATION ==========
  var crashBtn = document.getElementById('crashBtn');
  var crashResults = document.getElementById('crashResults');
  var crashBarRdb = document.getElementById('crashBarRdb');
  var crashBarAof = document.getElementById('crashBarAof');
  var crashMarker = document.getElementById('crashMarker');
  var modeSelect = document.getElementById('modeSelect');

  crashBtn.addEventListener('click', function() {
    runCrashSim();
  });

  document.getElementById('resetCrashBtn').addEventListener('click', function() {
    crashResults.innerHTML = '';
    crashBarRdb.style.width = '0%';
    crashBarAof.style.width = '0%';
    crashMarker.style.display = 'none';
  });

  async function runCrashSim() {
    var mode = modeSelect.value;
    crashResults.innerHTML = '';
    crashBarRdb.style.width = '0%';
    crashBarAof.style.width = '0%';
    crashMarker.style.display = 'none';

    // Animate 5 seconds of writes
    for (var t = 0; t <= 50; t++) {
      await sleep(80);
      var pct = (t / 50) * 100;

      // RDB bar: last snapshot was at t=0 (beginning)
      if (mode === 'rdb' || mode === 'both') {
        crashBarRdb.style.width = '0%'; // RDB snapshot at time 0
      }

      // AOF bar
      if (mode.startsWith('aof') || mode === 'both') {
        var aofPct;
        if (mode === 'aof-always' || mode === 'both') {
          aofPct = pct; // synced up to current
        } else if (mode === 'aof-everysec') {
          aofPct = Math.max(0, pct - 20); // ~1s behind
        } else {
          aofPct = Math.max(0, pct - 60); // OS decides, could be way behind
        }
        crashBarAof.style.width = aofPct + '%';
      }
    }

    // Crash!
    crashMarker.style.display = 'block';
    await sleep(300);

    // Show results
    var card = document.createElement('div');
    card.className = 'crash-result-card';

    var title = '';
    var body = '';

    if (mode === 'rdb') {
      title = '<h4 style="color:#ef4444;">\uD83D\uDCA5 RDB Only: All 5 seconds of writes LOST</h4>';
      body = '<p>Last RDB snapshot was taken before the writes began. ' +
             'All <span class="lost">~500 write operations</span> since the last snapshot are gone. ' +
             'RDB trades durability for simplicity and fast restarts.</p>';
    } else if (mode === 'aof-always') {
      title = '<h4 style="color:#22c55e;">\u2705 AOF (always): Zero data loss!</h4>';
      body = '<p>Every write was fsync\'d to disk immediately. ' +
             '<span class="saved">All ~500 operations preserved</span>. ' +
             'Cost: higher latency per write (~1ms).</p>';
    } else if (mode === 'aof-everysec') {
      title = '<h4 style="color:#fbbf24;">\u26A0\uFE0F AOF (everysec): ~1 second of writes lost</h4>';
      body = '<p>AOF was synced once per second. The last <span class="lost">~100 operations</span> (from the final second) are lost. ' +
             '<span class="saved">~400 operations preserved</span>. Best balance of durability and performance.</p>';
    } else if (mode === 'aof-no') {
      title = '<h4 style="color:#ef4444;">\uD83D\uDCA5 AOF (no fsync): ~3 seconds of writes lost</h4>';
      body = '<p>OS flushes when it wants (every ~30s). Up to <span class="lost">~300 operations lost</span>. ' +
             '<span class="saved">~200 operations preserved</span>. Fastest, but risky.</p>';
    } else if (mode === 'both') {
      title = '<h4 style="color:#22c55e;">\u2705 RDB+AOF: Minimal data loss + fast recovery</h4>';
      body = '<p>AOF (everysec) preserves all but the last second of writes: <span class="saved">~400 operations saved</span>. ' +
             'RDB provides a fast-loading baseline. On restart, Redis loads from AOF (more complete). ' +
             '<span class="lost">~100 operations lost</span> from the final second.</p>';
    }

    card.innerHTML = title + body;
    crashResults.appendChild(card);
  }

  // ========== HYBRID PERSISTENCE ==========
  var hybridPlayBtn = document.getElementById('hybridPlayBtn');
  var hybridRdb = document.getElementById('hybridRdb');
  var hybridAof = document.getElementById('hybridAof');
  var hybridTimeline = document.getElementById('hybridTimeline');
  var hybridRunning = false;

  hybridPlayBtn.addEventListener('click', function() {
    if (hybridRunning) return;
    hybridRunning = true;
    runHybridTimeline();
  });

  document.getElementById('resetHybridBtn').addEventListener('click', function() {
    hybridRunning = false;
    hybridRdb.style.flex = '3';
    hybridAof.style.flex = '0';
    hybridTimeline.innerHTML = '';
    document.getElementById('hybridStartup').textContent = '~200ms';
    document.getElementById('hybridLoss').innerHTML = '&lt;1s';
    document.getElementById('hybridSize').textContent = 'Compact';
  });

  function addHybridEvent(text, cls) {
    var el = document.createElement('div');
    el.className = 'hybrid-event ' + cls;
    el.textContent = text;
    hybridTimeline.appendChild(el);
    hybridTimeline.scrollTop = hybridTimeline.scrollHeight;
  }

  async function runHybridTimeline() {
    hybridTimeline.innerHTML = '';
    hybridRdb.style.flex = '3';
    hybridAof.style.flex = '0';

    addHybridEvent('\uD83D\uDD04 BGREWRITEAOF triggered \u2014 generating hybrid AOF file', 'rdb-ev');
    await sleep(1000);

    addHybridEvent('\uD83D\uDCF8 Writing RDB preamble (binary snapshot of current dataset)', 'rdb-ev');
    await sleep(1200);

    addHybridEvent('\u2705 RDB preamble complete \u2014 this is the "fast load" portion', 'rdb-ev');
    await sleep(800);

    // Now AOF tail grows
    addHybridEvent('\u270F\uFE0F New writes begin appending as AOF commands after the preamble', 'aof-ev');
    hybridAof.style.flex = '0.5';
    await sleep(800);

    addHybridEvent('SET user:1 "Alice" \u2192 appended to AOF tail', 'aof-ev');
    hybridAof.style.flex = '1';
    await sleep(600);

    addHybridEvent('INCR pageviews \u2192 appended to AOF tail', 'aof-ev');
    hybridAof.style.flex = '1.3';
    await sleep(600);

    addHybridEvent('SET session:x token123 \u2192 appended to AOF tail', 'aof-ev');
    hybridAof.style.flex = '1.5';
    await sleep(600);

    addHybridEvent('\uD83D\uDCA5 If Redis crashes NOW: load RDB preamble (~200ms) then replay 3 AOF commands (~instant)', 'done-ev');
    document.getElementById('hybridStartup').textContent = '~200ms';
    document.getElementById('hybridLoss').innerHTML = '&lt;1s';
    document.getElementById('hybridSize').textContent = 'Optimal';
    await sleep(1000);

    addHybridEvent('\uD83D\uDD04 Next BGREWRITEAOF: entire dataset becomes new RDB preamble, AOF tail resets', 'done-ev');
    hybridRunning = false;
  }

  // ========== FILE SIZE GROWTH CHART ==========
  var growthCanvas = document.getElementById('growthCanvas');
  var growthCtx = growthCanvas.getContext('2d');
  var growthRunning = false;

  document.getElementById('growthPlayBtn').addEventListener('click', function() {
    if (growthRunning) return;
    growthRunning = true;
    runGrowthChart();
  });

  document.getElementById('resetGrowthBtn').addEventListener('click', function() {
    growthRunning = false;
    growthCtx.clearRect(0, 0, growthCanvas.width, growthCanvas.height);
    drawGrowthAxes();
  });

  function drawGrowthAxes() {
    var w = growthCanvas.width;
    var h = growthCanvas.height;
    var pad = 50;

    growthCtx.strokeStyle = 'rgba(255,255,255,0.15)';
    growthCtx.lineWidth = 1;
    growthCtx.beginPath();
    growthCtx.moveTo(pad, 10);
    growthCtx.lineTo(pad, h - pad);
    growthCtx.lineTo(w - 10, h - pad);
    growthCtx.stroke();

    growthCtx.fillStyle = '#666';
    growthCtx.font = '11px Inter';
    growthCtx.textAlign = 'center';
    growthCtx.fillText('Time (writes)', w / 2, h - 10);
    growthCtx.save();
    growthCtx.translate(15, h / 2);
    growthCtx.rotate(-Math.PI / 2);
    growthCtx.fillText('File Size', 0, 0);
    growthCtx.restore();
  }

  drawGrowthAxes();

  async function runGrowthChart() {
    growthCtx.clearRect(0, 0, growthCanvas.width, growthCanvas.height);
    drawGrowthAxes();

    var w = growthCanvas.width;
    var h = growthCanvas.height;
    var pad = 50;
    var plotW = w - pad - 10;
    var plotH = h - pad - 10;
    var steps = 100;

    var rdbPoints = [];
    var aofPoints = [];
    var aofRewritePoints = [];

    var rdbSize = 50;
    var aofSize = 0;
    var aofRewriteSize = 0;
    var aofRewriteAt = 60;

    for (var i = 0; i <= steps; i++) {
      if (!growthRunning) return;

      // RDB: step function (jumps at snapshots)
      if (i === 0) rdbSize = 50;
      else if (i === 40) rdbSize = 80;
      else if (i === 80) rdbSize = 110;

      // AOF: grows linearly
      aofSize += 2.5;

      // AOF after rewrite at step 60
      if (i === aofRewriteAt) {
        aofRewriteSize = 60; // compacted
      } else if (i > aofRewriteAt) {
        aofRewriteSize += 2.5;
      }

      rdbPoints.push(rdbSize);
      aofPoints.push(aofSize);
      aofRewritePoints.push(aofRewriteSize);

      // Redraw
      growthCtx.clearRect(pad + 1, 0, plotW + 10, h - pad);

      var maxVal = 280;

      // Draw AOF line (blue)
      growthCtx.strokeStyle = '#3b82f6';
      growthCtx.lineWidth = 2;
      growthCtx.beginPath();
      for (var j = 0; j <= i; j++) {
        var x = pad + (j / steps) * plotW;
        var y = (h - pad) - (aofPoints[j] / maxVal) * plotH;
        if (j === 0) growthCtx.moveTo(x, y);
        else growthCtx.lineTo(x, y);
      }
      growthCtx.stroke();

      // Draw AOF rewrite line (green)
      if (i >= aofRewriteAt) {
        growthCtx.strokeStyle = '#22c55e';
        growthCtx.lineWidth = 2;
        growthCtx.setLineDash([4, 4]);
        growthCtx.beginPath();
        for (var k = aofRewriteAt; k <= i; k++) {
          var x2 = pad + (k / steps) * plotW;
          var y2 = (h - pad) - (aofRewritePoints[k] / maxVal) * plotH;
          if (k === aofRewriteAt) growthCtx.moveTo(x2, y2);
          else growthCtx.lineTo(x2, y2);
        }
        growthCtx.stroke();
        growthCtx.setLineDash([]);

        // Rewrite marker
        var rwX = pad + (aofRewriteAt / steps) * plotW;
        growthCtx.fillStyle = '#22c55e';
        growthCtx.font = '10px Inter';
        growthCtx.textAlign = 'center';
        growthCtx.fillText('\u2193 rewrite', rwX, 20);
      }

      // Draw RDB line (red, step function)
      growthCtx.strokeStyle = '#ef4444';
      growthCtx.lineWidth = 2;
      growthCtx.beginPath();
      for (var m = 0; m <= i; m++) {
        var x3 = pad + (m / steps) * plotW;
        var y3 = (h - pad) - (rdbPoints[m] / maxVal) * plotH;
        if (m === 0) growthCtx.moveTo(x3, y3);
        else growthCtx.lineTo(x3, y3);
      }
      growthCtx.stroke();

      await sleep(60);
    }
    growthRunning = false;
  }
</script>
