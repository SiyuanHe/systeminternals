  .share-btn:hover { background: rgba(255, 255, 255, 0.2); color: #fff; }

  @media (max-width: 768px) {
    .viz-header h1 { font-size: 1.8rem; }
    .explain-grid { grid-template-columns: 1fr; }
    .migration-viz { grid-template-columns: 1fr; }
    .migrate-arrow { transform: rotate(90deg); width: auto; height: 50px; }
    .calc-input-row { flex-direction: column; }
  }
</style>

<script>
  // ========== CONSTANTS ==========
  const NODE_COLORS = [
    '#ef4444', '#3b82f6', '#22c55e', '#f59e0b', '#8b5cf6', '#ec4899'
  ];
  const NODE_NAMES = ['Node A', 'Node B', 'Node C', 'Node D', 'Node E', 'Node F'];
  const TOTAL_SLOTS = 16384;

  // ========== STATE ==========
  let masterCount = 3;
  let slotOwnership: number[] = []; // slotOwnership[i] = which master (0-based) owns slot i
  let clusterNodes: Array<{
    id: number; name: string; color: string; isMaster: boolean;
    masterOf?: number; slots: [number, number]; replicaOf?: number;
    x: number; y: number;
  }> = [];

  function distributeSlots(numMasters: number) {
    slotOwnership = new Array(TOTAL_SLOTS);
    const perNode = Math.floor(TOTAL_SLOTS / numMasters);
    for (let i = 0; i < TOTAL_SLOTS; i++) {
      const owner = Math.min(Math.floor(i / perNode), numMasters - 1);
      slotOwnership[i] = owner;
    }
  }

  function buildCluster(numMasters: number) {
    clusterNodes = [];
    const perNode = Math.floor(TOTAL_SLOTS / numMasters);
    for (let i = 0; i < numMasters; i++) {
      const startSlot = i * perNode;
      const endSlot = i === numMasters - 1 ? TOTAL_SLOTS - 1 : (i + 1) * perNode - 1;
      clusterNodes.push({
        id: i, name: NODE_NAMES[i], color: NODE_COLORS[i], isMaster: true,
        slots: [startSlot, endSlot], x: 0, y: 0
      });
    }
    // Add replicas
    for (let i = 0; i < numMasters; i++) {
      clusterNodes.push({
        id: numMasters + i, name: `${NODE_NAMES[i]} Replica`,
        color: NODE_COLORS[i], isMaster: false, replicaOf: i,
        slots: [0, 0], x: 0, y: 0
      });
    }
  }

  // ========== CRC16 ==========
  function crc16(str: string): number {
    const table = new Uint16Array(256);
    for (let i = 0; i < 256; i++) {
      let crc = i << 8;
      for (let j = 0; j < 8; j++) {
        crc = (crc & 0x8000) ? ((crc << 1) ^ 0x1021) : (crc << 1);
        crc &= 0xFFFF;
      }
      table[i] = crc;
    }
    let crc = 0;
    for (let i = 0; i < str.length; i++) {
      crc = ((crc << 8) ^ table[((crc >> 8) ^ str.charCodeAt(i)) & 0xFF]) & 0xFFFF;
    }
    return crc;
  }

  function keyToSlot(key: string): number {
    // Handle hash tags: {tag}
    const start = key.indexOf('{');
    if (start !== -1) {
      const end = key.indexOf('}', start + 1);
      if (end !== -1 && end !== start + 1) {
        key = key.substring(start + 1, end);
      }
    }
    return crc16(key) & 16383;
  }

  // ========== INIT ==========
  distributeSlots(masterCount);
  buildCluster(masterCount);

  // ========== KEY CALCULATOR ==========
  const keyInput = document.getElementById('keyInput') as HTMLInputElement;
  const calcBtn = document.getElementById('calcBtn')!;
  const calcResult = document.getElementById('calcResult')!;
  const calcFormula = document.getElementById('calcFormula')!;

  function calculate() {
    const key = keyInput.value.trim();
    if (!key) { calcResult.innerHTML = ''; calcFormula.innerHTML = ''; return; }
    const slot = keyToSlot(key);
    const owner = slotOwnership[slot];
    const node = clusterNodes[owner];
    calcResult.innerHTML = `
      <span style="color:${node.color};">●</span>
      Slot <span style="color:#ef4444;font-family:monospace;">${slot}</span> → 
      <span style="color:${node.color};font-weight:700;">${node.name}</span>
      <span style="color:#888;font-size:0.9rem;">(slots ${node.slots[0]}–${node.slots[1]})</span>
    `;
    const crcVal = crc16(key);
    calcFormula.textContent = `CRC16("${key}") = ${crcVal} → ${crcVal} & 16383 = ${slot}`;
  }

  calcBtn.addEventListener('click', calculate);
  keyInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') calculate(); });
  keyInput.addEventListener('input', calculate);

  // ========== SLOT GRID (Canvas) ==========
  const slotCanvas = document.getElementById('slotCanvas') as HTMLCanvasElement;
  const slotCtx = slotCanvas.getContext('2d')!;
  const slotHoverInfo = document.getElementById('slotHoverInfo')!;
  const nodeLegend = document.getElementById('nodeLegend')!;

  function renderLegend() {
    nodeLegend.innerHTML = '';
    for (let i = 0; i < masterCount; i++) {
      const item = document.createElement('span');
      item.className = 'legend-item';
      const perNode = Math.floor(TOTAL_SLOTS / masterCount);
      const start = i * perNode;
      const end = i === masterCount - 1 ? TOTAL_SLOTS - 1 : (i + 1) * perNode - 1;
      item.innerHTML = `<span class="legend-swatch" style="background:${NODE_COLORS[i]};"></span>${NODE_NAMES[i]} (${start}–${end})`;
      nodeLegend.appendChild(item);
    }
  }

  function renderSlotGrid() {
    const cols = 128;
    const rows = Math.ceil(TOTAL_SLOTS / cols);
    const cellW = slotCanvas.width / cols;
    const cellH = slotCanvas.height / rows;

    slotCtx.clearRect(0, 0, slotCanvas.width, slotCanvas.height);

    for (let i = 0; i < TOTAL_SLOTS; i++) {
      const col = i % cols;
      const row = Math.floor(i / cols);
      const owner = slotOwnership[i];
      slotCtx.fillStyle = NODE_COLORS[owner];
      slotCtx.globalAlpha = 0.8;
      slotCtx.fillRect(col * cellW + 0.5, row * cellH + 0.5, cellW - 1, cellH - 1);
    }
    slotCtx.globalAlpha = 1;
  }

  slotCanvas.addEventListener('mousemove', (e) => {
    const rect = slotCanvas.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    const cols = 128;
    const rows = Math.ceil(TOTAL_SLOTS / cols);
    const cellW = slotCanvas.width / cols;
    const cellH = slotCanvas.height / rows;
    const col = Math.floor(x / cellW);
    const row = Math.floor(y / cellH);
    const slot = row * cols + col;
    if (slot >= 0 && slot < TOTAL_SLOTS) {
      const owner = slotOwnership[slot];
      slotHoverInfo.textContent = `Slot ${slot} → ${NODE_NAMES[owner]} (${NODE_COLORS[owner]})`;
    }
  });

  // Master slider
  const masterSlider = document.getElementById('masterSlider') as HTMLInputElement;
  const masterCountLabel = document.getElementById('masterCountLabel')!;

  masterSlider.addEventListener('input', () => {
    masterCount = parseInt(masterSlider.value);
    masterCountLabel.textContent = String(masterCount);
  });

  document.getElementById('redistributeBtn')?.addEventListener('click', () => {
    masterCount = parseInt(masterSlider.value);
    distributeSlots(masterCount);
    buildCluster(masterCount);
    renderSlotGrid();
    renderLegend();
    renderTopology();
    renderFailoverCanvas();
    renderPartitionCanvas(false, -1);
    // Recalculate if key is present
    if (keyInput.value.trim()) calculate();
  });

  // ========== TOPOLOGY (Canvas) ==========
  const topoCanvas = document.getElementById('topoCanvas') as HTMLCanvasElement;
  const topoCtx = topoCanvas.getContext('2d')!;
  const topoInfoPanel = document.getElementById('topoInfoPanel')!;

  function renderTopology() {
    topoCtx.clearRect(0, 0, topoCanvas.width, topoCanvas.height);
    const cx = topoCanvas.width / 2;
    const cy = 180;
    const radius = 140;

    // Position masters in a circle
    const masters = clusterNodes.filter(n => n.isMaster);
    const replicas = clusterNodes.filter(n => !n.isMaster);

    masters.forEach((node, i) => {
      const angle = (Math.PI * 2 * i / masters.length) - Math.PI / 2;
      node.x = cx + Math.cos(angle) * radius;
      node.y = cy + Math.sin(angle) * radius;
    });

    // Position replicas below their masters
    replicas.forEach(r => {
      const master = masters[r.replicaOf!];
      const angle = Math.atan2(master.y - cy, master.x - cx);
      r.x = master.x + Math.cos(angle) * 80;
      r.y = master.y + Math.sin(angle) * 80;
    });

    // Draw gossip connections between masters (dashed)
    topoCtx.setLineDash([4, 4]);
    topoCtx.strokeStyle = 'rgba(255,255,255,0.1)';
    topoCtx.lineWidth = 1;
    for (let i = 0; i < masters.length; i++) {
      for (let j = i + 1; j < masters.length; j++) {
        topoCtx.beginPath();
        topoCtx.moveTo(masters[i].x, masters[i].y);
        topoCtx.lineTo(masters[j].x, masters[j].y);
        topoCtx.stroke();
      }
    }
    topoCtx.setLineDash([]);

    // Draw master→replica connections
    replicas.forEach(r => {
      const master = masters[r.replicaOf!];
      topoCtx.strokeStyle = master.color + '40';
      topoCtx.lineWidth = 2;
      topoCtx.beginPath();
      topoCtx.moveTo(master.x, master.y);
      topoCtx.lineTo(r.x, r.y);
      topoCtx.stroke();
    });

    // Draw nodes
    clusterNodes.forEach(node => {
      const r = node.isMaster ? 28 : 18;
      // Glow
      topoCtx.shadowColor = node.color;
      topoCtx.shadowBlur = node.isMaster ? 15 : 8;
      topoCtx.fillStyle = node.color + '30';
      topoCtx.beginPath();
      topoCtx.arc(node.x, node.y, r, 0, Math.PI * 2);
      topoCtx.fill();

      topoCtx.strokeStyle = node.color;
      topoCtx.lineWidth = 2;
      topoCtx.beginPath();
      topoCtx.arc(node.x, node.y, r, 0, Math.PI * 2);
      topoCtx.stroke();
      topoCtx.shadowBlur = 0;

      // Label
      topoCtx.fillStyle = '#fff';
      topoCtx.font = node.isMaster ? 'bold 11px Inter' : '10px Inter';
      topoCtx.textAlign = 'center';
      topoCtx.textBaseline = 'middle';
      topoCtx.fillText(node.isMaster ? node.name : 'R', node.x, node.y);

      if (node.isMaster) {
        topoCtx.fillStyle = '#888';
        topoCtx.font = '9px Monaco, monospace';
        topoCtx.fillText(`${node.slots[0]}–${node.slots[1]}`, node.x, node.y + r + 14);
      }
    });

    // Center label
    topoCtx.fillStyle = 'rgba(255,255,255,0.15)';
    topoCtx.font = '11px Inter';
    topoCtx.textAlign = 'center';
    topoCtx.fillText('Cluster Bus (Gossip)', cx, cy);
  }

  topoCanvas.addEventListener('click', (e) => {
    const rect = topoCanvas.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;

    for (const node of clusterNodes) {
      const r = node.isMaster ? 28 : 18;
      const dist = Math.sqrt((x - node.x) ** 2 + (y - node.y) ** 2);
      if (dist <= r + 5) {
        showNodeInfo(node);
        return;
      }
    }
  });

  function showNodeInfo(node: typeof clusterNodes[0]) {
    if (node.isMaster) {
      const replicas = clusterNodes.filter(n => !n.isMaster && n.replicaOf === node.id);
      const replicaNames = replicas.map(r => r.name).join(', ') || 'None';
      topoInfoPanel.innerHTML = `
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
          <span style="width:16px;height:16px;border-radius:50%;background:${node.color};display:inline-block;"></span>
          <strong style="color:#fff;font-size:1.1rem;">${node.name}</strong>
          <span style="color:#888;font-size:0.85rem;">Master</span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;font-size:0.9rem;">
          <div><span style="color:#888;">Slot range:</span> <span style="color:#fff;font-family:monospace;">${node.slots[0]}–${node.slots[1]}</span></div>
          <div><span style="color:#888;">Slot count:</span> <span style="color:#fff;">${node.slots[1] - node.slots[0] + 1}</span></div>
          <div><span style="color:#888;">Replicas:</span> <span style="color:#fff;">${replicaNames}</span></div>
          <div><span style="color:#888;">Connections:</span> <span style="color:#fff;">${clusterNodes.filter(n => n.isMaster).length - 1} masters</span></div>
        </div>
      `;
    } else {
      const master = clusterNodes[node.replicaOf!];
      topoInfoPanel.innerHTML = `
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
          <span style="width:16px;height:16px;border-radius:50%;background:${node.color};opacity:0.6;display:inline-block;"></span>
          <strong style="color:#fff;font-size:1.1rem;">${node.name}</strong>
          <span style="color:#888;font-size:0.85rem;">Replica</span>
        </div>
        <div style="font-size:0.9rem;">
          <span style="color:#888;">Replicates:</span> 
          <span style="color:${master.color};font-weight:600;">${master.name}</span> 
          <span style="color:#888;">(slots ${master.slots[0]}–${master.slots[1]})</span>
        </div>
        <div style="font-size:0.85rem;color:#888;margin-top:8px;">
          Read-only. Receives replication stream from master. Promotes on master failure.
        </div>
      `;
    }
  }

  // ========== FAILOVER ==========
  const failoverCanvas = document.getElementById('failoverCanvas') as HTMLCanvasElement;
  const failoverCtx = failoverCanvas.getContext('2d')!;
  const failoverTimeline = document.getElementById('failoverTimeline')!;
  const failoverBadge = document.getElementById('failoverBadge')!;
  const failoverStatusText = document.getElementById('failoverStatusText')!;

  let failoverStep = 0;
  let killedNode = -1;
  let failoverAutoPlaying = false;

  const failoverSteps = [
    { badge: 'failed', badgeText: '💀 NODE DOWN', cls: 'fail-step',
      text: (n: string) => `💀 ${n} has crashed! No more heartbeats from this node.` },
    { badge: 'detecting', badgeText: 'PFAIL', cls: 'detect-step',
      text: (n: string) => `⏱ After ~1s: Nodes notice ${n} isn't responding → mark as PFAIL (subjective failure)` },
    { badge: 'detecting', badgeText: 'PFAIL GOSSIP', cls: 'detect-step',
      text: (n: string) => `📡 Gossip spreads: nodes share PFAIL status for ${n} via cluster bus` },
    { badge: 'failed', badgeText: 'FAIL', cls: 'fail-step',
      text: (n: string) => `❌ Majority of masters agree ${n} is unreachable → marked FAIL (objective failure)` },
    { badge: 'electing', badgeText: 'ELECTION', cls: 'elect-step',
      text: (n: string) => `🗳 ${n}'s replica starts election: increments epoch, requests votes from masters` },
    { badge: 'electing', badgeText: 'VOTING', cls: 'elect-step',
      text: (_n: string) => `✅ Majority of masters vote YES — replica wins the election` },
    { badge: 'promoting', badgeText: 'PROMOTED', cls: 'promote-step',
      text: (n: string) => `🎉 Replica promoted to master! Takes over ${n}'s slots. Cluster is healthy again.` },
  ];

  function renderFailoverCanvas() {
    failoverCtx.clearRect(0, 0, failoverCanvas.width, failoverCanvas.height);
    const masters = clusterNodes.filter(n => n.isMaster);
    const spacing = failoverCanvas.width / (masters.length + 1);
    const y = 100;

    masters.forEach((node, i) => {
      const x = spacing * (i + 1);
      const isDead = killedNode === node.id && failoverStep >= 0;
      const isPromoted = killedNode === node.id && failoverStep >= 6;

      // Draw node
      failoverCtx.shadowColor = isDead && !isPromoted ? '#ef4444' : node.color;
      failoverCtx.shadowBlur = 12;

      failoverCtx.fillStyle = isDead && !isPromoted ? 'rgba(239,68,68,0.1)' : node.color + '30';
      failoverCtx.beginPath();
      failoverCtx.arc(x, y, 35, 0, Math.PI * 2);
      failoverCtx.fill();

      failoverCtx.strokeStyle = isDead && !isPromoted ? '#ef4444' : node.color;
      failoverCtx.lineWidth = isDead && !isPromoted ? 1 : 2;
      failoverCtx.setLineDash(isDead && !isPromoted ? [4, 4] : []);
      failoverCtx.beginPath();
      failoverCtx.arc(x, y, 35, 0, Math.PI * 2);
      failoverCtx.stroke();
      failoverCtx.setLineDash([]);
      failoverCtx.shadowBlur = 0;

      // X mark if dead
      if (isDead && !isPromoted) {
        failoverCtx.strokeStyle = '#ef4444';
        failoverCtx.lineWidth = 3;
        failoverCtx.beginPath();
        failoverCtx.moveTo(x - 15, y - 15); failoverCtx.lineTo(x + 15, y + 15);
        failoverCtx.moveTo(x + 15, y - 15); failoverCtx.lineTo(x - 15, y + 15);
        failoverCtx.stroke();
      }

      // Label
      failoverCtx.fillStyle = isDead && !isPromoted ? '#666' : '#fff';
      failoverCtx.font = 'bold 12px Inter';
      failoverCtx.textAlign = 'center';
      failoverCtx.textBaseline = 'middle';
      failoverCtx.fillText(node.name, x, y);

      // Replica below
      const replicaY = y + 110;
      const replica = clusterNodes.find(n => !n.isMaster && n.replicaOf === node.id);
      if (replica) {
        const promoted = killedNode === node.id && failoverStep >= 6;

        // Connection line
        failoverCtx.strokeStyle = promoted ? '#22c55e' : 'rgba(255,255,255,0.15)';
        failoverCtx.lineWidth = promoted ? 2 : 1;
        failoverCtx.setLineDash(promoted ? [] : [3, 3]);
        failoverCtx.beginPath();
        failoverCtx.moveTo(x, y + 35);
        failoverCtx.lineTo(x, replicaY - 22);
        failoverCtx.stroke();
        failoverCtx.setLineDash([]);

        // Replica circle
        const rColor = promoted ? '#22c55e' : node.color;
        failoverCtx.shadowColor = rColor;
        failoverCtx.shadowBlur = promoted ? 15 : 6;
        failoverCtx.fillStyle = rColor + (promoted ? '40' : '20');
        failoverCtx.beginPath();
        failoverCtx.arc(x, replicaY, promoted ? 28 : 22, 0, Math.PI * 2);
        failoverCtx.fill();
        failoverCtx.strokeStyle = rColor;
        failoverCtx.lineWidth = promoted ? 2 : 1;
        failoverCtx.beginPath();
        failoverCtx.arc(x, replicaY, promoted ? 28 : 22, 0, Math.PI * 2);
        failoverCtx.stroke();
        failoverCtx.shadowBlur = 0;

        failoverCtx.fillStyle = '#fff';
        failoverCtx.font = promoted ? 'bold 11px Inter' : '10px Inter';
        failoverCtx.fillText(promoted ? 'New Master' : 'Replica', x, replicaY);

        if (promoted) {
          failoverCtx.fillStyle = '#22c55e';
          failoverCtx.font = 'bold 11px Inter';
          failoverCtx.fillText('★ PROMOTED', x, replicaY + 40);
        }
      }
    });
  }

  document.getElementById('killNodeBtn')?.addEventListener('click', () => {
    killedNode = 0; // Kill Node A
    failoverStep = 0;
    failoverTimeline.innerHTML = '';

    const step = failoverSteps[0];
    failoverBadge.className = `status-badge ${step.badge}`;
    failoverBadge.textContent = step.badgeText;
    failoverStatusText.textContent = step.text(NODE_NAMES[killedNode]);

    const el = document.createElement('div');
    el.className = `failover-step ${step.cls}`;
    el.textContent = step.text(NODE_NAMES[killedNode]);
    failoverTimeline.appendChild(el);

    renderFailoverCanvas();
    (document.getElementById('stepFailoverBtn') as HTMLButtonElement).disabled = false;
    (document.getElementById('autoFailoverBtn') as HTMLButtonElement).disabled = false;
  });

  document.getElementById('stepFailoverBtn')?.addEventListener('click', () => {
    if (failoverStep < failoverSteps.length - 1) {
      failoverStep++;
      const step = failoverSteps[failoverStep];
      failoverBadge.className = `status-badge ${step.badge}`;
      failoverBadge.textContent = step.badgeText;
      failoverStatusText.textContent = step.text(NODE_NAMES[killedNode]);

      const el = document.createElement('div');
      el.className = `failover-step ${step.cls}`;
      el.textContent = step.text(NODE_NAMES[killedNode]);
      failoverTimeline.appendChild(el);
      failoverTimeline.scrollTop = failoverTimeline.scrollHeight;

      renderFailoverCanvas();
      if (failoverStep >= failoverSteps.length - 1) {
        (document.getElementById('stepFailoverBtn') as HTMLButtonElement).disabled = true;
        (document.getElementById('autoFailoverBtn') as HTMLButtonElement).disabled = true;
      }
    }
  });

  document.getElementById('autoFailoverBtn')?.addEventListener('click', async () => {
    if (failoverAutoPlaying) return;
    failoverAutoPlaying = true;
    (document.getElementById('autoFailoverBtn') as HTMLButtonElement).disabled = true;
    (document.getElementById('stepFailoverBtn') as HTMLButtonElement).disabled = true;
    while (failoverStep < failoverSteps.length - 1) {
      await new Promise(r => setTimeout(r, 1500));
      failoverStep++;
      const step = failoverSteps[failoverStep];
      failoverBadge.className = `status-badge ${step.badge}`;
      failoverBadge.textContent = step.badgeText;
      failoverStatusText.textContent = step.text(NODE_NAMES[killedNode]);

      const el = document.createElement('div');
      el.className = `failover-step ${step.cls}`;
      el.textContent = step.text(NODE_NAMES[killedNode]);
      failoverTimeline.appendChild(el);
      failoverTimeline.scrollTop = failoverTimeline.scrollHeight;
      renderFailoverCanvas();
    }
    failoverAutoPlaying = false;
  });

  document.getElementById('resetFailoverBtn')?.addEventListener('click', () => {
    killedNode = -1;
    failoverStep = 0;
    failoverAutoPlaying = false;
    failoverTimeline.innerHTML = '';
    failoverBadge.className = 'status-badge idle';
    failoverBadge.textContent = 'Ready';
    failoverStatusText.textContent = 'Click "Kill Master" to begin the failover simulation';
    (document.getElementById('stepFailoverBtn') as HTMLButtonElement).disabled = true;
    (document.getElementById('autoFailoverBtn') as HTMLButtonElement).disabled = true;
    renderFailoverCanvas();
  });

  // ========== SLOT MIGRATION ==========
  const migrateSource = document.getElementById('migrateSource')!;
  const migrateTarget = document.getElementById('migrateTarget')!;
  const migrateLog = document.getElementById('migrateLog')!;
  const flyingKey = document.getElementById('flyingKey')!;

  let migrationSlots = [100, 101, 102, 103, 104, 105, 106, 107];
  let migratedSlots: number[] = [];

  function renderMigrationSlots() {
    migrateSource.innerHTML = '';
    migrateTarget.innerHTML = '';
    migrationSlots.filter(s => !migratedSlots.includes(s)).forEach(s => {
      const el = document.createElement('div');
      el.className = 'migrate-slot source-slot';
      el.textContent = String(s);
      migrateSource.appendChild(el);
    });
    migratedSlots.forEach(s => {
      const el = document.createElement('div');
      el.className = 'migrate-slot target-slot';
      el.textContent = String(s);
      migrateTarget.appendChild(el);
    });
  }

  document.getElementById('startMigrateBtn')?.addEventListener('click', async () => {
    (document.getElementById('startMigrateBtn') as HTMLButtonElement).disabled = true;
    migrateLog.innerHTML = '';
    migratedSlots = [];
    renderMigrationSlots();

    const addLog = (html: string) => {
      const entry = document.createElement('div');
      entry.className = 'migrate-log-entry';
      entry.innerHTML = html;
      migrateLog.appendChild(entry);
      migrateLog.scrollTop = migrateLog.scrollHeight;
    };

    addLog('<span class="cmd">CLUSTER SETSLOT 100-107 IMPORTING</span> on Node B');
    await new Promise(r => setTimeout(r, 600));
    addLog('<span class="cmd">CLUSTER SETSLOT 100-107 MIGRATING</span> on Node A');
    await new Promise(r => setTimeout(r, 600));

    for (const slot of migrationSlots) {
      addLog(`<span class="info">CLUSTER GETKEYSINSLOT ${slot} 100</span> → found keys`);
      await new Promise(r => setTimeout(r, 300));

      // Show flying animation
      flyingKey.style.display = 'block';
      flyingKey.style.animation = 'none';
      void flyingKey.offsetWidth;
      flyingKey.style.animation = 'flyAcross 0.6s ease-in-out';

      addLog(`<span class="cmd">MIGRATE</span> Node-B 6379 "" 0 5000 KEYS key:${slot}:*`);
      await new Promise(r => setTimeout(r, 600));
      flyingKey.style.display = 'none';

      migratedSlots.push(slot);
      renderMigrationSlots();
    }

    addLog('<span class="cmd">CLUSTER SETSLOT 100-107 NODE</span> Node-B-id → complete ✅');
    (document.getElementById('startMigrateBtn') as HTMLButtonElement).disabled = false;
  });

  document.getElementById('resetMigrateBtn')?.addEventListener('click', () => {
    migratedSlots = [];
    migrateLog.innerHTML = '';
    renderMigrationSlots();
    (document.getElementById('startMigrateBtn') as HTMLButtonElement).disabled = false;
  });

  // ========== NETWORK PARTITION ==========
  const partitionCanvas = document.getElementById('partitionCanvas') as HTMLCanvasElement;
  const partitionCtx = partitionCanvas.getContext('2d')!;
  const partitionLog = document.getElementById('partitionLog')!;
  let isPartitioned = false;

  function renderPartitionCanvas(partitioned: boolean, splitAt: number) {
    partitionCtx.clearRect(0, 0, partitionCanvas.width, partitionCanvas.height);
    const masters = clusterNodes.filter(n => n.isMaster);
    const spacing = partitionCanvas.width / (masters.length + 1);
    const y = 150;

    // Draw partition line
    if (partitioned && splitAt >= 0) {
      const lineX = spacing * (splitAt + 1) + spacing / 2;
      partitionCtx.strokeStyle = '#ef4444';
      partitionCtx.lineWidth = 3;
      partitionCtx.setLineDash([8, 6]);
      partitionCtx.beginPath();
      partitionCtx.moveTo(lineX, 20);
      partitionCtx.lineTo(lineX, partitionCanvas.height - 20);
      partitionCtx.stroke();
      partitionCtx.setLineDash([]);

      // Labels
      partitionCtx.fillStyle = '#ef4444';
      partitionCtx.font = 'bold 11px Inter';
      partitionCtx.textAlign = 'center';
      partitionCtx.fillText('⚡ PARTITION ⚡', lineX, 15);

      // Minority/majority labels
      const leftCount = splitAt + 1;
      const rightCount = masters.length - leftCount;
      const leftLabel = leftCount <= masters.length / 2 ? 'MINORITY' : 'MAJORITY';
      const rightLabel = rightCount <= masters.length / 2 ? 'MINORITY' : 'MAJORITY';

      partitionCtx.fillStyle = leftLabel === 'MINORITY' ? '#ef4444' : '#22c55e';
      partitionCtx.fillText(leftLabel, lineX / 2, partitionCanvas.height - 10);
      partitionCtx.fillStyle = rightLabel === 'MINORITY' ? '#ef4444' : '#22c55e';
      partitionCtx.fillText(rightLabel, lineX + (partitionCanvas.width - lineX) / 2, partitionCanvas.height - 10);
    }

    // Draw connections
    for (let i = 0; i < masters.length; i++) {
      for (let j = i + 1; j < masters.length; j++) {
        const x1 = spacing * (i + 1);
        const x2 = spacing * (j + 1);
        const crossesPartition = partitioned && splitAt >= 0 && i <= splitAt && j > splitAt;

        partitionCtx.strokeStyle = crossesPartition ? 'rgba(239,68,68,0.15)' : 'rgba(255,255,255,0.1)';
        partitionCtx.lineWidth = 1;
        partitionCtx.setLineDash(crossesPartition ? [2, 4] : [3, 3]);
        partitionCtx.beginPath();
        partitionCtx.moveTo(x1, y);
        partitionCtx.lineTo(x2, y);
        partitionCtx.stroke();
      }
    }
    partitionCtx.setLineDash([]);

    // Draw nodes
    masters.forEach((node, i) => {
      const x = spacing * (i + 1);
      const inMinority = partitioned && splitAt >= 0 && i <= splitAt && (splitAt + 1) <= masters.length / 2;

      partitionCtx.shadowColor = inMinority ? '#ef4444' : node.color;
      partitionCtx.shadowBlur = 12;
      partitionCtx.fillStyle = (inMinority ? '#ef4444' : node.color) + '30';
      partitionCtx.beginPath();
      partitionCtx.arc(x, y, 32, 0, Math.PI * 2);
      partitionCtx.fill();

      partitionCtx.strokeStyle = inMinority ? '#ef4444' : node.color;
      partitionCtx.lineWidth = 2;
      partitionCtx.beginPath();
      partitionCtx.arc(x, y, 32, 0, Math.PI * 2);
      partitionCtx.stroke();
      partitionCtx.shadowBlur = 0;

      partitionCtx.fillStyle = '#fff';
      partitionCtx.font = 'bold 12px Inter';
      partitionCtx.textAlign = 'center';
      partitionCtx.textBaseline = 'middle';
      partitionCtx.fillText(node.name, x, y);

      if (inMinority) {
        partitionCtx.fillStyle = '#ef4444';
        partitionCtx.font = '10px Inter';
        partitionCtx.fillText('⚠ Read-only', x, y + 46);
      }
    });
  }

  document.getElementById('partitionBtn')?.addEventListener('click', async () => {
    isPartitioned = true;
    partitionLog.innerHTML = '';
    (document.getElementById('partitionBtn') as HTMLButtonElement).disabled = true;
    (document.getElementById('healBtn') as HTMLButtonElement).disabled = false;

    const splitAt = 0; // Node A gets isolated

    renderPartitionCanvas(true, splitAt);

    const addLog = (html: string, cls: string) => {
      const entry = document.createElement('div');
      entry.className = `partition-entry ${cls}`;
      entry.innerHTML = html;
      partitionLog.appendChild(entry);
      partitionLog.scrollTop = partitionLog.scrollHeight;
    };

    addLog('⚡ Network partition created — Node A is isolated from Nodes B and C', 'error');
    await new Promise(r => setTimeout(r, 1000));
    addLog(`⏱ After cluster-node-timeout: B and C mark A as PFAIL`, 'warning');
    await new Promise(r => setTimeout(r, 1000));
    addLog(`❌ Majority agrees: A marked FAIL. Its replica starts election.`, 'error');
    await new Promise(r => setTimeout(r, 1000));
    addLog(`🗳 A's replica wins election, promoted to master in the majority partition`, 'info-entry');
    await new Promise(r => setTimeout(r, 800));
    addLog(`⚠ Node A (minority) can still receive reads but REJECTS writes — not enough masters reachable`, 'warning');
    await new Promise(r => setTimeout(r, 800));
    addLog(`📝 Clients connected to minority partition get CLUSTERDOWN errors on writes`, 'error');
  });

  document.getElementById('healBtn')?.addEventListener('click', async () => {
    (document.getElementById('healBtn') as HTMLButtonElement).disabled = true;

    renderPartitionCanvas(false, -1);

    const addLog = (html: string, cls: string) => {
      const entry = document.createElement('div');
      entry.className = `partition-entry ${cls}`;
      entry.innerHTML = html;
      partitionLog.appendChild(entry);
      partitionLog.scrollTop = partitionLog.scrollHeight;
    };

    addLog('🩹 Network healed — all nodes can communicate again', 'success');
    await new Promise(r => setTimeout(r, 800));
    addLog('📡 Node A discovers it lost mastership → becomes replica of promoted node', 'info-entry');
    await new Promise(r => setTimeout(r, 800));
    addLog('✅ Cluster fully healthy. All slots served. Node A syncing as replica.', 'success');

    isPartitioned = false;
    (document.getElementById('partitionBtn') as HTMLButtonElement).disabled = false;
  });

  document.getElementById('resetPartitionBtn')?.addEventListener('click', () => {
    isPartitioned = false;
    partitionLog.innerHTML = '';
    renderPartitionCanvas(false, -1);
    (document.getElementById('partitionBtn') as HTMLButtonElement).disabled = false;
    (document.getElementById('healBtn') as HTMLButtonElement).disabled = true;
  });

  // ========== INITIAL RENDER ==========
  renderLegend();
  renderSlotGrid();
  renderTopology();
  renderFailoverCanvas();
  renderMigrationSlots();
  renderPartitionCanvas(false, -1);
</script>
