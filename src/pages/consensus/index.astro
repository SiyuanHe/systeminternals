---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "Raft Consensus Algorithm", description: "Interactive visualization of leader election, log replication, and failure recovery", href: "/raft/", status: "live" },
  { title: "Paxos vs Raft", description: "Side-by-side comparison of the two most important consensus algorithms", href: "/consensus/paxos-vs-raft/", status: "live" },
  { title: "Byzantine Fault Tolerance", description: "PBFT, Tendermint, and consensus when nodes can lie", href: "#", status: "coming" },
  { title: "Viewstamped Replication", description: "The predecessor to Raft with similar leader-based ideas", href: "#", status: "coming" },
  { title: "EPaxos", description: "Leaderless Paxos variant for geo-distributed systems", href: "#", status: "coming" },
  { title: "Flexible Paxos", description: "Relaxing quorum requirements — intersection is enough", href: "#", status: "coming" },
];
---

<BaseLayout 
  title="Consensus Algorithms" 
  description="Interactive visualizations of distributed consensus algorithms — Paxos, Raft, BFT, and more"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Consensus", href: "/consensus/" }]}
>
  <section class="section-header">
    <h1>🤝 Consensus Algorithms</h1>
    <p>
      How do distributed systems agree on a value when nodes can crash and networks can partition?
      These visualizations explore the algorithms that make it possible — from the foundational
      Paxos to the practical Raft and beyond.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(0, 212, 255, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
