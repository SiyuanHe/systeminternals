---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Paxos vs Raft — Consensus Algorithms Compared" 
  description="Interactive side-by-side comparison of Paxos and Raft consensus algorithms with live simulations"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "Consensus", href: "/consensus/" },
    { label: "Paxos vs Raft", href: "/consensus/paxos-vs-raft/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>⚖️ Paxos vs Raft</h1>
      <p class="subtitle">Two Approaches to Consensus — Compared Side by Side</p>
    </header>

    <!-- Overview -->
    <section class="overview-section">
      <div class="overview-card">
        <p>
          <a href="https://lamport.azurewebsites.net/pubs/paxos-simple.pdf" target="_blank">Paxos</a> (Lamport, 1989)
          and <a href="https://raft.github.io/raft.pdf" target="_blank">Raft</a> (Ongaro &amp; Ousterhout, 2014)
          both solve the same problem: getting a cluster of unreliable nodes to agree on values.
          Paxos came first and is provably correct — but notoriously hard to understand and implement.
          Raft was explicitly designed for <em>understandability</em>, decomposing consensus into
          leader election, log replication, and safety. The result? Nearly every modern system chose Raft.
        </p>
      </div>
    </section>

    <!-- Single-Decree Paxos -->
    <section class="explain-section">
      <h2>📜 Single-Decree Paxos</h2>
      <div class="explain-card highlight-card">
        <h3>Roles &amp; Phases</h3>
        <p>
          Paxos has three roles: <strong>Proposer</strong> (proposes values),
          <strong>Acceptor</strong> (votes on proposals), and <strong>Learner</strong> (learns decided values).
          A single node can play multiple roles.
        </p>
        <div class="phase-grid">
          <div class="phase-box">
            <h4>Phase 1: Prepare</h4>
            <p>Proposer picks a unique proposal number <em>n</em> and sends <code>Prepare(n)</code> to all acceptors.</p>
            <p>Each acceptor responds with <code>Promise(n, accepted_value)</code> if <em>n</em> is higher than any it has seen, pledging to reject lower-numbered proposals.</p>
          </div>
          <div class="phase-box">
            <h4>Phase 2: Accept</h4>
            <p>If the proposer gets promises from a <em>majority</em>, it sends <code>Accept(n, value)</code> — using the highest previously accepted value, or its own if none.</p>
            <p>Acceptors accept if they haven't promised a higher number. Once a majority accepts, the value is <strong>chosen</strong>.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Paxos Step-Through -->
    <section class="cluster-section">
      <h2>🔬 Paxos Step-Through</h2>
      <p class="section-desc">Walk through single-decree Paxos with 5 nodes. Click "Step" to advance each phase.</p>
      <div class="cluster-controls">
        <button id="paxosStepBtn" class="action-btn primary-btn">Step →</button>
        <button id="paxosResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>
      <div class="cluster-status" id="paxosStatus">
        <span class="status-badge idle" id="paxosBadge">Ready</span>
        <span class="status-text" id="paxosStatusText">Click "Step" to begin a Paxos round</span>
      </div>
      <div class="cluster-ring-wrapper">
        <svg id="paxosSvg" viewBox="0 0 700 400" class="cluster-svg"></svg>
      </div>
    </section>

    <!-- Multi-Paxos -->
    <section class="explain-section">
      <h2>🔄 Multi-Paxos</h2>
      <div class="explain-grid">
        <div class="explain-card">
          <h3>Stable Leader Optimization</h3>
          <p>
            In practice, running two phases for every single value is expensive.
            <strong>Multi-Paxos</strong> elects a stable leader who skips Phase 1
            for subsequent proposals — sending Accept directly. This looks remarkably like Raft.
          </p>
        </div>
        <div class="explain-card">
          <h3>The Specification Gap</h3>
          <p>
            Multi-Paxos was never fully specified in Lamport's papers.
            Every implementation (Chubby, Spanner, etc.) had to fill in gaps for
            log management, snapshotting, and membership changes — leading to
            subtly different and incompatible variants.
          </p>
        </div>
      </div>
    </section>

    <!-- Raft Recap -->
    <section class="explain-section">
      <h2>🗳️ Raft (Quick Recap)</h2>
      <div class="explain-card">
        <h3>Designed for Understandability</h3>
        <p>
          Raft decomposes consensus into three clean sub-problems:
          <strong>Leader Election</strong> (who's in charge),
          <strong>Log Replication</strong> (how writes propagate), and
          <strong>Safety</strong> (why it's correct). All writes go through a single strong leader.
          See the <a href="/raft/">full interactive Raft demo</a> for a deep dive.
        </p>
        <p style="margin-top:12px;">
          Key insight: Raft and Multi-Paxos are <em>equivalent in power</em> — but Raft was
          designed so that a grad student could implement it correctly from the paper alone.
          Paxos requires reading multiple papers, folklore, and years of distributed systems experience.
        </p>
      </div>
    </section>

    <!-- Dueling Proposers -->
    <section class="explain-section">
      <div class="explain-card" style="border-color: rgba(251, 146, 60, 0.3); background: rgba(251, 146, 60, 0.05);">
        <h3>⚠️ Dueling Proposers (Paxos Livelock)</h3>
        <p>
          Paxos has a liveness problem: two proposers can keep preempting each other indefinitely.
          Proposer A sends Prepare(1), then Proposer B sends Prepare(2) before A completes Phase 2.
          A's Accept(1) gets rejected, so A tries Prepare(3), preempting B — and the cycle continues.
          The protocol never violates safety, but <strong>no value ever gets chosen</strong>.
          Raft avoids this entirely: only the leader proposes, and elections have randomized timeouts.
        </p>
      </div>
    </section>

    <!-- Side-by-Side Simulation -->
    <section class="cluster-section">
      <h2>🖧 Side-by-Side Simulation</h2>
      <p class="section-desc">Watch the same scenario play out in both protocols simultaneously.</p>

      <div class="cluster-controls">
        <button id="proposeBtn" class="action-btn primary-btn">📝 Propose Value</button>
        <button id="killLeaderBtn" class="action-btn chaos-btn">💀 Kill Leader</button>
        <button id="duelBtn" class="action-btn election-btn" style="background: linear-gradient(135deg, #fb923c, #f97316);">⚔️ Dueling Proposers</button>
        <button id="resetBtn" class="action-btn reset-btn">🔄 Reset</button>
        <div class="speed-control">
          <label>Speed: <strong id="speedLabel">2×</strong></label>
          <input type="range" id="speedSlider" min="1" max="5" value="2" step="1">
        </div>
      </div>

      <div class="cluster-status" id="simStatus">
        <span class="status-badge idle" id="simBadge">Ready</span>
        <span class="status-text" id="simStatusText">Click "Propose Value" to start both protocols</span>
      </div>

      <!-- Complexity Meters -->
      <div class="complexity-meters">
        <div class="meter-group">
          <h4>Paxos</h4>
          <div class="meter-row">
            <span class="meter-label">Messages</span>
            <div class="meter-bar"><div class="meter-fill paxos-fill" id="paxosMsgMeter"></div></div>
            <span class="meter-value" id="paxosMsgCount">0</span>
          </div>
          <div class="meter-row">
            <span class="meter-label">Round Trips</span>
            <div class="meter-bar"><div class="meter-fill paxos-fill" id="paxosRtMeter"></div></div>
            <span class="meter-value" id="paxosRtCount">0</span>
          </div>
        </div>
        <div class="meter-group">
          <h4>Raft</h4>
          <div class="meter-row">
            <span class="meter-label">Messages</span>
            <div class="meter-bar"><div class="meter-fill raft-fill" id="raftMsgMeter"></div></div>
            <span class="meter-value" id="raftMsgCount">0</span>
          </div>
          <div class="meter-row">
            <span class="meter-label">Round Trips</span>
            <div class="meter-bar"><div class="meter-fill raft-fill" id="raftRtMeter"></div></div>
            <span class="meter-value" id="raftRtCount">0</span>
          </div>
        </div>
      </div>

      <!-- Split Screen -->
      <div class="split-screen">
        <div class="split-panel">
          <h3 class="panel-title paxos-title">Paxos</h3>
          <div class="cluster-ring-wrapper">
            <svg id="paxosSimSvg" viewBox="0 0 340 320" class="cluster-svg"></svg>
          </div>
        </div>
        <div class="split-divider"></div>
        <div class="split-panel">
          <h3 class="panel-title raft-title">Raft</h3>
          <div class="cluster-ring-wrapper">
            <svg id="raftSimSvg" viewBox="0 0 340 320" class="cluster-svg"></svg>
          </div>
        </div>
      </div>
    </section>

    <!-- Event Log -->
    <section class="event-log-section">
      <h2>📋 Event Log</h2>
      <div class="event-log" id="eventLog">
        <div class="event-log-empty">Events will appear here...</div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="explain-section">
      <h2>📊 Comparison Table</h2>
      <div class="comparison-table-wrap">
        <table class="comparison-table" id="comparisonTable">
          <thead>
            <tr>
              <th>Aspect</th>
              <th class="paxos-col">Paxos</th>
              <th class="raft-col">Raft</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Leader Election</td>
              <td>Implicit (any proposer can lead)</td>
              <td>Explicit (randomized timeouts, majority vote)</td>
            </tr>
            <tr>
              <td>Who Can Propose</td>
              <td>Any node (proposer role)</td>
              <td>Leader only</td>
            </tr>
            <tr>
              <td>Log Replication</td>
              <td>Not specified (Multi-Paxos ad-hoc)</td>
              <td>Fully specified (AppendEntries RPC)</td>
            </tr>
            <tr>
              <td>Membership Changes</td>
              <td>Not specified in original paper</td>
              <td>Joint consensus protocol specified</td>
            </tr>
            <tr>
              <td>Understandability</td>
              <td class="cell-bad">Hard (multiple papers, folklore)</td>
              <td class="cell-good">Easy (one paper, clear decomposition)</td>
            </tr>
            <tr>
              <td>Correctness Proof</td>
              <td class="cell-good">Well-established</td>
              <td class="cell-good">TLA+ verified</td>
            </tr>
            <tr>
              <td>Livelock Risk</td>
              <td class="cell-bad">Yes (dueling proposers)</td>
              <td class="cell-good">No (single leader)</td>
            </tr>
            <tr>
              <td>Message Complexity</td>
              <td>2 round trips (Prepare + Accept)</td>
              <td>1 round trip (AppendEntries) with stable leader</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Where Each is Used -->
    <section class="explain-section">
      <h2>🏭 Where Each is Used</h2>
      <div class="explain-grid">
        <div class="explain-card">
          <h3>Paxos in Production</h3>
          <p>
            <strong>Google Chubby</strong> — distributed lock service (the paper that popularized Paxos in industry).<br/>
            <strong>Google Spanner</strong> — global SQL database using Multi-Paxos for replication across datacenters.<br/>
            <strong>Apache Zookeeper</strong> — uses Zab (Paxos-derived) for coordination.
          </p>
        </div>
        <div class="explain-card">
          <h3>Raft in Production</h3>
          <p>
            <strong>etcd</strong> — Kubernetes backing store.<br/>
            <strong>TiKV</strong> — distributed key-value store (TiDB's storage engine).<br/>
            <strong>CockroachDB</strong> — distributed SQL database.<br/>
            <strong>Consul</strong> — service discovery by HashiCorp.<br/>
            <strong>RethinkDB</strong> — real-time database.
          </p>
        </div>
      </div>
      <div class="explain-card" style="margin-top: 20px;">
        <h3>📈 The Modern Trend</h3>
        <p>
          Nearly every system built after 2014 chose Raft. Why? Not because Raft is more powerful —
          they're equivalent — but because Raft is <em>implementable</em>. Engineers can read one paper,
          understand the algorithm, and build a correct implementation. With Paxos, even experts
          at Google had to "fill in the gaps," and the Chubby paper famously noted that the Paxos
          description was "like pseudo-code that was missing several key pieces."
        </p>
      </div>
    </section>

    <!-- Variants & Extensions -->
    <section class="explain-section">
      <h2>🧬 Variants &amp; Extensions</h2>
      <div class="variants-table-wrap">
        <table class="comparison-table" id="variantsTable">
          <thead>
            <tr>
              <th>Variant</th>
              <th>Leader</th>
              <th>Latency</th>
              <th>Complexity</th>
              <th>Fault Tolerance</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Basic Paxos</strong></td>
              <td>None</td>
              <td class="cell-bad">2 RTT</td>
              <td class="cell-bad">High</td>
              <td class="cell-good">f &lt; n/2</td>
            </tr>
            <tr>
              <td><strong>Multi-Paxos</strong></td>
              <td>Stable</td>
              <td class="cell-good">1 RTT</td>
              <td class="cell-bad">High (underspecified)</td>
              <td class="cell-good">f &lt; n/2</td>
            </tr>
            <tr>
              <td><strong>Raft</strong></td>
              <td>Strong</td>
              <td class="cell-good">1 RTT</td>
              <td class="cell-good">Low</td>
              <td class="cell-good">f &lt; n/2</td>
            </tr>
            <tr>
              <td><strong>EPaxos</strong></td>
              <td>None</td>
              <td class="cell-good">1 RTT (fast path)</td>
              <td class="cell-bad">Very High</td>
              <td class="cell-good">f &lt; n/2</td>
            </tr>
            <tr>
              <td><strong>Flexible Paxos</strong></td>
              <td>Optional</td>
              <td>Varies</td>
              <td class="cell-bad">High</td>
              <td class="cell-good">Configurable quorums</td>
            </tr>
            <tr>
              <td><strong>Viewstamped Replication</strong></td>
              <td>Primary</td>
              <td class="cell-good">1 RTT</td>
              <td>Medium</td>
              <td class="cell-good">f &lt; n/2</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="explain-grid" style="margin-top: 20px;">
        <div class="explain-card">
          <h3>EPaxos</h3>
          <p>
            <strong>Egalitarian Paxos</strong> — leaderless, any replica can propose.
            Achieves optimal commit latency in geo-distributed settings when commands don't conflict.
            Extremely complex to implement correctly.
          </p>
        </div>
        <div class="explain-card">
          <h3>Flexible Paxos</h3>
          <p>
            The key insight: Phase 1 and Phase 2 quorums don't need to be majorities —
            they just need to <em>intersect</em>. This allows tuning read vs write latency
            by adjusting quorum sizes.
          </p>
        </div>
        <div class="explain-card">
          <h3>Viewstamped Replication</h3>
          <p>
            Developed independently around the same time as Paxos. Uses a primary (leader)
            with view changes for failover — very similar to Raft. Often considered a
            predecessor to Raft's design philosophy.
          </p>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>
        Based on
        <a href="https://lamport.azurewebsites.net/pubs/paxos-simple.pdf" target="_blank">Paxos Made Simple</a> (Lamport, 2001) and
        <a href="https://raft.github.io/raft.pdf" target="_blank">In Search of an Understandable Consensus Algorithm</a> (Ongaro &amp; Ousterhout, 2014)
      </p>
    </footer>

    <div class="share-buttons">
      <span>Share this visualization:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20Paxos%20vs%20Raft%20comparison&url=https://systeminternals.dev/consensus/paxos-vs-raft/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/consensus/paxos-vs-raft/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/consensus/paxos-vs-raft/&t=Interactive%20Paxos%20vs%20Raft%20Consensus%20Comparison" target="_blank" class="share-btn">🟧 Hacker News</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .viz-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .viz-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #fb923c, #60a5fa, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #888;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 12px;
  }

  .section-desc {
    color: #888;
    margin-bottom: 24px;
    font-size: 1rem;
  }

  /* Overview */
  .overview-section {
    margin-bottom: 50px;
  }

  .overview-card {
    background: linear-gradient(135deg, rgba(251, 146, 60, 0.1), rgba(96, 165, 250, 0.05));
    border: 1px solid rgba(251, 146, 60, 0.3);
    border-radius: 16px;
    padding: 24px 28px;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #ccc;
  }

  .overview-card strong { color: #fff; }
  .overview-card em { color: #fb923c; font-style: normal; font-weight: 500; }
  .overview-card a { color: #60a5fa; }

  /* Explain sections */
  .explain-section {
    margin-bottom: 50px;
  }

  .explain-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 16px;
  }

  .explain-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    color: #ccc;
    line-height: 1.7;
  }

  .explain-card h3 {
    color: #fff;
    font-size: 1.15rem;
    margin-bottom: 12px;
  }

  .explain-card strong { color: #fff; }
  .explain-card em { color: #4ade80; font-style: normal; font-weight: 500; }
  .explain-card code {
    background: rgba(255,255,255,0.1);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
    color: #f9a8d4;
  }
  .explain-card a { color: #60a5fa; }

  .highlight-card {
    border-color: rgba(251, 146, 60, 0.3);
    background: linear-gradient(135deg, rgba(251, 146, 60, 0.08), rgba(96, 165, 250, 0.03));
  }

  .phase-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 16px;
  }

  .phase-box {
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 16px;
  }

  .phase-box h4 {
    color: #fb923c;
    margin-bottom: 8px;
    font-size: 1rem;
  }

  .phase-box p {
    font-size: 0.95rem;
    margin-bottom: 8px;
  }

  .phase-box p:last-child { margin-bottom: 0; }

  /* Action Buttons */
  .action-btn {
    padding: 10px 20px;
    border: none;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .action-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .primary-btn {
    background: linear-gradient(135deg, #a78bfa, #7c3aed);
    color: white;
  }

  .primary-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(124, 58, 237, 0.4);
  }

  .election-btn {
    background: linear-gradient(135deg, #4ade80, #22c55e);
    color: white;
  }

  .election-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(34, 197, 94, 0.4);
  }

  .chaos-btn {
    background: linear-gradient(135deg, #f472b6, #ef4444);
    color: white;
  }

  .chaos-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(239, 68, 68, 0.4);
  }

  .reset-btn {
    background: rgba(255,255,255,0.1);
    color: #aaa;
  }

  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  /* Cluster Section */
  .cluster-section {
    margin-bottom: 50px;
  }

  .cluster-controls {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 20px;
    align-items: center;
  }

  .speed-control {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .speed-control label {
    color: #aaa;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .speed-control strong {
    color: #4ade80;
  }

  .speed-control input[type="range"] {
    width: 100px;
    height: 6px;
    -webkit-appearance: none;
    background: rgba(255,255,255,0.15);
    border-radius: 3px;
    cursor: pointer;
  }

  .speed-control input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #4ade80;
    cursor: pointer;
  }

  .cluster-status {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    padding: 12px 16px;
    background: rgba(255,255,255,0.03);
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .status-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .status-badge.idle { background: rgba(107, 114, 128, 0.3); color: #9ca3af; }
  .status-badge.running { background: rgba(74, 222, 128, 0.2); color: #4ade80; }
  .status-badge.election { background: rgba(251, 146, 60, 0.2); color: #fb923c; }
  .status-badge.livelock { background: rgba(239, 68, 68, 0.2); color: #f87171; }

  .status-text {
    color: #aaa;
    font-size: 0.95rem;
  }

  .cluster-ring-wrapper {
    position: relative;
    background: rgba(0,0,0,0.3);
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.1);
    overflow: hidden;
    margin-bottom: 20px;
  }

  .cluster-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Split Screen */
  .split-screen {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    margin-bottom: 20px;
  }

  .split-panel {
    min-width: 0;
  }

  .split-divider {
    width: 2px;
    background: rgba(255,255,255,0.1);
    margin: 0 8px;
  }

  .panel-title {
    text-align: center;
    font-size: 1.1rem;
    font-weight: 700;
    padding: 8px;
    border-radius: 10px 10px 0 0;
    margin-bottom: 0;
  }

  .paxos-title {
    color: #fb923c;
    background: rgba(251, 146, 60, 0.1);
  }

  .raft-title {
    color: #60a5fa;
    background: rgba(96, 165, 250, 0.1);
  }

  /* Complexity Meters */
  .complexity-meters {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .meter-group h4 {
    color: #fff;
    font-size: 0.95rem;
    margin-bottom: 10px;
  }

  .meter-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .meter-label {
    font-size: 0.8rem;
    color: #888;
    width: 80px;
    flex-shrink: 0;
  }

  .meter-bar {
    flex: 1;
    height: 8px;
    background: rgba(255,255,255,0.08);
    border-radius: 4px;
    overflow: hidden;
  }

  .meter-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.5s ease;
    width: 0%;
  }

  .paxos-fill { background: linear-gradient(90deg, #fb923c, #f97316); }
  .raft-fill { background: linear-gradient(90deg, #60a5fa, #3b82f6); }

  .meter-value {
    font-size: 0.85rem;
    font-weight: 700;
    color: #fff;
    width: 24px;
    text-align: right;
  }

  /* Event Log */
  .event-log-section {
    margin-bottom: 50px;
  }

  .event-log {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 16px;
    max-height: 250px;
    overflow-y: auto;
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 0.8rem;
    scroll-behavior: smooth;
  }

  .event-log-empty {
    color: #555;
    font-style: italic;
  }

  :global(.log-event) {
    padding: 4px 8px;
    margin-bottom: 4px;
    border-radius: 6px;
    animation: eventAppear 0.3s ease-out;
    line-height: 1.5;
  }

  :global(.log-event.paxos-event) { background: rgba(251, 146, 60, 0.1); color: #fdba74; }
  :global(.log-event.raft-event) { background: rgba(96, 165, 250, 0.1); color: #93c5fd; }
  :global(.log-event.commit-event) { background: rgba(34, 197, 94, 0.12); color: #86efac; }
  :global(.log-event.failure-event) { background: rgba(239, 68, 68, 0.12); color: #fca5a5; }
  :global(.log-event.livelock-event) { background: rgba(239, 68, 68, 0.15); color: #fca5a5; }

  @keyframes eventAppear {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Comparison Table */
  .comparison-table-wrap, .variants-table-wrap {
    overflow-x: auto;
    margin-bottom: 10px;
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .comparison-table th, .comparison-table td {
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .comparison-table th {
    color: #fff;
    font-weight: 700;
    background: rgba(255,255,255,0.05);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .comparison-table td {
    color: #bbb;
  }

  .comparison-table tbody tr {
    transition: background 0.2s;
  }

  .comparison-table tbody tr:hover {
    background: rgba(255,255,255,0.03);
  }

  .paxos-col { color: #fb923c; }
  .raft-col { color: #60a5fa; }

  .cell-good { color: #4ade80; }
  .cell-bad { color: #f87171; }

  /* Footer & Share */
  .viz-footer {
    text-align: center;
    margin-top: 50px;
    padding: 20px;
    border-top: 1px solid rgba(255,255,255,0.08);
    color: #555;
    font-size: 0.9rem;
  }

  .viz-footer a { color: #60a5fa; }

  .share-buttons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 20px;
    flex-wrap: wrap;
    color: #555;
    font-size: 0.85rem;
  }

  .share-btn {
    padding: 8px 16px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    color: #aaa;
    font-size: 0.85rem;
    transition: all 0.2s;
  }

  .share-btn:hover {
    background: rgba(255,255,255,0.1);
    color: #fff;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .phase-grid { grid-template-columns: 1fr; }
    .split-screen { grid-template-columns: 1fr; }
    .split-divider { width: auto; height: 2px; margin: 8px 0; }
    .complexity-meters { grid-template-columns: 1fr; }
    .explain-grid { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
(function() {
  // ============================================================
  // UTILITIES
  // ============================================================
  var COLORS = {
    proposer: '#fb923c',
    acceptor: '#a78bfa',
    learner: '#4ade80',
    leader: '#4ade80',
    follower: '#60a5fa',
    candidate: '#fb923c',
    dead: '#ef4444',
    message: '#fbbf24',
    paxos: '#fb923c',
    raft: '#60a5fa'
  };

  var speed = 2;
  var speedSlider = document.getElementById('speedSlider');
  var speedLabel = document.getElementById('speedLabel');
  if (speedSlider) {
    speedSlider.addEventListener('input', function() {
      speed = parseInt(this.value);
      speedLabel.textContent = speed + '×';
    });
  }

  function delay(ms) {
    return new Promise(function(resolve) {
      setTimeout(resolve, ms / speed);
    });
  }

  function log(msg, cls) {
    var el = document.getElementById('eventLog');
    if (!el) return;
    var empty = el.querySelector('.event-log-empty');
    if (empty) empty.remove();
    var div = document.createElement('div');
    div.className = 'log-event ' + (cls || '');
    div.textContent = msg;
    el.appendChild(div);
    el.scrollTop = el.scrollHeight;
  }

  // ============================================================
  // PAXOS STEP-THROUGH
  // ============================================================
  var paxosStep = 0;
  var paxosSvg = document.getElementById('paxosSvg');
  var paxosStepBtn = document.getElementById('paxosStepBtn');
  var paxosResetBtn = document.getElementById('paxosResetBtn');
  var paxosBadge = document.getElementById('paxosBadge');
  var paxosStatusText = document.getElementById('paxosStatusText');

  var paxosNodePositions = [
    { x: 350, y: 60 },
    { x: 560, y: 190 },
    { x: 480, y: 360 },
    { x: 220, y: 360 },
    { x: 140, y: 190 }
  ];

  var paxosNodeLabels = ['P1', 'A1', 'A2', 'A3', 'A4'];
  var paxosNodeRoles = ['Proposer', 'Acceptor', 'Acceptor', 'Acceptor', 'Acceptor'];

  function drawPaxosNodes(svg, positions, labels, roles, highlights) {
    while (svg.firstChild) svg.removeChild(svg.firstChild);

    // Draw connection lines
    for (var i = 0; i < positions.length; i++) {
      for (var j = i + 1; j < positions.length; j++) {
        var line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', positions[i].x);
        line.setAttribute('y1', positions[i].y);
        line.setAttribute('x2', positions[j].x);
        line.setAttribute('y2', positions[j].y);
        line.setAttribute('stroke', 'rgba(255,255,255,0.06)');
        line.setAttribute('stroke-width', '1');
        svg.appendChild(line);
      }
    }

    for (var k = 0; k < positions.length; k++) {
      var p = positions[k];
      var hl = highlights && highlights[k];
      var color = hl ? hl.color : (k === 0 ? COLORS.proposer : COLORS.acceptor);
      var opacity = hl ? 1 : 0.5;

      var circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('cx', p.x);
      circle.setAttribute('cy', p.y);
      circle.setAttribute('r', 28);
      circle.setAttribute('fill', color);
      circle.setAttribute('fill-opacity', opacity * 0.25);
      circle.setAttribute('stroke', color);
      circle.setAttribute('stroke-width', '2');
      circle.setAttribute('stroke-opacity', opacity);
      svg.appendChild(circle);

      var text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.setAttribute('x', p.x);
      text.setAttribute('y', p.y + 5);
      text.setAttribute('text-anchor', 'middle');
      text.setAttribute('fill', '#fff');
      text.setAttribute('font-size', '14');
      text.setAttribute('font-weight', '700');
      text.textContent = labels[k];
      svg.appendChild(text);

      var roleText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      roleText.setAttribute('x', p.x);
      roleText.setAttribute('y', p.y + 52);
      roleText.setAttribute('text-anchor', 'middle');
      roleText.setAttribute('fill', '#888');
      roleText.setAttribute('font-size', '11');
      roleText.textContent = roles[k];
      svg.appendChild(roleText);

      // Status text below role
      if (hl && hl.status) {
        var statusText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        statusText.setAttribute('x', p.x);
        statusText.setAttribute('y', p.y + 66);
        statusText.setAttribute('text-anchor', 'middle');
        statusText.setAttribute('fill', color);
        statusText.setAttribute('font-size', '10');
        statusText.setAttribute('font-weight', '600');
        statusText.textContent = hl.status;
        svg.appendChild(statusText);
      }
    }
  }

  function drawArrow(svg, from, to, color, label) {
    var dx = to.x - from.x;
    var dy = to.y - from.y;
    var dist = Math.sqrt(dx * dx + dy * dy);
    var nx = dx / dist;
    var ny = dy / dist;
    var sx = from.x + nx * 32;
    var sy = from.y + ny * 32;
    var ex = to.x - nx * 32;
    var ey = to.y - ny * 32;

    var line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.setAttribute('x1', sx);
    line.setAttribute('y1', sy);
    line.setAttribute('x2', ex);
    line.setAttribute('y2', ey);
    line.setAttribute('stroke', color);
    line.setAttribute('stroke-width', '2');
    line.setAttribute('stroke-opacity', '0.8');
    svg.appendChild(line);

    // Arrowhead
    var angle = Math.atan2(ey - sy, ex - sx);
    var headLen = 10;
    var p1x = ex - headLen * Math.cos(angle - Math.PI / 6);
    var p1y = ey - headLen * Math.sin(angle - Math.PI / 6);
    var p2x = ex - headLen * Math.cos(angle + Math.PI / 6);
    var p2y = ey - headLen * Math.sin(angle + Math.PI / 6);
    var arrow = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
    arrow.setAttribute('points', ex + ',' + ey + ' ' + p1x + ',' + p1y + ' ' + p2x + ',' + p2y);
    arrow.setAttribute('fill', color);
    arrow.setAttribute('fill-opacity', '0.8');
    svg.appendChild(arrow);

    if (label) {
      var mx = (sx + ex) / 2;
      var my = (sy + ey) / 2;
      var perpX = -ny * 14;
      var perpY = nx * 14;
      var t = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      t.setAttribute('x', mx + perpX);
      t.setAttribute('y', my + perpY);
      t.setAttribute('text-anchor', 'middle');
      t.setAttribute('fill', color);
      t.setAttribute('font-size', '10');
      t.setAttribute('font-weight', '600');
      t.textContent = label;
      svg.appendChild(t);
    }
  }

  var paxosSteps = [
    function() {
      // Step 0: Initial state
      var hl = [
        { color: COLORS.proposer, status: 'Preparing n=1' },
        { color: COLORS.acceptor },
        { color: COLORS.acceptor },
        { color: COLORS.acceptor },
        { color: COLORS.acceptor }
      ];
      drawPaxosNodes(paxosSvg, paxosNodePositions, paxosNodeLabels, paxosNodeRoles, hl);
      paxosBadge.textContent = 'Phase 1';
      paxosBadge.className = 'status-badge election';
      paxosStatusText.textContent = 'Proposer P1 sends Prepare(n=1) to all acceptors';
      // Draw prepare arrows
      for (var i = 1; i < 5; i++) {
        drawArrow(paxosSvg, paxosNodePositions[0], paxosNodePositions[i], '#fb923c', 'Prepare(1)');
      }
    },
    function() {
      // Step 1: Promises
      var hl = [
        { color: COLORS.proposer, status: 'Collecting promises' },
        { color: COLORS.acceptor, status: 'Promise(1, null)' },
        { color: COLORS.acceptor, status: 'Promise(1, null)' },
        { color: COLORS.acceptor, status: 'Promise(1, null)' },
        { color: COLORS.acceptor, status: 'Promise(1, null)' }
      ];
      drawPaxosNodes(paxosSvg, paxosNodePositions, paxosNodeLabels, paxosNodeRoles, hl);
      paxosStatusText.textContent = 'All acceptors promise not to accept proposals < 1';
      for (var i = 1; i < 5; i++) {
        drawArrow(paxosSvg, paxosNodePositions[i], paxosNodePositions[0], '#a78bfa', 'Promise');
      }
    },
    function() {
      // Step 2: Accept
      var hl = [
        { color: COLORS.proposer, status: 'Sending Accept' },
        { color: COLORS.acceptor },
        { color: COLORS.acceptor },
        { color: COLORS.acceptor },
        { color: COLORS.acceptor }
      ];
      drawPaxosNodes(paxosSvg, paxosNodePositions, paxosNodeLabels, paxosNodeRoles, hl);
      paxosBadge.textContent = 'Phase 2';
      paxosBadge.className = 'status-badge running';
      paxosStatusText.textContent = 'P1 got majority promises → sends Accept(1, "X") to all';
      for (var i = 1; i < 5; i++) {
        drawArrow(paxosSvg, paxosNodePositions[0], paxosNodePositions[i], '#22c55e', 'Accept(1,"X")');
      }
    },
    function() {
      // Step 3: Accepted
      var hl = [
        { color: COLORS.proposer, status: 'Value chosen!' },
        { color: '#4ade80', status: 'Accepted(1,"X")' },
        { color: '#4ade80', status: 'Accepted(1,"X")' },
        { color: '#4ade80', status: 'Accepted(1,"X")' },
        { color: '#4ade80', status: 'Accepted(1,"X")' }
      ];
      drawPaxosNodes(paxosSvg, paxosNodePositions, paxosNodeLabels, paxosNodeRoles, hl);
      paxosBadge.textContent = 'Decided';
      paxosBadge.className = 'status-badge running';
      paxosStatusText.textContent = 'Majority accepted → value "X" is chosen! Learners are notified.';
      for (var i = 1; i < 5; i++) {
        drawArrow(paxosSvg, paxosNodePositions[i], paxosNodePositions[0], '#4ade80', 'Accepted');
      }
    }
  ];

  function resetPaxosStepThrough() {
    paxosStep = 0;
    paxosBadge.textContent = 'Ready';
    paxosBadge.className = 'status-badge idle';
    paxosStatusText.textContent = 'Click "Step" to begin a Paxos round';
    paxosStepBtn.disabled = false;
    drawPaxosNodes(paxosSvg, paxosNodePositions, paxosNodeLabels, paxosNodeRoles, null);
  }

  if (paxosStepBtn) {
    paxosStepBtn.addEventListener('click', function() {
      if (paxosStep < paxosSteps.length) {
        paxosSteps[paxosStep]();
        paxosStep++;
        if (paxosStep >= paxosSteps.length) {
          paxosStepBtn.disabled = true;
        }
      }
    });
  }
  if (paxosResetBtn) {
    paxosResetBtn.addEventListener('click', resetPaxosStepThrough);
  }
  // Initial draw
  if (paxosSvg) {
    drawPaxosNodes(paxosSvg, paxosNodePositions, paxosNodeLabels, paxosNodeRoles, null);
  }

  // ============================================================
  // SIDE-BY-SIDE SIMULATION
  // ============================================================
  var paxosSimSvg = document.getElementById('paxosSimSvg');
  var raftSimSvg = document.getElementById('raftSimSvg');
  var simBadge = document.getElementById('simBadge');
  var simStatusText = document.getElementById('simStatusText');
  var proposeBtn = document.getElementById('proposeBtn');
  var killLeaderBtn = document.getElementById('killLeaderBtn');
  var duelBtn = document.getElementById('duelBtn');
  var resetBtn = document.getElementById('resetBtn');

  var paxosMsgCount = document.getElementById('paxosMsgCount');
  var paxosRtCount = document.getElementById('paxosRtCount');
  var raftMsgCount = document.getElementById('raftMsgCount');
  var raftRtCount = document.getElementById('raftRtCount');
  var paxosMsgMeter = document.getElementById('paxosMsgMeter');
  var paxosRtMeter = document.getElementById('paxosRtMeter');
  var raftMsgMeter = document.getElementById('raftMsgMeter');
  var raftRtMeter = document.getElementById('raftRtMeter');

  var simRunning = false;

  // Node positions for 5-node cluster in smaller SVG
  var simPositions = [
    { x: 170, y: 50 },
    { x: 290, y: 140 },
    { x: 245, y: 275 },
    { x: 95, y: 275 },
    { x: 50, y: 140 }
  ];

  var simPaxosState = {
    nodes: ['P', 'A', 'A', 'A', 'A'],
    alive: [true, true, true, true, true],
    leader: -1,
    msgs: 0,
    rts: 0
  };

  var simRaftState = {
    nodes: ['F', 'F', 'F', 'F', 'F'],
    alive: [true, true, true, true, true],
    leader: 0,
    msgs: 0,
    rts: 0
  };

  function drawSimNodes(svg, positions, state, protocol) {
    while (svg.firstChild) svg.removeChild(svg.firstChild);

    // Connection lines
    for (var i = 0; i < positions.length; i++) {
      for (var j = i + 1; j < positions.length; j++) {
        if (!state.alive[i] || !state.alive[j]) continue;
        var line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', positions[i].x);
        line.setAttribute('y1', positions[i].y);
        line.setAttribute('x2', positions[j].x);
        line.setAttribute('y2', positions[j].y);
        line.setAttribute('stroke', 'rgba(255,255,255,0.06)');
        line.setAttribute('stroke-width', '1');
        svg.appendChild(line);
      }
    }

    for (var k = 0; k < positions.length; k++) {
      var p = positions[k];
      var alive = state.alive[k];
      var isLeader = state.leader === k;
      var color;
      if (!alive) {
        color = COLORS.dead;
      } else if (isLeader) {
        color = COLORS.leader;
      } else if (protocol === 'paxos') {
        color = k === 0 ? COLORS.proposer : COLORS.acceptor;
      } else {
        color = COLORS.follower;
      }

      var circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('cx', p.x);
      circle.setAttribute('cy', p.y);
      circle.setAttribute('r', 22);
      circle.setAttribute('fill', color);
      circle.setAttribute('fill-opacity', alive ? 0.25 : 0.1);
      circle.setAttribute('stroke', color);
      circle.setAttribute('stroke-width', '2');
      circle.setAttribute('stroke-opacity', alive ? 1 : 0.3);
      svg.appendChild(circle);

      var label;
      if (protocol === 'paxos') {
        label = 'N' + (k + 1);
      } else {
        label = isLeader ? 'L' : 'F' + (k + 1);
      }
      if (!alive) label = '✕';

      var text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.setAttribute('x', p.x);
      text.setAttribute('y', p.y + 5);
      text.setAttribute('text-anchor', 'middle');
      text.setAttribute('fill', alive ? '#fff' : '#666');
      text.setAttribute('font-size', '13');
      text.setAttribute('font-weight', '700');
      text.textContent = label;
      svg.appendChild(text);

      // Role label
      var roleTxt;
      if (!alive) {
        roleTxt = 'Dead';
      } else if (protocol === 'paxos') {
        roleTxt = k === 0 ? 'Proposer' : 'Acceptor';
      } else {
        roleTxt = isLeader ? 'Leader' : 'Follower';
      }
      var roleEl = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      roleEl.setAttribute('x', p.x);
      roleEl.setAttribute('y', p.y + 42);
      roleEl.setAttribute('text-anchor', 'middle');
      roleEl.setAttribute('fill', '#666');
      roleEl.setAttribute('font-size', '10');
      roleEl.textContent = roleTxt;
      svg.appendChild(roleEl);
    }
  }

  function animateMessage(svg, positions, from, to, color, label) {
    return new Promise(function(resolve) {
      var fx = positions[from].x;
      var fy = positions[from].y;
      var tx = positions[to].x;
      var ty = positions[to].y;

      var circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('cx', fx);
      circle.setAttribute('cy', fy);
      circle.setAttribute('r', 6);
      circle.setAttribute('fill', color);
      svg.appendChild(circle);

      var lbl = null;
      if (label) {
        lbl = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        lbl.setAttribute('x', fx);
        lbl.setAttribute('y', fy - 12);
        lbl.setAttribute('text-anchor', 'middle');
        lbl.setAttribute('fill', color);
        lbl.setAttribute('font-size', '9');
        lbl.setAttribute('font-weight', '600');
        lbl.textContent = label;
        svg.appendChild(lbl);
      }

      var duration = 600 / speed;
      var start = null;
      function step(ts) {
        if (!start) start = ts;
        var pct = Math.min((ts - start) / duration, 1);
        var cx = fx + (tx - fx) * pct;
        var cy = fy + (ty - fy) * pct;
        circle.setAttribute('cx', cx);
        circle.setAttribute('cy', cy);
        if (lbl) {
          lbl.setAttribute('x', cx);
          lbl.setAttribute('y', cy - 12);
        }
        if (pct < 1) {
          requestAnimationFrame(step);
        } else {
          if (circle.parentNode) circle.parentNode.removeChild(circle);
          if (lbl && lbl.parentNode) lbl.parentNode.removeChild(lbl);
          resolve();
        }
      }
      requestAnimationFrame(step);
    });
  }

  function updateMeters() {
    paxosMsgCount.textContent = simPaxosState.msgs;
    paxosRtCount.textContent = simPaxosState.rts;
    raftMsgCount.textContent = simRaftState.msgs;
    raftRtCount.textContent = simRaftState.rts;

    var maxMsg = Math.max(simPaxosState.msgs, simRaftState.msgs, 1);
    var maxRt = Math.max(simPaxosState.rts, simRaftState.rts, 1);
    paxosMsgMeter.style.width = (simPaxosState.msgs / maxMsg * 100) + '%';
    raftMsgMeter.style.width = (simRaftState.msgs / maxMsg * 100) + '%';
    paxosRtMeter.style.width = (simPaxosState.rts / maxRt * 100) + '%';
    raftRtMeter.style.width = (simRaftState.rts / maxRt * 100) + '%';
  }

  function resetSim() {
    simRunning = false;
    simPaxosState = { nodes: ['P', 'A', 'A', 'A', 'A'], alive: [true, true, true, true, true], leader: -1, msgs: 0, rts: 0 };
    simRaftState = { nodes: ['L', 'F', 'F', 'F', 'F'], alive: [true, true, true, true, true], leader: 0, msgs: 0, rts: 0 };
    simBadge.textContent = 'Ready';
    simBadge.className = 'status-badge idle';
    simStatusText.textContent = 'Click "Propose Value" to start both protocols';
    drawSimNodes(paxosSimSvg, simPositions, simPaxosState, 'paxos');
    drawSimNodes(raftSimSvg, simPositions, simRaftState, 'raft');
    updateMeters();
    setSimBtns(false);
  }

  function setSimBtns(disabled) {
    proposeBtn.disabled = disabled;
    killLeaderBtn.disabled = disabled;
    duelBtn.disabled = disabled;
  }

  // Propose Value
  async function runPropose() {
    if (simRunning) return;
    simRunning = true;
    setSimBtns(true);
    simBadge.textContent = 'Running';
    simBadge.className = 'status-badge running';

    // Reset counters
    simPaxosState.msgs = 0;
    simPaxosState.rts = 0;
    simRaftState.msgs = 0;
    simRaftState.rts = 0;

    // --- PAXOS: Phase 1 ---
    simStatusText.textContent = 'Paxos: Phase 1 — Prepare | Raft: Leader sends AppendEntries';
    log('[Paxos] Proposer N1 sends Prepare(1) to all acceptors', 'paxos-event');
    log('[Raft] Leader sends AppendEntries("V") to all followers', 'raft-event');

    var paxosP1 = [];
    var raftAE = [];
    for (var i = 1; i < 5; i++) {
      if (simPaxosState.alive[i]) {
        paxosP1.push(animateMessage(paxosSimSvg, simPositions, 0, i, COLORS.paxos, 'Prepare'));
        simPaxosState.msgs++;
      }
      if (simRaftState.alive[i]) {
        raftAE.push(animateMessage(raftSimSvg, simPositions, 0, i, COLORS.raft, 'Append'));
        simRaftState.msgs++;
      }
    }
    await Promise.all(paxosP1.concat(raftAE));
    simPaxosState.rts++;
    simRaftState.rts++;
    updateMeters();
    drawSimNodes(paxosSimSvg, simPositions, simPaxosState, 'paxos');
    drawSimNodes(raftSimSvg, simPositions, simRaftState, 'raft');

    await delay(300);

    // --- PAXOS: Promise responses & Raft: ACKs ---
    simStatusText.textContent = 'Paxos: Promises received | Raft: ACKs received';
    log('[Paxos] Acceptors reply with Promise(1, null)', 'paxos-event');
    log('[Raft] Followers ACK AppendEntries', 'raft-event');

    var paxosPromises = [];
    var raftAcks = [];
    for (var j = 1; j < 5; j++) {
      if (simPaxosState.alive[j]) {
        paxosPromises.push(animateMessage(paxosSimSvg, simPositions, j, 0, '#a78bfa', 'Promise'));
        simPaxosState.msgs++;
      }
      if (simRaftState.alive[j]) {
        raftAcks.push(animateMessage(raftSimSvg, simPositions, j, 0, '#4ade80', 'ACK'));
        simRaftState.msgs++;
      }
    }
    await Promise.all(paxosPromises.concat(raftAcks));
    simPaxosState.rts++;
    simRaftState.rts++;
    updateMeters();

    await delay(300);

    // --- Raft: DONE! Paxos: Phase 2 ---
    log('[Raft] ✅ Majority ACKed — value committed!', 'commit-event');
    simStatusText.textContent = 'Raft: Committed! | Paxos: Phase 2 — Accept';
    log('[Paxos] Proposer sends Accept(1, "V") to acceptors', 'paxos-event');

    var paxosAccept = [];
    for (var m = 1; m < 5; m++) {
      if (simPaxosState.alive[m]) {
        paxosAccept.push(animateMessage(paxosSimSvg, simPositions, 0, m, '#22c55e', 'Accept'));
        simPaxosState.msgs++;
      }
    }
    await Promise.all(paxosAccept);
    simPaxosState.rts++;
    updateMeters();

    await delay(300);

    // Paxos: Accepted responses
    log('[Paxos] Acceptors respond Accepted', 'paxos-event');
    var paxosAccepted = [];
    for (var n = 1; n < 5; n++) {
      if (simPaxosState.alive[n]) {
        paxosAccepted.push(animateMessage(paxosSimSvg, simPositions, n, 0, '#4ade80', 'Accepted'));
        simPaxosState.msgs++;
      }
    }
    await Promise.all(paxosAccepted);
    simPaxosState.rts++;
    updateMeters();

    log('[Paxos] ✅ Majority accepted — value chosen!', 'commit-event');
    simStatusText.textContent = 'Both protocols committed. Paxos: 4 RTT, ' + simPaxosState.msgs + ' msgs | Raft: 2 RTT, ' + simRaftState.msgs + ' msgs';
    simBadge.textContent = 'Done';
    simRunning = false;
    setSimBtns(false);
  }

  // Kill Leader
  async function runKillLeader() {
    if (simRunning) return;
    simRunning = true;
    setSimBtns(true);

    // Reset counters
    simPaxosState.msgs = 0;
    simPaxosState.rts = 0;
    simRaftState.msgs = 0;
    simRaftState.rts = 0;

    // Kill node 0 in both
    simPaxosState.alive[0] = false;
    simRaftState.alive[0] = false;
    simRaftState.leader = -1;
    drawSimNodes(paxosSimSvg, simPositions, simPaxosState, 'paxos');
    drawSimNodes(raftSimSvg, simPositions, simRaftState, 'raft');
    simBadge.textContent = 'Recovery';
    simBadge.className = 'status-badge election';
    simStatusText.textContent = 'Leader/Proposer killed! Watch recovery...';
    log('[Paxos] 💀 Proposer N1 crashed', 'failure-event');
    log('[Raft] 💀 Leader N1 crashed', 'failure-event');

    await delay(800);

    // Paxos: another node takes over as proposer
    log('[Paxos] N2 detects no progress, becomes new proposer', 'paxos-event');
    simStatusText.textContent = 'Paxos: N2 becomes proposer | Raft: Election timeout fires';

    // Raft: election
    log('[Raft] N2 election timeout fires — becomes candidate', 'raft-event');
    simRaftState.nodes[1] = 'C';
    drawSimNodes(raftSimSvg, simPositions, simRaftState, 'raft');

    await delay(500);

    // Raft: request votes
    log('[Raft] N2 sends RequestVote to N3, N4, N5', 'raft-event');
    var voteReqs = [];
    for (var i = 2; i < 5; i++) {
      voteReqs.push(animateMessage(raftSimSvg, simPositions, 1, i, COLORS.candidate, 'Vote?'));
      simRaftState.msgs++;
    }
    await Promise.all(voteReqs);
    simRaftState.rts++;
    updateMeters();

    await delay(300);

    // Raft: receive votes
    log('[Raft] N3, N4, N5 grant votes to N2', 'raft-event');
    var voteGrants = [];
    for (var j = 2; j < 5; j++) {
      voteGrants.push(animateMessage(raftSimSvg, simPositions, j, 1, '#4ade80', 'Granted'));
      simRaftState.msgs++;
    }
    await Promise.all(voteGrants);
    simRaftState.rts++;

    simRaftState.leader = 1;
    simRaftState.nodes[1] = 'L';
    drawSimNodes(raftSimSvg, simPositions, simRaftState, 'raft');
    log('[Raft] ✅ N2 elected as new leader (1 RTT)', 'commit-event');
    updateMeters();

    await delay(400);

    // Paxos: new proposer does full 2-phase
    log('[Paxos] N2 runs Prepare(2) — full 2-phase required', 'paxos-event');
    var prepMsgs = [];
    for (var k = 2; k < 5; k++) {
      prepMsgs.push(animateMessage(paxosSimSvg, simPositions, 1, k, COLORS.paxos, 'Prepare(2)'));
      simPaxosState.msgs++;
    }
    await Promise.all(prepMsgs);
    simPaxosState.rts++;
    updateMeters();

    await delay(300);

    var promMsgs = [];
    for (var l = 2; l < 5; l++) {
      promMsgs.push(animateMessage(paxosSimSvg, simPositions, l, 1, '#a78bfa', 'Promise'));
      simPaxosState.msgs++;
    }
    await Promise.all(promMsgs);
    simPaxosState.rts++;

    await delay(300);

    var accMsgs = [];
    for (var mm = 2; mm < 5; mm++) {
      accMsgs.push(animateMessage(paxosSimSvg, simPositions, 1, mm, '#22c55e', 'Accept'));
      simPaxosState.msgs++;
    }
    await Promise.all(accMsgs);
    simPaxosState.rts++;

    await delay(300);

    var accdMsgs = [];
    for (var nn = 2; nn < 5; nn++) {
      accdMsgs.push(animateMessage(paxosSimSvg, simPositions, nn, 1, '#4ade80', 'Accepted'));
      simPaxosState.msgs++;
    }
    await Promise.all(accdMsgs);
    simPaxosState.rts++;
    updateMeters();

    log('[Paxos] ✅ N2 completes proposal (4 RTT total)', 'commit-event');
    simStatusText.textContent = 'Recovery complete. Raft: new leader in 2 RTT | Paxos: new proposer needs full 2-phase (4 RTT)';
    simBadge.textContent = 'Recovered';
    simBadge.className = 'status-badge running';
    simRunning = false;
    setSimBtns(false);
  }

  // Dueling Proposers
  async function runDuel() {
    if (simRunning) return;
    simRunning = true;
    setSimBtns(true);

    simPaxosState.msgs = 0;
    simPaxosState.rts = 0;
    simRaftState.msgs = 0;
    simRaftState.rts = 0;

    simBadge.textContent = 'Livelock';
    simBadge.className = 'status-badge livelock';
    simStatusText.textContent = 'Paxos: Two proposers dueling | Raft: Only leader proposes (no conflict)';
    log('[Paxos] ⚔️ N1 and N2 both try to propose simultaneously', 'livelock-event');
    log('[Raft] Leader simply appends — no conflict possible', 'raft-event');

    // Raft: just works (one round trip)
    var raftMsgs = [];
    for (var r = 1; r < 5; r++) {
      raftMsgs.push(animateMessage(raftSimSvg, simPositions, 0, r, COLORS.raft, 'Append'));
      simRaftState.msgs++;
    }

    // Paxos: N1 sends Prepare(1)
    log('[Paxos] N1 sends Prepare(1)', 'paxos-event');
    var p1 = [];
    for (var a = 1; a < 5; a++) {
      p1.push(animateMessage(paxosSimSvg, simPositions, 0, a, COLORS.paxos, 'Prep(1)'));
      simPaxosState.msgs++;
    }
    await Promise.all(p1.concat(raftMsgs));
    simPaxosState.rts++;
    simRaftState.rts++;
    updateMeters();

    await delay(200);

    // Raft ACKs come back
    var raftAcks = [];
    for (var ra = 1; ra < 5; ra++) {
      raftAcks.push(animateMessage(raftSimSvg, simPositions, ra, 0, '#4ade80', 'ACK'));
      simRaftState.msgs++;
    }

    // Paxos: N2 sends Prepare(2) before N1 can Accept
    log('[Paxos] N2 sends Prepare(2) — preempts N1!', 'livelock-event');
    var p2 = [];
    for (var b = 0; b < 5; b++) {
      if (b === 1) continue;
      p2.push(animateMessage(paxosSimSvg, simPositions, 1, b, '#ef4444', 'Prep(2)'));
      simPaxosState.msgs++;
    }
    await Promise.all(p2.concat(raftAcks));
    simPaxosState.rts++;
    simRaftState.rts++;
    updateMeters();

    log('[Raft] ✅ Committed in 1 round trip!', 'commit-event');

    await delay(300);

    // Paxos: N1 tries Accept(1) — rejected
    log('[Paxos] N1 tries Accept(1, "X") — REJECTED (acceptors promised n=2)', 'livelock-event');
    var rej = [];
    for (var c = 1; c < 5; c++) {
      rej.push(animateMessage(paxosSimSvg, simPositions, 0, c, '#ef4444', 'Accept(1)'));
      simPaxosState.msgs++;
    }
    await Promise.all(rej);
    simPaxosState.rts++;
    updateMeters();

    await delay(300);

    // N1 retries with Prepare(3)
    log('[Paxos] N1 retries with Prepare(3) — preempts N2!', 'livelock-event');
    var p3 = [];
    for (var d = 1; d < 5; d++) {
      p3.push(animateMessage(paxosSimSvg, simPositions, 0, d, '#fb923c', 'Prep(3)'));
      simPaxosState.msgs++;
    }
    await Promise.all(p3);
    simPaxosState.rts++;
    updateMeters();

    await delay(300);

    // N2 tries Accept(2) — rejected
    log('[Paxos] N2 tries Accept(2, "Y") — REJECTED (acceptors promised n=3)', 'livelock-event');
    var rej2 = [];
    for (var e = 0; e < 5; e++) {
      if (e === 1) continue;
      rej2.push(animateMessage(paxosSimSvg, simPositions, 1, e, '#ef4444', 'Accept(2)'));
      simPaxosState.msgs++;
    }
    await Promise.all(rej2);
    simPaxosState.rts++;
    updateMeters();

    log('[Paxos] ⚠️ Livelock! No value chosen after ' + simPaxosState.rts + ' round trips and ' + simPaxosState.msgs + ' messages', 'livelock-event');
    simStatusText.textContent = 'Paxos: LIVELOCK — proposers keep preempting each other | Raft: Done long ago';
    simRunning = false;
    setSimBtns(false);
  }

  if (proposeBtn) proposeBtn.addEventListener('click', runPropose);
  if (killLeaderBtn) killLeaderBtn.addEventListener('click', runKillLeader);
  if (duelBtn) duelBtn.addEventListener('click', runDuel);
  if (resetBtn) resetBtn.addEventListener('click', resetSim);

  // Initial draw
  if (paxosSimSvg && raftSimSvg) {
    drawSimNodes(paxosSimSvg, simPositions, simPaxosState, 'paxos');
    drawSimNodes(raftSimSvg, simPositions, simRaftState, 'raft');
    updateMeters();
  }

  // ============================================================
  // TABLE HOVER ANIMATION
  // ============================================================
  var tables = document.querySelectorAll('.comparison-table tbody tr');
  tables.forEach(function(row) {
    row.addEventListener('mouseenter', function() {
      row.style.background = 'rgba(255,255,255,0.05)';
    });
    row.addEventListener('mouseleave', function() {
      row.style.background = '';
    });
  });
})();
</script>
</BaseLayout>
