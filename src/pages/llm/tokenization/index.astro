---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Tokenization & BPE" 
  description="Interactive visualization of BPE tokenization, vocabulary building, and encoding comparisons"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "LLM Internals", href: "/llm/" },
    { label: "Tokenization & BPE", href: "/llm/tokenization/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🔤 Tokenization &amp; BPE</h1>
      <p class="subtitle">Watch text become tokens — step through Byte Pair Encoding and see why it matters</p>
    </header>

    <!-- Live Tokenizer -->
    <section class="panel" id="liveTokenizer">
      <h2>Live Tokenizer</h2>
      <p class="panel-desc">Type below and see tokens highlighted in real-time. Each color is a different token.</p>
      <textarea id="liveInput" rows="3" placeholder="Type anything here...">The quick brown fox jumps over the lazy dog</textarea>
      <div class="token-display" id="liveTokenDisplay"></div>
      <div class="stats-row">
        <div class="stat"><span class="stat-val" id="charCount">0</span><span class="stat-label">Characters</span></div>
        <div class="stat"><span class="stat-val" id="tokenCount">0</span><span class="stat-label">Tokens</span></div>
        <div class="stat"><span class="stat-val" id="ratioVal">0</span><span class="stat-label">Chars/Token</span></div>
      </div>
    </section>

    <!-- BPE Step-Through -->
    <section class="panel" id="bpeSection">
      <h2>BPE Algorithm Step-Through</h2>
      <p class="panel-desc">Byte Pair Encoding starts with individual characters and iteratively merges the most frequent pair. Watch the vocabulary grow.</p>
      <div class="bpe-controls">
        <button id="bpeStep" class="action-btn">Step Merge →</button>
        <button id="bpeAuto" class="action-btn secondary">▶ Auto Play</button>
        <button id="bpeReset" class="action-btn tertiary">↺ Reset</button>
        <span class="merge-counter">Merge #<span id="mergeNum">0</span> / <span id="mergeTotal">0</span></span>
      </div>
      <div class="bpe-layout">
        <div class="bpe-main">
          <h4>Current Tokens</h4>
          <div class="bpe-tokens" id="bpeTokens"></div>
          <div class="bpe-merge-info" id="bpeMergeInfo">Press "Step Merge" to begin</div>
        </div>
        <div class="bpe-vocab-panel">
          <h4>Vocabulary <span class="vocab-count" id="vocabCount">0</span></h4>
          <div class="bpe-vocab" id="bpeVocab"></div>
        </div>
      </div>
    </section>

    <!-- Token Boundary Visualizer -->
    <section class="panel">
      <h2>Token Boundary Visualizer</h2>
      <p class="panel-desc">See why the same letters split differently depending on context. "tokenization" doesn't always split as "token" + "ization".</p>
      <div class="boundary-examples" id="boundaryExamples"></div>
    </section>

    <!-- Encoding Comparison -->
    <section class="panel">
      <h2>Encoding Comparison</h2>
      <p class="panel-desc">Same text, three different tokenization strategies. See the token count difference.</p>
      <input type="text" id="compInput" value="unbelievably" class="text-input-full">
      <div class="comp-grid" id="compGrid"></div>
    </section>

    <!-- Edge Cases -->
    <section class="panel">
      <h2>Edge Cases</h2>
      <p class="panel-desc">Numbers, code, Unicode, and emojis tokenize in surprising ways. Click examples or type your own.</p>
      <div class="edge-tabs">
        <button class="edge-tab active" data-edge="numbers">Numbers</button>
        <button class="edge-tab" data-edge="code">Code</button>
        <button class="edge-tab" data-edge="unicode">Unicode</button>
        <button class="edge-tab" data-edge="emoji">Emoji</button>
      </div>
      <div class="edge-content" id="edgeContent"></div>
    </section>

    <!-- Cost Calculator -->
    <section class="panel">
      <h2>Token Cost Calculator</h2>
      <p class="panel-desc">How much does your text cost to process? Estimate based on popular model pricing.</p>
      <div class="cost-layout">
        <div class="cost-input-area">
          <textarea id="costInput" rows="4" placeholder="Paste your text here...">Large language models have revolutionized natural language processing by learning to predict the next token in a sequence.</textarea>
          <div class="cost-stats" id="costStats"></div>
        </div>
        <div class="cost-table" id="costTable"></div>
      </div>
    </section>

    <!-- Vocab Explorer -->
    <section class="panel">
      <h2>Vocabulary Explorer</h2>
      <p class="panel-desc">Browse common GPT-2 tokens. Each token has an ID and byte representation.</p>
      <input type="text" id="vocabSearch" class="text-input-full" placeholder="Search tokens...">
      <div class="vocab-grid" id="vocabGrid"></div>
    </section>

    <!-- Educational footer -->
    <section class="edu-section">
      <h3>Why This Matters</h3>
      <div class="edu-grid">
        <div class="edu-card">
          <h4>💰 Tokens = Cost</h4>
          <p>API pricing is per-token. Understanding tokenization helps you estimate costs and optimize prompts. A well-tokenized prompt can be 30% cheaper.</p>
        </div>
        <div class="edu-card">
          <h4>🧮 Context Window</h4>
          <p>Models have fixed token limits (4K, 8K, 128K). One "word" might be 1-4 tokens. Code and non-English text often use more tokens per character.</p>
        </div>
        <div class="edu-card">
          <h4>🌍 Multilingual Bias</h4>
          <p>BPE vocabularies trained on English-heavy data tokenize other languages less efficiently. Japanese text can use 3-5× more tokens than English for the same meaning.</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style is:inline>
.viz-container { max-width: 1000px; margin: 0 auto; }
.viz-header { text-align: center; margin-bottom: 30px; }
.viz-header h1 { font-size: 2.2rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
.subtitle { color: #888; font-size: 1.1rem; }

.panel {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 24px;
}
.panel h2 { font-size: 1.4rem; color: #fff; margin-bottom: 6px; }
.panel-desc { color: #888; font-size: 0.95rem; margin-bottom: 16px; line-height: 1.5; }

textarea, .text-input-full {
  width: 100%;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.15);
  color: #fff;
  padding: 12px;
  border-radius: 10px;
  font-family: inherit;
  font-size: 0.95rem;
  resize: vertical;
  margin-bottom: 12px;
}
textarea:focus, .text-input-full:focus {
  outline: none;
  border-color: #00d4ff;
}

.token-display {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  min-height: 40px;
  padding: 12px;
  background: rgba(0,0,0,0.2);
  border-radius: 10px;
  margin-bottom: 12px;
}
.tok {
  padding: 3px 8px;
  border-radius: 4px;
  font-size: 0.88rem;
  font-family: monospace;
  color: #fff;
  white-space: pre;
}

.stats-row {
  display: flex;
  gap: 24px;
}
.stat { text-align: center; }
.stat-val { display: block; font-size: 1.6rem; font-weight: 700; color: #00d4ff; }
.stat-label { font-size: 0.75rem; color: #888; text-transform: uppercase; letter-spacing: 0.5px; }

/* BPE */
.bpe-controls {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.action-btn {
  padding: 8px 16px;
  border: 1px solid rgba(0,212,255,0.3);
  background: rgba(0,212,255,0.1);
  color: #00d4ff;
  border-radius: 8px;
  cursor: pointer;
  font-family: inherit;
  font-size: 0.85rem;
  font-weight: 600;
  transition: all 0.2s;
}
.action-btn:hover { background: rgba(0,212,255,0.2); }
.action-btn.secondary { border-color: rgba(74,222,128,0.3); background: rgba(74,222,128,0.1); color: #4ade80; }
.action-btn.secondary:hover { background: rgba(74,222,128,0.2); }
.action-btn.tertiary { border-color: rgba(255,255,255,0.15); background: rgba(255,255,255,0.05); color: #aaa; }
.merge-counter { color: #888; font-size: 0.85rem; margin-left: 8px; }

.bpe-layout {
  display: flex;
  gap: 20px;
}
.bpe-main { flex: 1; }
.bpe-main h4, .bpe-vocab-panel h4 { font-size: 0.85rem; color: #888; text-transform: uppercase; margin-bottom: 8px; }
.bpe-tokens {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  min-height: 60px;
  padding: 12px;
  background: rgba(0,0,0,0.2);
  border-radius: 10px;
  margin-bottom: 10px;
}
.bpe-tok {
  padding: 4px 8px;
  border-radius: 4px;
  font-family: monospace;
  font-size: 0.85rem;
  color: #fff;
  transition: all 0.3s;
  border: 1px solid transparent;
}
.bpe-tok.highlight {
  border-color: #f59e0b;
  box-shadow: 0 0 8px rgba(245,158,11,0.4);
}
.bpe-tok.merged {
  animation: mergeFlash 0.5s ease;
}
@keyframes mergeFlash {
  0% { transform: scale(1.2); }
  100% { transform: scale(1); }
}
.bpe-merge-info {
  background: rgba(124,58,237,0.1);
  border: 1px solid rgba(124,58,237,0.2);
  border-radius: 8px;
  padding: 10px 14px;
  color: #c4b5fd;
  font-size: 0.9rem;
}
.bpe-vocab-panel {
  width: 220px;
  flex-shrink: 0;
}
.vocab-count {
  background: rgba(0,212,255,0.15);
  color: #00d4ff;
  padding: 1px 8px;
  border-radius: 10px;
  font-size: 0.75rem;
  margin-left: 6px;
}
.bpe-vocab {
  max-height: 300px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.bpe-vocab-item {
  font-family: monospace;
  font-size: 0.8rem;
  color: #aaa;
  padding: 3px 8px;
  border-radius: 4px;
  background: rgba(255,255,255,0.03);
}
.bpe-vocab-item.new {
  color: #4ade80;
  background: rgba(74,222,128,0.1);
}

/* Boundary */
.boundary-examples {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.boundary-row {
  display: flex;
  align-items: center;
  gap: 12px;
}
.boundary-word {
  min-width: 140px;
  font-family: monospace;
  font-size: 1rem;
  color: #fff;
}
.boundary-tokens {
  display: flex;
  gap: 2px;
}
.boundary-tok {
  padding: 4px 8px;
  border-radius: 4px;
  font-family: monospace;
  font-size: 0.85rem;
  color: #fff;
}
.boundary-count {
  color: #888;
  font-size: 0.8rem;
  min-width: 70px;
}

/* Comparison */
.comp-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-top: 12px;
}
.comp-card {
  background: rgba(0,0,0,0.2);
  border-radius: 12px;
  padding: 16px;
}
.comp-card h4 { font-size: 0.9rem; color: #fff; margin-bottom: 4px; }
.comp-card .comp-count { font-size: 0.8rem; color: #888; margin-bottom: 8px; }
.comp-tokens {
  display: flex;
  flex-wrap: wrap;
  gap: 3px;
}
.comp-tok {
  padding: 2px 6px;
  border-radius: 3px;
  font-family: monospace;
  font-size: 0.8rem;
  color: #fff;
}

/* Edge cases */
.edge-tabs {
  display: flex;
  gap: 6px;
  margin-bottom: 12px;
}
.edge-tab {
  padding: 6px 14px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.03);
  color: #888;
  border-radius: 8px;
  cursor: pointer;
  font-family: inherit;
  font-size: 0.85rem;
  transition: all 0.2s;
}
.edge-tab:hover { border-color: #00d4ff; color: #ccc; }
.edge-tab.active { background: rgba(0,212,255,0.12); border-color: #00d4ff; color: #fff; }
.edge-content {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 12px;
  background: rgba(0,0,0,0.2);
  border-radius: 10px;
}
.edge-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 6px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.edge-row:last-child { border-bottom: none; }
.edge-input {
  font-family: monospace;
  color: #fff;
  min-width: 140px;
}
.edge-tokens {
  display: flex;
  flex-wrap: wrap;
  gap: 3px;
}
.edge-tok {
  padding: 2px 6px;
  border-radius: 3px;
  font-family: monospace;
  font-size: 0.8rem;
  color: #fff;
}
.edge-count { color: #888; font-size: 0.8rem; }

/* Cost */
.cost-layout {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
}
.cost-input-area { flex: 1; min-width: 250px; }
.cost-stats {
  display: flex;
  gap: 16px;
  margin-top: 8px;
}
.cost-table {
  flex: 1;
  min-width: 250px;
}
.cost-row {
  display: flex;
  justify-content: space-between;
  padding: 8px 12px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  font-size: 0.9rem;
}
.cost-model { color: #ccc; }
.cost-price { color: #4ade80; font-family: monospace; }

/* Vocab explorer */
.vocab-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  gap: 6px;
  max-height: 350px;
  overflow-y: auto;
  margin-top: 10px;
}
.vocab-item {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 6px;
  padding: 6px 10px;
  font-family: monospace;
  font-size: 0.8rem;
}
.vocab-item-token { color: #fff; }
.vocab-item-id { color: #666; font-size: 0.7rem; }

/* Edu */
.edu-section { margin-top: 40px; }
.edu-section h3 { font-size: 1.3rem; color: #fff; margin-bottom: 16px; }
.edu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
.edu-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 20px; }
.edu-card h4 { color: #fff; margin-bottom: 8px; }
.edu-card p { color: #888; font-size: 0.9rem; line-height: 1.5; }

@media (max-width: 768px) {
  .bpe-layout { flex-direction: column; }
  .bpe-vocab-panel { width: 100%; }
  .comp-grid { grid-template-columns: 1fr; }
  .cost-layout { flex-direction: column; }
}
</style>

<script is:inline>
(function() {
  var tokenColors = ['#00d4ff','#7c3aed','#4ade80','#f59e0b','#ef4444','#ec4899','#06b6d4','#8b5cf6','#22c55e','#f97316','#e11d48','#14b8a6','#a78bfa','#fbbf24','#fb923c'];

  // Simple BPE-like tokenizer for visualization
  function simpleTokenize(text) {
    // Split on spaces keeping spaces, then split long words
    var result = [];
    var words = text.split(/(\s+)/);
    words.forEach(function(w) {
      if (w.length === 0) return;
      if (/^\s+$/.test(w)) {
        result.push(w);
        return;
      }
      // Simulate subword splits for common patterns
      var parts = simulateBPE(w);
      parts.forEach(function(p) { result.push(p); });
    });
    return result;
  }

  function simulateBPE(word) {
    // Common GPT-2-like subword splits
    var common = {
      'the': ['the'], 'The': ['The'], 'quick': ['quick'], 'brown': ['brown'],
      'fox': ['fox'], 'jumps': ['jump','s'], 'over': ['over'], 'lazy': ['lazy'],
      'dog': ['dog'], 'and': ['and'], 'is': ['is'], 'are': ['are'],
      'tokenization': ['token','ization'], 'unbelievably': ['un','believ','ably'],
      'Hello': ['Hello'], 'world': ['world'], 'programming': ['programm','ing'],
      'language': ['language'], 'model': ['model'], 'transformer': ['transform','er'],
      'attention': ['attention'], 'embedding': ['embed','ding'],
      'processing': ['process','ing'], 'natural': ['natural'],
      'learning': ['learn','ing'], 'revolutionized': ['revolution','ized'],
      'predict': ['predict'], 'sequence': ['sequence'],
      'Large': ['Large'], 'have': ['have'], 'by': ['by'], 'to': ['to'],
      'the': ['the'], 'in': ['in'], 'a': ['a'], 'next': ['next'], 'token': ['token'],
    };
    if (common[word]) return common[word];
    if (word.length <= 4) return [word];
    // Split longer unknown words
    if (word.length > 8) {
      var mid = Math.floor(word.length * 0.6);
      return [word.slice(0, mid), word.slice(mid)];
    }
    return [word];
  }

  // Live tokenizer
  var liveInput = document.getElementById('liveInput');
  var liveDisplay = document.getElementById('liveTokenDisplay');

  function updateLiveTokenizer() {
    var text = liveInput.value;
    var toks = simpleTokenize(text);
    liveDisplay.innerHTML = '';
    toks.forEach(function(t, i) {
      var span = document.createElement('span');
      span.className = 'tok';
      span.textContent = t;
      span.style.background = tokenColors[i % tokenColors.length] + '33';
      span.style.borderLeft = '2px solid ' + tokenColors[i % tokenColors.length];
      liveDisplay.appendChild(span);
    });
    document.getElementById('charCount').textContent = text.length;
    document.getElementById('tokenCount').textContent = toks.length;
    document.getElementById('ratioVal').textContent = toks.length > 0 ? (text.length / toks.length).toFixed(1) : '0';
  }

  liveInput.addEventListener('input', updateLiveTokenizer);
  updateLiveTokenizer();

  // BPE step-through
  var bpeCorpus = 'low lower lowest new newer newest';
  var bpeChars = [];
  var bpeMerges = [];
  var bpeVocabSet = new Set();
  var bpeMergeIdx = 0;
  var bpeAutoInterval = null;

  function initBPE() {
    // Start with character-level tokens + end-of-word marker
    var words = bpeCorpus.split(' ');
    bpeChars = [];
    words.forEach(function(w, wi) {
      var chars = w.split('').map(function(c) { return c; });
      chars.push('_'); // end of word
      if (wi > 0) bpeChars.push(' ');
      chars.forEach(function(c) { bpeChars.push(c); });
    });

    // Pre-compute merge order (most frequent pairs)
    bpeMerges = [
      { pair: ['e', 'r'], result: 'er' },
      { pair: ['er', '_'], result: 'er_' },
      { pair: ['n', 'e'], result: 'ne' },
      { pair: ['ne', 'w'], result: 'new' },
      { pair: ['new', 'er_'], result: 'newer_' },
      { pair: ['e', 's'], result: 'es' },
      { pair: ['es', 't'], result: 'est' },
      { pair: ['l', 'o'], result: 'lo' },
      { pair: ['lo', 'w'], result: 'low' },
      { pair: ['low', '_'], result: 'low_' },
      { pair: ['low', 'er_'], result: 'lower_' },
      { pair: ['low', 'est'], result: 'lowest' },
      { pair: ['new', '_'], result: 'new_' },
      { pair: ['new', 'est'], result: 'newest' },
    ];

    bpeVocabSet = new Set();
    bpeCorpus.split('').forEach(function(c) { if (c !== ' ') bpeVocabSet.add(c); });
    bpeVocabSet.add('_');
    bpeMergeIdx = 0;

    document.getElementById('mergeTotal').textContent = bpeMerges.length;
    document.getElementById('mergeNum').textContent = '0';
    renderBPE();
  }

  function renderBPE() {
    var container = document.getElementById('bpeTokens');
    container.innerHTML = '';
    bpeChars.forEach(function(c, i) {
      if (c === ' ') {
        var sp = document.createElement('span');
        sp.style.width = '12px';
        sp.style.display = 'inline-block';
        container.appendChild(sp);
        return;
      }
      var span = document.createElement('span');
      span.className = 'bpe-tok';
      span.textContent = c;
      var hash = 0;
      for (var j = 0; j < c.length; j++) hash = (hash * 31 + c.charCodeAt(j)) & 0xffffff;
      span.style.background = tokenColors[hash % tokenColors.length] + '33';
      container.appendChild(span);
    });

    // Vocab
    var vocabContainer = document.getElementById('bpeVocab');
    vocabContainer.innerHTML = '';
    var vocabArr = Array.from(bpeVocabSet);
    vocabArr.forEach(function(v) {
      var div = document.createElement('div');
      div.className = 'bpe-vocab-item';
      div.textContent = '"' + v.replace('_', '⎵') + '"';
      vocabContainer.appendChild(div);
    });
    document.getElementById('vocabCount').textContent = vocabArr.length;
  }

  function stepBPE() {
    if (bpeMergeIdx >= bpeMerges.length) return;
    var merge = bpeMerges[bpeMergeIdx];
    var p1 = merge.pair[0];
    var p2 = merge.pair[1];
    var result = merge.result;

    // Apply merge to bpeChars
    var newChars = [];
    var i = 0;
    while (i < bpeChars.length) {
      if (i < bpeChars.length - 1 && bpeChars[i] === p1 && bpeChars[i + 1] === p2) {
        newChars.push(result);
        i += 2;
      } else {
        newChars.push(bpeChars[i]);
        i++;
      }
    }
    bpeChars = newChars;
    bpeVocabSet.add(result);
    bpeMergeIdx++;

    document.getElementById('mergeNum').textContent = bpeMergeIdx;
    document.getElementById('bpeMergeInfo').innerHTML = 'Merged <strong>"' + p1.replace('_', '⎵') + '"</strong> + <strong>"' + p2.replace('_', '⎵') + '"</strong> → <strong>"' + result.replace('_', '⎵') + '"</strong>';
    renderBPE();
  }

  document.getElementById('bpeStep').addEventListener('click', stepBPE);
  document.getElementById('bpeReset').addEventListener('click', function() {
    if (bpeAutoInterval) { clearInterval(bpeAutoInterval); bpeAutoInterval = null; }
    initBPE();
    document.getElementById('bpeMergeInfo').textContent = 'Press "Step Merge" to begin';
  });
  document.getElementById('bpeAuto').addEventListener('click', function() {
    if (bpeAutoInterval) {
      clearInterval(bpeAutoInterval);
      bpeAutoInterval = null;
      this.textContent = '▶ Auto Play';
      return;
    }
    this.textContent = '⏸ Pause';
    bpeAutoInterval = setInterval(function() {
      if (bpeMergeIdx >= bpeMerges.length) {
        clearInterval(bpeAutoInterval);
        bpeAutoInterval = null;
        document.getElementById('bpeAuto').textContent = '▶ Auto Play';
        return;
      }
      stepBPE();
    }, 800);
  });

  initBPE();

  // Boundary visualizer
  var boundaryData = [
    { word: 'tokenization', tokens: ['token', 'ization'] },
    { word: 'token', tokens: ['token'] },
    { word: 'tokenize', tokens: ['token', 'ize'] },
    { word: 'untokenizable', tokens: ['un', 'token', 'izable'] },
    { word: 'transformer', tokens: ['transform', 'er'] },
    { word: 'transformed', tokens: ['transform', 'ed'] },
    { word: 'transformers', tokens: ['transform', 'ers'] },
    { word: 'GPT', tokens: ['G', 'PT'] },
    { word: 'ChatGPT', tokens: ['Chat', 'G', 'PT'] },
  ];

  var boundaryContainer = document.getElementById('boundaryExamples');
  boundaryData.forEach(function(item) {
    var row = document.createElement('div');
    row.className = 'boundary-row';
    var wordSpan = document.createElement('span');
    wordSpan.className = 'boundary-word';
    wordSpan.textContent = item.word;
    row.appendChild(wordSpan);

    var tokensDiv = document.createElement('div');
    tokensDiv.className = 'boundary-tokens';
    item.tokens.forEach(function(t, i) {
      var tok = document.createElement('span');
      tok.className = 'boundary-tok';
      tok.textContent = t;
      tok.style.background = tokenColors[i % tokenColors.length] + '44';
      tokensDiv.appendChild(tok);
    });
    row.appendChild(tokensDiv);

    var count = document.createElement('span');
    count.className = 'boundary-count';
    count.textContent = item.tokens.length + ' token' + (item.tokens.length > 1 ? 's' : '');
    row.appendChild(count);

    boundaryContainer.appendChild(row);
  });

  // Encoding comparison
  var compInput = document.getElementById('compInput');
  function updateComparison() {
    var text = compInput.value;
    var grid = document.getElementById('compGrid');
    grid.innerHTML = '';

    // Character-level
    var charTokens = text.split('');
    // BPE-like
    var bpeTokens = simulateBPE(text);
    // WordPiece-like (## prefix for continuation)
    var wpTokens = [];
    if (text.length <= 4) {
      wpTokens = [text];
    } else {
      wpTokens = [text.slice(0, 3)];
      var rest = text.slice(3);
      while (rest.length > 0) {
        var chunk = rest.slice(0, Math.min(4, rest.length));
        wpTokens.push('##' + chunk);
        rest = rest.slice(chunk.length);
      }
    }

    var methods = [
      { name: 'Character-level', tokens: charTokens },
      { name: 'BPE (GPT-style)', tokens: bpeTokens },
      { name: 'WordPiece (BERT)', tokens: wpTokens },
    ];

    methods.forEach(function(m) {
      var card = document.createElement('div');
      card.className = 'comp-card';
      card.innerHTML = '<h4>' + m.name + '</h4><div class="comp-count">' + m.tokens.length + ' tokens</div>';
      var toks = document.createElement('div');
      toks.className = 'comp-tokens';
      m.tokens.forEach(function(t, i) {
        var span = document.createElement('span');
        span.className = 'comp-tok';
        span.textContent = t;
        span.style.background = tokenColors[i % tokenColors.length] + '33';
        toks.appendChild(span);
      });
      card.appendChild(toks);
      grid.appendChild(card);
    });
  }
  compInput.addEventListener('input', updateComparison);
  updateComparison();

  // Edge cases
  var edgeData = {
    numbers: [
      { input: '42', tokens: ['42'] },
      { input: '3.14159', tokens: ['3', '.', '14', '159'] },
      { input: '1000000', tokens: ['100', '0000'] },
      { input: '2024-01-15', tokens: ['202', '4', '-', '01', '-', '15'] },
      { input: '$99.99', tokens: ['$', '99', '.', '99'] },
    ],
    code: [
      { input: 'console.log()', tokens: ['console', '.', 'log', '()'] },
      { input: 'def foo():', tokens: ['def', ' foo', '():', ] },
      { input: '    indent', tokens: ['   ', ' indent'] },
      { input: '#!/bin/bash', tokens: ['#!/', 'bin', '/', 'bash'] },
      { input: 'x += 1', tokens: ['x', ' +=', ' 1'] },
    ],
    unicode: [
      { input: 'café', tokens: ['caf', 'é'] },
      { input: '日本語', tokens: ['æ', '—', '¥', 'æ', '\\u0153', '¬', 'è', 'ª', 'ž'] },
      { input: 'naïve', tokens: ['na', 'ï', 've'] },
      { input: 'über', tokens: ['ü', 'ber'] },
    ],
    emoji: [
      { input: '😀', tokens: ['ð', '\\u0178', '\\u0141', '\\u20ac'] },
      { input: '👨‍💻', tokens: ['ð', '\\u0178', '¨', 'â€', 'ð', '\\u0178', '»', '»'] },
      { input: '🇺🇸', tokens: ['ð', '\\u0178', '\\u2021', 'º', 'ð', '\\u0178', '\\u2021', '¸'] },
      { input: '❤️', tokens: ['â', '¤', 'ï¸'] },
    ],
  };

  function renderEdge(category) {
    var container = document.getElementById('edgeContent');
    container.innerHTML = '';
    var data = edgeData[category] || [];
    data.forEach(function(item) {
      var row = document.createElement('div');
      row.className = 'edge-row';
      row.innerHTML = '<span class="edge-input">' + item.input + '</span>';
      var toksDiv = document.createElement('div');
      toksDiv.className = 'edge-tokens';
      item.tokens.forEach(function(t, i) {
        var span = document.createElement('span');
        span.className = 'edge-tok';
        span.textContent = t;
        span.style.background = tokenColors[i % tokenColors.length] + '33';
        toksDiv.appendChild(span);
      });
      row.appendChild(toksDiv);
      var count = document.createElement('span');
      count.className = 'edge-count';
      count.textContent = item.tokens.length + ' tok';
      row.appendChild(count);
      container.appendChild(row);
    });
  }

  document.querySelectorAll('.edge-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.edge-tab').forEach(function(t) { t.classList.remove('active'); });
      this.classList.add('active');
      renderEdge(this.getAttribute('data-edge'));
    });
  });
  renderEdge('numbers');

  // Cost calculator
  var costInput = document.getElementById('costInput');
  var pricing = [
    { model: 'GPT-4o', input: 2.50, output: 10.00 },
    { model: 'GPT-4o mini', input: 0.15, output: 0.60 },
    { model: 'Claude 3.5 Sonnet', input: 3.00, output: 15.00 },
    { model: 'Claude 3 Haiku', input: 0.25, output: 1.25 },
    { model: 'Gemini 1.5 Pro', input: 1.25, output: 5.00 },
    { model: 'Llama 3.1 405B', input: 3.00, output: 3.00 },
  ];

  function updateCost() {
    var text = costInput.value;
    var toks = simpleTokenize(text);
    var nTokens = toks.length;

    var stats = document.getElementById('costStats');
    stats.innerHTML = '<div class="stat"><span class="stat-val">' + nTokens + '</span><span class="stat-label">Tokens</span></div>';

    var table = document.getElementById('costTable');
    table.innerHTML = '<div class="cost-row" style="border-bottom:2px solid rgba(255,255,255,0.15)"><span class="cost-model" style="font-weight:600">Model</span><span class="cost-price" style="font-weight:600;color:#fff">Cost (input)</span></div>';
    pricing.forEach(function(p) {
      var cost = (nTokens / 1000000) * p.input;
      var costStr = cost < 0.0001 ? '<$0.0001' : '$' + cost.toFixed(6);
      table.innerHTML += '<div class="cost-row"><span class="cost-model">' + p.model + '</span><span class="cost-price">' + costStr + '</span></div>';
    });
  }
  costInput.addEventListener('input', updateCost);
  updateCost();

  // Vocabulary explorer
  var vocabData = [
    { token: 'the', id: 1169 }, { token: ' the', id: 262 }, { token: 'The', id: 464 },
    { token: ' a', id: 257 }, { token: 'is', id: 271 }, { token: ' is', id: 318 },
    { token: 'in', id: 259 }, { token: ' in', id: 287 }, { token: 'it', id: 270 },
    { token: ' it', id: 340 }, { token: 'of', id: 1659 }, { token: ' of', id: 286 },
    { token: 'to', id: 1462 }, { token: ' to', id: 284 }, { token: 'and', id: 392 },
    { token: ' and', id: 290 }, { token: 'er', id: 263 }, { token: 'ing', id: 278 },
    { token: 'tion', id: 653 }, { token: ' that', id: 326 }, { token: 'for', id: 1640 },
    { token: ' for', id: 329 }, { token: 'on', id: 261 }, { token: 'al', id: 282 },
    { token: 'ent', id: 298 }, { token: 'or', id: 273 }, { token: 're', id: 260 },
    { token: 'Ġ', id: 220 }, { token: '\\n', id: 198 }, { token: '.', id: 13 },
    { token: ',', id: 11 }, { token: '!', id: 0 }, { token: '?', id: 30 },
    { token: ' (', id: 357 }, { token: ')', id: 8 }, { token: '"', id: 1 },
    { token: '0', id: 15 }, { token: '1', id: 16 }, { token: 'def', id: 4299 },
    { token: 'class', id: 4871 }, { token: 'import', id: 11748 }, { token: 'return', id: 7783 },
    { token: 'function', id: 8818 }, { token: 'var', id: 7785 }, { token: 'const', id: 9979 },
    { token: 'if', id: 361 }, { token: 'else', id: 17772 }, { token: 'while', id: 4514 },
  ];

  function renderVocab(filter) {
    var grid = document.getElementById('vocabGrid');
    grid.innerHTML = '';
    var filtered = filter ? vocabData.filter(function(v) {
      return v.token.toLowerCase().indexOf(filter.toLowerCase()) >= 0;
    }) : vocabData;
    filtered.forEach(function(v) {
      var div = document.createElement('div');
      div.className = 'vocab-item';
      div.innerHTML = '<div class="vocab-item-token">"' + v.token.replace(/</g, '&lt;').replace(/\n/g, '\\n') + '"</div><div class="vocab-item-id">ID: ' + v.id + '</div>';
      grid.appendChild(div);
    });
  }

  document.getElementById('vocabSearch').addEventListener('input', function() {
    renderVocab(this.value);
  });
  renderVocab('');
})();
</script>
</BaseLayout>
