---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "Transformer Architecture", description: "Interactive attention heatmaps, layer-by-layer forward pass, Q/K/V matrices, and feed-forward networks", href: "/llm/transformer/", status: "live" },
  { title: "Tokenization & BPE", description: "Live tokenizer, BPE merge step-through, vocabulary explorer, and encoding comparisons", href: "/llm/tokenization/", status: "live" },
  { title: "KV Cache & Inference", description: "Autoregressive generation, KV cache memory, PagedAttention, MQA/GQA, and continuous batching", href: "/llm/kv-cache/", status: "live" },
  { title: "GPU Memory Management", description: "CUDA memory allocator, memory pooling, gradient checkpointing, mixed precision, OOM strategies", href: "/llm/gpu-memory/", status: "live" },
  { title: "Inference Serving", description: "Continuous batching, PagedAttention (vLLM), speculative decoding, KV cache optimization, TTFT vs TPS", href: "/llm/inference-serving/", status: "live" },
  { title: "Model Quantization", description: "INT8/INT4/GPTQ/AWQ, calibration, accuracy-speed tradeoffs for efficient deployment", href: "/llm/quantization/", status: "live" },
];
---

<BaseLayout 
  title="LLM Internals" 
  description="Interactive visualizations for understanding large language model architecture, tokenization, and inference optimization"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "LLM Internals", href: "/llm/" }]}
>
  <section class="section-header">
    <h1>🧠 LLM Internals</h1>
    <p>
      Large Language Models are reshaping computing, but their internals remain opaque to most engineers.
      These visualizations let you step through transformer attention, watch BPE tokenization unfold,
      and understand why KV caches matter for inference performance.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(124, 58, 237, 0.4);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
