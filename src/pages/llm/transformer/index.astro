---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Transformer Architecture" 
  description="Interactive visualization of transformer attention, Q/K/V matrices, feed-forward networks, and layer-by-layer forward pass"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "LLM Internals", href: "/llm/" },
    { label: "Transformer Architecture", href: "/llm/transformer/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🔮 Transformer Architecture</h1>
      <p class="subtitle">Step through attention, see Q/K/V in action, and watch data flow layer by layer</p>
    </header>

    <!-- Controls -->
    <section class="controls-panel">
      <div class="control-row">
        <div class="control-group">
          <label>Layers</label>
          <input type="range" id="numLayers" min="1" max="12" value="4">
          <span class="control-val" id="numLayersVal">4</span>
        </div>
        <div class="control-group">
          <label>Heads</label>
          <input type="range" id="numHeads" min="1" max="16" value="4">
          <span class="control-val" id="numHeadsVal">4</span>
        </div>
        <div class="control-group">
          <label>d_model</label>
          <select id="dModel">
            <option value="64">64</option>
            <option value="128" selected>128</option>
            <option value="256">256</option>
            <option value="512">512</option>
          </select>
        </div>
      </div>
      <div class="control-row">
        <label class="input-label">Input text:</label>
        <input type="text" id="inputText" value="The cat sat on the mat because it was tired" class="text-input">
      </div>
    </section>

    <!-- Main layout: sidebar + content -->
    <div class="main-layout">
      <!-- Architecture sidebar -->
      <aside class="arch-sidebar" id="archSidebar">
        <h3>Architecture</h3>
        <div class="arch-block active" data-stage="embedding">
          <div class="arch-dot"></div>
          <span>Token Embedding</span>
        </div>
        <div class="arch-layers" id="archLayers">
          <!-- generated by JS -->
        </div>
        <div class="arch-block" data-stage="output">
          <div class="arch-dot"></div>
          <span>Output Head</span>
        </div>
        <div class="step-controls">
          <button id="prevStep" class="step-btn" disabled>← Prev</button>
          <button id="nextStep" class="step-btn">Next →</button>
          <button id="resetSteps" class="step-btn reset">Reset</button>
        </div>
      </aside>

      <!-- Content area -->
      <div class="content-area">
        <!-- Stage: Embedding -->
        <section class="stage-panel" id="stageEmbedding">
          <h2>Token Embedding</h2>
          <p class="stage-desc">Input text is split into tokens, each mapped to an ID, then to a dense embedding vector. Positional encodings are added so the model knows word order.</p>
          <div class="token-flow">
            <div class="flow-section">
              <h4>Tokens</h4>
              <div class="token-list" id="tokenList"></div>
            </div>
            <div class="flow-arrow">→</div>
            <div class="flow-section">
              <h4>Token IDs</h4>
              <div class="token-ids" id="tokenIds"></div>
            </div>
            <div class="flow-arrow">→</div>
            <div class="flow-section">
              <h4>Embeddings</h4>
              <div class="embedding-viz" id="embeddingViz"></div>
            </div>
          </div>
        </section>

        <!-- Stage: Attention -->
        <section class="stage-panel hidden" id="stageAttention">
          <h2>Multi-Head Self-Attention <span class="layer-badge" id="attnLayerBadge">Layer 1</span></h2>
          <p class="stage-desc">Each token creates Query, Key, and Value vectors. Attention scores = softmax(Q·K&#x1D40;/√d_k). Click a token below to see what it attends to.</p>
          
          <div class="qkv-panel">
            <div class="qkv-matrix">
              <h4>Q (Query)</h4>
              <canvas id="canvasQ" width="200" height="140"></canvas>
            </div>
            <div class="qkv-op">×</div>
            <div class="qkv-matrix">
              <h4>K&#x1D40; (Key)</h4>
              <canvas id="canvasK" width="200" height="140"></canvas>
            </div>
            <div class="qkv-op">=</div>
            <div class="qkv-matrix">
              <h4>Scores</h4>
              <canvas id="canvasScores" width="200" height="140"></canvas>
            </div>
          </div>

          <div class="head-selector">
            <label>Attention Head:</label>
            <div class="head-tabs" id="headTabs"></div>
          </div>

          <div class="attention-section">
            <h4>Attention Heatmap <span class="hint">(click a token row to highlight)</span></h4>
            <div class="heatmap-container">
              <canvas id="heatmapCanvas" width="600" height="400"></canvas>
              <div class="heatmap-labels-x" id="heatmapLabelsX"></div>
              <div class="heatmap-labels-y" id="heatmapLabelsY"></div>
            </div>
            <div class="attention-insight" id="attentionInsight">
              Click on a token to see its attention pattern
            </div>
          </div>
        </section>

        <!-- Stage: Add & Norm (after attention) -->
        <section class="stage-panel hidden" id="stageAddNorm1">
          <h2>Add &amp; Layer Norm <span class="layer-badge" id="an1LayerBadge">Layer 1</span></h2>
          <p class="stage-desc">The attention output is added back to the input (residual connection), then layer-normalized. This stabilizes training and allows gradients to flow through deep networks.</p>
          <div class="residual-viz">
            <div class="res-block input-block">
              <h4>Input (x)</h4>
              <canvas id="resInput1" width="300" height="80"></canvas>
            </div>
            <div class="res-op">+</div>
            <div class="res-block attn-block">
              <h4>Attention(x)</h4>
              <canvas id="resAttn" width="300" height="80"></canvas>
            </div>
            <div class="res-op">→ LN →</div>
            <div class="res-block norm-block">
              <h4>Normalized</h4>
              <canvas id="resNorm1" width="300" height="80"></canvas>
            </div>
          </div>
          <div class="norm-explanation">
            <p><strong>Why residual connections?</strong> Without them, gradients vanish in deep networks. The skip connection lets the model learn <em>modifications</em> to the input rather than entirely new representations — making optimization much easier.</p>
            <p><strong>Layer Norm</strong> normalizes across the feature dimension (not the batch), making each token's representation zero-mean and unit-variance before the next sub-layer.</p>
          </div>
        </section>

        <!-- Stage: FFN -->
        <section class="stage-panel hidden" id="stageFFN">
          <h2>Feed-Forward Network <span class="layer-badge" id="ffnLayerBadge">Layer 1</span></h2>
          <p class="stage-desc">Two linear transformations with a non-linearity: FFN(x) = GELU(xW₁ + b₁)W₂ + b₂. The hidden dimension is typically 4× the model dimension.</p>
          <div class="ffn-viz">
            <div class="ffn-layer">
              <h4>Input</h4>
              <div class="ffn-neurons" id="ffnInput"></div>
              <div class="ffn-dim" id="ffnInputDim">d_model = 128</div>
            </div>
            <div class="ffn-expand">
              <div class="ffn-arrows expand-arrows"></div>
              <div class="ffn-label">W₁ (expand)</div>
            </div>
            <div class="ffn-layer wide">
              <h4>Hidden + GELU</h4>
              <div class="ffn-neurons wide" id="ffnHidden"></div>
              <div class="ffn-dim" id="ffnHiddenDim">4 × d_model = 512</div>
            </div>
            <div class="ffn-expand">
              <div class="ffn-arrows contract-arrows"></div>
              <div class="ffn-label">W₂ (project)</div>
            </div>
            <div class="ffn-layer">
              <h4>Output</h4>
              <div class="ffn-neurons" id="ffnOutput"></div>
              <div class="ffn-dim" id="ffnOutputDim">d_model = 128</div>
            </div>
          </div>
          <div class="activation-chart">
            <h4>GELU Activation</h4>
            <canvas id="geluCanvas" width="400" height="200"></canvas>
            <p class="hint">GELU is smoother than ReLU — it allows small negative values through, which helps with gradient flow.</p>
          </div>
        </section>

        <!-- Stage: Add & Norm 2 -->
        <section class="stage-panel hidden" id="stageAddNorm2">
          <h2>Add &amp; Layer Norm (post-FFN) <span class="layer-badge" id="an2LayerBadge">Layer 1</span></h2>
          <p class="stage-desc">Same pattern: residual connection + layer normalization after the feed-forward block. The output of this becomes input to the next transformer layer.</p>
          <div class="residual-viz">
            <div class="res-block input-block">
              <h4>Input (post-attn)</h4>
              <canvas id="resInput2" width="300" height="80"></canvas>
            </div>
            <div class="res-op">+</div>
            <div class="res-block ffn-out-block">
              <h4>FFN(x)</h4>
              <canvas id="resFFN" width="300" height="80"></canvas>
            </div>
            <div class="res-op">→ LN →</div>
            <div class="res-block norm-block">
              <h4>To next layer</h4>
              <canvas id="resNorm2" width="300" height="80"></canvas>
            </div>
          </div>
        </section>

        <!-- Stage: Output -->
        <section class="stage-panel hidden" id="stageOutput">
          <h2>Output Head</h2>
          <p class="stage-desc">Final layer norm → linear projection to vocabulary size → softmax gives probability distribution over all possible next tokens.</p>
          <div class="output-pipeline">
            <div class="output-step">
              <h4>Final Hidden State</h4>
              <canvas id="finalHidden" width="250" height="60"></canvas>
            </div>
            <div class="output-arrow">→ LayerNorm →</div>
            <div class="output-step">
              <h4>Linear (d_model → vocab)</h4>
              <div class="vocab-project">128 → 50,257</div>
            </div>
            <div class="output-arrow">→ Softmax →</div>
            <div class="output-step wide">
              <h4>Top-k Predictions</h4>
              <div class="predictions" id="predictions"></div>
            </div>
          </div>
          <div class="output-explanation">
            <p><strong>Why softmax?</strong> It converts raw logits into a valid probability distribution. High logits get exponentially more probability mass, creating a "winner-take-most" dynamic.</p>
            <p><strong>Temperature</strong> controls randomness: lower temperature → more peaked distribution → more deterministic output.</p>
          </div>
        </section>
      </div>
    </div>

    <!-- Educational footer -->
    <section class="edu-section">
      <h3>Why This Matters</h3>
      <div class="edu-grid">
        <div class="edu-card">
          <h4>🎯 Attention is O(n²)</h4>
          <p>Self-attention compares every token to every other token, making it quadratic in sequence length. This is why context windows are expensive to scale.</p>
        </div>
        <div class="edu-card">
          <h4>🧩 Residual Connections</h4>
          <p>Without skip connections, transformers deeper than a few layers would be impossible to train. They let gradients flow directly through the network.</p>
        </div>
        <div class="edu-card">
          <h4>📐 Scaling Laws</h4>
          <p>Performance improves predictably with model size (layers, heads, d_model), data, and compute. This is why GPT-4 is so much better than GPT-2.</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style is:inline>
.viz-container {
  max-width: 1100px;
  margin: 0 auto;
}
.viz-header {
  text-align: center;
  margin-bottom: 30px;
}
.viz-header h1 {
  font-size: 2.2rem;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8px;
}
.subtitle {
  color: #888;
  font-size: 1.1rem;
}

/* Controls */
.controls-panel {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 24px;
}
.control-row {
  display: flex;
  align-items: center;
  gap: 24px;
  flex-wrap: wrap;
  margin-bottom: 12px;
}
.control-row:last-child { margin-bottom: 0; }
.control-group {
  display: flex;
  align-items: center;
  gap: 8px;
}
.control-group label {
  color: #aaa;
  font-size: 0.85rem;
  font-weight: 600;
}
.control-val {
  color: #00d4ff;
  font-weight: 700;
  min-width: 24px;
}
input[type="range"] {
  -webkit-appearance: none;
  background: rgba(255,255,255,0.1);
  height: 6px;
  border-radius: 3px;
  width: 120px;
}
input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: #00d4ff;
  cursor: pointer;
}
select, .text-input {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  color: #fff;
  padding: 6px 12px;
  border-radius: 8px;
  font-family: inherit;
  font-size: 0.9rem;
}
.text-input {
  flex: 1;
  min-width: 200px;
}
.input-label {
  color: #aaa;
  font-size: 0.85rem;
  font-weight: 600;
  white-space: nowrap;
}

/* Main layout */
.main-layout {
  display: flex;
  gap: 20px;
  margin-bottom: 40px;
}

/* Sidebar */
.arch-sidebar {
  width: 200px;
  flex-shrink: 0;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
  padding: 16px;
  position: sticky;
  top: 80px;
  max-height: calc(100vh - 100px);
  overflow-y: auto;
}
.arch-sidebar h3 {
  font-size: 0.85rem;
  color: #888;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 12px;
}
.arch-block {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px;
  border-radius: 8px;
  font-size: 0.8rem;
  color: #888;
  cursor: pointer;
  transition: all 0.2s;
  margin-bottom: 4px;
}
.arch-block:hover { color: #ccc; background: rgba(255,255,255,0.04); }
.arch-block.active { color: #00d4ff; background: rgba(0,212,255,0.1); }
.arch-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #444;
  flex-shrink: 0;
}
.arch-block.active .arch-dot { background: #00d4ff; box-shadow: 0 0 8px #00d4ff; }
.arch-layer-group {
  border-left: 2px solid rgba(255,255,255,0.08);
  margin-left: 12px;
  padding-left: 8px;
  margin-bottom: 4px;
}
.arch-layer-label {
  font-size: 0.75rem;
  color: #666;
  padding: 4px 0;
  font-weight: 600;
}
.step-controls {
  display: flex;
  gap: 6px;
  margin-top: 12px;
  flex-wrap: wrap;
}
.step-btn {
  flex: 1;
  padding: 6px 8px;
  border: 1px solid rgba(255,255,255,0.15);
  background: rgba(255,255,255,0.05);
  color: #ccc;
  border-radius: 6px;
  cursor: pointer;
  font-size: 0.75rem;
  font-family: inherit;
  transition: all 0.2s;
}
.step-btn:hover:not(:disabled) { background: rgba(0,212,255,0.15); border-color: #00d4ff; color: #fff; }
.step-btn:disabled { opacity: 0.3; cursor: default; }
.step-btn.reset { flex: 0.7; }

/* Content */
.content-area {
  flex: 1;
  min-width: 0;
}
.stage-panel {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
  padding: 24px;
}
.stage-panel.hidden { display: none; }
.stage-panel h2 {
  font-size: 1.4rem;
  color: #fff;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.layer-badge {
  font-size: 0.75rem;
  background: rgba(124,58,237,0.2);
  color: #a78bfa;
  padding: 2px 10px;
  border-radius: 12px;
}
.stage-desc {
  color: #888;
  font-size: 0.95rem;
  margin-bottom: 20px;
  line-height: 1.6;
}

/* Token flow */
.token-flow {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  overflow-x: auto;
  padding-bottom: 8px;
}
.flow-section h4 {
  font-size: 0.8rem;
  color: #888;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.flow-arrow {
  color: #555;
  font-size: 1.5rem;
  padding-top: 24px;
}
.token-list {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.token-chip {
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 0.85rem;
  font-weight: 500;
  color: #fff;
  cursor: pointer;
  transition: transform 0.15s;
}
.token-chip:hover { transform: scale(1.08); }
.token-ids {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.token-id {
  padding: 4px 8px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 6px;
  font-family: monospace;
  font-size: 0.8rem;
  color: #aaa;
}
.embedding-viz {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.embed-row {
  display: flex;
  gap: 1px;
  height: 14px;
}
.embed-cell {
  width: 4px;
  border-radius: 1px;
  transition: all 0.2s;
}

/* QKV panel */
.qkv-panel {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
  overflow-x: auto;
  padding-bottom: 8px;
}
.qkv-matrix h4 {
  font-size: 0.8rem;
  color: #888;
  margin-bottom: 6px;
  text-align: center;
}
.qkv-matrix canvas {
  border-radius: 8px;
  border: 1px solid rgba(255,255,255,0.08);
}
.qkv-op {
  font-size: 1.5rem;
  color: #555;
  font-weight: 300;
}

/* Head selector */
.head-selector {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 16px;
}
.head-selector label { color: #888; font-size: 0.85rem; }
.head-tabs {
  display: flex;
  gap: 4px;
}
.head-tab {
  padding: 4px 12px;
  border-radius: 6px;
  font-size: 0.8rem;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.03);
  color: #888;
  cursor: pointer;
  transition: all 0.2s;
}
.head-tab:hover { border-color: #00d4ff; color: #ccc; }
.head-tab.active { background: rgba(0,212,255,0.15); border-color: #00d4ff; color: #fff; }

/* Heatmap */
.attention-section h4 {
  font-size: 1rem;
  color: #fff;
  margin-bottom: 10px;
}
.hint { color: #666; font-size: 0.8rem; font-weight: 400; }
.heatmap-container {
  position: relative;
  display: inline-block;
  margin-bottom: 12px;
}
.heatmap-container canvas {
  border-radius: 8px;
  display: block;
  max-width: 100%;
  cursor: pointer;
}
.attention-insight {
  background: rgba(124,58,237,0.1);
  border: 1px solid rgba(124,58,237,0.2);
  border-radius: 10px;
  padding: 12px 16px;
  color: #c4b5fd;
  font-size: 0.9rem;
  line-height: 1.5;
}

/* Residual viz */
.residual-viz {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 16px;
}
.res-block h4 {
  font-size: 0.75rem;
  color: #888;
  margin-bottom: 4px;
}
.res-block canvas {
  border-radius: 6px;
  border: 1px solid rgba(255,255,255,0.08);
}
.res-op {
  color: #00d4ff;
  font-weight: 600;
  font-size: 1.1rem;
}
.norm-explanation {
  background: rgba(74,222,128,0.06);
  border: 1px solid rgba(74,222,128,0.15);
  border-radius: 10px;
  padding: 16px;
}
.norm-explanation p {
  color: #aaa;
  font-size: 0.9rem;
  line-height: 1.6;
  margin-bottom: 8px;
}
.norm-explanation p:last-child { margin-bottom: 0; }

/* FFN */
.ffn-viz {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 20px;
  overflow-x: auto;
  padding-bottom: 8px;
}
.ffn-layer { text-align: center; }
.ffn-layer h4 { font-size: 0.8rem; color: #888; margin-bottom: 6px; }
.ffn-neurons {
  display: flex;
  flex-direction: column;
  gap: 3px;
  align-items: center;
}
.ffn-neuron {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  transition: all 0.3s;
}
.ffn-dim { font-size: 0.7rem; color: #666; margin-top: 4px; font-family: monospace; }
.ffn-expand { text-align: center; }
.ffn-label { font-size: 0.7rem; color: #666; margin-top: 4px; }
.ffn-arrows { font-size: 1.2rem; color: #555; }
.activation-chart {
  background: rgba(255,255,255,0.02);
  border-radius: 12px;
  padding: 16px;
  text-align: center;
}
.activation-chart h4 { font-size: 0.9rem; color: #fff; margin-bottom: 8px; }
.activation-chart canvas { max-width: 100%; }

/* Output */
.output-pipeline {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 20px;
}
.output-step { text-align: center; }
.output-step h4 { font-size: 0.8rem; color: #888; margin-bottom: 6px; }
.output-step canvas { border-radius: 6px; }
.output-step.wide { flex: 1; min-width: 200px; }
.output-arrow { color: #555; font-size: 0.9rem; }
.vocab-project {
  background: rgba(124,58,237,0.15);
  border: 1px solid rgba(124,58,237,0.3);
  border-radius: 8px;
  padding: 12px 16px;
  font-family: monospace;
  color: #a78bfa;
  font-size: 0.9rem;
}
.predictions {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.pred-row {
  display: flex;
  align-items: center;
  gap: 10px;
}
.pred-token {
  font-weight: 600;
  color: #fff;
  min-width: 80px;
  font-family: monospace;
}
.pred-bar-wrap {
  flex: 1;
  height: 22px;
  background: rgba(255,255,255,0.05);
  border-radius: 4px;
  overflow: hidden;
}
.pred-bar {
  height: 100%;
  border-radius: 4px;
  transition: width 0.5s;
}
.pred-pct {
  font-size: 0.8rem;
  color: #888;
  min-width: 45px;
  text-align: right;
  font-family: monospace;
}
.output-explanation {
  background: rgba(0,212,255,0.06);
  border: 1px solid rgba(0,212,255,0.15);
  border-radius: 10px;
  padding: 16px;
}
.output-explanation p {
  color: #aaa;
  font-size: 0.9rem;
  line-height: 1.6;
  margin-bottom: 8px;
}
.output-explanation p:last-child { margin-bottom: 0; }

/* Edu section */
.edu-section {
  margin-top: 40px;
}
.edu-section h3 {
  font-size: 1.3rem;
  color: #fff;
  margin-bottom: 16px;
}
.edu-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
}
.edu-card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  padding: 20px;
}
.edu-card h4 { color: #fff; margin-bottom: 8px; font-size: 1rem; }
.edu-card p { color: #888; font-size: 0.9rem; line-height: 1.5; }

@media (max-width: 768px) {
  .main-layout { flex-direction: column; }
  .arch-sidebar { width: 100%; position: static; max-height: none; }
  .qkv-panel { flex-direction: column; }
  .token-flow { flex-direction: column; }
  .flow-arrow { transform: rotate(90deg); padding: 0; }
  .residual-viz { flex-direction: column; }
  .ffn-viz { flex-direction: column; }
  .output-pipeline { flex-direction: column; }
}
</style>

<script is:inline>
(function() {
  // State
  var tokens = [];
  var numLayers = 4;
  var numHeads = 4;
  var dModel = 128;
  var currentStep = 0;
  var totalSteps = 0;
  var selectedHead = 0;
  var selectedToken = -1;
  var attentionWeights = [];
  var tokenColors = ['#00d4ff','#7c3aed','#4ade80','#f59e0b','#ef4444','#ec4899','#06b6d4','#8b5cf6','#22c55e','#f97316','#e11d48','#14b8a6'];

  // Elements
  var inputText = document.getElementById('inputText');
  var numLayersSlider = document.getElementById('numLayers');
  var numHeadsSlider = document.getElementById('numHeads');
  var dModelSelect = document.getElementById('dModel');
  var prevBtn = document.getElementById('prevStep');
  var nextBtn = document.getElementById('nextStep');
  var resetBtn = document.getElementById('resetSteps');

  function tokenize(text) {
    // Simple whitespace tokenizer for visualization
    return text.split(/\s+/).filter(function(t) { return t.length > 0; });
  }

  function pseudoRandom(seed) {
    var x = Math.sin(seed * 9301 + 49297) * 49297;
    return x - Math.floor(x);
  }

  function generateAttention(nTokens, nHeads) {
    // Generate plausible attention patterns
    attentionWeights = [];
    for (var h = 0; h < nHeads; h++) {
      var headWeights = [];
      for (var i = 0; i < nTokens; i++) {
        var row = [];
        var sum = 0;
        for (var j = 0; j < nTokens; j++) {
          // Make attention somewhat structured
          var val = pseudoRandom(h * 1000 + i * 100 + j);
          // Boost self-attention
          if (i === j) val *= 2;
          // Boost attention to first token (BOS-like)
          if (j === 0) val *= 1.5;
          // For head 0, make pronouns attend to nouns (simulate "it" -> "cat")
          if (h === 0) {
            var ti = tokens[i] ? tokens[i].toLowerCase() : '';
            var tj = tokens[j] ? tokens[j].toLowerCase() : '';
            if ((ti === 'it' || ti === 'its') && (tj === 'cat' || tj === 'the')) val *= 4;
            if (ti === 'was' && tj === 'it') val *= 3;
          }
          // Head 1: position-based (attend to nearby)
          if (h === 1) {
            var dist = Math.abs(i - j);
            val *= Math.exp(-dist * 0.5);
          }
          row.push(val);
          sum += val;
        }
        // Normalize (softmax-like)
        for (var j = 0; j < nTokens; j++) {
          row[j] = row[j] / sum;
        }
        headWeights.push(row);
      }
      attentionWeights.push(headWeights);
    }
  }

  function buildSidebar() {
    var container = document.getElementById('archLayers');
    container.innerHTML = '';
    for (var l = 0; l < numLayers; l++) {
      var group = document.createElement('div');
      group.className = 'arch-layer-group';
      group.innerHTML = '<div class="arch-layer-label">Layer ' + (l + 1) + '</div>' +
        '<div class="arch-block" data-stage="attention" data-layer="' + l + '"><div class="arch-dot"></div><span>Attention</span></div>' +
        '<div class="arch-block" data-stage="addnorm1" data-layer="' + l + '"><div class="arch-dot"></div><span>Add&Norm</span></div>' +
        '<div class="arch-block" data-stage="ffn" data-layer="' + l + '"><div class="arch-dot"></div><span>FFN</span></div>' +
        '<div class="arch-block" data-stage="addnorm2" data-layer="' + l + '"><div class="arch-dot"></div><span>Add&Norm</span></div>';
      container.appendChild(group);
    }
    // Total steps: embedding + (attention + addnorm1 + ffn + addnorm2) * layers + output
    totalSteps = 1 + numLayers * 4 + 1;
  }

  function buildHeadTabs() {
    var container = document.getElementById('headTabs');
    container.innerHTML = '';
    for (var h = 0; h < numHeads; h++) {
      var btn = document.createElement('button');
      btn.className = 'head-tab' + (h === selectedHead ? ' active' : '');
      btn.textContent = 'H' + (h + 1);
      btn.setAttribute('data-head', h);
      btn.addEventListener('click', function() {
        selectedHead = parseInt(this.getAttribute('data-head'));
        buildHeadTabs();
        drawHeatmap();
        drawQKV();
      });
      container.appendChild(btn);
    }
  }

  function renderTokens() {
    var list = document.getElementById('tokenList');
    var ids = document.getElementById('tokenIds');
    var embViz = document.getElementById('embeddingViz');
    list.innerHTML = '';
    ids.innerHTML = '';
    embViz.innerHTML = '';

    tokens.forEach(function(tok, i) {
      var color = tokenColors[i % tokenColors.length];
      var chip = document.createElement('span');
      chip.className = 'token-chip';
      chip.style.background = color + '33';
      chip.style.border = '1px solid ' + color;
      chip.textContent = tok;
      list.appendChild(chip);

      var id = document.createElement('span');
      id.className = 'token-id';
      id.textContent = (1000 + i * 137 + tok.charCodeAt(0) * 7) % 50257;
      ids.appendChild(id);

      // Embedding bars
      var row = document.createElement('div');
      row.className = 'embed-row';
      row.title = tok;
      var dims = Math.min(dModel, 32); // Show max 32 dims
      for (var d = 0; d < dims; d++) {
        var cell = document.createElement('div');
        cell.className = 'embed-cell';
        var val = pseudoRandom(i * 100 + d);
        var r = Math.floor(val * 255);
        var g = Math.floor(pseudoRandom(i * 100 + d + 50) * 255);
        var b = Math.floor(pseudoRandom(i * 100 + d + 99) * 255);
        cell.style.background = 'rgb(' + r + ',' + g + ',' + b + ')';
        cell.style.opacity = (0.3 + val * 0.7);
        row.appendChild(cell);
      }
      embViz.appendChild(row);
    });
  }

  function drawMatrixCanvas(canvas, rows, cols, seedOffset, color) {
    var ctx = canvas.getContext('2d');
    var w = canvas.width;
    var h = canvas.height;
    ctx.clearRect(0, 0, w, h);
    var cellW = w / cols;
    var cellH = h / rows;
    for (var r = 0; r < rows; r++) {
      for (var c = 0; c < cols; c++) {
        var val = pseudoRandom(seedOffset + r * 100 + c);
        ctx.fillStyle = color;
        ctx.globalAlpha = 0.1 + val * 0.8;
        ctx.fillRect(c * cellW, r * cellH, cellW - 1, cellH - 1);
      }
    }
    ctx.globalAlpha = 1;
  }

  function drawQKV() {
    var n = tokens.length;
    var headDim = Math.max(4, Math.floor(dModel / numHeads));
    var visDim = Math.min(headDim, 16);
    drawMatrixCanvas(document.getElementById('canvasQ'), n, visDim, selectedHead * 3000, '#00d4ff');
    drawMatrixCanvas(document.getElementById('canvasK'), visDim, n, selectedHead * 3000 + 1000, '#7c3aed');
    drawMatrixCanvas(document.getElementById('canvasScores'), n, n, selectedHead * 3000 + 2000, '#f59e0b');
  }

  function drawHeatmap() {
    var canvas = document.getElementById('heatmapCanvas');
    var ctx = canvas.getContext('2d');
    var n = tokens.length;
    if (n === 0) return;

    var size = Math.min(500, Math.max(300, n * 50));
    canvas.width = size;
    canvas.height = size;

    var cellSize = size / n;
    ctx.clearRect(0, 0, size, size);

    var weights = attentionWeights[selectedHead] || [];

    for (var i = 0; i < n; i++) {
      for (var j = 0; j < n; j++) {
        var val = weights[i] ? weights[i][j] : 0;
        // Color: low=dark purple, high=bright yellow/cyan
        var r, g, b;
        if (val < 0.2) {
          r = Math.floor(val * 5 * 60);
          g = Math.floor(val * 5 * 20);
          b = Math.floor(40 + val * 5 * 100);
        } else if (val < 0.5) {
          var t = (val - 0.2) / 0.3;
          r = Math.floor(60 + t * 180);
          g = Math.floor(20 + t * 80);
          b = Math.floor(140 - t * 40);
        } else {
          var t = (val - 0.5) / 0.5;
          r = Math.floor(240 + t * 15);
          g = Math.floor(100 + t * 155);
          b = Math.floor(100 - t * 60);
        }
        ctx.fillStyle = 'rgb(' + r + ',' + g + ',' + b + ')';

        if (selectedToken === i) {
          ctx.globalAlpha = 1;
        } else if (selectedToken >= 0) {
          ctx.globalAlpha = 0.25;
        } else {
          ctx.globalAlpha = 1;
        }

        ctx.fillRect(j * cellSize, i * cellSize, cellSize - 1, cellSize - 1);
      }
    }
    ctx.globalAlpha = 1;

    // Labels
    ctx.fillStyle = '#ccc';
    ctx.font = '11px Inter, sans-serif';
    ctx.textAlign = 'center';
    for (var i = 0; i < n; i++) {
      // Top labels (keys)
      ctx.save();
      ctx.translate(i * cellSize + cellSize / 2, -4);
      ctx.fillText(tokens[i], 0, 0);
      ctx.restore();
      // Left labels (queries)
      ctx.textAlign = 'right';
      ctx.fillText(tokens[i], -4, i * cellSize + cellSize / 2 + 4);
      ctx.textAlign = 'center';
    }

    // Insight text
    var insight = document.getElementById('attentionInsight');
    if (selectedToken >= 0 && weights[selectedToken]) {
      var row = weights[selectedToken];
      var maxIdx = 0;
      for (var j = 1; j < row.length; j++) {
        if (row[j] > row[maxIdx]) maxIdx = j;
      }
      var pct = (row[maxIdx] * 100).toFixed(1);
      insight.innerHTML = '<strong>"' + tokens[selectedToken] + '"</strong> attends most strongly to <strong>"' + tokens[maxIdx] + '"</strong> (' + pct + '% weight in head ' + (selectedHead + 1) + ')';
      // If "it" attends to "cat"
      if (tokens[selectedToken].toLowerCase() === 'it' && tokens[maxIdx].toLowerCase() === 'cat') {
        insight.innerHTML += ' — The model learned that "it" refers to "the cat"! This is coreference resolution emerging from attention.';
      }
    } else {
      insight.textContent = 'Click on the heatmap to see attention patterns for a specific token';
    }
  }

  function drawResidualCanvas(canvasId, seedOffset, color) {
    var canvas = document.getElementById(canvasId);
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var w = canvas.width, h = canvas.height;
    ctx.clearRect(0, 0, w, h);
    var n = Math.min(tokens.length, 10);
    var barW = w / (n || 1);
    for (var i = 0; i < n; i++) {
      for (var d = 0; d < 8; d++) {
        var val = pseudoRandom(seedOffset + i * 50 + d);
        ctx.fillStyle = color;
        ctx.globalAlpha = 0.2 + val * 0.7;
        ctx.fillRect(i * barW + d * (barW / 8), 0, barW / 8 - 1, h);
      }
    }
    ctx.globalAlpha = 1;
  }

  function drawFFN() {
    var hdim = dModel * 4;
    document.getElementById('ffnInputDim').textContent = 'd_model = ' + dModel;
    document.getElementById('ffnHiddenDim').textContent = '4 × d_model = ' + hdim;
    document.getElementById('ffnOutputDim').textContent = 'd_model = ' + dModel;

    var inputNeurons = document.getElementById('ffnInput');
    var hiddenNeurons = document.getElementById('ffnHidden');
    var outputNeurons = document.getElementById('ffnOutput');
    inputNeurons.innerHTML = '';
    hiddenNeurons.innerHTML = '';
    outputNeurons.innerHTML = '';

    var showN = Math.min(8, dModel);
    var showH = Math.min(12, hdim);

    for (var i = 0; i < showN; i++) {
      var n = document.createElement('div');
      n.className = 'ffn-neuron';
      n.style.background = 'rgba(0,212,255,' + (0.3 + pseudoRandom(i) * 0.7) + ')';
      inputNeurons.appendChild(n);
    }
    for (var i = 0; i < showH; i++) {
      var n = document.createElement('div');
      n.className = 'ffn-neuron';
      var val = pseudoRandom(i + 200);
      var gelu = val > 0 ? val : val * 0.1; // simplified
      n.style.background = gelu > 0.3 ? 'rgba(74,222,128,' + (0.3 + gelu * 0.7) + ')' : 'rgba(255,255,255,0.08)';
      hiddenNeurons.appendChild(n);
    }
    for (var i = 0; i < showN; i++) {
      var n = document.createElement('div');
      n.className = 'ffn-neuron';
      n.style.background = 'rgba(124,58,237,' + (0.3 + pseudoRandom(i + 100) * 0.7) + ')';
      outputNeurons.appendChild(n);
    }

    // GELU chart
    var canvas = document.getElementById('geluCanvas');
    var ctx = canvas.getContext('2d');
    var w = canvas.width, h = canvas.height;
    ctx.clearRect(0, 0, w, h);

    // Axes
    ctx.strokeStyle = 'rgba(255,255,255,0.15)';
    ctx.beginPath();
    ctx.moveTo(0, h / 2);
    ctx.lineTo(w, h / 2);
    ctx.moveTo(w / 2, 0);
    ctx.lineTo(w / 2, h);
    ctx.stroke();

    ctx.font = '10px monospace';
    ctx.fillStyle = '#666';
    ctx.fillText('-4', 4, h / 2 - 4);
    ctx.fillText('4', w - 14, h / 2 - 4);
    ctx.fillText('0', w / 2 + 4, h / 2 - 4);

    // GELU curve
    ctx.strokeStyle = '#4ade80';
    ctx.lineWidth = 2;
    ctx.beginPath();
    for (var px = 0; px < w; px++) {
      var x = (px / w) * 8 - 4;
      var gelu = 0.5 * x * (1 + Math.tanh(Math.sqrt(2 / Math.PI) * (x + 0.044715 * x * x * x)));
      var py = h / 2 - gelu * (h / 8);
      if (px === 0) ctx.moveTo(px, py);
      else ctx.lineTo(px, py);
    }
    ctx.stroke();

    // ReLU comparison
    ctx.strokeStyle = 'rgba(239,68,68,0.4)';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 4]);
    ctx.beginPath();
    for (var px = 0; px < w; px++) {
      var x = (px / w) * 8 - 4;
      var relu = Math.max(0, x);
      var py = h / 2 - relu * (h / 8);
      if (px === 0) ctx.moveTo(px, py);
      else ctx.lineTo(px, py);
    }
    ctx.stroke();
    ctx.setLineDash([]);

    // Legend
    ctx.fillStyle = '#4ade80';
    ctx.fillText('GELU', w - 80, 16);
    ctx.fillStyle = '#ef4444';
    ctx.fillText('ReLU', w - 80, 30);
  }

  function renderOutput() {
    var canvas = document.getElementById('finalHidden');
    if (canvas) {
      drawMatrixCanvas(canvas, 1, Math.min(32, dModel), 9999, '#7c3aed');
    }

    var container = document.getElementById('predictions');
    container.innerHTML = '';
    var preds = [
      { token: '"sleepy"', prob: 0.23, color: '#4ade80' },
      { token: '"lazy"', prob: 0.18, color: '#00d4ff' },
      { token: '"hungry"', prob: 0.11, color: '#7c3aed' },
      { token: '"cold"', prob: 0.08, color: '#f59e0b' },
      { token: '"warm"', prob: 0.06, color: '#ef4444' },
    ];
    preds.forEach(function(p) {
      var row = document.createElement('div');
      row.className = 'pred-row';
      row.innerHTML = '<span class="pred-token">' + p.token + '</span>' +
        '<div class="pred-bar-wrap"><div class="pred-bar" style="width:' + (p.prob * 300) + '%;background:' + p.color + '"></div></div>' +
        '<span class="pred-pct">' + (p.prob * 100).toFixed(1) + '%</span>';
      container.appendChild(row);
    });
  }

  function getStageInfo(step) {
    if (step === 0) return { stage: 'embedding', layer: -1 };
    if (step === totalSteps - 1) return { stage: 'output', layer: -1 };
    var inLayer = step - 1;
    var layer = Math.floor(inLayer / 4);
    var sub = inLayer % 4;
    var stages = ['attention', 'addnorm1', 'ffn', 'addnorm2'];
    return { stage: stages[sub], layer: layer };
  }

  function showStage(info) {
    // Hide all
    var panels = ['stageEmbedding', 'stageAttention', 'stageAddNorm1', 'stageFFN', 'stageAddNorm2', 'stageOutput'];
    panels.forEach(function(id) {
      document.getElementById(id).classList.add('hidden');
    });

    // Show correct panel
    var panelMap = {
      'embedding': 'stageEmbedding',
      'attention': 'stageAttention',
      'addnorm1': 'stageAddNorm1',
      'ffn': 'stageFFN',
      'addnorm2': 'stageAddNorm2',
      'output': 'stageOutput'
    };
    var panel = document.getElementById(panelMap[info.stage]);
    panel.classList.remove('hidden');

    // Update layer badges
    if (info.layer >= 0) {
      var layerText = 'Layer ' + (info.layer + 1);
      var badges = ['attnLayerBadge', 'an1LayerBadge', 'ffnLayerBadge', 'an2LayerBadge'];
      badges.forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.textContent = layerText;
      });
    }

    // Update sidebar highlighting
    var allBlocks = document.querySelectorAll('.arch-block');
    allBlocks.forEach(function(b) { b.classList.remove('active'); });

    if (info.stage === 'embedding') {
      document.querySelector('.arch-block[data-stage="embedding"]').classList.add('active');
    } else if (info.stage === 'output') {
      document.querySelector('.arch-block[data-stage="output"]').classList.add('active');
    } else {
      var selector = '.arch-block[data-stage="' + info.stage + '"][data-layer="' + info.layer + '"]';
      var el = document.querySelector(selector);
      if (el) el.classList.add('active');
    }

    // Render stage content
    if (info.stage === 'attention') {
      drawQKV();
      drawHeatmap();
    } else if (info.stage === 'addnorm1') {
      drawResidualCanvas('resInput1', info.layer * 100, '#00d4ff');
      drawResidualCanvas('resAttn', info.layer * 100 + 30, '#7c3aed');
      drawResidualCanvas('resNorm1', info.layer * 100 + 60, '#4ade80');
    } else if (info.stage === 'ffn') {
      drawFFN();
    } else if (info.stage === 'addnorm2') {
      drawResidualCanvas('resInput2', info.layer * 200, '#00d4ff');
      drawResidualCanvas('resFFN', info.layer * 200 + 50, '#f59e0b');
      drawResidualCanvas('resNorm2', info.layer * 200 + 90, '#4ade80');
    } else if (info.stage === 'output') {
      renderOutput();
    }

    // Update buttons
    prevBtn.disabled = currentStep === 0;
    nextBtn.disabled = currentStep >= totalSteps - 1;
  }

  function updateAll() {
    tokens = tokenize(inputText.value);
    numLayers = parseInt(numLayersSlider.value);
    numHeads = parseInt(numHeadsSlider.value);
    dModel = parseInt(dModelSelect.value);

    document.getElementById('numLayersVal').textContent = numLayers;
    document.getElementById('numHeadsVal').textContent = numHeads;

    buildSidebar();
    buildHeadTabs();
    generateAttention(tokens.length, numHeads);
    renderTokens();
    currentStep = 0;
    selectedToken = -1;
    showStage(getStageInfo(0));
  }

  // Events
  numLayersSlider.addEventListener('input', updateAll);
  numHeadsSlider.addEventListener('input', updateAll);
  dModelSelect.addEventListener('change', updateAll);
  inputText.addEventListener('input', function() {
    tokens = tokenize(inputText.value);
    generateAttention(tokens.length, numHeads);
    renderTokens();
    if (getStageInfo(currentStep).stage === 'attention') {
      drawQKV();
      drawHeatmap();
    }
  });

  nextBtn.addEventListener('click', function() {
    if (currentStep < totalSteps - 1) {
      currentStep++;
      showStage(getStageInfo(currentStep));
    }
  });
  prevBtn.addEventListener('click', function() {
    if (currentStep > 0) {
      currentStep--;
      showStage(getStageInfo(currentStep));
    }
  });
  resetBtn.addEventListener('click', function() {
    currentStep = 0;
    selectedToken = -1;
    showStage(getStageInfo(0));
  });

  // Heatmap click
  document.getElementById('heatmapCanvas').addEventListener('click', function(e) {
    var rect = this.getBoundingClientRect();
    var y = e.clientY - rect.top;
    var cellSize = this.height / tokens.length;
    var idx = Math.floor(y / cellSize);
    if (idx >= 0 && idx < tokens.length) {
      selectedToken = selectedToken === idx ? -1 : idx;
      drawHeatmap();
    }
  });

  // Sidebar block clicks
  document.getElementById('archSidebar').addEventListener('click', function(e) {
    var block = e.target.closest('.arch-block');
    if (!block) return;
    var stage = block.getAttribute('data-stage');
    var layer = parseInt(block.getAttribute('data-layer'));
    if (stage === 'embedding') {
      currentStep = 0;
    } else if (stage === 'output') {
      currentStep = totalSteps - 1;
    } else {
      var stageMap = { 'attention': 0, 'addnorm1': 1, 'ffn': 2, 'addnorm2': 3 };
      currentStep = 1 + layer * 4 + stageMap[stage];
    }
    showStage(getStageInfo(currentStep));
  });

  // Init
  updateAll();
})();
</script>
</BaseLayout>
