---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="NATS JetStream — Persistence & Streaming" 
  description="Interactive visualization of NATS JetStream streams, consumers, ack policies, Key-Value store, and exactly-once delivery"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "NATS", href: "/nats/" },
    { label: "JetStream", href: "/nats/jetstream/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>⚡ JetStream — Persistence & Streaming</h1>
      <p class="subtitle">How NATS Adds Durability, Replay, and Exactly-Once Delivery to Pub/Sub</p>
    </header>

    <section class="overview-section">
      <div class="overview-card">
        <p>
          Core NATS is <strong>fire-and-forget</strong> — if no subscriber is listening, the message is lost.
          <em>JetStream</em> adds a persistence layer: messages published to <strong>subjects</strong> are captured
          into <strong>streams</strong> and stored on disk or in memory. <em>Consumers</em> read from streams
          with tracking, replay, and acknowledgment. Built on top of JetStream, NATS also provides
          <strong>Key-Value</strong> and <strong>Object Store</strong> APIs — all backed by streams under the hood.
        </p>
      </div>
    </section>

    <!-- Pub/Sub with Subject Routing -->
    <section class="pubsub-section">
      <h2>📨 Subject-Based Pub/Sub</h2>
      <p class="section-desc">Publish messages to subjects with wildcards. Watch how NATS routes them to matching subscribers.</p>

      <div class="pubsub-controls">
        <div class="input-row">
          <label>Publish to:</label>
          <input type="text" id="pubSubject" value="orders.us.new" placeholder="e.g. orders.us.new" class="text-input">
          <input type="text" id="pubPayload" value="order-1234" placeholder="payload" class="text-input small">
          <button id="publishBtn" class="action-btn primary-btn">📤 Publish</button>
        </div>
        <div class="subscribers-list" id="subscribersList">
          <div class="sub-item active" data-subject="orders.>">
            <span class="sub-subject">orders.&gt;</span>
            <span class="sub-label">All orders (wildcard)</span>
            <span class="sub-indicator" id="subInd0">●</span>
          </div>
          <div class="sub-item active" data-subject="orders.us.*">
            <span class="sub-subject">orders.us.*</span>
            <span class="sub-label">US orders only</span>
            <span class="sub-indicator" id="subInd1">●</span>
          </div>
          <div class="sub-item active" data-subject="orders.eu.new">
            <span class="sub-subject">orders.eu.new</span>
            <span class="sub-label">EU new orders (exact)</span>
            <span class="sub-indicator" id="subInd2">●</span>
          </div>
          <div class="sub-item active" data-subject="payments.>">
            <span class="sub-subject">payments.&gt;</span>
            <span class="sub-label">All payments</span>
            <span class="sub-indicator" id="subInd3">●</span>
          </div>
        </div>
      </div>

      <div class="pubsub-log" id="pubsubLog">
        <div class="log-placeholder">Publish a message to see routing in action</div>
      </div>

      <div class="wildcard-ref">
        <strong>Wildcard reference:</strong>
        <code>*</code> matches exactly one token &nbsp;|&nbsp;
        <code>&gt;</code> matches one or more tokens (must be last)
      </div>
    </section>

    <!-- Queue Groups -->
    <section class="queue-section">
      <h2>⚖️ Queue Groups — Load Balancing</h2>
      <p class="section-desc">Multiple subscribers in the same queue group — only ONE gets each message.</p>

      <div class="queue-viz" id="queueViz">
        <div class="queue-publisher">
          <div class="queue-label">Publisher</div>
          <div class="queue-box pub-box" id="queuePubBox">📤</div>
        </div>
        <div class="queue-arrow">→</div>
        <div class="queue-nats">
          <div class="queue-label">NATS Server</div>
          <div class="queue-box nats-box">⚡</div>
        </div>
        <div class="queue-arrow">→</div>
        <div class="queue-consumers">
          <div class="queue-label">Queue Group "workers"</div>
          <div class="queue-members" id="queueMembers">
            <div class="queue-member" id="qm0">W0</div>
            <div class="queue-member" id="qm1">W1</div>
            <div class="queue-member" id="qm2">W2</div>
          </div>
        </div>
      </div>

      <div class="queue-controls">
        <button id="queueSendBtn" class="action-btn primary-btn">📤 Send Message</button>
        <button id="queueBurstBtn" class="action-btn secondary-btn">🔥 Send 10 Messages</button>
      </div>

      <div class="queue-stats" id="queueStats">
        <span>W0: <strong id="qs0">0</strong></span>
        <span>W1: <strong id="qs1">0</strong></span>
        <span>W2: <strong id="qs2">0</strong></span>
      </div>
    </section>

    <!-- Stream Configuration -->
    <section class="stream-section">
      <h2>🗄️ Stream Configuration</h2>
      <p class="section-desc">Configure a JetStream stream and see how messages are stored and retained.</p>

      <div class="stream-config">
        <div class="config-row">
          <div class="config-group">
            <label>Stream Name:</label>
            <input type="text" id="streamName" value="ORDERS" class="text-input" readonly>
          </div>
          <div class="config-group">
            <label>Subjects:</label>
            <input type="text" id="streamSubjects" value="orders.>" class="text-input">
          </div>
        </div>
        <div class="config-row">
          <div class="config-group">
            <label>Storage:</label>
            <div class="toggle-buttons">
              <button class="toggle-btn active" data-storage="file" id="storageFile">💾 File</button>
              <button class="toggle-btn" data-storage="memory" id="storageMem">🧠 Memory</button>
            </div>
          </div>
          <div class="config-group">
            <label>Retention:</label>
            <div class="toggle-buttons">
              <button class="toggle-btn active" data-retention="limits" id="retLimits">📏 Limits</button>
              <button class="toggle-btn" data-retention="interest" id="retInterest">👀 Interest</button>
              <button class="toggle-btn" data-retention="workqueue" id="retWork">🔨 WorkQueue</button>
            </div>
          </div>
        </div>
        <div class="config-row">
          <div class="slider-group">
            <label>Max Messages: <strong id="maxMsgsLabel">10</strong></label>
            <input type="range" id="maxMsgsSlider" min="5" max="30" value="10">
          </div>
          <div class="slider-group">
            <label>Max Age (sec): <strong id="maxAgeLabel">60</strong></label>
            <input type="range" id="maxAgeSlider" min="10" max="120" value="60" step="5">
          </div>
        </div>
      </div>

      <div class="stream-viz-wrapper">
        <div class="stream-label-bar">
          <span>Stream: ORDERS</span>
          <span class="stream-info" id="streamInfoBar">0 messages | File | Limits</span>
        </div>
        <div class="stream-viz" id="streamViz"></div>
      </div>

      <div class="stream-controls">
        <button id="streamPublishBtn" class="action-btn primary-btn">📤 Publish Message</button>
        <button id="streamBurstBtn" class="action-btn secondary-btn">🔥 Publish 5</button>
        <button id="streamResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="retention-desc" id="retentionDesc">
        <strong>Limits:</strong> Messages are kept until the stream hits its configured limits (max messages, max bytes, or max age). Oldest messages are discarded first.
      </div>
    </section>

    <!-- Consumer Types & Ack -->
    <section class="consumer-section">
      <h2>🔄 Consumers — Push vs Pull</h2>
      <p class="section-desc">Step through message delivery and acknowledgment with different consumer types.</p>

      <div class="consumer-controls">
        <div class="consumer-toggle">
          <button class="cons-type-btn active" data-type="pull">🤲 Pull Consumer</button>
          <button class="cons-type-btn" data-type="push">📬 Push Consumer</button>
        </div>
        <div class="consumer-toggle">
          <button class="dur-type-btn active" data-dur="durable">💾 Durable</button>
          <button class="dur-type-btn" data-dur="ephemeral">💨 Ephemeral</button>
        </div>
        <div class="ack-group">
          <label>Ack Policy:</label>
          <select id="ackPolicy" class="styled-select">
            <option value="explicit">Explicit</option>
            <option value="none">None</option>
            <option value="all">All</option>
          </select>
        </div>
      </div>

      <div class="consumer-viz-wrapper">
        <div class="consumer-stream-side">
          <div class="cs-label">Stream: ORDERS</div>
          <div class="cs-messages" id="csMessages"></div>
        </div>
        <div class="consumer-arrow-area">
          <div class="arrow-flow" id="arrowFlow">
            <div class="arrow-label" id="arrowLabel">waiting</div>
          </div>
        </div>
        <div class="consumer-client-side">
          <div class="cc-label" id="ccLabel">Pull Consumer (durable)</div>
          <div class="cc-received" id="ccReceived"></div>
          <div class="cc-ack-status" id="ccAckStatus">No messages yet</div>
        </div>
      </div>

      <div class="consumer-actions">
        <button id="consFetchBtn" class="action-btn primary-btn">📥 Fetch / Deliver</button>
        <button id="consAckBtn" class="action-btn commit-btn" disabled>✅ Ack</button>
        <button id="consNakBtn" class="action-btn danger-btn" disabled>❌ Nak (redeliver)</button>
        <button id="consResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="consumer-info" id="consumerInfo">
        <strong>Pull Consumer:</strong> Client explicitly requests messages with Fetch(). Server delivers a batch, client processes and acknowledges. Cursor position is tracked server-side.
      </div>

      <div class="ack-timeline" id="ackTimeline"></div>
    </section>

    <!-- Replay & Redelivery -->
    <section class="replay-section">
      <h2>⏪ Stream Replay & Redelivery</h2>
      <p class="section-desc">New consumers can replay from the beginning, or start from a specific sequence/time.</p>

      <div class="replay-controls">
        <label>Deliver Policy:</label>
        <div class="replay-buttons">
          <button class="replay-btn active" data-policy="all">All</button>
          <button class="replay-btn" data-policy="new">New Only</button>
          <button class="replay-btn" data-policy="sequence">By Sequence</button>
          <button class="replay-btn" data-policy="last">Last</button>
          <button class="replay-btn" data-policy="last_per_subject">Last Per Subject</button>
        </div>
        <div class="seq-input-group" id="seqInputGroup" style="display:none">
          <label>Start Sequence:</label>
          <input type="number" id="replaySeq" value="5" min="1" max="20" class="text-input small">
        </div>
      </div>

      <div class="replay-viz" id="replayViz">
        <div class="replay-stream" id="replayStream"></div>
        <div class="replay-pointer" id="replayPointer"></div>
        <div class="replay-delivered" id="replayDelivered"></div>
      </div>

      <div class="replay-actions">
        <button id="replayStartBtn" class="action-btn primary-btn">▶ Create Consumer & Replay</button>
        <button id="replayStepBtn" class="action-btn step-btn" disabled>⏭ Next Message</button>
        <button id="replayResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="replay-info" id="replayInfo">Choose a deliver policy and create a consumer to start replay.</div>
    </section>

    <!-- Key-Value Store -->
    <section class="kv-section">
      <h2>🗝️ Key-Value Store</h2>
      <p class="section-desc">A KV API built on JetStream streams — keys are subjects, values are messages.</p>

      <div class="kv-controls">
        <div class="input-row">
          <input type="text" id="kvKey" value="config.region" placeholder="key" class="text-input">
          <input type="text" id="kvValue" value="us-east-1" placeholder="value" class="text-input">
          <button id="kvPutBtn" class="action-btn primary-btn">Put</button>
          <button id="kvGetBtn" class="action-btn secondary-btn">Get</button>
          <button id="kvDelBtn" class="action-btn danger-btn">Delete</button>
        </div>
      </div>

      <div class="kv-viz" id="kvViz">
        <div class="kv-bucket-header">
          <span>Bucket: CONFIG</span>
          <span class="kv-count" id="kvCount">0 keys</span>
        </div>
        <div class="kv-entries" id="kvEntries">
          <div class="kv-empty">No entries yet — Put a key to start</div>
        </div>
      </div>

      <div class="kv-watch" id="kvWatch">
        <div class="kv-watch-header">👁️ Watch (real-time updates)</div>
        <div class="kv-watch-log" id="kvWatchLog"></div>
      </div>

      <div class="kv-info">
        Under the hood, a KV bucket is a JetStream stream named <code>KV_CONFIG</code>.
        Keys become subjects (<code>$KV.CONFIG.config.region</code>), and values are message payloads.
        History is maintained per key via stream retention.
      </div>
    </section>

    <!-- Explanations -->
    <section class="explain-section">
      <div class="explain-grid">
        <div class="explain-card highlight-card">
          <h3>💡 Core NATS vs JetStream</h3>
          <p>
            Core NATS is <strong>at-most-once</strong> — fire-and-forget with zero persistence.
            JetStream adds <em>at-least-once</em> and <em>exactly-once</em> delivery via server-side
            message storage, consumer tracking, and deduplication windows.
            You choose which semantics you need per use case.
          </p>
        </div>
        <div class="explain-card">
          <h3>🔨 WorkQueue Retention</h3>
          <p>
            In WorkQueue mode, messages are <strong>deleted after acknowledgment</strong>.
            Each message is delivered to exactly one consumer. Think of it like a job queue —
            once a worker acks, the message is gone. No replay possible.
          </p>
        </div>
        <div class="explain-card">
          <h3>👀 Interest-Based Retention</h3>
          <p>
            Messages are kept <strong>only while consumers exist</strong>. Once all defined
            consumers have acknowledged a message, it is removed. If no consumers are defined,
            messages are discarded immediately. Great for active consumption patterns.
          </p>
        </div>
        <div class="explain-card">
          <h3>🔁 Exactly-Once via Dedup</h3>
          <p>
            Publishers set a <code>Nats-Msg-Id</code> header. JetStream deduplicates within
            a configurable window. Combined with double-ack on the consumer side
            (ack + publish as atomic), you get <strong>exactly-once processing</strong>.
          </p>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://docs.nats.io/nats-concepts/jetstream" target="_blank">NATS JetStream Documentation</a> and <a href="https://nats.io/blog/" target="_blank">NATS Blog</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20NATS%20JetStream%20Visualizer&url=https://systeminternals.dev/nats/jetstream/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/nats/jetstream/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/nats/jetstream/&t=Interactive%20NATS%20JetStream%20Visualizer" target="_blank" class="share-btn">🟧 HN</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container { max-width: 1100px; margin: 0 auto; }
  .viz-header { text-align: center; margin-bottom: 40px; }
  .viz-header h1 { font-size: 2.5rem; margin-bottom: 10px; background: linear-gradient(90deg, #34d399, #22d3ee, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .subtitle { color: #888; font-size: 1.1rem; }
  h2 { font-size: 1.5rem; color: #fff; margin-bottom: 12px; }
  .section-desc { color: #888; margin-bottom: 24px; }

  .overview-section { margin-bottom: 50px; }
  .overview-card { background: linear-gradient(135deg, rgba(52,211,153,0.1), rgba(34,211,238,0.05)); border: 1px solid rgba(52,211,153,0.3); border-radius: 16px; padding: 24px 28px; font-size: 1.05rem; line-height: 1.8; color: #ccc; }
  .overview-card strong { color: #fff; }
  .overview-card em { color: #22d3ee; font-style: normal; font-weight: 500; }
  .overview-card code { background: rgba(0,0,0,0.3); padding: 2px 6px; border-radius: 4px; font-size: 0.9rem; color: #34d399; }

  .action-btn { padding: 10px 20px; border: none; border-radius: 10px; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .action-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .primary-btn { background: linear-gradient(135deg, #34d399, #059669); color: white; }
  .primary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(52,211,153,0.4); }
  .secondary-btn { background: linear-gradient(135deg, #22d3ee, #0891b2); color: white; }
  .secondary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(34,211,238,0.4); }
  .danger-btn { background: linear-gradient(135deg, #f87171, #ef4444); color: white; }
  .danger-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(239,68,68,0.4); }
  .step-btn { background: linear-gradient(135deg, #60a5fa, #3b82f6); color: white; }
  .commit-btn { background: linear-gradient(135deg, #a78bfa, #7c3aed); color: white; }
  .reset-btn { background: rgba(255,255,255,0.1); color: #aaa; }
  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  .text-input { padding: 8px 12px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.05); color: #fff; font-size: 0.9rem; font-family: 'Monaco','Menlo',monospace; }
  .text-input:focus { outline: none; border-color: #34d399; }
  .text-input.small { width: 120px; }
  .styled-select { padding: 8px 12px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.05); color: #fff; font-size: 0.9rem; }
  .styled-select option { background: #1a1a2e; }

  input[type="range"] { -webkit-appearance: none; height: 8px; background: rgba(255,255,255,0.15); border-radius: 4px; cursor: pointer; width: 100%; }
  input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 20px; height: 20px; border-radius: 50%; background: #34d399; cursor: pointer; }

  /* Pub/Sub Section */
  .pubsub-section { margin-bottom: 50px; }
  .input-row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 16px; }
  .input-row label { color: #ccc; font-size: 0.95rem; white-space: nowrap; }

  .subscribers-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
  .sub-item { display: flex; align-items: center; gap: 12px; padding: 10px 16px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; transition: all 0.3s; }
  .sub-item.matched { border-color: rgba(52,211,153,0.5); background: rgba(52,211,153,0.1); }
  .sub-subject { font-family: 'Monaco','Menlo',monospace; font-size: 0.9rem; color: #22d3ee; font-weight: 600; min-width: 140px; }
  .sub-label { color: #888; font-size: 0.85rem; flex: 1; }
  .sub-indicator { color: #4b5563; font-size: 1.2rem; transition: color 0.3s; }
  .sub-item.matched .sub-indicator { color: #34d399; }

  .pubsub-log { background: rgba(0,0,0,0.2); border-radius: 12px; padding: 16px; border: 1px solid rgba(255,255,255,0.1); min-height: 60px; max-height: 200px; overflow-y: auto; margin-bottom: 16px; font-size: 0.85rem; font-family: 'Monaco','Menlo',monospace; }
  .log-placeholder { color: #555; text-align: center; padding: 16px; }

  .wildcard-ref { padding: 12px 16px; background: rgba(34,211,238,0.06); border: 1px solid rgba(34,211,238,0.2); border-radius: 10px; font-size: 0.85rem; color: #aaa; }
  .wildcard-ref strong { color: #22d3ee; }
  .wildcard-ref code { background: rgba(0,0,0,0.3); padding: 2px 6px; border-radius: 4px; color: #22d3ee; }

  /* Queue Groups */
  .queue-section { margin-bottom: 50px; }
  .queue-viz { display: flex; align-items: center; justify-content: center; gap: 20px; padding: 30px; background: rgba(0,0,0,0.2); border-radius: 14px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 16px; flex-wrap: wrap; }
  .queue-label { font-size: 0.75rem; color: #888; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; text-align: center; }
  .queue-box { width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; border-radius: 12px; font-size: 1.5rem; }
  .pub-box { background: rgba(52,211,153,0.15); border: 1px solid rgba(52,211,153,0.4); }
  .nats-box { background: rgba(34,211,238,0.15); border: 1px solid rgba(34,211,238,0.4); }
  .queue-arrow { color: #555; font-size: 1.5rem; }
  .queue-members { display: flex; gap: 10px; }
  .queue-member { width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 10px; background: rgba(167,139,250,0.12); border: 1px solid rgba(167,139,250,0.3); color: #a78bfa; font-weight: 700; font-size: 0.85rem; transition: all 0.3s; }
  .queue-member.active-delivery { background: rgba(52,211,153,0.2); border-color: rgba(52,211,153,0.5); color: #34d399; transform: scale(1.1); }
  .queue-controls { display: flex; gap: 12px; margin-bottom: 12px; }
  .queue-stats { display: flex; gap: 20px; color: #aaa; font-size: 0.9rem; }
  .queue-stats strong { color: #34d399; }

  /* Stream Section */
  .stream-section { margin-bottom: 50px; }
  .stream-config { background: rgba(0,0,0,0.2); border-radius: 14px; padding: 20px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 20px; }
  .config-row { display: flex; gap: 20px; margin-bottom: 16px; flex-wrap: wrap; }
  .config-group { flex: 1; min-width: 200px; }
  .config-group label { display: block; color: #888; font-size: 0.85rem; margin-bottom: 6px; }
  .toggle-buttons { display: flex; gap: 8px; }
  .toggle-btn { padding: 8px 14px; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; background: rgba(255,255,255,0.03); color: #ccc; font-size: 0.85rem; cursor: pointer; transition: all 0.2s; }
  .toggle-btn.active { border-color: #34d399; background: rgba(52,211,153,0.15); color: #34d399; font-weight: 600; }
  .slider-group { flex: 1; min-width: 200px; }
  .slider-group label { color: #ccc; font-size: 0.95rem; display: block; margin-bottom: 8px; }
  .slider-group strong { color: #34d399; }

  .stream-viz-wrapper { background: rgba(0,0,0,0.2); border-radius: 14px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 16px; overflow: hidden; }
  .stream-label-bar { display: flex; justify-content: space-between; padding: 12px 16px; background: rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.08); font-size: 0.85rem; color: #888; }
  .stream-label-bar span:first-child { color: #22d3ee; font-weight: 600; }
