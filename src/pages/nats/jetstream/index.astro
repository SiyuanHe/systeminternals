  .consumer-info strong { color: #22d3ee; }

  .ack-timeline { background: rgba(0,0,0,0.2); border-radius: 12px; padding: 16px; border: 1px solid rgba(255,255,255,0.1); min-height: 40px; max-height: 200px; overflow-y: auto; font-size: 0.85rem; font-family: 'Monaco','Menlo',monospace; }

  /* Replay Section */
  .replay-section { margin-bottom: 50px; }
  .replay-controls { margin-bottom: 20px; }
  .replay-controls label { color: #ccc; font-size: 0.95rem; display: block; margin-bottom: 8px; }
  .replay-buttons { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
  .replay-btn { padding: 8px 14px; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; background: rgba(255,255,255,0.03); color: #ccc; font-size: 0.85rem; cursor: pointer; transition: all 0.2s; }
  .replay-btn.active { border-color: #22d3ee; background: rgba(34,211,238,0.15); color: #22d3ee; font-weight: 600; }
  .seq-input-group { display: flex; align-items: center; gap: 8px; }
  .seq-input-group label { margin-bottom: 0; }

  .replay-viz { background: rgba(0,0,0,0.2); border-radius: 14px; padding: 20px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 16px; min-height: 80px; }
  .replay-stream { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 12px; }
  .replay-pointer { font-size: 0.85rem; color: #22d3ee; margin-bottom: 8px; min-height: 20px; }
  .replay-delivered { display: flex; gap: 6px; flex-wrap: wrap; min-height: 30px; }

  .replay-actions { display: flex; gap: 12px; margin-bottom: 12px; }
  .replay-info { font-size: 0.9rem; color: #888; text-align: center; padding: 8px; }

  /* KV Section */
  .kv-section { margin-bottom: 50px; }
  .kv-viz { background: rgba(0,0,0,0.2); border-radius: 14px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 16px; overflow: hidden; }
  .kv-bucket-header { display: flex; justify-content: space-between; padding: 12px 16px; background: rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.08); font-size: 0.85rem; color: #22d3ee; font-weight: 600; }
  .kv-count { color: #888; font-weight: 400; }
  .kv-entries { padding: 12px 16px; min-height: 50px; }
  .kv-empty { color: #555; text-align: center; padding: 16px; }

  .kv-watch { background: rgba(0,0,0,0.2); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 16px; overflow: hidden; }
  .kv-watch-header { padding: 10px 16px; background: rgba(167,139,250,0.08); border-bottom: 1px solid rgba(167,139,250,0.2); font-size: 0.85rem; color: #a78bfa; font-weight: 600; }
  .kv-watch-log { padding: 12px 16px; min-height: 40px; max-height: 150px; overflow-y: auto; font-size: 0.8rem; font-family: 'Monaco','Menlo',monospace; }

  .kv-info { padding: 14px 18px; background: rgba(167,139,250,0.06); border: 1px solid rgba(167,139,250,0.2); border-radius: 10px; font-size: 0.9rem; color: #aaa; line-height: 1.6; }
  .kv-info code { background: rgba(0,0,0,0.3); padding: 2px 6px; border-radius: 4px; font-size: 0.85rem; color: #a78bfa; }

  /* Explain Section */
  .explain-section { margin-bottom: 50px; }
  .explain-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .explain-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 24px; }
  .explain-card h3 { font-size: 1rem; color: #fff; margin-bottom: 10px; }
  .explain-card p { color: #aaa; line-height: 1.6; font-size: 0.9rem; }
  .explain-card strong { color: #34d399; }
  .explain-card em { color: #22d3ee; }
  .explain-card code { background: rgba(0,0,0,0.3); padding: 2px 6px; border-radius: 4px; font-size: 0.85rem; color: #34d399; }
  .highlight-card { background: linear-gradient(135deg, rgba(52,211,153,0.08), rgba(34,211,238,0.08)); border-color: rgba(52,211,153,0.3); }

  .viz-footer { text-align: center; color: #666; font-size: 0.9rem; padding: 20px 0; border-top: 1px solid rgba(255,255,255,0.1); margin-bottom: 30px; }
  .viz-footer a { color: #34d399; }
  .share-buttons { display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; }
  .share-buttons span { color: #666; }
  .share-btn { padding: 10px 20px; background: rgba(255,255,255,0.1); border-radius: 8px; color: #fff; font-size: 0.9rem; transition: background 0.2s; }
  .share-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  @media (max-width: 768px) {
    .viz-header h1 { font-size: 1.8rem; }
    .explain-grid { grid-template-columns: 1fr; }
    .consumer-viz-wrapper { flex-direction: column; }
    .consumer-arrow-area { width: auto; height: 40px; }
    .queue-viz { flex-direction: column; }
    .queue-arrow { transform: rotate(90deg); }
  }
</style>

<script is:inline>
  // ========== PUB/SUB ROUTING ==========
  var pubMsgId = 0;

  function natsMatch(subject, pattern) {
    var subTokens = subject.split('.');
    var patTokens = pattern.split('.');
    for (var i = 0; i < patTokens.length; i++) {
      if (patTokens[i] === '>') return true;
      if (i >= subTokens.length) return false;
      if (patTokens[i] !== '*' && patTokens[i] !== subTokens[i]) return false;
    }
    return subTokens.length === patTokens.length;
  }

  document.getElementById('publishBtn').addEventListener('click', function() {
    var subject = document.getElementById('pubSubject').value.trim();
    var payload = document.getElementById('pubPayload').value.trim();
    if (!subject) return;
    pubMsgId++;

    var log = document.getElementById('pubsubLog');
    if (log.querySelector('.log-placeholder')) log.innerHTML = '';

    var items = document.querySelectorAll('.sub-item');
    var matched = [];
    items.forEach(function(item) {
      var pattern = item.getAttribute('data-subject');
      if (natsMatch(subject, pattern)) {
        matched.push(pattern);
        item.classList.add('matched');
        setTimeout(function() { item.classList.remove('matched'); }, 800);
      }
    });

    var entry = document.createElement('div');
    entry.style.cssText = 'padding:3px 0;animation:eventAppear 0.3s ease-out;';
    if (matched.length > 0) {
      entry.style.color = '#6ee7b7';
      entry.textContent = '[msg-' + pubMsgId + '] PUB ' + subject + ' → matched: ' + matched.join(', ') + ' (payload: ' + payload + ')';
    } else {
      entry.style.color = '#fca5a5';
      entry.textContent = '[msg-' + pubMsgId + '] PUB ' + subject + ' → no matching subscribers';
    }
    log.appendChild(entry);
    log.scrollTop = log.scrollHeight;
  });

  // ========== QUEUE GROUPS ==========
  var queueCounts = [0, 0, 0];
  var queueNext = 0;

  function sendQueueMsg() {
    var idx = queueNext % 3;
    queueNext++;
    queueCounts[idx]++;

    var member = document.getElementById('qm' + idx);
    member.classList.add('active-delivery');
    setTimeout(function() { member.classList.remove('active-delivery'); }, 400);

    for (var i = 0; i < 3; i++) {
      document.getElementById('qs' + i).textContent = queueCounts[i];
    }
  }

  document.getElementById('queueSendBtn').addEventListener('click', sendQueueMsg);

  document.getElementById('queueBurstBtn').addEventListener('click', function() {
    var count = 0;
    var iv = setInterval(function() {
      sendQueueMsg();
      count++;
      if (count >= 10) clearInterval(iv);
    }, 150);
  });

  // ========== STREAM CONFIG ==========
  var streamMessages = [];
  var streamSeq = 0;
  var streamStorage = 'file';
  var streamRetention = 'limits';
  var streamMaxMsgs = 10;
  var streamMaxAge = 60;
  var subjects = ['orders.us.new', 'orders.eu.new', 'orders.us.update', 'orders.asia.new'];

  document.getElementById('maxMsgsSlider').addEventListener('input', function(e) {
    streamMaxMsgs = parseInt(e.target.value);
    document.getElementById('maxMsgsLabel').textContent = streamMaxMsgs;
    enforceRetention();
    renderStream();
  });

  document.getElementById('maxAgeSlider').addEventListener('input', function(e) {
    streamMaxAge = parseInt(e.target.value);
    document.getElementById('maxAgeLabel').textContent = streamMaxAge;
  });

  document.querySelectorAll('[data-storage]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('[data-storage]').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      streamStorage = btn.getAttribute('data-storage');
      renderStream();
    });
  });

  document.querySelectorAll('[data-retention]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('[data-retention]').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      streamRetention = btn.getAttribute('data-retention');
      var descs = {
        limits: '<strong>Limits:</strong> Messages are kept until the stream hits its configured limits (max messages, max bytes, or max age). Oldest messages are discarded first.',
        interest: '<strong>Interest:</strong> Messages are kept only while active consumers exist. Once all consumers ack a message, it is removed. No consumers = immediate discard.',
        workqueue: '<strong>WorkQueue:</strong> Each message is delivered to exactly one consumer. Once acknowledged, the message is deleted from the stream. No replay.'
      };
      document.getElementById('retentionDesc').innerHTML = descs[streamRetention];
      enforceRetention();
      renderStream();
    });
  });

  function enforceRetention() {
    if (streamRetention === 'limits') {
      while (streamMessages.length > streamMaxMsgs) {
        streamMessages.shift();
      }
    }
  }

  function renderStream() {
    var viz = document.getElementById('streamViz');
    viz.innerHTML = '';
    streamMessages.forEach(function(msg) {
      var el = document.createElement('div');
      el.style.cssText = 'padding:6px 10px;background:rgba(34,211,238,0.1);border:1px solid rgba(34,211,238,0.3);border-radius:8px;font-size:0.8rem;color:#22d3ee;font-family:Monaco,Menlo,monospace;animation:eventAppear 0.3s ease-out;';
      if (msg.acked) {
        el.style.background = 'rgba(52,211,153,0.1)';
        el.style.borderColor = 'rgba(52,211,153,0.3)';
        el.style.color = '#34d399';
      }
      el.textContent = '#' + msg.seq + ' ' + msg.subject;
      viz.appendChild(el);
    });
    document.getElementById('streamInfoBar').textContent = streamMessages.length + ' messages | ' + (streamStorage === 'file' ? 'File' : 'Memory') + ' | ' + streamRetention.charAt(0).toUpperCase() + streamRetention.slice(1);
  }

  function publishToStream() {
    streamSeq++;
    var subj = subjects[Math.floor(Math.random() * subjects.length)];
    streamMessages.push({ seq: streamSeq, subject: subj, time: Date.now(), acked: false });
    enforceRetention();
    renderStream();
  }

  document.getElementById('streamPublishBtn').addEventListener('click', publishToStream);

  document.getElementById('streamBurstBtn').addEventListener('click', function() {
    var count = 0;
    var iv = setInterval(function() {
      publishToStream();
      count++;
      if (count >= 5) clearInterval(iv);
    }, 200);
  });

  document.getElementById('streamResetBtn').addEventListener('click', function() {
    streamMessages = [];
    streamSeq = 0;
    renderStream();
  });

  // ========== CONSUMERS ==========
  var consumerType = 'pull';
  var durableType = 'durable';
  var ackPolicy = 'explicit';
  var consStreamMsgs = [];
  var consCursor = 0;
  var consReceived = [];
  var consAcked = [];

  // Initialize consumer stream with some messages
  for (var i = 1; i <= 8; i++) {
    consStreamMsgs.push({ seq: i, subject: subjects[(i - 1) % subjects.length], acked: false });
  }

  function renderConsumerViz() {
    var csMsgs = document.getElementById('csMessages');
    csMsgs.innerHTML = '';
    consStreamMsgs.forEach(function(msg) {
      var el = document.createElement('div');
      var color = msg.acked ? '#34d399' : (consReceived.indexOf(msg.seq) >= 0 ? '#fbbf24' : '#22d3ee');
      var bg = msg.acked ? 'rgba(52,211,153,0.1)' : (consReceived.indexOf(msg.seq) >= 0 ? 'rgba(251,191,36,0.1)' : 'rgba(34,211,238,0.08)');
      el.style.cssText = 'padding:5px 10px;background:' + bg + ';border:1px solid ' + color + '33;border-radius:6px;font-size:0.8rem;color:' + color + ';font-family:Monaco,Menlo,monospace;';
      var status = msg.acked ? ' ✅' : (consReceived.indexOf(msg.seq) >= 0 ? ' 📤' : '');
      el.textContent = '#' + msg.seq + ' ' + msg.subject + status;
      csMsgs.appendChild(el);
    });

    var ccRecv = document.getElementById('ccReceived');
    ccRecv.innerHTML = '';
    consReceived.forEach(function(seq) {
      var el = document.createElement('div');
      var isAcked = consAcked.indexOf(seq) >= 0;
      el.style.cssText = 'padding:5px 10px;background:' + (isAcked ? 'rgba(52,211,153,0.1)' : 'rgba(251,191,36,0.1)') + ';border:1px solid ' + (isAcked ? 'rgba(52,211,153,0.3)' : 'rgba(251,191,36,0.3)') + ';border-radius:6px;font-size:0.8rem;color:' + (isAcked ? '#34d399' : '#fbbf24') + ';font-family:Monaco,Menlo,monospace;';
      el.textContent = '#' + seq + (isAcked ? ' ✅ acked' : ' pending');
      ccRecv.appendChild(el);
    });

    document.getElementById('ccLabel').textContent = (consumerType === 'pull' ? 'Pull' : 'Push') + ' Consumer (' + durableType + ')';

    var pendingCount = consReceived.filter(function(s) { return consAcked.indexOf(s) < 0; }).length;
    document.getElementById('ccAckStatus').textContent = pendingCount > 0 ? pendingCount + ' message(s) pending ack' : (consReceived.length > 0 ? 'All acknowledged' : 'No messages yet');

    document.getElementById('consAckBtn').disabled = pendingCount === 0;
    document.getElementById('consNakBtn').disabled = pendingCount === 0;

    var arrowLabel = document.getElementById('arrowLabel');
    if (consumerType === 'pull') {
      arrowLabel.textContent = 'fetch →';
    } else {
      arrowLabel.textContent = '← push';
    }
  }

  document.querySelectorAll('.cons-type-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.cons-type-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      consumerType = btn.getAttribute('data-type');
      var infos = {
        pull: '<strong>Pull Consumer:</strong> Client explicitly requests messages with Fetch(). Server delivers a batch, client processes and acknowledges. Cursor position is tracked server-side.',
        push: '<strong>Push Consumer:</strong> Server proactively delivers messages to a specified delivery subject. Client subscribes and processes. Simpler but less control over flow.'
      };
      document.getElementById('consumerInfo').innerHTML = infos[consumerType];
      renderConsumerViz();
    });
  });

  document.querySelectorAll('.dur-type-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.dur-type-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      durableType = btn.getAttribute('data-dur');
      renderConsumerViz();
    });
  });

  document.getElementById('ackPolicy').addEventListener('change', function(e) {
    ackPolicy = e.target.value;
  });

  document.getElementById('consFetchBtn').addEventListener('click', function() {
    if (consCursor >= consStreamMsgs.length) {
      addAckEvent('No more messages in stream');
      return;
    }
    var msg = consStreamMsgs[consCursor];
    consCursor++;
    consReceived.push(msg.seq);

    addAckEvent((consumerType === 'pull' ? 'FETCH' : 'PUSH') + ' → received #' + msg.seq + ' (' + msg.subject + ')');

    if (ackPolicy === 'none') {
      consAcked.push(msg.seq);
      msg.acked = true;
      addAckEvent('ACK policy=none → auto-ack #' + msg.seq);
      if (streamRetention === 'workqueue') {
        streamMessages = streamMessages.filter(function(m) { return m.seq !== msg.seq; });
      }
    }

    renderConsumerViz();
  });

  document.getElementById('consAckBtn').addEventListener('click', function() {
    var pending = consReceived.filter(function(s) { return consAcked.indexOf(s) < 0; });
    if (pending.length === 0) return;

    if (ackPolicy === 'all') {
      // Ack all up to the latest
      pending.forEach(function(seq) {
        consAcked.push(seq);
        var m = consStreamMsgs.find(function(x) { return x.seq === seq; });
        if (m) m.acked = true;
      });
      addAckEvent('ACK ALL → acked #' + pending[0] + ' through #' + pending[pending.length - 1]);
    } else {
      var seq = pending[0];
      consAcked.push(seq);
      var m = consStreamMsgs.find(function(x) { return x.seq === seq; });
      if (m) m.acked = true;
      addAckEvent('ACK → confirmed #' + seq);
    }

    if (streamRetention === 'workqueue') {
      consAcked.forEach(function(seq) {
        streamMessages = streamMessages.filter(function(m) { return m.seq !== seq; });
      });
      addAckEvent('WorkQueue → acked messages removed from stream');
    }

    renderConsumerViz();
    renderStream();
  });

  document.getElementById('consNakBtn').addEventListener('click', function() {
    var pending = consReceived.filter(function(s) { return consAcked.indexOf(s) < 0; });
    if (pending.length === 0) return;
    var seq = pending[0];
    // Remove from received, reset cursor to redeliver
    consReceived = consReceived.filter(function(s) { return s !== seq; });
    consCursor = Math.min(consCursor, consStreamMsgs.findIndex(function(m) { return m.seq === seq; }));
    addAckEvent('NAK → #' + seq + ' will be redelivered');
    renderConsumerViz();
  });

  document.getElementById('consResetBtn').addEventListener('click', function() {
    consCursor = 0;
    consReceived = [];
    consAcked = [];
    consStreamMsgs.forEach(function(m) { m.acked = false; });
    document.getElementById('ackTimeline').innerHTML = '';
    renderConsumerViz();
  });

  function addAckEvent(text) {
    var timeline = document.getElementById('ackTimeline');
    var el = document.createElement('div');
    el.style.cssText = 'padding:3px 0;color:#aaa;animation:eventAppear 0.3s ease-out;';
    el.textContent = '[' + new Date().toISOString().slice(11, 19) + '] ' + text;
    timeline.appendChild(el);
    timeline.scrollTop = timeline.scrollHeight;
  }

  // ========== REPLAY ==========
  var replayPolicy = 'all';
  var replayMsgs = [];
  var replayIdx = 0;
  var replayDeliveredList = [];
  var replaySubjects = ['orders.us.new', 'orders.eu.new', 'orders.us.update', 'orders.asia.new', 'orders.us.new'];

  // Build replay stream
  for (var ri = 1; ri <= 12; ri++) {
    replayMsgs.push({ seq: ri, subject: replaySubjects[(ri - 1) % replaySubjects.length] });
  }

  function renderReplay() {
    var streamDiv = document.getElementById('replayStream');
    streamDiv.innerHTML = '';
    replayMsgs.forEach(function(msg) {
      var el = document.createElement('div');
      var delivered = replayDeliveredList.indexOf(msg.seq) >= 0;
      var isNext = replayIdx < replayMsgs.length && replayMsgs[replayIdx].seq === msg.seq;
      el.style.cssText = 'display:inline-block;padding:5px 10px;border-radius:6px;font-size:0.8rem;font-family:Monaco,Menlo,monospace;margin:2px;';
      if (delivered) {
        el.style.background = 'rgba(52,211,153,0.15)';
        el.style.border = '1px solid rgba(52,211,153,0.4)';
        el.style.color = '#34d399';
      } else if (isNext) {
        el.style.background = 'rgba(251,191,36,0.15)';
        el.style.border = '1px solid rgba(251,191,36,0.4)';
        el.style.color = '#fbbf24';
      } else {
        el.style.background = 'rgba(255,255,255,0.05)';
        el.style.border = '1px solid rgba(255,255,255,0.1)';
        el.style.color = '#888';
      }
      el.textContent = '#' + msg.seq;
      streamDiv.appendChild(el);
    });

    var pointer = document.getElementById('replayPointer');
    if (replayIdx < replayMsgs.length) {
      pointer.textContent = '▲ Next: #' + replayMsgs[replayIdx].seq + ' (' + replayMsgs[replayIdx].subject + ')';
    } else {
      pointer.textContent = '✅ All messages delivered';
    }

    var deliveredDiv = document.getElementById('replayDelivered');
    deliveredDiv.innerHTML = '';
    replayDeliveredList.forEach(function(seq) {
      var el = document.createElement('div');
      el.style.cssText = 'display:inline-block;padding:4px 8px;background:rgba(52,211,153,0.1);border:1px solid rgba(52,211,153,0.3);border-radius:6px;font-size:0.75rem;color:#34d399;font-family:Monaco,Menlo,monospace;margin:2px;';
      el.textContent = '#' + seq;
      deliveredDiv.appendChild(el);
    });
  }

  document.querySelectorAll('.replay-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.replay-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      replayPolicy = btn.getAttribute('data-policy');
      document.getElementById('seqInputGroup').style.display = replayPolicy === 'sequence' ? 'flex' : 'none';
    });
  });

  document.getElementById('replayStartBtn').addEventListener('click', function() {
    replayDeliveredList = [];
    var seq;

    if (replayPolicy === 'all') {
      replayIdx = 0;
    } else if (replayPolicy === 'new') {
      replayIdx = replayMsgs.length;
    } else if (replayPolicy === 'sequence') {
      seq = parseInt(document.getElementById('replaySeq').value) || 1;
      replayIdx = replayMsgs.findIndex(function(m) { return m.seq >= seq; });
      if (replayIdx < 0) replayIdx = replayMsgs.length;
    } else if (replayPolicy === 'last') {
      replayIdx = replayMsgs.length - 1;
    } else if (replayPolicy === 'last_per_subject') {
      // Find last msg for each unique subject
      var seen = {};
      for (var li = replayMsgs.length - 1; li >= 0; li--) {
        if (!seen[replayMsgs[li].subject]) {
          seen[replayMsgs[li].subject] = true;
          replayDeliveredList.unshift(replayMsgs[li].seq);
        }
      }
      replayIdx = replayMsgs.length;
    }

    document.getElementById('replayStepBtn').disabled = replayIdx >= replayMsgs.length && replayPolicy !== 'last_per_subject';
    document.getElementById('replayInfo').textContent = 'Consumer created with DeliverPolicy=' + replayPolicy + '. Step through delivery.';
    renderReplay();
  });

  document.getElementById('replayStepBtn').addEventListener('click', function() {
    if (replayIdx >= replayMsgs.length) return;
    replayDeliveredList.push(replayMsgs[replayIdx].seq);
    replayIdx++;
    if (replayIdx >= replayMsgs.length) {
      document.getElementById('replayStepBtn').disabled = true;
      document.getElementById('replayInfo').textContent = 'All messages delivered!';
    }
    renderReplay();
  });

  document.getElementById('replayResetBtn').addEventListener('click', function() {
    replayIdx = 0;
    replayDeliveredList = [];
    document.getElementById('replayStepBtn').disabled = true;
    document.getElementById('replayInfo').textContent = 'Choose a deliver policy and create a consumer to start replay.';
    renderReplay();
  });

  // ========== KEY-VALUE STORE ==========
  var kvStore = {};
  var kvRevision = 0;

  function renderKV() {
    var entries = document.getElementById('kvEntries');
    var keys = Object.keys(kvStore);
    document.getElementById('kvCount').textContent = keys.length + ' keys';

    if (keys.length === 0) {
      entries.innerHTML = '<div class="kv-empty">No entries yet — Put a key to start</div>';
      return;
    }

    entries.innerHTML = '';
    keys.sort().forEach(function(key) {
      var entry = kvStore[key];
      var el = document.createElement('div');
      el.style.cssText = 'display:flex;justify-content:space-between;padding:8px 12px;border-bottom:1px solid rgba(255,255,255,0.05);font-family:Monaco,Menlo,monospace;font-size:0.85rem;animation:eventAppear 0.3s ease-out;';
      el.innerHTML = '<span style="color:#22d3ee">' + key + '</span><span style="color:#ccc">' + entry.value + '</span><span style="color:#555">rev:' + entry.revision + '</span>';
      entries.appendChild(el);
    });
  }

  function addKVWatch(op, key, value) {
    var log = document.getElementById('kvWatchLog');
    var el = document.createElement('div');
    var color = op === 'PUT' ? '#6ee7b7' : (op === 'DEL' ? '#fca5a5' : '#93c5fd');
    el.style.cssText = 'padding:2px 0;color:' + color + ';animation:eventAppear 0.3s ease-out;';
    el.textContent = '[' + new Date().toISOString().slice(11, 19) + '] ' + op + ' ' + key + (value !== undefined ? ' = ' + value : '');
    log.appendChild(el);
    log.scrollTop = log.scrollHeight;
  }

  document.getElementById('kvPutBtn').addEventListener('click', function() {
    var key = document.getElementById('kvKey').value.trim();
    var value = document.getElementById('kvValue').value.trim();
    if (!key) return;
    kvRevision++;
    kvStore[key] = { value: value, revision: kvRevision };
    addKVWatch('PUT', key, value);
    renderKV();
  });

  document.getElementById('kvGetBtn').addEventListener('click', function() {
    var key = document.getElementById('kvKey').value.trim();
    if (!key) return;
    if (kvStore[key]) {
      addKVWatch('GET', key, kvStore[key].value + ' (rev:' + kvStore[key].revision + ')');
    } else {
      addKVWatch('GET', key + ' → not found');
    }
  });

  document.getElementById('kvDelBtn').addEventListener('click', function() {
    var key = document.getElementById('kvKey').value.trim();
    if (!key || !kvStore[key]) return;
    delete kvStore[key];
    kvRevision++;
    addKVWatch('DEL', key);
    renderKV();
  });

  // ========== INIT ==========
  renderConsumerViz();
  renderReplay();
  renderStream();
  renderKV();
</script>
