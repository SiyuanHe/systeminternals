---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "JetStream", description: "Persistent streams, consumers, ack policies, and exactly-once delivery", href: "/nats/jetstream/", status: "live" },
  { title: "Subject-Based Routing", description: "Wildcards, token matching, and hierarchical subjects", href: "#", status: "coming" },
  { title: "Queue Groups", description: "Load balancing consumers without a broker", href: "#", status: "coming" },
  { title: "Request-Reply", description: "RPC over messaging with scatter-gather patterns", href: "#", status: "coming" },
  { title: "Leaf Nodes & Superclusters", description: "Multi-cluster topologies and edge connectivity", href: "#", status: "coming" },
  { title: "Security & Auth", description: "NKeys, JWT-based auth, and account isolation", href: "#", status: "coming" },
];
---

<BaseLayout 
  title="NATS Internals" 
  description="Interactive visualizations for understanding NATS messaging, JetStream persistence, and distributed patterns"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "NATS", href: "/nats/" }]}
>
  <section class="section-header">
    <h1>⚡ NATS Internals</h1>
    <p>
      NATS is a high-performance messaging system built for cloud-native applications. 
      Core NATS provides fire-and-forget pub/sub with subject-based routing. JetStream 
      adds persistence, streaming, and exactly-once semantics on top.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(52, 211, 153, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
