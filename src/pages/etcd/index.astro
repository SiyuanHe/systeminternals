---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "Leader Election", description: "Lease-based leader election, campaign flow, and automatic failover", href: "/etcd/leader-election/", status: "live" },
  { title: "Watch API", description: "Real-time key change notifications and revision tracking", href: "#", status: "coming" },
  { title: "Distributed Locks", description: "Fair lock queues using revision ordering", href: "#", status: "coming" },
  { title: "Leases & TTL", description: "Time-to-live leases for ephemeral keys", href: "#", status: "coming" },
  { title: "MVCC & Revisions", description: "Multi-version concurrency control in the key-value store", href: "#", status: "coming" },
  { title: "Raft Under the Hood", description: "How etcd uses Raft for consensus internally", href: "#", status: "coming" },
];
---

<BaseLayout 
  title="etcd Internals" 
  description="Interactive visualizations for understanding etcd — distributed key-value store, leader election, watches, and distributed coordination"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "etcd", href: "/etcd/" }]}
>
  <section class="section-header">
    <h1>🔑 etcd Internals</h1>
    <p>
      etcd is a distributed, reliable key-value store used as the backbone of Kubernetes and many
      distributed systems. It uses Raft consensus to replicate data across nodes, providing
      linearizable reads and writes with a powerful Watch API for real-time coordination.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(0, 212, 255, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
