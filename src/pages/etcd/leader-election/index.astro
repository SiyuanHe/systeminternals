    padding: 10px 14px;
    background: rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    font-size: 0.85rem;
  }
  .watch-prefix { color: #888; font-family: monospace; font-size: 0.75rem; }
  .watch-events {
    padding: 10px;
    min-height: 80px;
    max-height: 200px;
    overflow-y: auto;
  }
  .watch-event {
    padding: 6px 10px;
