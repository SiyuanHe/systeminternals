    font-family: monospace;
    animation: watchFlash 0.5s ease;
  }
  .watch-event.put { background: rgba(74, 222, 128, 0.1); border-left: 3px solid #4ade80; color: #4ade80; }
  .watch-event.delete { background: rgba(239, 68, 68, 0.1); border-left: 3px solid #ef4444; color: #ef4444; }
  @keyframes watchFlash {
    0% { opacity: 0; transform: translateX(-10px); }
