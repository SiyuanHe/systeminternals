  }
  .info-label { font-size: 0.8rem; color: #888; }
  .info-value { font-weight: 600; color: #fff; font-family: monospace; }

  /* Lock Section */
  .lock-section { margin-bottom: 50px; }
  .lock-controls { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px; }
  .lock-visual {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
  }
  .lock-key-header {
    font-family: monospace;
    font-weight: 600;
    color: #8b5cf6;
    margin-bottom: 16px;
    font-size: 1rem;
  }
  .lock-queue {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .lock-empty { color: #555; font-style: italic; }
  .lock-entry {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 10px;
    font-family: monospace;
    font-size: 0.85rem;
    animation: fadeIn 0.3s ease;
    transition: all 0.3s;
  }
  .lock-entry.holder {
    background: rgba(74, 222, 128, 0.1);
    border: 1px solid rgba(74, 222, 128, 0.3);
  }
  .lock-entry.waiting {
    background: rgba(96, 165, 250, 0.08);
    border: 1px solid rgba(96, 165, 250, 0.2);
  }
  .lock-icon { font-size: 1.2rem; }
  .lock-name { color: #fff; font-weight: 600; }
  .lock-rev { color: #888; }
  .lock-state { margin-left: auto; padding: 3px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
  .lock-state.holding { background: rgba(74, 222, 128, 0.2); color: #4ade80; }
  .lock-state.queued { background: rgba(96, 165, 250, 0.15); color: #60a5fa; }
  .lock-watch-info {
    font-size: 0.75rem;
    color: #888;
    margin-top: 2px;
  }

  /* Explain Cards */
  .explain-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 24px 28px;
    margin-bottom: 24px;
  }
  .explain-card.highlight-card {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.08), rgba(139, 92, 246, 0.04));
    border-color: rgba(245, 158, 11, 0.25);
  }
  .explain-card h3 { font-size: 1.1rem; color: #fff; margin-bottom: 10px; }
  .explain-card p { color: #bbb; line-height: 1.8; font-size: 0.95rem; }
  .explain-card code {
    background: rgba(255,255,255,0.08);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.85rem;
    color: #f59e0b;
  }
  .explain-card strong { color: #fff; }
  .explain-card em { color: #f59e0b; font-style: normal; font-weight: 500; }

  /* Event Log */
  .event-log-section { margin-bottom: 40px; }
  .event-log {
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 16px;
    max-height: 300px;
    overflow-y: auto;
    font-family: monospace;
    font-size: 0.8rem;
  }
  .event-log-empty { color: #555; font-style: italic; }
  .log-entry { padding: 4px 0; color: #aaa; border-bottom: 1px solid rgba(255,255,255,0.03); }
  .log-entry .log-time { color: #666; margin-right: 8px; }
  .log-entry .log-type { font-weight: 600; margin-right: 6px; }
  .log-type.election { color: #f59e0b; }
  .log-type.campaign { color: #4ade80; }
  .log-type.watch { color: #60a5fa; }
  .log-type.lock { color: #8b5cf6; }
  .log-type.lease { color: #fb923c; }

  /* Footer */
  .viz-footer {
    text-align: center;
    padding: 30px 0;
    color: #666;
    font-size: 0.85rem;
  }
  .viz-footer a { color: #60a5fa; }

  .share-buttons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 20px 0 40px;
    color: #666;
    font-size: 0.9rem;
    flex-wrap: wrap;
  }
  .share-btn {
    padding: 8px 16px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    color: #ccc;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .share-btn:hover { border-color: rgba(255,255,255,0.3); background: rgba(255,255,255,0.05); }

  @media (max-width: 768px) {
    .candidates-grid { grid-template-columns: 1fr; }
    .watch-panels { grid-template-columns: 1fr; }
    .campaign-controls { flex-direction: column; }
  }
</style>

<script is:inline>
(function() {
  // ===================== UTILITIES =====================
  var NODE_NAMES = ['Node A', 'Node B', 'Node C'];
  var NODE_COLORS = ['#4ade80', '#60a5fa', '#a78bfa'];
  var revision = 1;
  var kvData = {};

  function logEvent(type, msg) {
    var log = document.getElementById('eventLog');
    var empty = log.querySelector('.event-log-empty');
    if (empty) empty.remove();
    var entry = document.createElement('div');
    entry.className = 'log-entry';
    var now = new Date();
    var time = now.toLocaleTimeString();
    entry.innerHTML = '<span class="log-time">' + time + '</span><span class="log-type ' + type + '">[' + type.toUpperCase() + ']</span> ' + msg;
    log.prepend(entry);
    if (log.children.length > 100) log.removeChild(log.lastChild);
  }

  function updateKvDisplay() {
    var entries = document.getElementById('kvEntries');
    var keys = Object.keys(kvData);
    if (keys.length === 0) {
      entries.innerHTML = '<div class="kv-empty">Store is empty</div>';
    } else {
      entries.innerHTML = '';
      keys.forEach(function(k) {
        var d = kvData[k];
        var div = document.createElement('div');
        div.className = 'kv-entry new';
        div.innerHTML = '<span class="kv-key">' + k + '</span><span class="kv-val">' + d.value + '</span>' + (d.lease ? '<span class="kv-lease">lease:' + d.lease + '</span>' : '');
        entries.appendChild(div);
      });
    }
    document.getElementById('kvRevision').textContent = 'Revision: ' + revision;
  }

  function putKv(key, value, lease) {
    revision++;
    kvData[key] = { value: value, lease: lease || null, rev: revision };
    updateKvDisplay();
    return revision;
  }

  function deleteKv(key) {
    if (kvData[key]) {
      revision++;
      delete kvData[key];
      updateKvDisplay();
      return revision;
    }
    return null;
  }

  // ===================== CLUSTER SVG =====================
  (function drawCluster() {
    var svg = document.getElementById('clusterNodes');
    var positions = [
      { x: 100, y: 100 },
      { x: 300, y: 100 },
      { x: 500, y: 100 }
    ];
    positions.forEach(function(pos, i) {
      var g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      // Circle
      var circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('cx', pos.x);
      circle.setAttribute('cy', pos.y);
      circle.setAttribute('r', 40);
      circle.setAttribute('fill', 'rgba(255,255,255,0.05)');
      circle.setAttribute('stroke', NODE_COLORS[i]);
      circle.setAttribute('stroke-width', '2');
      circle.id = 'clusterCircle' + i;
      g.appendChild(circle);
      // Label
      var text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.setAttribute('x', pos.x);
      text.setAttribute('y', pos.y - 8);
      text.setAttribute('text-anchor', 'middle');
      text.setAttribute('fill', '#fff');
      text.setAttribute('font-size', '14');
      text.setAttribute('font-weight', '600');
      text.textContent = NODE_NAMES[i];
      g.appendChild(text);
      // Role label
      var role = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      role.setAttribute('x', pos.x);
      role.setAttribute('y', pos.y + 12);
      role.setAttribute('text-anchor', 'middle');
      role.setAttribute('fill', '#888');
      role.setAttribute('font-size', '11');
      role.id = 'clusterRole' + i;
      role.textContent = 'member';
      g.appendChild(role);
      svg.appendChild(g);
    });
    // Connection lines
    var lines = [[0,1],[1,2],[0,2]];
    lines.forEach(function(pair) {
      var line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      line.setAttribute('x1', positions[pair[0]].x);
      line.setAttribute('y1', positions[pair[0]].y);
      line.setAttribute('x2', positions[pair[1]].x);
      line.setAttribute('y2', positions[pair[1]].y);
      line.setAttribute('stroke', 'rgba(255,255,255,0.08)');
      line.setAttribute('stroke-width', '1');
      svg.insertBefore(line, svg.firstChild);
    });
  })();

  // ===================== LEASE-BASED ELECTION DEMO =====================
  (function() {
    var LEASE_TTL = 15; // seconds
    var electionState = { step: 0, running: false, leader: -1, leases: [-1, -1, -1], timers: [] };
    var steps = [
      function() {
        // All nodes create leases
        for (var i = 0; i < 3; i++) {
          electionState.leases[i] = LEASE_TTL;
          document.getElementById('leaseBar' + i).className = 'lease-bar active';
          document.getElementById('leaseBar' + i).style.width = '100%';
          document.getElementById('leaseLabel' + i).textContent = 'TTL: ' + LEASE_TTL + 's';
          document.getElementById('candidateStatus' + i).textContent = 'Lease granted (TTL=' + LEASE_TTL + 's)';
        }
        setStatusBadge('electionStatus', 'active', 'All 3 candidates create leases with TTL=' + LEASE_TTL + 's');
        logEvent('lease', 'All candidates granted leases (TTL=' + LEASE_TTL + 's)');
      },
      function() {
        // Race to create key — Node A wins (lowest latency)
        var winner = 0;
        electionState.leader = winner;
        var r = putKv('/election/leader', NODE_NAMES[winner], 'lease-' + winner);
        document.getElementById('candidateRole' + winner).textContent = '👑 Leader';
        document.getElementById('candidateRole' + winner).className = 'candidate-role leader-role';
        document.querySelector('.candidate-card[data-id="' + winner + '"]').classList.add('leader');
        document.getElementById('candidateStatus' + winner).textContent = 'Won election! Key created at rev=' + r;
        for (var i = 1; i < 3; i++) {
          document.getElementById('candidateRole' + i).textContent = '⏳ Waiting';
          document.getElementById('candidateRole' + i).className = 'candidate-role waiting-role';
          document.querySelector('.candidate-card[data-id="' + i + '"]').classList.add('waiting');
          document.getElementById('candidateStatus' + i).textContent = 'Key exists — watching for deletion';
        }
        setStatusBadge('electionStatus', 'success', NODE_NAMES[winner] + ' wins the election (first to create key at rev=' + r + ')');
        logEvent('election', NODE_NAMES[winner] + ' became leader (rev=' + r + ')');
        // Start keepalive countdown
        startLeaseCountdown();
      },
      function() {
        // Leader sends KeepAlive
        var leader = electionState.leader;
        electionState.leases[leader] = LEASE_TTL;
        document.getElementById('leaseBar' + leader).style.width = '100%';
        document.getElementById('leaseLabel' + leader).textContent = 'TTL: ' + LEASE_TTL + 's (renewed)';
        document.getElementById('candidateStatus' + leader).textContent = 'KeepAlive sent — lease renewed';
        setStatusBadge('electionStatus', 'active', 'Leader sends KeepAlive every ' + Math.floor(LEASE_TTL / 3) + 's to refresh lease');
        logEvent('lease', NODE_NAMES[leader] + ' sent KeepAlive — lease refreshed');
      },
      function() {
        // Leader dies — simulate lease expiry
        var oldLeader = electionState.leader;
        stopLeaseCountdown();
        electionState.leases[oldLeader] = 0;
        document.getElementById('leaseBar' + oldLeader).className = 'lease-bar expired';
        document.getElementById('leaseBar' + oldLeader).style.width = '0%';
        document.getElementById('leaseLabel' + oldLeader).textContent = 'EXPIRED';
        document.getElementById('candidateRole' + oldLeader).textContent = '💀 Dead';
        document.getElementById('candidateRole' + oldLeader).className = 'candidate-role';
        document.querySelector('.candidate-card[data-id="' + oldLeader + '"]').classList.remove('leader');
        document.getElementById('candidateStatus' + oldLeader).textContent = 'Crashed! Lease will expire...';
        deleteKv('/election/leader');
        setStatusBadge('electionStatus', 'error', NODE_NAMES[oldLeader] + ' crashed! Lease expired, key deleted');
        logEvent('election', NODE_NAMES[oldLeader] + ' crashed — lease expired, /election/leader deleted');
      },
      function() {
        // Node B wins new election
        var newLeader = 1;
        electionState.leader = newLeader;
        var r = putKv('/election/leader', NODE_NAMES[newLeader], 'lease-' + newLeader);
        document.getElementById('candidateRole' + newLeader).textContent = '👑 Leader';
        document.getElementById('candidateRole' + newLeader).className = 'candidate-role leader-role';
        document.querySelector('.candidate-card[data-id="' + newLeader + '"]').classList.remove('waiting');
        document.querySelector('.candidate-card[data-id="' + newLeader + '"]').classList.add('leader');
        document.getElementById('candidateStatus' + newLeader).textContent = 'New leader! Key created at rev=' + r;
        document.getElementById('candidateRole2').textContent = '⏳ Waiting';
        document.getElementById('candidateStatus2').textContent = 'Still watching for next chance';
        electionState.leases[newLeader] = LEASE_TTL;
        document.getElementById('leaseBar' + newLeader).className = 'lease-bar active';
        document.getElementById('leaseBar' + newLeader).style.width = '100%';
        document.getElementById('leaseLabel' + newLeader).textContent = 'TTL: ' + LEASE_TTL + 's';
        setStatusBadge('electionStatus', 'success', NODE_NAMES[newLeader] + ' detected deletion via watch and won new election');
        logEvent('election', NODE_NAMES[newLeader] + ' became new leader (rev=' + r + ')');
        startLeaseCountdown();
      }
    ];

    var leaseInterval = null;
    function startLeaseCountdown() {
      stopLeaseCountdown();
      leaseInterval = setInterval(function() {
        var leader = electionState.leader;
        if (leader < 0) return;
        electionState.leases[leader]--;
        var remaining = electionState.leases[leader];
        if (remaining <= 0) {
          document.getElementById('leaseBar' + leader).style.width = '0%';
          document.getElementById('leaseLabel' + leader).textContent = 'EXPIRED';
          stopLeaseCountdown();
          return;
        }
        var pct = (remaining / LEASE_TTL) * 100;
        document.getElementById('leaseBar' + leader).style.width = pct + '%';
        document.getElementById('leaseLabel' + leader).textContent = 'TTL: ' + remaining + 's';
        if (remaining <= 5) {
          document.getElementById('leaseBar' + leader).className = 'lease-bar expiring';
        }
      }, 1000);
    }
    function stopLeaseCountdown() {
      if (leaseInterval) { clearInterval(leaseInterval); leaseInterval = null; }
    }

    document.getElementById('startElectionBtn').addEventListener('click', function() {
      electionState.step = 0;
      electionState.running = true;
      document.getElementById('stepElectionBtn').disabled = false;
      steps[0]();
      electionState.step = 1;
    });

    document.getElementById('stepElectionBtn').addEventListener('click', function() {
      if (electionState.step < steps.length) {
        steps[electionState.step]();
        electionState.step++;
        if (electionState.step >= steps.length) {
          document.getElementById('stepElectionBtn').disabled = true;
        }
      }
    });

    document.getElementById('resetElectionBtn').addEventListener('click', function() {
      stopLeaseCountdown();
      electionState = { step: 0, running: false, leader: -1, leases: [-1, -1, -1], timers: [] };
      for (var i = 0; i < 3; i++) {
        document.getElementById('candidateRole' + i).textContent = 'Follower';
        document.getElementById('candidateRole' + i).className = 'candidate-role';
        document.getElementById('leaseBar' + i).className = 'lease-bar';
        document.getElementById('leaseBar' + i).style.width = '0%';
        document.getElementById('leaseLabel' + i).textContent = 'No lease';
        document.getElementById('candidateStatus' + i).textContent = 'Idle';
        document.querySelector('.candidate-card[data-id="' + i + '"]').classList.remove('leader', 'waiting');
      }
      deleteKv('/election/leader');
      document.getElementById('stepElectionBtn').disabled = true;
      setStatusBadge('electionStatus', 'idle', 'Click "Start Election Demo" to begin');
    });
  })();

  // ===================== CAMPAIGN FLOW =====================
  (function() {
    var campaignState = { leader: -1, waiters: [], leaseTimers: {} };
    var LEASE_TTL = 15;

    function updateCampaignVisual() {
      var ekVal = document.getElementById('ekValue');
      var ekRev = document.getElementById('ekRevision');
      var waitersDiv = document.getElementById('campaignWaiters');
      if (campaignState.leader >= 0) {
        ekVal.textContent = NODE_NAMES[campaignState.leader];
        ekVal.style.color = NODE_COLORS[campaignState.leader];
        ekRev.textContent = 'rev: ' + (kvData['/election/leader'] ? kvData['/election/leader'].rev : '?');
      } else {
        ekVal.innerHTML = '&#x2205; empty';
        ekVal.style.color = '#888';
        ekRev.textContent = 'rev: 0';
      }
      waitersDiv.innerHTML = '';
      campaignState.waiters.forEach(function(w) {
        var chip = document.createElement('span');
        chip.className = 'waiter-chip watching';
        chip.textContent = '👁️ ' + NODE_NAMES[w] + ' watching...';
        waitersDiv.appendChild(chip);
      });
    }

    function updateButtons() {
      for (var i = 0; i < 3; i++) {
        var isLeader = campaignState.leader === i;
        var isWaiting = campaignState.waiters.indexOf(i) >= 0;
        var campaignBtn = document.querySelector('[data-action="campaign"][data-node="' + i + '"]');
        var resignBtn = document.querySelector('[data-action="resign"][data-node="' + i + '"]');
        var proclaimBtn = document.querySelector('[data-action="proclaim"][data-node="' + i + '"]');
        campaignBtn.disabled = isLeader || isWaiting;
        resignBtn.disabled = !isLeader;
        proclaimBtn.disabled = !isLeader;
      }
      document.getElementById('killLeaderBtn').disabled = campaignState.leader < 0;
    }

    document.querySelectorAll('[data-action="campaign"]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var nodeId = parseInt(btn.getAttribute('data-node'));
        if (campaignState.leader < 0) {
          // Win election
          campaignState.leader = nodeId;
          var r = putKv('/election/leader', NODE_NAMES[nodeId], 'lease-c' + nodeId);
          setStatusBadge('campaignStatus', 'success', NODE_NAMES[nodeId] + ' won the campaign (rev=' + r + ')');
          logEvent('campaign', NODE_NAMES[nodeId] + ' campaigned and won leadership');
        } else {
          // Wait
          if (campaignState.waiters.indexOf(nodeId) < 0) {
            campaignState.waiters.push(nodeId);
          }
          setStatusBadge('campaignStatus', 'active', NODE_NAMES[nodeId] + ' is waiting (watching /election/leader)');
          logEvent('campaign', NODE_NAMES[nodeId] + ' campaigned but key exists — watching');
        }
        updateCampaignVisual();
        updateButtons();
      });
    });

    document.querySelectorAll('[data-action="resign"]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var nodeId = parseInt(btn.getAttribute('data-node'));
        if (campaignState.leader !== nodeId) return;
        var oldLeader = campaignState.leader;
        deleteKv('/election/leader');
        campaignState.leader = -1;
        logEvent('campaign', NODE_NAMES[oldLeader] + ' resigned');
        // Next waiter wins
        if (campaignState.waiters.length > 0) {
          var next = campaignState.waiters.shift();
          campaignState.leader = next;
          var r = putKv('/election/leader', NODE_NAMES[next], 'lease-c' + next);
          setStatusBadge('campaignStatus', 'success', NODE_NAMES[oldLeader] + ' resigned. ' + NODE_NAMES[next] + ' became leader (rev=' + r + ')');
          logEvent('campaign', NODE_NAMES[next] + ' detected resignation, became new leader');
        } else {
          setStatusBadge('campaignStatus', 'idle', NODE_NAMES[oldLeader] + ' resigned. No waiters — election key is empty');
        }
        updateCampaignVisual();
        updateButtons();
      });
    });

    document.querySelectorAll('[data-action="proclaim"]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var nodeId = parseInt(btn.getAttribute('data-node'));
        if (campaignState.leader !== nodeId) return;
        var msgs = ['config-v2', 'scale-up', 'maintenance-mode', 'ready'];
        var msg = msgs[Math.floor(Math.random() * msgs.length)];
        putKv('/election/leader', NODE_NAMES[nodeId] + ':' + msg, 'lease-c' + nodeId);
        setStatusBadge('campaignStatus', 'active', NODE_NAMES[nodeId] + ' proclaimed: "' + msg + '"');
        logEvent('campaign', NODE_NAMES[nodeId] + ' proclaimed: ' + msg);
        updateCampaignVisual();
      });
    });

    document.getElementById('killLeaderBtn').addEventListener('click', function() {
      if (campaignState.leader < 0) return;
      var dead = campaignState.leader;
      deleteKv('/election/leader');
      campaignState.leader = -1;
      logEvent('election', NODE_NAMES[dead] + ' was killed! Lease expired');
      if (campaignState.waiters.length > 0) {
        var next = campaignState.waiters.shift();
        campaignState.leader = next;
        var r = putKv('/election/leader', NODE_NAMES[next], 'lease-c' + next);
        setStatusBadge('campaignStatus', 'success', NODE_NAMES[dead] + ' killed! ' + NODE_NAMES[next] + ' took over (automatic failover, rev=' + r + ')');
        logEvent('election', NODE_NAMES[next] + ' became leader after failover');
      } else {
        setStatusBadge('campaignStatus', 'error', NODE_NAMES[dead] + ' killed! No waiters — cluster has no leader');
      }
      updateCampaignVisual();
      updateButtons();
    });

    updateButtons();
    updateCampaignVisual();
  })();

  // ===================== WATCH DEMO =====================
  (function() {
    var watchRevision = 1;
    var compactRevision = 0;

    function addWatchEvent(panelId, type, key, value, rev) {
      var panel = document.getElementById(panelId);
      var div = document.createElement('div');
      div.className = 'watch-event ' + type;
      if (type === 'put') {
        div.textContent = 'PUT ' + key + ' = ' + value + ' (rev:' + rev + ')';
      } else {
        div.textContent = 'DELETE ' + key + ' (rev:' + rev + ')';
      }
      panel.prepend(div);
      if (panel.children.length > 20) panel.removeChild(panel.lastChild);
    }

    function notifyWatchers(type, key, value, rev) {
      // Small random delay per watcher for realism
      ['watchEvents1', 'watchEvents2', 'watchEvents3'].forEach(function(id, idx) {
        setTimeout(function() {
          addWatchEvent(id, type, key, value, rev);
        }, 50 + idx * 120);
      });
      document.getElementById('watchRevision').textContent = rev;
    }

    document.getElementById('watchPutBtn').addEventListener('click', function() {
      var key = document.getElementById('watchKeyInput').value || '/config/db';
      var value = document.getElementById('watchValueInput').value || 'default';
      var r = putKv(key, value, null);
      watchRevision = r;
      notifyWatchers('put', key, value, r);
      logEvent('watch', 'PUT ' + key + ' = ' + value + ' (rev:' + r + ')');
    });

    document.getElementById('watchDeleteBtn').addEventListener('click', function() {
      var key = document.getElementById('watchKeyInput').value || '/config/db';
      var r = deleteKv(key);
      if (r) {
        watchRevision = r;
        notifyWatchers('delete', key, '', r);
        logEvent('watch', 'DELETE ' + key + ' (rev:' + r + ')');
      } else {
        logEvent('watch', 'Key not found: ' + key);
      }
    });

    document.getElementById('compactBtn').addEventListener('click', function() {
      compactRevision = watchRevision;
      document.getElementById('compactRevision').textContent = compactRevision;
      logEvent('watch', 'Compacted to revision ' + compactRevision + ' — old revisions reclaimed');
    });
  })();

  // ===================== DISTRIBUTED LOCKS =====================
  (function() {
    var lockQueue = [];
    var lockRevCounter = 100;
    var PROCESS_NAMES = ['Process-A', 'Process-B', 'Process-C'];
    var PROCESS_COLORS = ['#4ade80', '#60a5fa', '#a78bfa'];

    function renderLockQueue() {
      var container = document.getElementById('lockQueue');
      if (lockQueue.length === 0) {
        container.innerHTML = '<div class="lock-empty">No lock contention — click Acquire to start</div>';
        return;
      }
      container.innerHTML = '';
      lockQueue.forEach(function(entry, idx) {
        var div = document.createElement('div');
        div.className = 'lock-entry ' + (idx === 0 ? 'holder' : 'waiting');
        var watchInfo = '';
        if (idx > 0) {
          watchInfo = '<div class="lock-watch-info">👁️ watching ' + PROCESS_NAMES[lockQueue[idx - 1].processId] + ' (rev:' + lockQueue[idx - 1].rev + ')</div>';
        }
        div.innerHTML =
          '<span class="lock-icon">' + (idx === 0 ? '🔒' : '⏳') + '</span>' +
          '<div>' +
            '<span class="lock-name" style="color:' + PROCESS_COLORS[entry.processId] + '">' + PROCESS_NAMES[entry.processId] + '</span>' +
            '<span class="lock-rev"> /locks/mylock/' + entry.key + ' (rev:' + entry.rev + ')</span>' +
            watchInfo +
          '</div>' +
          '<span class="lock-state ' + (idx === 0 ? 'holding' : 'queued') + '">' + (idx === 0 ? 'HOLDING' : 'QUEUED') + '</span>';
        container.appendChild(div);
      });
    }

    document.getElementById('lockAcquireBtn').addEventListener('click', function() {
      lockQueue = [];
      // 3 processes try to acquire
      for (var i = 0; i < 3; i++) {
        lockRevCounter++;
        lockQueue.push({ processId: i, key: 'proc-' + String.fromCharCode(97 + i), rev: lockRevCounter });
        logEvent('lock', PROCESS_NAMES[i] + ' created /locks/mylock/proc-' + String.fromCharCode(97 + i) + ' (rev:' + lockRevCounter + ')');
      }
      // Sort by revision (first wins)
      lockQueue.sort(function(a, b) { return a.rev - b.rev; });
      logEvent('lock', PROCESS_NAMES[lockQueue[0].processId] + ' holds the lock (smallest revision)');
      logEvent('lock', 'Others watch the key just before theirs (no thundering herd)');
      renderLockQueue();
      document.getElementById('lockReleaseBtn').disabled = false;
      setStatusBadge('lockStatus', 'success', PROCESS_NAMES[lockQueue[0].processId] + ' holds lock. Others wait in revision order.');
    });

    document.getElementById('lockReleaseBtn').addEventListener('click', function() {
      if (lockQueue.length === 0) return;
      var released = lockQueue.shift();
      logEvent('lock', PROCESS_NAMES[released.processId] + ' released lock (deleted key)');
      if (lockQueue.length > 0) {
        logEvent('lock', PROCESS_NAMES[lockQueue[0].processId] + ' detected deletion, now holds the lock');
        setStatusBadge('lockStatus', 'success', PROCESS_NAMES[lockQueue[0].processId] + ' now holds the lock');
      } else {
        setStatusBadge('lockStatus', 'idle', 'Lock released — no more waiters');
        document.getElementById('lockReleaseBtn').disabled = true;
      }
      renderLockQueue();
    });

    document.getElementById('lockResetBtn').addEventListener('click', function() {
      lockQueue = [];
      renderLockQueue();
      document.getElementById('lockReleaseBtn').disabled = true;
      setStatusBadge('lockStatus', 'idle', 'Click "Acquire Lock" to see the queue mechanism');
    });
  })();

  // ===================== HELPERS =====================
  function setStatusBadge(containerId, type, text) {
    var container = document.getElementById(containerId);
    var badge = container.querySelector('.status-badge');
    var statusText = container.querySelector('.status-text');
    badge.className = 'status-badge ' + type;
    badge.textContent = type === 'idle' ? 'Ready' : type === 'active' ? 'Active' : type === 'success' ? 'Success' : 'Error';
    statusText.textContent = text;
  }
})();
</script>
</BaseLayout>
