---
import BaseLayout from '../layouts/BaseLayout.astro';

const consensusTopics = [
  { title: "Raft Consensus", description: "Leader election, log replication, and safety — the interactive way", href: "/raft/", status: "live" },
  { title: "Paxos vs Raft", description: "Split-screen comparison — same scenarios, different protocols", href: "/consensus/paxos-vs-raft/", status: "live" },
];

const kafkaTopics = [
  { title: "Partitions & Offsets", description: "The anatomy of a Kafka topic — and how to choose partition counts", href: "/kafka/partitions/", status: "live" },
  { title: "Consumer Groups & Rebalancing", description: "Assignment strategies, cooperative rebalancing, and rebalance storms", href: "/kafka/consumer-groups/", status: "live" },
  { title: "ISR & Replication", description: "In-sync replicas and durability guarantees", href: "/kafka/isr-replication/", status: "live" },
  { title: "Log Compaction", description: "Keeping the latest value per key", href: "/kafka/log-compaction/", status: "live" },
  { title: "KRaft", description: "Replacing ZooKeeper with Raft-based metadata management", href: "/kafka/kraft/", status: "live" },
];

const redisTopics = [
  { title: "Cluster Hashing & Failover", description: "Hash slots, MOVED redirections, and automatic failover", href: "/redis/cluster-hashing/", status: "live" },
  { title: "Persistence: RDB & AOF", description: "Snapshots vs append-only file — tradeoffs and tuning", href: "/redis/persistence/", status: "live" },
];

const postgresqlTopics = [
  { title: "MVCC & Vacuum", description: "Tuple versioning, dead tuples, bloat, autovacuum, and txn ID wraparound", href: "/postgresql/mvcc-vacuum/", status: "live" },
  { title: "WAL & Replication", description: "Write-ahead log, streaming replication, and logical replication", href: "/postgresql/wal-replication/", status: "live" },
  { title: "Query Planner", description: "How PostgreSQL decides to scan, join, and sort", href: "/postgresql/query-planner/", status: "live" },
];

const etcdTopics = [
  { title: "Leader Election", description: "Leases, campaigns, watches, and distributed locks", href: "/etcd/leader-election/", status: "live" },
  { title: "Watch & Revisions", description: "Event streaming, compaction, and consistency guarantees", href: "#", status: "coming" },
];

const cassandraTopics = [
  { title: "Consistent Hashing & Gossip", description: "Token ring, vnodes, gossip protocol, and phi accrual failure detection", href: "/cassandra/consistent-hashing/", status: "live" },
  { title: "Read/Write Path", description: "Coordinators, consistency levels, and read repair", href: "#", status: "coming" },
  { title: "Compaction Strategies", description: "STCS, LCS, TWCS — when to use each", href: "/cassandra/compaction/", status: "live" },
];

const zookeeperTopics = [
  { title: "ZNodes & Watches", description: "Tree hierarchy, ephemeral nodes, watches, leader election recipes", href: "/zookeeper/znodes-watches/", status: "live" },
  { title: "Sessions & Quorums", description: "Client sessions, ZAB protocol, and quorum mechanics", href: "#", status: "coming" },
];

const elasticsearchTopics = [
  { title: "Inverted Index & Search", description: "Analyzers, BM25 scoring, segments, and distributed search", href: "/elasticsearch/inverted-index/", status: "live" },
  { title: "Cluster Management", description: "Sharding, rebalancing, and split-brain prevention", href: "#", status: "coming" },
];

const kubernetesTopics = [
  { title: "Pod Scheduling", description: "Filtering, scoring, preemption, and topology spread", href: "/kubernetes/scheduling/", status: "live" },
  { title: "Networking & Services", description: "ClusterIP, NodePort, Ingress, and kube-proxy modes", href: "/kubernetes/networking/", status: "live" },
];

const mongodbTopics = [
  { title: "Sharding & Chunks", description: "How data distributes across shards — and how to avoid hotspots", href: "/mongodb/sharding/", status: "live" },
  { title: "WiredTiger Storage", description: "The engine behind MongoDB's performance", href: "/mongodb/wiredtiger/", status: "live" },
  { title: "Replica Set Elections", description: "Leader election and failover mechanics", href: "/mongodb/replica-set-elections/", status: "live" },
];

const tidbTopics = [
  { title: "Write & Read Path", description: "End-to-end journey of a SQL write and read through all layers", href: "/tidb/write-read-path/", status: "live" },
  { title: "Raft Region Size", description: "The invisible lever for performance & recovery", href: "/tidb/raft-region-size/", status: "live" },
  { title: "LSM-Tree & Compaction", description: "How TiKV stores data and manages write amplification", href: "/tidb/lsm-tree/", status: "live" },
  { title: "Distributed Transactions", description: "Percolator 2PC: prewrite, commit, and lock resolution", href: "/tidb/distributed-transactions/", status: "live" },
  { title: "Hot Regions & Load Balancing", description: "PD scheduler: splitting, scattering, and rebalancing", href: "#", status: "coming" },
  { title: "TiFlash HTAP", description: "Row store vs column store, when to use each", href: "#", status: "coming" },
  { title: "Coprocessor Push-Down", description: "Moving computation to storage nodes", href: "#", status: "coming" },
  { title: "GC & MVCC", description: "Multi-version concurrency and garbage collection", href: "#", status: "coming" },
  { title: "Backup & PITR", description: "Full backups, incremental, and point-in-time recovery", href: "#", status: "coming" },
];

const dynamodbTopics = [
  { title: "Partitioning & Adaptive Capacity", description: "Hash partitioning, auto-split, burst capacity, GSI vs LSI", href: "/dynamodb/partitioning/", status: "live" },
  { title: "DynamoDB Streams", description: "Change data capture and event-driven architectures", href: "#", status: "coming" },
];

const grpcTopics = [
  { title: "gRPC Internals", description: "HTTP/2 multiplexing, Protobuf encoding, streaming, deadlines", href: "/grpc/internals/", status: "live" },
  { title: "Load Balancing", description: "Client-side vs proxy LB, xDS, service mesh integration", href: "#", status: "coming" },
];

const rocksdbTopics = [
  { title: "Compaction Strategies", description: "Leveled, Universal, FIFO — amplification tradeoffs, bloom filters, block cache", href: "/rocksdb/compaction/", status: "live" },
  { title: "Write Path Deep Dive", description: "WAL, MemTable, flush triggers, and write stalls", href: "#", status: "coming" },
];

const dockerTopics = [
  { title: "Container Internals", description: "Namespaces, cgroups, overlay FS, and container lifecycle", href: "/docker/container-internals/", status: "live" },
  { title: "Image Building", description: "Layers, caching, multi-stage builds, and BuildKit", href: "#", status: "coming" },
];

const vitessTopics = [
  { title: "Sharding", description: "VSchema, vindexes, query routing, and zero-downtime resharding", href: "/vitess/sharding/", status: "live" },
  { title: "VReplication", description: "Stream-based data movement and materialized views", href: "#", status: "coming" },
];

const envoyTopics = [
  { title: "Proxy Internals", description: "Request flow, load balancing, circuit breaking, xDS, and health checking", href: "/envoy/proxy-internals/", status: "live" },
  { title: "TLS & mTLS", description: "Certificate management, SDS, and mutual TLS in service mesh", href: "#", status: "coming" },
];

const clickhouseTopics = [
  { title: "MergeTree Engine", description: "Parts, merges, sparse indexes, and column-oriented storage", href: "/clickhouse/mergetree/", status: "live" },
  { title: "Distributed Tables", description: "Sharding, replication, and cross-shard queries", href: "#", status: "coming" },
  { title: "Materialized Views", description: "Real-time aggregation pipelines and projection chains", href: "#", status: "coming" },
];

const cockroachdbTopics = [
  { title: "Architecture", description: "SQL → Distribution → Replication → Storage, ranges, leases, multi-region", href: "/cockroachdb/architecture/", status: "live" },
  { title: "Multi-Region Patterns", description: "Regional, global, and regional-by-row table configurations", href: "#", status: "coming" },
];

const natsTopics = [
  { title: "JetStream", description: "Persistent streams, consumers, replay policies, KV store", href: "/nats/jetstream/", status: "live" },
  { title: "Clustering & Super-Clusters", description: "Route, gateway, and leaf node topologies", href: "#", status: "coming" },
];

const prometheusTopics = [
  { title: "TSDB Internals", description: "Head block, WAL, chunks, Gorilla compression, inverted index, and compaction", href: "/prometheus/tsdb/", status: "live" },
  { title: "PromQL Evaluation", description: "How range queries scan blocks, series, and samples", href: "#", status: "coming" },
];

const sparkTopics = [
  { title: "DAG Execution", description: "Stages, tasks, and the execution plan — plus tuning for performance", href: "/spark/dag-execution/", status: "live" },
  { title: "Shuffle Internals", description: "The most expensive operation in Spark", href: "/spark/shuffle/", status: "live" },
];
---

<BaseLayout title="Interactive Distributed Systems Visualizations">
  <section class="hero">
    <h1>Feel the tradeoffs.<br>Don't just read about them.</h1>
    <p class="hero-subtitle">
      Interactive visualizations that let you <em>play</em> with distributed systems concepts.
      Drag sliders, click buttons, watch data flow — and finally understand why things break.
    </p>
  </section>

  <section class="topics-section">
    <h2>
      <span class="section-icon">🗳️</span>
      Consensus Algorithms
    </h2>
    <div class="topics-grid">
      {consensusTopics.map(topic => (
        <a href={topic.href} class={`topic-card ${topic.status}`}>
          <div class="topic-status">
            {topic.status === "live" ? "✦ Live" : "Coming soon"}
          </div>
          <h3>{topic.title}</h3>
          <p>{topic.description}</p>
        </a>
      ))}
    </div>
  </section>

