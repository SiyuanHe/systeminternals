---
import BaseLayout from '../layouts/BaseLayout.astro';

const tidbTopics = [
  { title: "Raft Region Size", description: "The invisible lever for performance & recovery", href: "/tidb/raft-region-size/", status: "live" },
  { title: "LSM-Tree & Compaction", description: "How TiKV stores data and manages write amplification", href: "/tidb/lsm-tree/", status: "live" },
  { title: "Distributed Transactions", description: "Percolate 2PC: prewrite, commit, and lock resolution", href: "#", status: "coming" },
  { title: "Hot Regions & Load Balancing", description: "PD scheduler: splitting, scattering, and rebalancing", href: "#", status: "coming" },
  { title: "TiFlash HTAP", description: "Row store vs column store, when to use each", href: "#", status: "coming" },
  { title: "Coprocessor Push-Down", description: "Moving computation to storage nodes", href: "#", status: "coming" },
  { title: "GC & MVCC", description: "Multi-version concurrency and garbage collection", href: "#", status: "coming" },
  { title: "Backup & PITR", description: "Full backups, incremental, and point-in-time recovery", href: "#", status: "coming" },
];

const mongodbTopics = [
  { title: "Sharding & Chunks", description: "How data distributes across shards", href: "#", status: "coming" },
  { title: "WiredTiger Storage", description: "The engine behind MongoDB's performance", href: "#", status: "coming" },
  { title: "Replica Set Elections", description: "Leader election and failover mechanics", href: "#", status: "coming" },
];

const kafkaTopics = [
  { title: "Partitions & Offsets", description: "The anatomy of a Kafka topic", href: "#", status: "coming" },
  { title: "ISR & Replication", description: "In-sync replicas and durability guarantees", href: "#", status: "coming" },
  { title: "Log Compaction", description: "Keeping the latest value per key", href: "#", status: "coming" },
];

const sparkTopics = [
  { title: "DAG Execution", description: "Stages, tasks, and the execution plan", href: "#", status: "coming" },
  { title: "Shuffle Internals", description: "The most expensive operation in Spark", href: "#", status: "coming" },
];
---

<BaseLayout title="Interactive Distributed Systems Visualizations">
  <section class="hero">
    <h1>Feel the tradeoffs.<br>Don't just read about them.</h1>
    <p class="hero-subtitle">
      Interactive visualizations that let you <em>play</em> with distributed systems concepts.
      Drag sliders, click buttons, watch data flow — and finally understand why things break.
    </p>
  </section>

  <section class="topics-section">
    <h2>
      <span class="section-icon">🔷</span>
      TiDB / Database Internals
    </h2>
    <div class="topics-grid">
      {tidbTopics.map(topic => (
        <a href={topic.href} class={`topic-card ${topic.status}`}>
          <div class="topic-status">
            {topic.status === "live" ? "✦ Live" : "Coming soon"}
          </div>
          <h3>{topic.title}</h3>
          <p>{topic.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="topics-section">
    <h2>
      <span class="section-icon">🍃</span>
      MongoDB
    </h2>
    <div class="topics-grid">
      {mongodbTopics.map(topic => (
        <a href={topic.href} class={`topic-card ${topic.status}`}>
          <div class="topic-status">Coming soon</div>
          <h3>{topic.title}</h3>
          <p>{topic.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="topics-section">
    <h2>
      <span class="section-icon">📨</span>
      Apache Kafka
    </h2>
    <div class="topics-grid">
      {kafkaTopics.map(topic => (
        <a href={topic.href} class={`topic-card ${topic.status}`}>
          <div class="topic-status">Coming soon</div>
          <h3>{topic.title}</h3>
          <p>{topic.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="topics-section">
    <h2>
      <span class="section-icon">⚡</span>
      Apache Spark
    </h2>
    <div class="topics-grid">
      {sparkTopics.map(topic => (
        <a href={topic.href} class={`topic-card ${topic.status}`}>
          <div class="topic-status">Coming soon</div>
          <h3>{topic.title}</h3>
          <p>{topic.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 60px 20px 80px;
  }

  .hero h1 {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 20px;
    background: linear-gradient(135deg, #00d4ff 0%, #7c3aed 50%, #f472b6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: #888;
    max-width: 650px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .hero-subtitle em {
    color: #00d4ff;
    font-style: normal;
    font-weight: 500;
  }

  .topics-section {
    margin-bottom: 60px;
  }

  .topics-section h2 {
    font-size: 1.5rem;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    color: #fff;
  }

  .section-icon {
    font-size: 1.3rem;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(0, 212, 255, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 1.1rem;
    }

    .topics-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
