---
import BaseLayout from '../../layouts/BaseLayout.astro';

const topics = [
  { title: "DNS Resolution", description: "How a domain name becomes an IP address, step by step", href: "/dns/resolution/", status: "live" },
  { title: "DNS Record Types", description: "A, AAAA, CNAME, MX, NS, TXT, SRV, SOA — when to use each", href: "#", status: "coming" },
  { title: "DNS Caching & TTL", description: "How caching works at every layer and TTL mechanics", href: "#", status: "coming" },
  { title: "DNSSEC", description: "Chain of trust, RRSIG, DNSKEY, and DS records", href: "#", status: "coming" },
  { title: "DNS over HTTPS & TLS", description: "DoH and DoT: encrypted DNS for privacy", href: "#", status: "coming" },
  { title: "Anycast Routing", description: "How root servers and CDN DNS handle global traffic", href: "#", status: "coming" },
  { title: "DNS Attacks & Defenses", description: "Cache poisoning, amplification, and mitigations", href: "#", status: "coming" },
  { title: "mDNS & Service Discovery", description: "Multicast DNS and DNS-SD for local networks", href: "#", status: "coming" },
];
---

<BaseLayout 
  title="DNS Internals" 
  description="Interactive visualizations for understanding DNS resolution, caching, security, and infrastructure"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "DNS", href: "/dns/" }]}
>
  <section class="section-header">
    <h1>🌐 DNS Internals</h1>
    <p>
      The Domain Name System is the internet's phonebook — translating human-readable names into IP addresses.
      These visualizations explore the hierarchy, resolution process, caching, security, and infrastructure
      that make DNS work at global scale.
    </p>
  </section>

  <div class="topics-grid">
    {topics.map(topic => (
      <a href={topic.href} class={`topic-card ${topic.status}`}>
        <div class="topic-status">
          {topic.status === "live" ? "✦ Live" : "Coming soon"}
        </div>
        <h3>{topic.title}</h3>
        <p>{topic.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 40px;
  }

  .section-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #888;
    max-width: 700px;
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s;
    display: block;
    color: inherit;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(0, 212, 255, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .topic-card.coming {
    opacity: 0.5;
    cursor: default;
  }

  .topic-card.coming:hover {
    transform: none;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .topic-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    color: #666;
  }

  .topic-card.live .topic-status {
    color: #22c55e;
  }

  .topic-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }

  .topic-card p {
    font-size: 0.95rem;
    color: #888;
    line-height: 1.5;
  }
</style>
