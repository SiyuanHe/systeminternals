---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="DNS Recursive Resolution" 
  description="Interactive visualization of DNS recursive resolution: root servers, TLD servers, authoritative servers, caching, TTL, and DNSSEC"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "DNS", href: "/dns/" },
    { label: "Recursive Resolution", href: "/dns/recursive-resolution/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🌍 Recursive DNS Resolution</h1>
      <p class="subtitle">What Happens Between Typing a URL and Getting an IP Address</p>
    </header>

    <section class="overview-section">
      <div class="overview-card">
        <p>
          When you type <code>api.example.com</code>, your browser doesn't magically know the IP.
          A <strong>recursive resolver</strong> walks the DNS hierarchy: <em>Root</em> → <em>.com TLD</em>
          → <em>example.com authoritative</em> → answer. Each response is <strong>cached</strong>
          based on TTL, so most lookups resolve in 1-2 hops, not 4.
        </p>
      </div>
    </section>

    <!-- Interactive Resolution -->
    <section class="resolve-section">
      <h2>🔍 Resolve a Domain</h2>
      <p class="section-desc">Enter a domain and step through the resolution process. Watch packets fly between servers.</p>

      <div class="resolve-input">
        <input type="text" id="resolveInput" placeholder="api.example.com" value="api.example.com" maxlength="60">
        <button id="resolveBtn" class="action-btn primary-btn">🔍 Resolve</button>
        <button id="resolveStepBtn" class="action-btn secondary-btn" disabled>⏭ Next Step</button>
        <button id="resolveResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="resolve-viz" id="resolveViz">
        <div class="resolve-col client-col">
          <div class="resolve-server" id="rClient">
            <div class="rs-icon">💻</div>
            <div class="rs-name">Your Browser</div>
            <div class="rs-detail" id="rClientDetail">Waiting...</div>
          </div>
        </div>

        <div class="resolve-col resolver-col">
          <div class="resolve-server" id="rResolver">
            <div class="rs-icon">🔄</div>
            <div class="rs-name">Recursive Resolver</div>
            <div class="rs-detail" id="rResolverDetail">8.8.8.8</div>
            <div class="rs-cache" id="rResolverCache">Cache: empty</div>
          </div>
        </div>

        <div class="resolve-col servers-col">
          <div class="resolve-server" id="rRoot">
            <div class="rs-icon">🌐</div>
            <div class="rs-name">Root Server</div>
            <div class="rs-detail">a.root-servers.net</div>
          </div>
          <div class="resolve-server" id="rTLD">
            <div class="rs-icon">📁</div>
            <div class="rs-name">TLD Server</div>
            <div class="rs-detail" id="rTLDDetail">.com</div>
          </div>
          <div class="resolve-server" id="rAuth">
            <div class="rs-icon">📋</div>
            <div class="rs-name">Authoritative</div>
            <div class="rs-detail" id="rAuthDetail">ns1.example.com</div>
          </div>
        </div>
      </div>

      <div class="resolve-timeline" id="resolveTimeline"></div>

      <div class="resolve-result" id="resolveResult"></div>
    </section>

    <!-- Caching & TTL -->
    <section class="cache-section">
      <h2>⏰ Caching & TTL</h2>
      <p class="section-desc">Adjust TTL and see how caching reduces lookup hops over time.</p>

      <div class="ttl-controls">
        <div class="slider-group">
          <label>TTL: <strong id="ttlLabel">300</strong> seconds</label>
          <input type="range" id="ttlSlider" min="1" max="86400" value="300" step="1">
        </div>
        <button id="ttlLookupBtn" class="action-btn primary-btn">🔍 Lookup</button>
        <button id="ttlExpireBtn" class="action-btn danger-btn">⏰ Expire Cache</button>
      </div>

      <div class="ttl-viz">
        <div class="ttl-cache" id="ttlCache">
          <div class="ttl-cache-label">Resolver Cache</div>
          <div class="ttl-entries" id="ttlEntries">
            <div class="ttl-empty">Cache empty — do a lookup!</div>
          </div>
        </div>
        <div class="ttl-stats">
          <div class="ttl-stat">
            <div class="ttl-stat-label">Cache Hits</div>
            <div class="ttl-stat-value" id="ttlHits">0</div>
          </div>
          <div class="ttl-stat">
            <div class="ttl-stat-label">Cache Misses</div>
            <div class="ttl-stat-value" id="ttlMisses">0</div>
          </div>
          <div class="ttl-stat">
            <div class="ttl-stat-label">Avg Hops</div>
            <div class="ttl-stat-value" id="ttlAvgHops">—</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Record Types -->
    <section class="records-section">
      <h2>📋 DNS Record Types</h2>
      <div class="records-grid">
        <div class="record-card">
          <div class="record-type">A</div>
          <div class="record-desc">Maps domain → IPv4 address</div>
          <code>example.com → 93.184.216.34</code>
        </div>
        <div class="record-card">
          <div class="record-type">AAAA</div>
          <div class="record-desc">Maps domain → IPv6 address</div>
          <code>example.com → 2606:2800:220:1:...</code>
        </div>
        <div class="record-card">
          <div class="record-type">CNAME</div>
          <div class="record-desc">Alias pointing to another domain</div>
          <code>www.example.com → example.com</code>
        </div>
        <div class="record-card">
          <div class="record-type">MX</div>
          <div class="record-desc">Mail server for the domain</div>
          <code>example.com → mail.example.com (pri: 10)</code>
        </div>
        <div class="record-card">
          <div class="record-type">NS</div>
          <div class="record-desc">Nameserver for the zone</div>
          <code>example.com → ns1.example.com</code>
        </div>
        <div class="record-card">
          <div class="record-type">TXT</div>
          <div class="record-desc">Arbitrary text (SPF, DKIM, verification)</div>
          <code>"v=spf1 include:_spf.google.com ~all"</code>
        </div>
      </div>
    </section>

    <!-- Explanations -->
    <section class="explain-section">
      <div class="explain-grid">
        <div class="explain-card highlight-card">
          <h3>💡 Why Resolution Feels Instant</h3>
          <p>
            Your OS, browser, and resolver all cache DNS. A typical <code>.com</code> TLD response
            has TTL of <strong>48 hours</strong>. After the first lookup, subsequent domains under
            <code>.com</code> skip the root entirely. Most real-world lookups: 0-1 hops (cache hit).
          </p>
        </div>
        <div class="explain-card">
          <h3>🔒 DNSSEC</h3>
          <p>
            DNS responses are unsigned by default — vulnerable to spoofing. DNSSEC adds cryptographic
            signatures to DNS records. The chain of trust runs from root → TLD → authoritative.
            Check with <code>dig +dnssec example.com</code>.
          </p>
        </div>
        <div class="explain-card">
          <h3>⚡ DNS over HTTPS (DoH)</h3>
          <p>
            Traditional DNS is plaintext UDP — your ISP sees every domain you query.
            DoH wraps DNS in HTTPS (port 443), encrypting queries. Used by Firefox (Cloudflare)
            and Chrome (system resolver). Tradeoff: harder to filter/monitor at network level.
          </p>
        </div>
        <div class="explain-card">
          <h3>🌐 Anycast & Resilience</h3>
          <p>
            Root servers use <strong>anycast</strong> — the same IP is advertised from hundreds
            of locations worldwide. Your query goes to the nearest instance. There are 13 root
            server addresses but 1000+ physical servers globally.
          </p>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://www.rfc-editor.org/rfc/rfc1035" target="_blank">RFC 1035</a> and <a href="https://www.cloudflare.com/learning/dns/what-is-dns/" target="_blank">Cloudflare DNS Learning</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20DNS%20Resolution%20Visualizer&url=https://systeminternals.dev/dns/recursive-resolution/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/dns/recursive-resolution/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/dns/recursive-resolution/&t=Interactive%20DNS%20Resolution%20Visualizer" target="_blank" class="share-btn">🟧 HN</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container { max-width: 1100px; margin: 0 auto; }
  .viz-header { text-align: center; margin-bottom: 40px; }
  .viz-header h1 { font-size: 2.5rem; margin-bottom: 10px; background: linear-gradient(90deg, #34d399, #60a5fa, #fbbf24); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .subtitle { color: #888; font-size: 1.1rem; }
  h2 { font-size: 1.5rem; color: #fff; margin-bottom: 12px; }
  .section-desc { color: #888; margin-bottom: 24px; }

  .overview-section { margin-bottom: 50px; }
  .overview-card { background: linear-gradient(135deg, rgba(52,211,153,0.1), rgba(96,165,250,0.05)); border: 1px solid rgba(52,211,153,0.3); border-radius: 16px; padding: 24px 28px; font-size: 1.05rem; line-height: 1.8; color: #ccc; }
  .overview-card strong { color: #fff; }
  .overview-card em { color: #34d399; font-style: normal; font-weight: 500; }
  .overview-card code { background: rgba(0,0,0,0.3); padding: 2px 6px; border-radius: 4px; font-size: 0.9rem; color: #34d399; }

  .action-btn { padding: 10px 20px; border: none; border-radius: 10px; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .action-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .primary-btn { background: linear-gradient(135deg, #34d399, #059669); color: white; }
  .primary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(52,211,153,0.4); }
  .secondary-btn { background: linear-gradient(135deg, #60a5fa, #3b82f6); color: white; }
  .secondary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(96,165,250,0.4); }
  .danger-btn { background: linear-gradient(135deg, #f87171, #ef4444); color: white; }
  .danger-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(239,68,68,0.4); }
  .reset-btn { background: rgba(255,255,255,0.1); color: #aaa; }
  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }
  input[type="range"] { -webkit-appearance: none; height: 8px; background: rgba(255,255,255,0.15); border-radius: 4px; cursor: pointer; width: 100%; max-width: 400px; }
  input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 20px; height: 20px; border-radius: 50%; background: #34d399; cursor: pointer; }

  /* Resolve */
  .resolve-section { margin-bottom: 50px; }
  .resolve-input { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px; align-items: center; }
  .resolve-input input { padding: 10px 16px; border: 1px solid rgba(255,255,255,0.2); border-radius: 10px; background: rgba(255,255,255,0.05); color: #fff; font-size: 0.95rem; font-family: 'Monaco','Menlo',monospace; width: 260px; }

  .resolve-viz { display: flex; gap: 20px; margin-bottom: 20px; justify-content: center; align-items: flex-start; flex-wrap: wrap; }
  .resolve-col { display: flex; flex-direction: column; gap: 12px; }
  .servers-col { gap: 10px; }
  .resolve-server { padding: 14px 18px; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; text-align: center; min-width: 150px; transition: all 0.4s; }
  .resolve-server.active { border-color: rgba(52,211,153,0.5); background: rgba(52,211,153,0.08); box-shadow: 0 0 20px rgba(52,211,153,0.15); }
  .resolve-server.queried { border-color: rgba(96,165,250,0.5); background: rgba(96,165,250,0.08); }
  .rs-icon { font-size: 1.5rem; margin-bottom: 4px; }
  .rs-name { font-size: 0.85rem; font-weight: 700; color: #fff; margin-bottom: 2px; }
  .rs-detail { font-size: 0.75rem; color: #888; font-family: 'Monaco','Menlo',monospace; }
  .rs-cache { font-size: 0.7rem; color: #666; margin-top: 4px; padding: 4px 8px; background: rgba(0,0,0,0.2); border-radius: 6px; }

  .resolve-timeline { display: flex; flex-direction: column; gap: 4px; margin-bottom: 16px; max-height: 250px; overflow-y: auto; }
  :global(.rt-step) { padding: 8px 14px; border-radius: 8px; font-size: 0.8rem; animation: stepAppear 0.4s ease-out; display: flex; gap: 10px; align-items: center; }
  @keyframes stepAppear { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }
  :global(.rt-step.query) { background: rgba(96,165,250,0.08); border-left: 3px solid #60a5fa; color: #93c5fd; }
  :global(.rt-step.response) { background: rgba(52,211,153,0.08); border-left: 3px solid #34d399; color: #6ee7b7; }
  :global(.rt-step.cache) { background: rgba(251,191,36,0.08); border-left: 3px solid #fbbf24; color: #fde68a; }
  :global(.rt-step.result) { background: rgba(167,139,250,0.08); border-left: 3px solid #a78bfa; color: #c4b5fd; }
  :global(.rt-arrow) { font-size: 0.7rem; color: #555; }
  :global(.rt-latency) { font-size: 0.7rem; color: #666; margin-left: auto; }

  .resolve-result { font-size: 0.95rem; color: #aaa; text-align: center; padding: 10px; min-height: 30px; }

  /* TTL/Cache */
  .cache-section { margin-bottom: 50px; }
  .ttl-controls { display: flex; gap: 16px; align-items: flex-end; flex-wrap: wrap; margin-bottom: 20px; }
  .slider-group { flex: 1; min-width: 200px; }
  .slider-group label { color: #ccc; font-size: 0.95rem; display: block; margin-bottom: 8px; }
  .slider-group strong { color: #34d399; }

  .ttl-viz { display: flex; gap: 20px; }
  .ttl-cache { flex: 2; background: rgba(0,0,0,0.2); border-radius: 14px; padding: 18px; border: 1px solid rgba(255,255,255,0.1); }
  .ttl-cache-label { font-size: 0.85rem; font-weight: 700; color: #60a5fa; margin-bottom: 10px; }
  .ttl-entries { display: flex; flex-direction: column; gap: 4px; min-height: 60px; }
  .ttl-empty { color: #666; font-size: 0.85rem; text-align: center; padding: 16px; }
  :global(.ttl-entry) { display: flex; justify-content: space-between; padding: 8px 12px; background: rgba(52,211,153,0.06); border: 1px solid rgba(52,211,153,0.15); border-radius: 8px; font-size: 0.8rem; font-family: 'Monaco','Menlo',monospace; }
  :global(.ttl-entry.expired) { opacity: 0.4; border-color: rgba(239,68,68,0.2); background: rgba(239,68,68,0.04); }
  :global(.ttl-domain) { color: #ccc; }
  :global(.ttl-ip) { color: #34d399; }
  :global(.ttl-time) { color: #888; }

  .ttl-stats { flex: 1; display: flex; flex-direction: column; gap: 12px; }
  .ttl-stat { background: rgba(0,0,0,0.2); border-radius: 12px; padding: 16px; border: 1px solid rgba(255,255,255,0.08); text-align: center; }
  .ttl-stat-label { font-size: 0.8rem; color: #888; margin-bottom: 4px; }
  .ttl-stat-value { font-size: 1.3rem; font-weight: 700; color: #34d399; }

  /* Records */
  .records-section { margin-bottom: 50px; }
  .records-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .record-card { background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 16px; }
  .record-type { font-size: 1.1rem; font-weight: 800; color: #60a5fa; font-family: 'Monaco','Menlo',monospace; margin-bottom: 4px; }
  .record-desc { font-size: 0.8rem; color: #aaa; margin-bottom: 8px; }
  .record-card code { display: block; background: rgba(0,0,0,0.3); padding: 6px 10px; border-radius: 6px; font-size: 0.7rem; color: #34d399; word-break: break-all; }

  /* Explain */
  .explain-section { margin-bottom: 50px; }
  .explain-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .explain-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 24px; }
  .explain-card h3 { font-size: 1rem; color: #fff; margin-bottom: 10px; }
  .explain-card p { color: #aaa; line-height: 1.6; font-size: 0.9rem; }
  .explain-card strong { color: #34d399; }
  .explain-card code { background: rgba(0,0,0,0.3); padding: 2px 6px; border-radius: 4px; font-size: 0.85rem; color: #34d399; }
  .highlight-card { background: linear-gradient(135deg, rgba(52,211,153,0.08), rgba(96,165,250,0.08)); border-color: rgba(52,211,153,0.3); }

  .viz-footer { text-align: center; color: #666; font-size: 0.9rem; padding: 20px 0; border-top: 1px solid rgba(255,255,255,0.1); margin-bottom: 30px; }
  .viz-footer a { color: #34d399; }
  .share-buttons { display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; }
  .share-buttons span { color: #666; }
  .share-btn { padding: 10px 20px; background: rgba(255,255,255,0.1); border-radius: 8px; color: #fff; font-size: 0.9rem; transition: background 0.2s; }
  .share-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  @media (max-width: 768px) {
    .viz-header h1 { font-size: 1.8rem; }
    .explain-grid { grid-template-columns: 1fr; }
    .records-grid { grid-template-columns: 1fr 1fr; }
    .resolve-viz { flex-direction: column; align-items: center; }
    .ttl-viz { flex-direction: column; }
  }
</style>

<script>
  // ========== DNS RESOLUTION ==========
  let resolveStep = 0;
  let resolveSteps: Array<{server: string; cls: string; text: string; latency: string; activeServer?: string}> = [];
  let domain = 'api.example.com';

  function buildResolveSteps(d: string) {
    const parts = d.split('.');
    const tld = parts[parts.length - 1];
    const sld = parts.slice(-2).join('.');
    const ip = `${Math.floor(Math.random() * 200) + 10}.${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 255) + 1}`;

    document.getElementById('rTLDDetail')!.textContent = `.${tld}`;
    document.getElementById('rAuthDetail')!.textContent = `ns1.${sld}`;

    return [
      { server: 'rClient', cls: 'query', text: `Browser: "What's the IP of ${d}?"`, latency: '', activeServer: 'rClient' },
      { server: 'rResolver', cls: 'query', text: `Resolver: Check local cache → MISS`, latency: '0ms', activeServer: 'rResolver' },
      { server: 'rRoot', cls: 'query', text: `→ Root: "Who handles .${tld}?"`, latency: '~25ms', activeServer: 'rRoot' },
      { server: 'rRoot', cls: 'response', text: `← Root: "Try a.gtld-servers.net for .${tld}"`, latency: '~25ms', activeServer: 'rRoot' },
      { server: 'rTLD', cls: 'query', text: `→ .${tld} TLD: "Who handles ${sld}?"`, latency: '~15ms', activeServer: 'rTLD' },
      { server: 'rTLD', cls: 'response', text: `← TLD: "Try ns1.${sld}"`, latency: '~15ms', activeServer: 'rTLD' },
      { server: 'rAuth', cls: 'query', text: `→ Authoritative: "What's the A record for ${d}?"`, latency: '~10ms', activeServer: 'rAuth' },
      { server: 'rAuth', cls: 'response', text: `← Authoritative: "${d} → ${ip}" (TTL: 300)`, latency: '~10ms', activeServer: 'rAuth' },
      { server: 'rResolver', cls: 'cache', text: `Resolver: Cache ${d} → ${ip} (TTL 300s)`, latency: '', activeServer: 'rResolver' },
      { server: 'rClient', cls: 'result', text: `✅ Browser: ${d} = ${ip} (total: ~95ms, 4 hops)`, latency: '~95ms', activeServer: 'rClient' },
    ];
  }

  function addTimelineStep(step: typeof resolveSteps[0]) {
    const timeline = document.getElementById('resolveTimeline')!;
    const el = document.createElement('div');
    el.className = `rt-step ${step.cls}`;
    el.innerHTML = `<span>${step.text}</span>${step.latency ? `<span class="rt-latency">${step.latency}</span>` : ''}`;
    timeline.appendChild(el);
    timeline.scrollTop = timeline.scrollHeight;

    // Highlight server
    document.querySelectorAll('.resolve-server').forEach(s => s.classList.remove('active', 'queried'));
    if (step.activeServer) {
      document.getElementById(step.activeServer)?.classList.add(step.cls === 'query' ? 'queried' : 'active');
    }
  }

  document.getElementById('resolveBtn')?.addEventListener('click', () => {
    domain = (document.getElementById('resolveInput') as HTMLInputElement).value.trim() || 'api.example.com';
    resolveSteps = buildResolveSteps(domain);
    resolveStep = 0;
    document.getElementById('resolveTimeline')!.innerHTML = '';
    document.getElementById('resolveResult')!.textContent = '';
    document.querySelectorAll('.resolve-server').forEach(s => s.classList.remove('active', 'queried'));
    (document.getElementById('resolveStepBtn') as HTMLButtonElement).disabled = false;

    // Auto-play all steps
    let i = 0;
    const interval = setInterval(() => {
      if (i >= resolveSteps.length) {
        clearInterval(interval);
        document.getElementById('resolveResult')!.textContent = `Resolved ${domain} in ${resolveSteps.length} steps`;
        return;
      }
      addTimelineStep(resolveSteps[i]);
      i++;
    }, 500);
  });

  document.getElementById('resolveStepBtn')?.addEventListener('click', () => {
    if (resolveStep < resolveSteps.length) {
      addTimelineStep(resolveSteps[resolveStep]);
      resolveStep++;
      if (resolveStep >= resolveSteps.length) {
        (document.getElementById('resolveStepBtn') as HTMLButtonElement).disabled = true;
        document.getElementById('resolveResult')!.textContent = `✅ Resolved ${domain}`;
      }
    }
  });

  document.getElementById('resolveResetBtn')?.addEventListener('click', () => {
    resolveStep = 0;
    resolveSteps = [];
    document.getElementById('resolveTimeline')!.innerHTML = '';
    document.getElementById('resolveResult')!.textContent = '';
    document.querySelectorAll('.resolve-server').forEach(s => s.classList.remove('active', 'queried'));
    (document.getElementById('resolveStepBtn') as HTMLButtonElement).disabled = true;
    document.getElementById('rResolverCache')!.textContent = 'Cache: empty';
  });

  // ========== TTL CACHING ==========
  let ttlHits = 0, ttlMisses = 0, ttlTotalHops = 0, ttlLookups = 0;
  interface CacheEntry { domain: string; ip: string; ttl: number; added: number; }
  let cacheEntries: CacheEntry[] = [];

  const SAMPLE_DOMAINS = ['example.com', 'api.example.com', 'cdn.example.com', 'mail.google.com', 'github.com'];
  let domainIdx = 0;

  function renderTTLCache() {
    const el = document.getElementById('ttlEntries')!;
    const now = Date.now();
    if (cacheEntries.length === 0) {
      el.innerHTML = '<div class="ttl-empty">Cache empty — do a lookup!</div>';
    } else {
      el.innerHTML = cacheEntries.map(e => {
        const remaining = Math.max(0, e.ttl - Math.floor((now - e.added) / 1000));
        const expired = remaining <= 0;
        return `<div class="ttl-entry ${expired ? 'expired' : ''}">
          <span class="ttl-domain">${e.domain}</span>
          <span class="ttl-ip">${e.ip}</span>
          <span class="ttl-time">${expired ? 'EXPIRED' : remaining + 's'}</span>
        </div>`;
      }).join('');
    }
    document.getElementById('ttlHits')!.textContent = String(ttlHits);
    document.getElementById('ttlMisses')!.textContent = String(ttlMisses);
    document.getElementById('ttlAvgHops')!.textContent = ttlLookups > 0 ? (ttlTotalHops / ttlLookups).toFixed(1) : '—';
  }

  document.getElementById('ttlSlider')?.addEventListener('input', (e) => {
    document.getElementById('ttlLabel')!.textContent = (e.target as HTMLInputElement).value;
  });

  document.getElementById('ttlLookupBtn')?.addEventListener('click', () => {
    const ttl = parseInt((document.getElementById('ttlSlider') as HTMLInputElement).value);
    const d = SAMPLE_DOMAINS[domainIdx % SAMPLE_DOMAINS.length];
    domainIdx++;
    const now = Date.now();
    ttlLookups++;

    // Check cache
    const cached = cacheEntries.find(e => e.domain === d && (now - e.added) / 1000 < e.ttl);
    if (cached) {
      ttlHits++;
      ttlTotalHops += 0;
    } else {
      ttlMisses++;
      ttlTotalHops += 4;
      const ip = `${Math.floor(Math.random() * 200) + 10}.${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 255) + 1}`;
      // Remove expired
      cacheEntries = cacheEntries.filter(e => (now - e.added) / 1000 < e.ttl);
      cacheEntries.push({ domain: d, ip, ttl, added: now });
    }
    renderTTLCache();
  });

  document.getElementById('ttlExpireBtn')?.addEventListener('click', () => {
    cacheEntries = [];
    renderTTLCache();
  });

  // Init
  renderTTLCache();
</script>
</BaseLayout>
