<script is:inline>
  // ========== DNS RECORD DATA ==========
  var dnsRecords = {
    A: { name: 'A (Address)', desc: 'Maps a domain to an IPv4 address. The most common record type.', example: 'example.com.  300  IN  A  93.184.216.34', use: 'Point your domain to a web server\'s IPv4 address.' },
    AAAA: { name: 'AAAA (IPv6 Address)', desc: 'Maps a domain to an IPv6 address. Same as A but for the modern internet.', example: 'example.com.  300  IN  AAAA  2606:2800:220:1:248:1893:25c8:1946', use: 'IPv6-enabled hosting. Most domains should have both A and AAAA.' },
    CNAME: { name: 'CNAME (Canonical Name)', desc: 'Alias one domain to another. The resolver follows the chain until it finds an A/AAAA.', example: 'www.example.com.  300  IN  CNAME  example.com.', use: 'Point subdomains to a canonical name. Cannot coexist with other records at same name.' },
    MX: { name: 'MX (Mail Exchange)', desc: 'Specifies mail servers for the domain, with priority (lower = preferred).', example: 'example.com.  300  IN  MX  10 mail.example.com.\nexample.com.  300  IN  MX  20 backup.example.com.', use: 'Email delivery. Multiple MX records provide failover.' },
    NS: { name: 'NS (Name Server)', desc: 'Delegates a zone to the specified authoritative nameservers.', example: 'example.com.  86400  IN  NS  ns1.example.com.\nexample.com.  86400  IN  NS  ns2.example.com.', use: 'Set at registrar to delegate your domain. Usually 2+ for redundancy.' },
    TXT: { name: 'TXT (Text)', desc: 'Stores arbitrary text. Used for SPF, DKIM, DMARC, domain verification, and more.', example: 'example.com.  300  IN  TXT  "v=spf1 include:_spf.google.com ~all"', use: 'Email authentication (SPF/DKIM/DMARC), domain ownership verification (Google, AWS).' },
    SRV: { name: 'SRV (Service)', desc: 'Specifies host and port for a service. Format: _service._proto.name TTL IN SRV priority weight port target.', example: '_sip._tcp.example.com.  300  IN  SRV  10 60 5060 sip.example.com.', use: 'Service discovery for SIP, XMPP, LDAP, Minecraft servers, etc.' },
    SOA: { name: 'SOA (Start of Authority)', desc: 'Contains zone metadata: primary NS, admin email, serial, refresh/retry/expire timers, and minimum TTL for negative caching.', example: 'example.com.  86400  IN  SOA  ns1.example.com. admin.example.com. (\n  2025032201  ; serial\n  3600        ; refresh\n  900         ; retry\n  604800      ; expire\n  300         ; minimum TTL\n)', use: 'Every zone must have exactly one SOA. Serial must increment on changes for zone transfers.' }
  };

  // ========== SIMULATED DNS DATABASE ==========
  var dnsDB = {
    'www.example.com': { A: '93.184.216.34', AAAA: '2606:2800:220:1:248:1893:25c8:1946', tld: 'com', auth: 'ns1.example.com' },
    'example.com': { A: '93.184.216.34', AAAA: '2606:2800:220:1:248:1893:25c8:1946', MX: '10 mail.example.com', NS: 'ns1.example.com', TXT: '"v=spf1 include:_spf.google.com ~all"', SOA: 'ns1.example.com admin.example.com 2025032201 3600 900 604800 300', tld: 'com', auth: 'ns1.example.com' },
    'google.com': { A: '142.250.80.46', AAAA: '2607:f8b0:4004:800::200e', MX: '10 smtp.google.com', tld: 'com', auth: 'ns1.google.com' },
    'www.google.com': { A: '142.250.80.46', CNAME: 'google.com', tld: 'com', auth: 'ns1.google.com' },
    'github.com': { A: '140.82.121.4', AAAA: '2606:50c0:8000::64', tld: 'com', auth: 'ns1.github.com' },
    'api.github.com': { A: '140.82.121.6', CNAME: 'github.com', tld: 'com', auth: 'ns1.github.com' },
    'cloudflare.com': { A: '104.16.132.229', tld: 'com', auth: 'ns1.cloudflare.com' },
    'systeminternals.dev': { A: '76.76.21.21', tld: 'dev', auth: 'ns1.vercel-dns.com' },
    'news.ycombinator.com': { A: '209.216.230.240', CNAME: 'ycombinator.com', tld: 'com', auth: 'ns1.ycombinator.com' },
    'default': { A: '203.0.113.42', tld: 'com', auth: 'ns1.default.com' }
  };

  // ========== DNS CACHE ==========
  var dnsCache = {};
  var cacheTimers = [];

  function addToCache(domain, type, value, ttl) {
    var key = domain + '/' + type;
    dnsCache[key] = { domain: domain, type: type, value: value, ttl: ttl, maxTtl: ttl, addedAt: Date.now() };
    renderCacheTable();
  }

  function checkCache(domain, type) {
    var key = domain + '/' + type;
    var entry = dnsCache[key];
    if (!entry) return null;
    var elapsed = Math.floor((Date.now() - entry.addedAt) / 1000);
    var remaining = entry.ttl - elapsed;
    if (remaining <= 0) {
      delete dnsCache[key];
      renderCacheTable();
      return null;
    }
    return { value: entry.value, remaining: remaining };
  }

  function clearCache() {
    dnsCache = {};
    renderCacheTable();
  }

  function renderCacheTable() {
    var table = document.getElementById('cacheTable');
    var keys = Object.keys(dnsCache);
    if (keys.length === 0) {
      table.innerHTML = '<div class="cache-empty">No cached records yet. Resolve a domain above!</div>';
      return;
    }
    var html = '<div class="cache-row cache-header"><span>Domain</span><span>Type</span><span>Value</span><span>TTL</span></div>';
    keys.forEach(function(key) {
      var e = dnsCache[key];
      var elapsed = Math.floor((Date.now() - e.addedAt) / 1000);
      var remaining = Math.max(0, e.ttl - elapsed);
      var expired = remaining <= 0;
      html += '<div class="cache-row">';
      html += '<span class="cache-domain">' + e.domain + '</span>';
      html += '<span class="cache-type">' + e.type + '</span>';
      html += '<span class="cache-value">' + e.value + '</span>';
      html += '<span class="cache-ttl' + (expired ? ' expired' : '') + '">' + (expired ? 'EXPIRED' : remaining + 's') + '</span>';
      html += '</div>';
    });
    table.innerHTML = html;
  }

  // Update cache display every second
  setInterval(renderCacheTable, 1000);

  // ========== RESOLUTION SIMULATOR ==========
  var resolving = false;

  function getDomainInfo(domain) {
    return dnsDB[domain] || dnsDB['default'];
  }

  function getTLD(domain) {
    var parts = domain.split('.');
    return '.' + parts[parts.length - 1];
  }

  function getBaseDomain(domain) {
    var parts = domain.split('.');
    if (parts.length >= 2) return parts.slice(-2).join('.');
    return domain;
  }

  function resetNodes() {
    document.querySelectorAll('.resolver-node').forEach(function(n) {
      n.classList.remove('active', 'cache-hit');
    });
    document.querySelectorAll('.resolver-arrow').forEach(function(a) {
      a.classList.remove('active');
    });
    ['arrowLabel1','arrowLabel2','arrowLabel3','arrowLabel4'].forEach(function(id) {
      document.getElementById(id).textContent = '';
    });
  }

  function activateNode(id, isCacheHit) {
    resetNodes();
    var node = document.getElementById(id);
    if (isCacheHit) {
      node.classList.add('cache-hit');
    } else {
      node.classList.add('active');
    }
  }

  function activateArrow(id) {
    document.getElementById(id).classList.add('active');
  }

  function addLog(text, color) {
    var log = document.getElementById('resolverLog');
    var el = document.createElement('div');
    el.style.cssText = 'padding:3px 0;color:' + (color || '#aaa') + ';animation:fadeIn 0.3s ease-out;';
    el.textContent = text;
    log.appendChild(el);
    log.scrollTop = log.scrollHeight;
  }

  document.getElementById('resolveBtn').addEventListener('click', function() {
    if (resolving) return;
    resolving = true;

    var domain = document.getElementById('domainInput').value.trim().toLowerCase();
    if (!domain) { resolving = false; return; }
    var qtype = document.getElementById('queryTypeSelect').value;
    var tld = getTLD(domain);
    var info = getDomainInfo(domain);

    document.getElementById('tldSublabel').textContent = tld;
    document.getElementById('authSublabel').textContent = info.auth || 'ns1.' + getBaseDomain(domain);

    var log = document.getElementById('resolverLog');
    log.innerHTML = '';
    document.getElementById('resolverResult').innerHTML = '';
    resetNodes();

    var steps = [];
    var cached = checkCache(domain, qtype);

    if (cached) {
      // Cache hit path
      steps.push(function(cb) {
        activateNode('nodeApp');
        addLog('$ dig ' + domain + ' ' + qtype, '#06b6d4');
        addLog('→ Stub resolver checks local cache...', '#aaa');
        setTimeout(cb, 600);
      });
      steps.push(function(cb) {
        activateNode('nodeRecursive', true);
        activateArrow('arrow1');
        document.getElementById('arrowLabel1').textContent = 'Query: ' + qtype;
        addLog('⚡ CACHE HIT! ' + domain + ' ' + qtype + ' → ' + cached.value + ' (TTL: ' + cached.remaining + 's remaining)', '#f59e0b');
        setTimeout(cb, 800);
      });
      steps.push(function(cb) {
        activateNode('nodeApp');
        var resultValue = cached.value;
        addLog('✅ Answer: ' + domain + ' → ' + resultValue + ' (from cache, ' + cached.remaining + 's TTL remaining)', '#10b981');
        document.getElementById('resolverResult').innerHTML = '<div class="result-box">⚡ ' + domain + ' ' + qtype + ' → ' + resultValue + ' (CACHED, TTL: ' + cached.remaining + 's)</div>';
        resolving = false;
        cb();
      });
    } else {
      // Full resolution
      var resultValue = info[qtype] || info['A'] || '203.0.113.42';
      var ttl = 300;

      steps.push(function(cb) {
        activateNode('nodeApp');
        addLog('$ dig ' + domain + ' ' + qtype, '#06b6d4');
        addLog('→ Application calls stub resolver (libc getaddrinfo)', '#aaa');
        setTimeout(cb, 700);
      });
      steps.push(function(cb) {
        activateNode('nodeRecursive');
        activateArrow('arrow1');
        document.getElementById('arrowLabel1').textContent = 'Query: ' + qtype;
        addLog('→ Stub resolver forwards to recursive resolver (8.8.8.8)', '#aaa');
        addLog('→ Recursive resolver checks its cache... MISS', '#888');
        setTimeout(cb, 800);
      });
      steps.push(function(cb) {
        activateNode('nodeRoot');
        activateArrow('arrow2');
        document.getElementById('arrowLabel2').textContent = 'Who has ' + tld + '?';
        addLog('→ Query root server: "Who handles ' + tld + '?"', '#f59e0b');
        addLog('← Root responds: "' + tld + ' NS is at ' + tld + '-servers" (referral)', '#f59e0b');
        setTimeout(cb, 900);
      });
      steps.push(function(cb) {
        activateNode('nodeTLD');
        activateArrow('arrow3');
        document.getElementById('arrowLabel3').textContent = 'Who has ' + getBaseDomain(domain) + '?';
        addLog('→ Query ' + tld + ' TLD server: "Who handles ' + getBaseDomain(domain) + '?"', '#8b5cf6');
        addLog('← TLD responds: "' + getBaseDomain(domain) + ' NS is ' + (info.auth || 'ns1.' + getBaseDomain(domain)) + '" (referral)', '#8b5cf6');
        setTimeout(cb, 900);
      });
      steps.push(function(cb) {
        activateNode('nodeAuth');
        activateArrow('arrow4');
        document.getElementById('arrowLabel4').textContent = qtype + ' for ' + domain + '?';
        addLog('→ Query authoritative NS (' + (info.auth || 'ns1.' + getBaseDomain(domain)) + '): "' + qtype + ' record for ' + domain + '?"', '#06b6d4');

        if (info[qtype]) {
          addLog('← Authoritative answer: ' + domain + ' ' + qtype + ' → ' + resultValue + ' (TTL: ' + ttl + 's)', '#10b981');
        } else {
          addLog('← No ' + qtype + ' record found. Returning A record as fallback.', '#f59e0b');
          addLog('← ' + domain + ' A → ' + resultValue + ' (TTL: ' + ttl + 's)', '#10b981');
        }
        setTimeout(cb, 800);
      });
      steps.push(function(cb) {
        activateNode('nodeRecursive');
        addLog('→ Recursive resolver caches answer (TTL: ' + ttl + 's)', '#888');
        addToCache(domain, qtype, resultValue, ttl);
        setTimeout(cb, 500);
      });
      steps.push(function(cb) {
        activateNode('nodeApp');
        addLog('✅ Final answer: ' + domain + ' ' + qtype + ' → ' + resultValue, '#10b981');
        addLog('Total hops: 4 (stub → recursive → root → TLD → auth)', '#888');
        document.getElementById('resolverResult').innerHTML = '<div class="result-box">✅ ' + domain + ' ' + qtype + ' → ' + resultValue + ' (TTL: ' + ttl + 's, cached)</div>';
        resolving = false;
        cb();
      });
    }

    // Execute steps sequentially
    var i = 0;
    function next() {
      if (i < steps.length) {
        steps[i](function() { i++; next(); });
      }
    }
    next();
  });

  document.getElementById('clearCacheBtn').addEventListener('click', function() {
    clearCache();
    addLog('🗑️ Cache cleared!', '#f59e0b');
  });

  // ========== RECORD TYPE EXPLORER ==========
  function renderRecordTabs() {
    var tabs = document.getElementById('recordTabs');
    var types = Object.keys(dnsRecords);
    tabs.innerHTML = '';
    types.forEach(function(type) {
      var btn = document.createElement('button');
      btn.className = 'record-tab';
      btn.textContent = type;
      btn.addEventListener('click', function() {
        document.querySelectorAll('.record-tab').forEach(function(t) { t.classList.remove('active'); });
        btn.classList.add('active');
        var rec = dnsRecords[type];
        var detail = document.getElementById('recordDetail');
        detail.innerHTML = '<div style="margin-bottom:12px;"><span style="font-size:1.1rem;font-weight:700;color:#10b981;">' + rec.name + '</span></div>' +
          '<p style="color:#ccc;margin-bottom:14px;line-height:1.6;">' + rec.desc + '</p>' +
          '<div style="margin-bottom:14px;"><span style="font-size:0.8rem;color:#888;font-weight:600;">EXAMPLE:</span><pre style="background:rgba(0,0,0,0.3);padding:12px;border-radius:8px;font-size:0.8rem;color:#06b6d4;margin-top:6px;white-space:pre-wrap;overflow-x:auto;">' + rec.example + '</pre></div>' +
          '<div><span style="font-size:0.8rem;color:#888;font-weight:600;">USE CASE:</span><p style="color:#aaa;font-size:0.9rem;margin-top:6px;">' + rec.use + '</p></div>';
      });
      tabs.appendChild(btn);
    });
  }
  renderRecordTabs();

  // ========== TTL COUNTDOWN ==========
  var ttlInterval = null;
  var ttlLayers = [
    { name: 'Browser', icon: '🌐', factor: 1.0 },
    { name: 'OS Cache', icon: '💻', factor: 1.0 },
    { name: 'Recursive Resolver', icon: '🔄', factor: 1.0 },
    { name: 'Authoritative NS', icon: '🏛️', factor: 1.0 }
  ];

  function renderTtlLayers(values) {
    var container = document.getElementById('ttlLayers');
    var maxTtl = parseInt(document.getElementById('ttlSlider').value);
    var html = '';
    ttlLayers.forEach(function(layer, i) {
      var val = values ? values[i] : maxTtl;
      var pct = maxTtl > 0 ? (val / maxTtl * 100) : 0;
      var color = pct > 50 ? '#10b981' : pct > 20 ? '#f59e0b' : '#ef4444';
      html += '<div class="ttl-layer">';
      html += '<div class="ttl-layer-icon">' + layer.icon + '</div>';
      html += '<div class="ttl-layer-name">' + layer.name + '</div>';
      html += '<div class="ttl-countdown">' + Math.max(0, val) + 's</div>';
      html += '<div class="ttl-bar"><div class="ttl-bar-fill" style="width:' + pct + '%;background:' + color + ';"></div></div>';
      html += '</div>';
    });
    container.innerHTML = html;
  }

  document.getElementById('ttlSlider').addEventListener('input', function(e) {
    document.getElementById('ttlLabel').textContent = e.target.value;
    if (!ttlInterval) renderTtlLayers(null);
  });

  document.getElementById('startTtlBtn').addEventListener('click', function() {
    if (ttlInterval) { clearInterval(ttlInterval); ttlInterval = null; }
    var maxTtl = parseInt(document.getElementById('ttlSlider').value);
    var startTime = Date.now();
    var speed = maxTtl > 600 ? 50 : 1; // speed up for large TTLs

    document.getElementById('ttlTimeline').textContent = 'Counting down... (' + (speed > 1 ? speed + 'x speed' : 'real-time') + ')';

    ttlInterval = setInterval(function() {
      var elapsed = Math.floor((Date.now() - startTime) / 1000) * speed;
      var values = ttlLayers.map(function(layer) {
        return Math.max(0, maxTtl - elapsed);
      });

      // Browser cache typically has shorter effective TTL
      values[0] = Math.max(0, Math.min(60, maxTtl) - elapsed);

      renderTtlLayers(values);

      if (values.every(function(v) { return v <= 0; })) {
        clearInterval(ttlInterval);
        ttlInterval = null;
        document.getElementById('ttlTimeline').textContent = '⏰ All TTLs expired! Next query will trigger full resolution.';
      }
    }, 1000);
  });

  document.getElementById('resetTtlBtn').addEventListener('click', function() {
    if (ttlInterval) { clearInterval(ttlInterval); ttlInterval = null; }
    renderTtlLayers(null);
    document.getElementById('ttlTimeline').textContent = '';
  });

  renderTtlLayers(null);

  // ========== RECURSIVE VS ITERATIVE ==========
  var currentMode = 'recursive';

  function renderModeViz() {
    var viz = document.getElementById('modeViz');
    var desc = document.getElementById('modeDesc');

    if (currentMode === 'recursive') {
      viz.innerHTML = '<div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;justify-content:center;">' +
        '<div style="padding:12px 16px;border-radius:10px;border:2px solid #06b6d4;background:rgba(6,182,212,0.1);text-align:center;"><div style="font-size:1.3rem;">💻</div><div style="font-size:0.75rem;color:#fff;font-weight:700;">Client</div></div>' +
        '<div style="text-align:center;"><div style="color:#06b6d4;font-size:0.7rem;">query →</div><div style="color:#10b981;font-size:0.7rem;">← final answer</div></div>' +
        '<div style="padding:12px 16px;border-radius:10px;border:2px solid #8b5cf6;background:rgba(139,92,246,0.1);text-align:center;min-width:120px;"><div style="font-size:1.3rem;">🔄</div><div style="font-size:0.75rem;color:#fff;font-weight:700;">Recursive Resolver</div><div style="font-size:0.6rem;color:#888;margin-top:4px;">Does ALL the work</div></div>' +
        '<div style="display:flex;flex-direction:column;gap:8px;">' +
          '<div style="display:flex;align-items:center;gap:8px;"><span style="color:#444;">→←</span><div style="padding:6px 12px;border-radius:8px;border:1px solid rgba(245,158,11,0.3);background:rgba(245,158,11,0.05);font-size:0.7rem;color:#f59e0b;">🌍 Root</div></div>' +
          '<div style="display:flex;align-items:center;gap:8px;"><span style="color:#444;">→←</span><div style="padding:6px 12px;border-radius:8px;border:1px solid rgba(139,92,246,0.3);background:rgba(139,92,246,0.05);font-size:0.7rem;color:#8b5cf6;">📁 TLD</div></div>' +
          '<div style="display:flex;align-items:center;gap:8px;"><span style="color:#444;">→←</span><div style="padding:6px 12px;border-radius:8px;border:1px solid rgba(6,182,212,0.3);background:rgba(6,182,212,0.05);font-size:0.7rem;color:#06b6d4;">🏛️ Auth NS</div></div>' +
        '</div>' +
        '</div>';
      desc.innerHTML = '<strong style="color:#8b5cf6;">Recursive query:</strong> The client sends one query to the recursive resolver, which then handles all the iterative lookups (root → TLD → authoritative) and returns the final answer. This is the standard model — your OS stub resolver sends a recursive query to 8.8.8.8 or your ISP\'s resolver.';
    } else {
      viz.innerHTML = '<div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;justify-content:center;">' +
        '<div style="padding:12px 16px;border-radius:10px;border:2px solid #06b6d4;background:rgba(6,182,212,0.1);text-align:center;min-width:80px;"><div style="font-size:1.3rem;">💻</div><div style="font-size:0.75rem;color:#fff;font-weight:700;">Client</div><div style="font-size:0.6rem;color:#888;">Does the walking</div></div>' +
        '<div style="display:flex;flex-direction:column;gap:12px;">' +
          '<div style="display:flex;align-items:center;gap:8px;"><span style="color:#f59e0b;font-size:0.65rem;">1. →←</span><div style="padding:6px 12px;border-radius:8px;border:1px solid rgba(245,158,11,0.3);background:rgba(245,158,11,0.05);font-size:0.7rem;color:#f59e0b;">🌍 Root: "try .com servers"</div></div>' +
          '<div style="display:flex;align-items:center;gap:8px;"><span style="color:#8b5cf6;font-size:0.65rem;">2. →←</span><div style="padding:6px 12px;border-radius:8px;border:1px solid rgba(139,92,246,0.3);background:rgba(139,92,246,0.05);font-size:0.7rem;color:#8b5cf6;">📁 TLD: "try ns1.example.com"</div></div>' +
          '<div style="display:flex;align-items:center;gap:8px;"><span style="color:#10b981;font-size:0.65rem;">3. →←</span><div style="padding:6px 12px;border-radius:8px;border:1px solid rgba(16,185,129,0.3);background:rgba(16,185,129,0.05);font-size:0.7rem;color:#10b981;">🏛️ Auth: "93.184.216.34!"</div></div>' +
        '</div>' +
        '</div>';
      desc.innerHTML = '<strong style="color:#f59e0b;">Iterative query:</strong> Each server returns a referral ("I don\'t know, but ask this server"). The querier follows each referral itself. This is what happens <em>between</em> the recursive resolver and the authoritative servers. Recursive resolvers use iterative queries internally.';
    }
  }

  document.querySelectorAll('.mode-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.mode-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentMode = btn.getAttribute('data-mode');
      renderModeViz();
    });
  });
  renderModeViz();

  // ========== DNSSEC CHAIN OF TRUST ==========
  function renderDnssecChain() {
    var chain = document.getElementById('dnssecChain');
    var levels = [
      { zone: '. (Root)', color: '#f59e0b', keys: 'KSK + ZSK', signs: 'Signs .com DS record' },
      { zone: '.com (TLD)', color: '#8b5cf6', keys: 'KSK + ZSK', signs: 'Signs example.com DS record' },
      { zone: 'example.com', color: '#06b6d4', keys: 'KSK + ZSK', signs: 'Signs A, MX, TXT records' },
    ];

    var html = '<div style="display:flex;flex-direction:column;gap:0;align-items:center;">';
    levels.forEach(function(level, i) {
      html += '<div style="display:flex;align-items:center;gap:16px;width:100%;max-width:600px;margin:0 auto;">';
      html += '<div style="padding:14px 20px;border-radius:12px;border:2px solid ' + level.color + ';background:' + level.color + '15;flex:1;text-align:center;">';
      html += '<div style="font-weight:700;color:' + level.color + ';font-size:0.9rem;">' + level.zone + '</div>';
      html += '<div style="font-size:0.7rem;color:#888;margin-top:4px;">🔑 ' + level.keys + '</div>';
      html += '</div>';
      html += '<div style="font-size:0.75rem;color:#aaa;min-width:180px;">' + level.signs + '</div>';
      html += '</div>';
      if (i < levels.length - 1) {
        html += '<div style="display:flex;align-items:center;gap:8px;margin:6px 0;">';
        html += '<div style="width:2px;height:20px;background:rgba(255,255,255,0.15);"></div>';
        html += '<span style="font-size:0.65rem;color:#888;">DS record (hash of child KSK) →</span>';
        html += '</div>';
      }
    });
    html += '</div>';
    html += '<div style="margin-top:14px;text-align:center;font-size:0.8rem;color:#888;">Trust anchor: Root KSK is pre-installed in validators (RFC 5011 rollover)</div>';
    chain.innerHTML = html;
  }
  renderDnssecChain();

  // ========== RESOLVER LOG HELPER ==========
  function addLog(text, color) {
    var log = document.getElementById('resolverLog');
    var el = document.createElement('div');
    el.style.cssText = 'padding:3px 0;color:' + (color || '#aaa') + ';animation:fadeIn 0.3s ease-out;';
    el.textContent = text;
    log.appendChild(el);
    log.scrollTop = log.scrollHeight;
  }
</script>
