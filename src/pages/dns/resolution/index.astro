---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="DNS Resolution: How a Domain Becomes an IP" 
  description="Interactive visualization of DNS resolution — recursive queries, record types, caching, TTL, DNSSEC, DoH/DoT, and anycast routing"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "DNS", href: "/dns/" },
    { label: "Resolution", href: "/dns/resolution/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🌐 DNS Resolution</h1>
      <p class="subtitle">From Domain Name to IP Address · Step by Step</p>
    </header>

    <section class="overview-section">
      <div class="overview-card">
        <p>
          When you type <strong>www.example.com</strong> in your browser, a chain of queries walks the
          <strong>DNS hierarchy</strong> — from <em>root servers</em> to <em>TLD servers</em> to
          <em>authoritative nameservers</em> — to find the IP address. Your machine's <strong>stub resolver</strong>
          asks a <strong>recursive resolver</strong> (like 8.8.8.8), which does the heavy lifting.
          Each answer is <strong>cached with a TTL</strong>, so repeated lookups are instant.
        </p>
      </div>
    </section>

    <!-- Interactive Resolution Simulator -->
    <section class="resolver-section">
      <h2>🔍 Interactive Resolution Simulator</h2>
      <p class="section-desc">Type a domain and watch the full recursive resolution unfold — stub resolver → recursive resolver → root → TLD → authoritative nameserver.</p>

      <div class="resolver-controls">
        <div class="domain-input-group">
          <span class="input-prefix">dig</span>
          <input type="text" id="domainInput" value="www.example.com" placeholder="Enter a domain..." spellcheck="false">
          <select id="queryTypeSelect">
            <option value="A">A</option>
            <option value="AAAA">AAAA</option>
            <option value="CNAME">CNAME</option>
            <option value="MX">MX</option>
            <option value="NS">NS</option>
            <option value="TXT">TXT</option>
            <option value="SRV">SRV</option>
            <option value="SOA">SOA</option>
          </select>
        </div>
        <button id="resolveBtn" class="action-btn primary-btn">▶ Resolve</button>
        <button id="clearCacheBtn" class="action-btn reset-btn">🗑️ Clear Cache</button>
      </div>

      <div class="resolver-viz">
        <div class="resolver-nodes">
          <div class="resolver-node" id="nodeApp">
            <div class="node-icon">💻</div>
            <div class="node-label">Your App</div>
            <div class="node-sublabel">stub resolver</div>
          </div>
          <div class="resolver-arrow" id="arrow1">
            <div class="arrow-line"></div>
            <div class="arrow-label" id="arrowLabel1"></div>
          </div>
          <div class="resolver-node" id="nodeRecursive">
            <div class="node-icon">🔄</div>
            <div class="node-label">Recursive Resolver</div>
            <div class="node-sublabel">e.g. 8.8.8.8</div>
          </div>
          <div class="resolver-arrow" id="arrow2">
            <div class="arrow-line"></div>
            <div class="arrow-label" id="arrowLabel2"></div>
          </div>
          <div class="resolver-node" id="nodeRoot">
            <div class="node-icon">🌍</div>
            <div class="node-label">Root Server</div>
            <div class="node-sublabel">. (13 anycast clusters)</div>
          </div>
          <div class="resolver-arrow" id="arrow3">
            <div class="arrow-line"></div>
            <div class="arrow-label" id="arrowLabel3"></div>
          </div>
          <div class="resolver-node" id="nodeTLD">
            <div class="node-icon">📁</div>
            <div class="node-label">TLD Server</div>
            <div class="node-sublabel" id="tldSublabel">.com</div>
          </div>
          <div class="resolver-arrow" id="arrow4">
            <div class="arrow-line"></div>
            <div class="arrow-label" id="arrowLabel4"></div>
          </div>
          <div class="resolver-node" id="nodeAuth">
            <div class="node-icon">🏛️</div>
            <div class="node-label">Authoritative NS</div>
            <div class="node-sublabel" id="authSublabel">ns1.example.com</div>
          </div>
        </div>
      </div>

      <div class="resolver-log" id="resolverLog"></div>

      <div class="resolver-result" id="resolverResult"></div>
    </section>

    <!-- DNS Hierarchy -->
    <section class="hierarchy-section">
      <h2>🏗️ DNS Hierarchy</h2>
      <p class="section-desc">DNS is a distributed tree. Every domain is a path from the root down.</p>

      <div class="hierarchy-tree">
        <div class="tree-level root-level">
          <div class="tree-node root-node">
            <span class="tree-dot root-dot"></span>
            <span class="tree-text">. (root)</span>
            <span class="tree-detail">13 root server clusters (a.root-servers.net – m.root-servers.net)</span>
          </div>
        </div>
        <div class="tree-connector"></div>
        <div class="tree-level tld-level">
          <div class="tree-node tld-node" data-tld=".com">
            <span class="tree-dot tld-dot"></span>
            <span class="tree-text">.com</span>
          </div>
          <div class="tree-node tld-node" data-tld=".org">
            <span class="tree-dot tld-dot"></span>
            <span class="tree-text">.org</span>
          </div>
          <div class="tree-node tld-node" data-tld=".dev">
            <span class="tree-dot tld-dot"></span>
            <span class="tree-text">.dev</span>
          </div>
          <div class="tree-node tld-node" data-tld=".io">
            <span class="tree-dot tld-dot"></span>
            <span class="tree-text">.io</span>
          </div>
          <div class="tree-node tld-node" data-tld=".net">
            <span class="tree-dot tld-dot"></span>
            <span class="tree-text">.net</span>
          </div>
          <div class="tree-node tld-node" data-tld=".uk">
            <span class="tree-dot tld-dot"></span>
            <span class="tree-text">.uk</span>
          </div>
        </div>
        <div class="tree-connector"></div>
        <div class="tree-level auth-level">
          <div class="tree-node auth-node">
            <span class="tree-dot auth-dot"></span>
            <span class="tree-text">example.com</span>
          </div>
          <div class="tree-node auth-node">
            <span class="tree-dot auth-dot"></span>
            <span class="tree-text">google.com</span>
          </div>
          <div class="tree-node auth-node">
            <span class="tree-dot auth-dot"></span>
            <span class="tree-text">github.dev</span>
          </div>
        </div>
        <div class="tree-connector"></div>
        <div class="tree-level record-level">
          <div class="tree-node record-node">
            <span class="tree-dot record-dot"></span>
            <span class="tree-text">www</span>
            <span class="tree-detail">A → 93.184.216.34</span>
          </div>
          <div class="tree-node record-node">
            <span class="tree-dot record-dot"></span>
            <span class="tree-text">mail</span>
            <span class="tree-detail">MX → 10 mail.example.com</span>
          </div>
          <div class="tree-node record-node">
            <span class="tree-dot record-dot"></span>
            <span class="tree-text">api</span>
            <span class="tree-detail">CNAME → lb.example.com</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Record Type Explorer -->
    <section class="records-section">
      <h2>📋 DNS Record Types</h2>
      <p class="section-desc">Click a record type to see its format, use case, and a real-world example.</p>

      <div class="record-tabs" id="recordTabs"></div>
      <div class="record-detail" id="recordDetail">
        <div class="record-detail-placeholder">Select a record type above</div>
      </div>
    </section>

    <!-- TTL & Caching -->
    <section class="ttl-section">
      <h2>⏱️ TTL &amp; Caching Layers</h2>
      <p class="section-desc">Every DNS response includes a TTL (Time To Live). Each layer caches independently. Watch the countdown.</p>

      <div class="ttl-controls">
        <div class="slider-group">
          <label>Initial TTL: <strong id="ttlLabel">300</strong> seconds</label>
          <input type="range" id="ttlSlider" min="30" max="86400" value="300" step="30">
        </div>
        <button id="startTtlBtn" class="action-btn primary-btn">▶ Start Countdown</button>
        <button id="resetTtlBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="ttl-layers" id="ttlLayers"></div>
      <div class="ttl-timeline" id="ttlTimeline"></div>
    </section>

    <!-- Recursive vs Iterative -->
    <section class="mode-section">
      <h2>🔀 Recursive vs Iterative Queries</h2>
      <p class="section-desc">A recursive query asks the resolver to do all the work. An iterative query gets referrals and follows them itself.</p>

      <div class="mode-toggle">
        <button class="mode-btn active" data-mode="recursive">Recursive</button>
        <button class="mode-btn" data-mode="iterative">Iterative</button>
      </div>

      <div class="mode-viz" id="modeViz"></div>
      <div class="mode-desc" id="modeDesc"></div>
    </section>

    <!-- DoH / DoT -->
    <section class="encrypted-section">
      <h2>🔒 DNS over HTTPS &amp; DNS over TLS</h2>
      <p class="section-desc">Traditional DNS is plaintext UDP. DoH and DoT encrypt queries for privacy.</p>

      <div class="encrypted-compare">
        <div class="encrypt-card">
          <div class="encrypt-header" style="border-color: #ef4444;">
            <h3>🔓 Traditional DNS</h3>
            <span class="encrypt-port">UDP/53</span>
          </div>
          <div class="encrypt-body">
            <div class="packet-viz plaintext-packet">
              <div class="packet-layer" style="background:rgba(239,68,68,0.15);border-color:rgba(239,68,68,0.4);">
                <span class="layer-label">UDP</span>
                <span class="layer-detail">No encryption</span>
              </div>
              <div class="packet-layer" style="background:rgba(239,68,68,0.1);border-color:rgba(239,68,68,0.3);">
                <span class="layer-label">DNS Query</span>
                <span class="layer-detail">Visible to ISP, routers, anyone on path</span>
              </div>
            </div>
            <ul class="encrypt-features">
              <li>❌ Query visible to network observers</li>
              <li>❌ Vulnerable to tampering (MITM)</li>
              <li>❌ ISP can log all domains you visit</li>
              <li>✅ Low latency (no handshake)</li>
              <li>✅ Universally supported</li>
            </ul>
          </div>
        </div>

        <div class="encrypt-card">
          <div class="encrypt-header" style="border-color: #8b5cf6;">
            <h3>🔐 DNS over TLS (DoT)</h3>
            <span class="encrypt-port">TCP/853</span>
          </div>
          <div class="encrypt-body">
            <div class="packet-viz">
              <div class="packet-layer" style="background:rgba(139,92,246,0.15);border-color:rgba(139,92,246,0.4);">
                <span class="layer-label">TLS 1.3</span>
                <span class="layer-detail">Encrypted tunnel</span>
              </div>
              <div class="packet-layer" style="background:rgba(139,92,246,0.1);border-color:rgba(139,92,246,0.3);">
                <span class="layer-label">DNS Query</span>
                <span class="layer-detail">Encrypted inside TLS</span>
              </div>
            </div>
            <ul class="encrypt-features">
              <li>✅ Query encrypted end-to-end</li>
              <li>✅ Server authenticated via certificate</li>
              <li>⚠️ Dedicated port (853) — easily blocked</li>
              <li>⚠️ TLS handshake adds latency</li>
              <li>✅ Supported by Android 9+, systemd-resolved</li>
            </ul>
          </div>
        </div>

        <div class="encrypt-card">
          <div class="encrypt-header" style="border-color: #06b6d4;">
            <h3>🛡️ DNS over HTTPS (DoH)</h3>
            <span class="encrypt-port">TCP/443</span>
          </div>
          <div class="encrypt-body">
            <div class="packet-viz">
              <div class="packet-layer" style="background:rgba(6,182,212,0.15);border-color:rgba(6,182,212,0.4);">
                <span class="layer-label">HTTPS</span>
                <span class="layer-detail">Looks like normal web traffic</span>
              </div>
              <div class="packet-layer" style="background:rgba(6,182,212,0.1);border-color:rgba(6,182,212,0.3);">
                <span class="layer-label">DNS Query</span>
                <span class="layer-detail">Hidden in HTTPS stream</span>
              </div>
            </div>
            <ul class="encrypt-features">
              <li>✅ Query encrypted end-to-end</li>
              <li>✅ Indistinguishable from web traffic</li>
              <li>✅ Hard to block (port 443)</li>
              <li>⚠️ Centralizes DNS at browser level</li>
              <li>✅ Firefox, Chrome, Edge, Safari support</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- DNSSEC -->
    <section class="dnssec-section">
      <h2>🔏 DNSSEC: Chain of Trust</h2>
      <p class="section-desc">DNSSEC adds cryptographic signatures to DNS records, creating a chain of trust from the root zone down.</p>

      <div class="dnssec-chain" id="dnssecChain"></div>

      <div class="dnssec-records">
        <div class="dnssec-record-card">
          <h4>DNSKEY</h4>
          <p>Public key published in DNS. Zone Signing Key (ZSK) signs records; Key Signing Key (KSK) signs the DNSKEY set.</p>
          <code>example.com. IN DNSKEY 257 3 13 mdsswUyr3DPW...</code>
        </div>
        <div class="dnssec-record-card">
          <h4>RRSIG</h4>
          <p>Signature over a record set. Validators use the DNSKEY to verify. Each RRSIG has an expiration.</p>
          <code>example.com. IN RRSIG A 13 2 300 20250401 20250301 12345 example.com. oJB1W6...</code>
        </div>
        <div class="dnssec-record-card">
          <h4>DS</h4>
          <p>Delegation Signer — hash of child's KSK, stored in the parent zone. Links parent trust to child zone.</p>
          <code>example.com. IN DS 12345 13 2 49FD46E6C4B45...</code>
        </div>
      </div>
    </section>

    <!-- Anycast -->
    <section class="anycast-section">
      <h2>🌍 Anycast: Global DNS Routing</h2>
      <p class="section-desc">Root servers and CDN DNS use anycast — the same IP address is announced from multiple locations. BGP routes you to the nearest one.</p>

      <div class="anycast-viz" id="anycastViz">
        <div class="anycast-map">
          <div class="anycast-server" style="top:25%;left:20%;" data-loc="Virginia">
            <div class="anycast-dot"></div>
            <div class="anycast-label">Virginia</div>
          </div>
          <div class="anycast-server" style="top:20%;left:45%;" data-loc="London">
            <div class="anycast-dot"></div>
            <div class="anycast-label">London</div>
          </div>
          <div class="anycast-server" style="top:30%;left:55%;" data-loc="Frankfurt">
            <div class="anycast-dot"></div>
            <div class="anycast-label">Frankfurt</div>
          </div>
          <div class="anycast-server" style="top:35%;left:75%;" data-loc="Tokyo">
            <div class="anycast-dot"></div>
            <div class="anycast-label">Tokyo</div>
          </div>
          <div class="anycast-server" style="top:55%;left:80%;" data-loc="Singapore">
            <div class="anycast-dot"></div>
            <div class="anycast-label">Singapore</div>
          </div>
          <div class="anycast-server" style="top:65%;left:30%;" data-loc="São Paulo">
            <div class="anycast-dot"></div>
            <div class="anycast-label">São Paulo</div>
          </div>
          <div class="anycast-server" style="top:70%;left:55%;" data-loc="Johannesburg">
            <div class="anycast-dot"></div>
            <div class="anycast-label">Johannesburg</div>
          </div>
        </div>
        <div class="anycast-info">
          <p>All 7 servers announce the <strong>same IP</strong> (e.g., <code>198.41.0.4</code>). BGP routers direct your query to the <strong>topologically nearest</strong> instance. If one goes down, traffic reroutes automatically — no DNS change needed.</p>
          <div class="anycast-stats">
            <div class="anycast-stat">
              <span class="stat-value-big">13</span>
              <span class="stat-label-sm">Root server letters</span>
            </div>
            <div class="anycast-stat">
              <span class="stat-value-big">1,700+</span>
              <span class="stat-label-sm">Root instances worldwide</span>
            </div>
            <div class="anycast-stat">
              <span class="stat-value-big">&lt;5ms</span>
              <span class="stat-label-sm">Typical root RTT</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Cache Status -->
    <section class="cache-section">
      <h2>📦 Cache Status</h2>
      <p class="section-desc">Records resolved during your session. TTLs count down in real time.</p>
      <div class="cache-table" id="cacheTable">
        <div class="cache-empty">No cached records yet. Resolve a domain above!</div>
      </div>
    </section>

    <!-- Explanations -->
    <section class="explain-section">
      <div class="explain-grid">
        <div class="explain-card highlight-card">
          <h3>💡 Why Not Just One Server?</h3>
          <p>
            A single DNS server would need to handle <strong>trillions of queries per day</strong>.
            The hierarchical design distributes load: root servers only point to TLD servers,
            TLD servers only point to authoritative servers. Each layer is independently scalable.
          </p>
        </div>
        <div class="explain-card">
          <h3>⚡ Negative Caching</h3>
          <p>
            When a domain <em>doesn't exist</em>, the NXDOMAIN response is also cached —
            with the SOA record's <code>minimum</code> field as TTL. This prevents repeated
            lookups for typos or non-existent domains.
          </p>
        </div>
        <div class="explain-card">
          <h3>🔄 Glue Records</h3>
          <p>
            If <code>ns1.example.com</code> is the nameserver for <code>example.com</code>,
            you have a chicken-and-egg problem. <strong>Glue records</strong> are A records
            for nameservers included in the parent zone's delegation.
          </p>
        </div>
        <div class="explain-card">
          <h3>📊 UDP vs TCP</h3>
          <p>
            DNS uses <strong>UDP by default</strong> (port 53) for speed. If a response exceeds
            <strong>512 bytes</strong> (or 4096 with EDNS0), the server sets the TC (truncated) bit
            and the client retries over <strong>TCP</strong>. Zone transfers (AXFR) always use TCP.
          </p>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://datatracker.ietf.org/doc/html/rfc1035" target="_blank">RFC 1035</a>, <a href="https://datatracker.ietf.org/doc/html/rfc8484" target="_blank">RFC 8484 (DoH)</a>, and <a href="https://datatracker.ietf.org/doc/html/rfc4033" target="_blank">RFC 4033 (DNSSEC)</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20DNS%20Resolution%20Visualizer&url=https://systeminternals.dev/dns/resolution/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/dns/resolution/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/dns/resolution/&t=Interactive%20DNS%20Resolution%20Visualizer" target="_blank" class="share-btn">🟧 HN</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container { max-width: 1100px; margin: 0 auto; }
  .viz-header { text-align: center; margin-bottom: 40px; }
  .viz-header h1 { font-size: 2.5rem; margin-bottom: 10px; background: linear-gradient(90deg, #06b6d4, #10b981, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .subtitle { color: #888; font-size: 1.1rem; }
  h2 { font-size: 1.5rem; color: #fff; margin-bottom: 12px; }
  .section-desc { color: #888; margin-bottom: 24px; }

  .overview-section { margin-bottom: 50px; }
  .overview-card { background: linear-gradient(135deg, rgba(6,182,212,0.1), rgba(16,185,129,0.05)); border: 1px solid rgba(6,182,212,0.3); border-radius: 16px; padding: 24px 28px; font-size: 1.05rem; line-height: 1.8; color: #ccc; }
  .overview-card strong { color: #fff; }
  .overview-card em { color: #10b981; font-style: normal; font-weight: 500; }

  .action-btn { padding: 10px 20px; border: none; border-radius: 10px; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .action-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .primary-btn { background: linear-gradient(135deg, #06b6d4, #0891b2); color: white; }
  .primary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(6,182,212,0.4); }
  .reset-btn { background: rgba(255,255,255,0.1); color: #aaa; }
  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  input[type="range"] { -webkit-appearance: none; height: 8px; background: rgba(255,255,255,0.15); border-radius: 4px; cursor: pointer; width: 100%; }
  input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 20px; height: 20px; border-radius: 50%; background: #06b6d4; cursor: pointer; }
  .slider-group { margin-bottom: 16px; }
  .slider-group label { color: #ccc; font-size: 0.95rem; display: block; margin-bottom: 8px; }
  .slider-group strong { color: #06b6d4; }
  .slider-group input[type="range"] { max-width: 400px; }

  /* Resolution Simulator */
  .resolver-section { margin-bottom: 50px; }
  .resolver-controls { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; margin-bottom: 24px; }
  .domain-input-group { display: flex; align-items: center; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.2); border-radius: 10px; overflow: hidden; }
  .input-prefix { padding: 10px 12px; color: #10b981; font-family: monospace; font-weight: 700; font-size: 0.9rem; background: rgba(16,185,129,0.1); }
  .domain-input-group input { padding: 10px 14px; background: transparent; border: none; color: #fff; font-size: 0.95rem; font-family: monospace; outline: none; min-width: 220px; }
  .domain-input-group select { padding: 10px 12px; background: rgba(255,255,255,0.05); border: none; border-left: 1px solid rgba(255,255,255,0.15); color: #06b6d4; font-size: 0.85rem; font-weight: 600; cursor: pointer; outline: none; }
  .domain-input-group select option { background: #1a1a2e; }

  .resolver-viz { background: rgba(0,0,0,0.2); border-radius: 14px; padding: 24px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 16px; overflow-x: auto; }
  .resolver-nodes { display: flex; align-items: center; gap: 0; min-width: 900px; }
  .resolver-node { text-align: center; flex-shrink: 0; width: 110px; padding: 12px 8px; border-radius: 12px; border: 2px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.03); transition: all 0.4s; }
  .resolver-node.active { border-color: #06b6d4; background: rgba(6,182,212,0.1); box-shadow: 0 0 20px rgba(6,182,212,0.3); }
