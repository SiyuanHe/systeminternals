---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="EVM Execution & Gas Metering" 
  description="Interactive visualization of the Ethereum Virtual Machine: step through opcodes, watch the stack, and understand gas costs"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "Ethereum", href: "/ethereum/" },
    { label: "EVM & Gas", href: "/ethereum/evm-gas/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>⚙️ EVM Execution & Gas</h1>
      <p class="subtitle">Step Through Bytecode and Watch the Ethereum Virtual Machine Think</p>
    </header>

    <section class="overview-section">
      <div class="overview-card">
        <p>
          The <strong>EVM</strong> is a stack-based virtual machine that executes smart contract bytecode.
          Every operation costs <em>gas</em> — a unit of computational effort. Gas prevents infinite loops
          and DoS attacks. Users set a <strong>gas limit</strong> (max gas to spend) and a
          <strong>gas price</strong> (ETH per unit). Unused gas is refunded; out-of-gas reverts all changes.
        </p>
      </div>
    </section>

    <!-- EVM Simulator -->
    <section class="evm-section">
      <h2>🖥️ EVM Simulator</h2>
      <p class="section-desc">Select a program or write opcodes. Step through execution and watch the stack, memory, and gas.</p>

      <div class="evm-presets">
        <button class="preset-btn active" data-program="add">1 + 2 = 3</button>
        <button class="preset-btn" data-program="multiply">3 × 7 = 21</button>
        <button class="preset-btn" data-program="compare">if (5 > 3)</button>
        <button class="preset-btn" data-program="storage">SSTORE + SLOAD</button>
        <button class="preset-btn" data-program="loop">Simple loop</button>
      </div>

      <div class="evm-viz">
        <div class="evm-code-col">
          <div class="evm-label">Bytecode</div>
          <div class="evm-code" id="evmCode"></div>
          <div class="evm-pc">PC: <strong id="evmPC">0</strong></div>
        </div>

        <div class="evm-state-col">
          <div class="evm-stack-section">
            <div class="evm-label">Stack <span class="evm-sublabel" id="evmStackDepth">(depth: 0)</span></div>
            <div class="evm-stack" id="evmStack">
              <div class="evm-empty">empty</div>
            </div>
          </div>

          <div class="evm-memory-section">
            <div class="evm-label">Memory</div>
            <div class="evm-memory" id="evmMemory">
              <div class="evm-empty">empty</div>
            </div>
          </div>

          <div class="evm-storage-section">
            <div class="evm-label">Storage</div>
            <div class="evm-storage" id="evmStorage">
              <div class="evm-empty">empty</div>
            </div>
          </div>
        </div>

        <div class="evm-gas-col">
          <div class="evm-label">Gas</div>
          <div class="gas-meter">
            <div class="gas-limit">Limit: <strong id="gasLimit">100000</strong></div>
            <div class="gas-bar-track"><div class="gas-bar-fill" id="gasBar" style="width:100%"></div></div>
            <div class="gas-remaining">Remaining: <strong id="gasRemaining">100000</strong></div>
            <div class="gas-used">Used: <strong id="gasUsed">0</strong></div>
          </div>
          <div class="gas-last-op" id="gasLastOp">—</div>
        </div>
      </div>

      <div class="evm-actions">
        <button id="evmStepBtn" class="action-btn primary-btn">⏭ Step</button>
        <button id="evmRunBtn" class="action-btn secondary-btn">▶ Run All</button>
        <button id="evmResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>

      <div class="evm-result" id="evmResult"></div>
    </section>

    <!-- Gas Costs Table -->
    <section class="gas-table-section">
      <h2>⛽ Gas Cost Reference</h2>
      <p class="section-desc">Every opcode has a fixed gas cost. Storage operations are the most expensive.</p>

      <div class="gas-categories">
        <div class="gas-category">
          <h3>🟢 Cheap (3 gas)</h3>
          <div class="gas-ops">
            <span class="gas-op">ADD</span>
            <span class="gas-op">SUB</span>
            <span class="gas-op">MUL</span>
            <span class="gas-op">LT</span>
            <span class="gas-op">GT</span>
            <span class="gas-op">EQ</span>
            <span class="gas-op">AND</span>
            <span class="gas-op">OR</span>
            <span class="gas-op">XOR</span>
            <span class="gas-op">NOT</span>
            <span class="gas-op">POP</span>
            <span class="gas-op">PUSH</span>
          </div>
        </div>
        <div class="gas-category">
          <h3>🟡 Medium (5-8 gas)</h3>
          <div class="gas-ops">
            <span class="gas-op">DIV <span class="gas-cost">5</span></span>
            <span class="gas-op">MOD <span class="gas-cost">5</span></span>
            <span class="gas-op">ADDMOD <span class="gas-cost">8</span></span>
            <span class="gas-op">MULMOD <span class="gas-cost">8</span></span>
            <span class="gas-op">JUMP <span class="gas-cost">8</span></span>
            <span class="gas-op">JUMPI <span class="gas-cost">10</span></span>
          </div>
        </div>
        <div class="gas-category">
          <h3>🔴 Expensive</h3>
          <div class="gas-ops">
            <span class="gas-op">SHA3 <span class="gas-cost">30+</span></span>
            <span class="gas-op">BALANCE <span class="gas-cost">2600</span></span>
            <span class="gas-op">SLOAD <span class="gas-cost">2100</span></span>
            <span class="gas-op">SSTORE <span class="gas-cost">20000*</span></span>
            <span class="gas-op">CREATE <span class="gas-cost">32000</span></span>
            <span class="gas-op">CALL <span class="gas-cost">2600+</span></span>
          </div>
        </div>
      </div>

      <div class="gas-note">* SSTORE: 20,000 gas for cold write (new slot), 2,900 for warm update, 0 + refund for clearing to zero.</div>
    </section>

    <!-- EIP-1559 Gas Market -->
    <section class="eip1559-section">
      <h2>📊 EIP-1559 Gas Market</h2>
      <p class="section-desc">Adjust block utilization and see how base fee changes. The base fee is burned, not paid to validators.</p>

      <div class="eip-controls">
        <div class="slider-group">
          <label>Block utilization: <strong id="eipUtilLabel">50</strong>% (target: 50%)</label>
          <input type="range" id="eipUtilSlider" min="0" max="100" value="50">
        </div>
        <div class="slider-group">
          <label>Priority fee (tip): <strong id="eipTipLabel">2</strong> gwei</label>
          <input type="range" id="eipTipSlider" min="0" max="50" value="2">
        </div>
      </div>

      <div class="eip-viz">
        <div class="eip-blocks" id="eipBlocks"></div>
        <div class="eip-fee-breakdown" id="eipFeeBreakdown">
          <div class="eip-fee-item">
            <div class="eip-fee-label">Base Fee</div>
            <div class="eip-fee-value" id="eipBaseFee">15.0 gwei</div>
            <div class="eip-fee-dest">🔥 Burned</div>
          </div>
          <div class="eip-fee-item">
            <div class="eip-fee-label">Priority Fee</div>
            <div class="eip-fee-value" id="eipPriorityFee">2.0 gwei</div>
            <div class="eip-fee-dest">💰 To Validator</div>
          </div>
          <div class="eip-fee-item total">
            <div class="eip-fee-label">Total per gas</div>
            <div class="eip-fee-value" id="eipTotalFee">17.0 gwei</div>
            <div class="eip-fee-dest">≈ $0.57 for 21k gas transfer</div>
          </div>
        </div>
      </div>

      <div class="eip-actions">
        <button id="eipNextBlockBtn" class="action-btn primary-btn">⛏️ Mine Next Block</button>
        <button id="eipResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>
    </section>

    <!-- Explanations -->
    <section class="explain-section">
      <div class="explain-grid">
        <div class="explain-card highlight-card">
          <h3>💡 Why Gas Exists</h3>
          <p>
            Without gas, anyone could deploy an infinite loop and halt the network.
            Gas makes computation <strong>economically bounded</strong>. Every node must execute
            the same bytecode and arrive at the same state — gas ensures this terminates.
            It's the "halting problem" solved with economics.
          </p>
        </div>
        <div class="explain-card">
          <h3>🔥 EIP-1559 Fee Burning</h3>
          <p>
            Pre-1559: all fees went to miners (first-price auction, overpaying).
            Post-1559: <strong>base fee is burned</strong> (removed from supply), only priority fee
            goes to validators. This makes ETH deflationary when usage is high
            and fees more predictable for users.
          </p>
        </div>
        <div class="explain-card">
          <h3>⚡ Gas Optimization Tips</h3>
          <p>
            Pack storage variables into single 32-byte slots.
            Use <code>calldata</code> instead of <code>memory</code> for read-only params.
            Prefer <code>uint256</code> over smaller types (EVM is 256-bit native).
            Batch operations to amortize the 21,000 base transaction cost.
          </p>
        </div>
        <div class="explain-card">
          <h3>📊 Stack Machine vs Register</h3>
          <p>
            The EVM is a <strong>stack machine</strong> — no registers, all operations push/pop
            from a 1024-deep stack. Each element is 256 bits (32 bytes). This makes bytecode
            compact and verification simple, but requires more instructions than a register machine.
          </p>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on the <a href="https://ethereum.github.io/yellowpaper/paper.pdf" target="_blank">Ethereum Yellow Paper</a> and <a href="https://www.evm.codes/" target="_blank">evm.codes</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20EVM%20%26%20Gas%20Visualizer&url=https://systeminternals.dev/ethereum/evm-gas/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/ethereum/evm-gas/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/ethereum/evm-gas/&t=Interactive%20EVM%20Execution%20%26%20Gas%20Visualizer" target="_blank" class="share-btn">🟧 HN</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container { max-width: 1100px; margin: 0 auto; }
  .viz-header { text-align: center; margin-bottom: 40px; }
  .viz-header h1 { font-size: 2.5rem; margin-bottom: 10px; background: linear-gradient(90deg, #818cf8, #a78bfa, #c084fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .subtitle { color: #888; font-size: 1.1rem; }
  h2 { font-size: 1.5rem; color: #fff; margin-bottom: 12px; }
  h3 { font-size: 1.05rem; color: #fff; margin-bottom: 8px; }
  .section-desc { color: #888; margin-bottom: 24px; }

  .overview-section { margin-bottom: 50px; }
  .overview-card { background: linear-gradient(135deg, rgba(129,140,248,0.1), rgba(167,139,250,0.05)); border: 1px solid rgba(129,140,248,0.3); border-radius: 16px; padding: 24px 28px; font-size: 1.05rem; line-height: 1.8; color: #ccc; }
  .overview-card strong { color: #fff; }
  .overview-card em { color: #818cf8; font-style: normal; font-weight: 500; }

  .action-btn { padding: 10px 20px; border: none; border-radius: 10px; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .action-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .primary-btn { background: linear-gradient(135deg, #818cf8, #6366f1); color: white; }
  .primary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(129,140,248,0.4); }
  .secondary-btn { background: linear-gradient(135deg, #a78bfa, #7c3aed); color: white; }
  .secondary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(167,139,250,0.4); }
  .reset-btn { background: rgba(255,255,255,0.1); color: #aaa; }
  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }
  input[type="range"] { -webkit-appearance: none; height: 8px; background: rgba(255,255,255,0.15); border-radius: 4px; cursor: pointer; width: 100%; max-width: 500px; }
  input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 20px; height: 20px; border-radius: 50%; background: #818cf8; cursor: pointer; }

  /* Presets */
  .evm-presets { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
  .preset-btn { padding: 8px 16px; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; background: rgba(255,255,255,0.03); color: #ccc; font-size: 0.85rem; cursor: pointer; transition: all 0.2s; }
  .preset-btn.active { border-color: #818cf8; background: rgba(129,140,248,0.15); color: #818cf8; font-weight: 600; }

  /* EVM Viz */
  .evm-section { margin-bottom: 50px; }
  .evm-viz { display: flex; gap: 16px; margin-bottom: 16px; }
  .evm-code-col { flex: 0.8; }
  .evm-state-col { flex: 1.2; }
  .evm-gas-col { flex: 0.8; }
  .evm-label { font-size: 0.85rem; font-weight: 700; color: #818cf8; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
  .evm-sublabel { font-weight: 400; color: #666; text-transform: none; letter-spacing: 0; }

  .evm-code { background: rgba(0,0,0,0.3); border-radius: 10px; padding: 12px; min-height: 200px; max-height: 300px; overflow-y: auto; font-family: 'Monaco','Menlo',monospace; font-size: 0.8rem; display: flex; flex-direction: column; gap: 2px; }
  :global(.evm-op) { padding: 4px 8px; border-radius: 4px; display: flex; gap: 8px; transition: all 0.2s; }
  :global(.evm-op.current) { background: rgba(129,140,248,0.2); border-left: 3px solid #818cf8; }
  :global(.evm-op.executed) { opacity: 0.5; }
  :global(.evm-op-pc) { color: #555; min-width: 24px; }
  :global(.evm-op-name) { color: #a78bfa; font-weight: 600; }
  :global(.evm-op-arg) { color: #888; }
  :global(.evm-op-gas) { color: #555; margin-left: auto; font-size: 0.7rem; }
  .evm-pc { font-size: 0.8rem; color: #888; margin-top: 6px; font-family: 'Monaco','Menlo',monospace; }
  .evm-pc strong { color: #818cf8; }

  .evm-stack, .evm-memory, .evm-storage { background: rgba(0,0,0,0.2); border-radius: 10px; padding: 10px; min-height: 50px; margin-bottom: 12px; display: flex; flex-direction: column; gap: 3px; }
  .evm-empty { color: #555; font-size: 0.8rem; text-align: center; padding: 8px; }
  :global(.evm-stack-item) { padding: 5px 10px; background: rgba(129,140,248,0.1); border: 1px solid rgba(129,140,248,0.25); border-radius: 6px; font-size: 0.75rem; font-family: 'Monaco','Menlo',monospace; color: #c4b5fd; display: flex; justify-content: space-between; animation: stackPush 0.2s ease-out; }
  @keyframes stackPush { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
  :global(.evm-stack-idx) { color: #555; font-size: 0.65rem; }
  :global(.evm-stack-val) { font-weight: 600; }
  :global(.evm-mem-item) { padding: 4px 8px; background: rgba(52,211,153,0.08); border-radius: 4px; font-size: 0.7rem; font-family: 'Monaco','Menlo',monospace; color: #6ee7b7; }
  :global(.evm-store-item) { padding: 4px 8px; background: rgba(251,191,36,0.08); border-radius: 4px; font-size: 0.7rem; font-family: 'Monaco','Menlo',monospace; color: #fde68a; }

  .gas-meter { background: rgba(0,0,0,0.2); border-radius: 10px; padding: 14px; }
  .gas-limit, .gas-remaining, .gas-used { font-size: 0.8rem; color: #888; margin-bottom: 6px; }
  .gas-limit strong, .gas-remaining strong { color: #34d399; }
  .gas-used strong { color: #f97316; }
  .gas-bar-track { height: 20px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; margin: 8px 0; }
  .gas-bar-fill { height: 100%; background: linear-gradient(90deg, #34d399, #818cf8); border-radius: 4px; transition: width 0.3s ease; }
  .gas-last-op { font-size: 0.75rem; color: #888; margin-top: 8px; font-family: 'Monaco','Menlo',monospace; padding: 6px 10px; background: rgba(0,0,0,0.2); border-radius: 6px; }

  .evm-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 12px; }
  .evm-result { font-size: 0.9rem; color: #aaa; min-height: 24px; padding: 8px; text-align: center; }

  /* Gas Table */
  .gas-table-section { margin-bottom: 50px; }
  .gas-categories { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 12px; }
  .gas-category { background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 18px; }
  .gas-category h3 { font-size: 0.9rem; margin-bottom: 10px; }
  .gas-ops { display: flex; flex-wrap: wrap; gap: 6px; }
  .gas-op { padding: 4px 10px; background: rgba(255,255,255,0.05); border-radius: 6px; font-size: 0.75rem; font-family: 'Monaco','Menlo',monospace; color: #ccc; }
  .gas-cost { color: #888; font-size: 0.65rem; }
  .gas-note { font-size: 0.8rem; color: #888; font-style: italic; }

  /* EIP-1559 */
  .eip1559-section { margin-bottom: 50px; }
  .eip-controls { margin-bottom: 20px; }
  .slider-group { margin-bottom: 16px; }
  .slider-group label { color: #ccc; font-size: 0.95rem; display: block; margin-bottom: 8px; }
  .slider-group strong { color: #818cf8; }

  .eip-viz { display: flex; gap: 20px; margin-bottom: 16px; flex-wrap: wrap; }
  .eip-blocks { display: flex; gap: 6px; flex: 2; min-height: 80px; align-items: flex-end; flex-wrap: wrap; }
  :global(.eip-block) { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  :global(.eip-block-bar) { width: 32px; border-radius: 4px 4px 0 0; transition: height 0.3s, background 0.3s; }
  :global(.eip-block-num) { font-size: 0.6rem; color: #555; }
  :global(.eip-block-fee) { font-size: 0.6rem; color: #888; font-family: 'Monaco','Menlo',monospace; }

  .eip-fee-breakdown { flex: 1; display: flex; flex-direction: column; gap: 8px; min-width: 200px; }
  .eip-fee-item { padding: 12px 16px; background: rgba(0,0,0,0.2); border-radius: 10px; border: 1px solid rgba(255,255,255,0.08); }
  .eip-fee-item.total { border-color: rgba(129,140,248,0.3); background: rgba(129,140,248,0.05); }
  .eip-fee-label { font-size: 0.75rem; color: #888; margin-bottom: 2px; }
  .eip-fee-value { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 2px; }
  .eip-fee-dest { font-size: 0.75rem; color: #666; }

  .eip-actions { display: flex; gap: 12px; }

  /* Explain */
  .explain-section { margin-bottom: 50px; }
  .explain-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .explain-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 24px; }
  .explain-card h3 { font-size: 1rem; color: #fff; margin-bottom: 10px; }
  .explain-card p { color: #aaa; line-height: 1.6; font-size: 0.9rem; }
  .explain-card strong { color: #818cf8; }
  .explain-card code { background: rgba(0,0,0,0.3); padding: 2px 6px; border-radius: 4px; font-size: 0.85rem; color: #a78bfa; }
  .highlight-card { background: linear-gradient(135deg, rgba(129,140,248,0.08), rgba(167,139,250,0.08)); border-color: rgba(129,140,248,0.3); }

  .viz-footer { text-align: center; color: #666; font-size: 0.9rem; padding: 20px 0; border-top: 1px solid rgba(255,255,255,0.1); margin-bottom: 30px; }
  .viz-footer a { color: #818cf8; }
  .share-buttons { display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; }
  .share-buttons span { color: #666; }
  .share-btn { padding: 10px 20px; background: rgba(255,255,255,0.1); border-radius: 8px; color: #fff; font-size: 0.9rem; transition: background 0.2s; }
  .share-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  @media (max-width: 768px) {
    .viz-header h1 { font-size: 1.8rem; }
    .explain-grid { grid-template-columns: 1fr; }
    .evm-viz { flex-direction: column; }
    .gas-categories { grid-template-columns: 1fr; }
    .eip-viz { flex-direction: column; }
  }
</style>

<script>
  // ========== EVM PROGRAMS ==========
  interface EvmOp { name: string; arg?: string; gas: number; exec: (state: EvmState) => void; }
  interface EvmState { stack: bigint[]; memory: Map<number, string>; storage: Map<string, string>; gasUsed: number; gasLimit: number; }

  const PROGRAMS: Record<string, EvmOp[]> = {
    add: [
      { name: 'PUSH1', arg: '0x01', gas: 3, exec: (s) => s.stack.unshift(1n) },
      { name: 'PUSH1', arg: '0x02', gas: 3, exec: (s) => s.stack.unshift(2n) },
      { name: 'ADD', gas: 3, exec: (s) => { const b = s.stack.shift()!; const a = s.stack.shift()!; s.stack.unshift(a + b); } },
      { name: 'STOP', gas: 0, exec: () => {} },
    ],
    multiply: [
      { name: 'PUSH1', arg: '0x03', gas: 3, exec: (s) => s.stack.unshift(3n) },
      { name: 'PUSH1', arg: '0x07', gas: 3, exec: (s) => s.stack.unshift(7n) },
      { name: 'MUL', gas: 5, exec: (s) => { const b = s.stack.shift()!; const a = s.stack.shift()!; s.stack.unshift(a * b); } },
      { name: 'STOP', gas: 0, exec: () => {} },
    ],
    compare: [
      { name: 'PUSH1', arg: '0x03', gas: 3, exec: (s) => s.stack.unshift(3n) },
      { name: 'PUSH1', arg: '0x05', gas: 3, exec: (s) => s.stack.unshift(5n) },
      { name: 'GT', gas: 3, exec: (s) => { const b = s.stack.shift()!; const a = s.stack.shift()!; s.stack.unshift(a > b ? 1n : 0n); } },
      { name: 'PUSH1', arg: '0x01', gas: 3, exec: (s) => s.stack.unshift(1n) },
      { name: 'EQ', gas: 3, exec: (s) => { const b = s.stack.shift()!; const a = s.stack.shift()!; s.stack.unshift(a === b ? 1n : 0n); } },
      { name: 'STOP', gas: 0, exec: () => {} },
    ],
    storage: [
      { name: 'PUSH1', arg: '0x42', gas: 3, exec: (s) => s.stack.unshift(0x42n) },
      { name: 'PUSH1', arg: '0x00', gas: 3, exec: (s) => s.stack.unshift(0n) },
      { name: 'SSTORE', gas: 22100, exec: (s) => { const key = s.stack.shift()!; const val = s.stack.shift()!; s.storage.set('0x' + key.toString(16).padStart(2, '0'), '0x' + val.toString(16)); } },
      { name: 'PUSH1', arg: '0x00', gas: 3, exec: (s) => s.stack.unshift(0n) },
      { name: 'SLOAD', gas: 2100, exec: (s) => { const key = s.stack.shift()!; const val = s.storage.get('0x' + key.toString(16).padStart(2, '0')) || '0x0'; s.stack.unshift(BigInt(val)); } },
      { name: 'STOP', gas: 0, exec: () => {} },
    ],
    loop: [
      { name: 'PUSH1', arg: '0x00', gas: 3, exec: (s) => s.stack.unshift(0n) },
      { name: 'PUSH1', arg: '0x01', gas: 3, exec: (s) => s.stack.unshift(1n) },
      { name: 'ADD', gas: 3, exec: (s) => { const b = s.stack.shift()!; const a = s.stack.shift()!; s.stack.unshift(a + b); } },
      { name: 'DUP1', gas: 3, exec: (s) => s.stack.unshift(s.stack[0]) },
      { name: 'PUSH1', arg: '0x05', gas: 3, exec: (s) => s.stack.unshift(5n) },
      { name: 'LT', gas: 3, exec: (s) => { const b = s.stack.shift()!; const a = s.stack.shift()!; s.stack.unshift(a < b ? 1n : 0n); } },
      { name: 'PUSH1', arg: '0x01', gas: 3, exec: (s) => s.stack.unshift(1n) },
      { name: 'JUMPI', arg: '→ PC 1', gas: 10, exec: (s) => { const dest = s.stack.shift()!; const cond = s.stack.shift()!; /* simulated */ } },
      { name: 'STOP', gas: 0, exec: () => {} },
    ],
  };

  // Unroll loop
  const loopUnrolled: EvmOp[] = [];
  for (let i = 0; i < 5; i++) {
    if (i === 0) {
      loopUnrolled.push({ name: 'PUSH1', arg: '0x00', gas: 3, exec: (s) => s.stack.unshift(0n) });
    }
    loopUnrolled.push({ name: 'PUSH1', arg: '0x01', gas: 3, exec: (s) => s.stack.unshift(1n) });
    loopUnrolled.push({ name: 'ADD', gas: 3, exec: (s) => { const b = s.stack.shift()!; const a = s.stack.shift()!; s.stack.unshift(a + b); } });
  }
  loopUnrolled.push({ name: 'STOP', gas: 0, exec: () => {} });
  PROGRAMS.loop = loopUnrolled;

  let currentProgram = 'add';
  let state: EvmState = { stack: [], memory: new Map(), storage: new Map(), gasUsed: 0, gasLimit: 100000 };
  let pc = 0;

  function renderEvm() {
    const ops = PROGRAMS[currentProgram];
    const codeEl = document.getElementById('evmCode')!;
    codeEl.innerHTML = ops.map((op, i) => {
      const cls = i < pc ? 'executed' : i === pc ? 'current' : '';
      return `<div class="evm-op ${cls}"><span class="evm-op-pc">${i}</span><span class="evm-op-name">${op.name}</span><span class="evm-op-arg">${op.arg || ''}</span><span class="evm-op-gas">${op.gas}g</span></div>`;
    }).join('');

    document.getElementById('evmPC')!.textContent = String(pc);

    // Stack
    const stackEl = document.getElementById('evmStack')!;
    if (state.stack.length === 0) {
      stackEl.innerHTML = '<div class="evm-empty">empty</div>';
    } else {
      stackEl.innerHTML = state.stack.map((v, i) =>
        `<div class="evm-stack-item"><span class="evm-stack-idx">[${i}]</span><span class="evm-stack-val">${v <= 0xFFFFn ? v.toString() : '0x' + v.toString(16)}</span></div>`
      ).join('');
    }
    document.getElementById('evmStackDepth')!.textContent = `(depth: ${state.stack.length})`;

    // Memory
    const memEl = document.getElementById('evmMemory')!;
    if (state.memory.size === 0) {
      memEl.innerHTML = '<div class="evm-empty">empty</div>';
    } else {
      memEl.innerHTML = [...state.memory.entries()].map(([k, v]) =>
        `<div class="evm-mem-item">[${k}] = ${v}</div>`
      ).join('');
    }

    // Storage
    const storeEl = document.getElementById('evmStorage')!;
    if (state.storage.size === 0) {
      storeEl.innerHTML = '<div class="evm-empty">empty</div>';
    } else {
      storeEl.innerHTML = [...state.storage.entries()].map(([k, v]) =>
        `<div class="evm-store-item">slot ${k} = ${v}</div>`
      ).join('');
    }

    // Gas
    const remaining = state.gasLimit - state.gasUsed;
    const pct = (remaining / state.gasLimit * 100);
    document.getElementById('gasLimit')!.textContent = String(state.gasLimit);
    document.getElementById('gasRemaining')!.textContent = remaining.toLocaleString();
    document.getElementById('gasUsed')!.textContent = state.gasUsed.toLocaleString();
    document.getElementById('gasBar')!.style.width = pct + '%';
    document.getElementById('gasBar')!.style.background = pct > 50 ? 'linear-gradient(90deg, #34d399, #818cf8)' : pct > 20 ? 'linear-gradient(90deg, #fbbf24, #f97316)' : 'linear-gradient(90deg, #ef4444, #dc2626)';
  }

  function evmStep() {
    const ops = PROGRAMS[currentProgram];
    if (pc >= ops.length) {
      document.getElementById('evmResult')!.textContent = '✅ Execution complete (STOP)';
      return false;
    }
    const op = ops[pc];
    if (state.gasUsed + op.gas > state.gasLimit) {
      document.getElementById('evmResult')!.textContent = `❌ OUT OF GAS at PC ${pc} (${op.name})`;
      return false;
    }
    op.exec(state);
    state.gasUsed += op.gas;
    document.getElementById('gasLastOp')!.textContent = `${op.name}${op.arg ? ' ' + op.arg : ''} → ${op.gas} gas`;
    pc++;
    renderEvm();
    return pc < ops.length && ops[pc - 1].name !== 'STOP';
  }

  document.getElementById('evmStepBtn')?.addEventListener('click', () => {
    evmStep();
  });

  document.getElementById('evmRunBtn')?.addEventListener('click', async () => {
    while (evmStep()) {
      await new Promise(r => setTimeout(r, 200));
    }
  });

  function evmReset() {
    pc = 0;
    state = { stack: [], memory: new Map(), storage: new Map(), gasUsed: 0, gasLimit: 100000 };
    document.getElementById('evmResult')!.textContent = '';
    document.getElementById('gasLastOp')!.textContent = '—';
    renderEvm();
  }

  document.getElementById('evmResetBtn')?.addEventListener('click', evmReset);

  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentProgram = (btn as HTMLElement).dataset.program!;
      evmReset();
    });
  });

  // ========== EIP-1559 ==========
  let baseFee = 15;
  let blocks: Array<{num: number; util: number; baseFee: number}> = [];
  let blockNum = 1;

  function updateEipFees() {
    const tip = parseFloat((document.getElementById('eipTipSlider') as HTMLInputElement).value);
    document.getElementById('eipBaseFee')!.textContent = baseFee.toFixed(1) + ' gwei';
    document.getElementById('eipPriorityFee')!.textContent = tip.toFixed(1) + ' gwei';
    const total = baseFee + tip;
    document.getElementById('eipTotalFee')!.textContent = total.toFixed(1) + ' gwei';
    const ethPrice = 2000; // approximate
    const txCost = (total * 21000 / 1e9) * ethPrice;
    (document.querySelector('.eip-fee-item.total .eip-fee-dest') as HTMLElement).textContent = `≈ $${txCost.toFixed(2)} for 21k gas transfer`;
  }

  function renderEipBlocks() {
    const el = document.getElementById('eipBlocks')!;
    el.innerHTML = blocks.slice(-15).map(b => {
      const height = Math.max(10, b.util * 0.8);
      const color = b.util > 75 ? '#ef4444' : b.util > 50 ? '#fbbf24' : '#34d399';
      return `<div class="eip-block">
        <div class="eip-block-fee">${b.baseFee.toFixed(0)}g</div>
        <div class="eip-block-bar" style="height:${height}px;background:${color}"></div>
        <div class="eip-block-num">#${b.num}</div>
      </div>`;
    }).join('');
  }

  document.getElementById('eipNextBlockBtn')?.addEventListener('click', () => {
    const util = parseInt((document.getElementById('eipUtilSlider') as HTMLInputElement).value);
    blocks.push({ num: blockNum++, util, baseFee });

    // EIP-1559: base fee adjusts by up to 12.5% based on target utilization (50%)
    const delta = (util - 50) / 50; // -1 to +1
    baseFee = Math.max(1, baseFee * (1 + delta * 0.125));

    updateEipFees();
    renderEipBlocks();
  });

  document.getElementById('eipResetBtn')?.addEventListener('click', () => {
    baseFee = 15;
    blocks = [];
    blockNum = 1;
    updateEipFees();
    renderEipBlocks();
  });

  document.getElementById('eipUtilSlider')?.addEventListener('input', (e) => {
    document.getElementById('eipUtilLabel')!.textContent = (e.target as HTMLInputElement).value;
  });

  document.getElementById('eipTipSlider')?.addEventListener('input', (e) => {
    document.getElementById('eipTipLabel')!.textContent = (e.target as HTMLInputElement).value;
    updateEipFees();
  });

  // Init
  renderEvm();
  updateEipFees();
</script>
</BaseLayout>
