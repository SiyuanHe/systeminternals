---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="MEV & Block Building" 
  description="Interactive visualization of MEV extraction, transaction ordering, sandwich attacks, and the Proposer-Builder Separation pipeline"
  breadcrumbs={[
    { label: "Home", href: "/" }, 
    { label: "Ethereum", href: "/ethereum/" },
    { label: "MEV & Block Building", href: "/ethereum/mev-block-building/" }
  ]}
>
  <div class="viz-container">
    <header class="viz-header">
      <h1>🤖 MEV & Block Building</h1>
      <p class="subtitle">Searchers, Builders, and Proposers — The Hidden Economy of Transaction Ordering</p>
    </header>

    <section class="overview-section">
      <div class="overview-card">
        <p>
          <strong>Maximal Extractable Value (MEV)</strong> is the profit a block producer can make by including,
          excluding, or reordering transactions. <em>Searchers</em> find MEV opportunities (arbitrage, liquidations,
          sandwich attacks), <em>builders</em> assemble optimal blocks, and <em>proposers</em> select the highest-bid
          block. This is <strong>Proposer-Builder Separation (PBS)</strong> — keeping block production decentralized
          while enabling specialized block construction via <em>MEV-Boost</em> and relays.
        </p>
      </div>
    </section>

    <!-- MEV Types -->
    <section class="mev-types-section">
      <h2>🎯 MEV Strategies</h2>
      <p class="section-desc">Click each strategy to see how it extracts value from transaction ordering.</p>

      <div class="mev-type-cards">
        <div class="mev-card active" data-type="arb" id="mevArb">
          <div class="mev-icon">🔄</div>
          <div class="mev-name">DEX Arbitrage</div>
          <div class="mev-profit">~60% of MEV</div>
        </div>
        <div class="mev-card" data-type="sandwich" id="mevSandwich">
          <div class="mev-icon">🥪</div>
          <div class="mev-name">Sandwich Attack</div>
          <div class="mev-profit">~20% of MEV</div>
        </div>
        <div class="mev-card" data-type="liquidation" id="mevLiquidation">
          <div class="mev-icon">💀</div>
          <div class="mev-name">Liquidation</div>
          <div class="mev-profit">~15% of MEV</div>
        </div>
        <div class="mev-card" data-type="backrun" id="mevBackrun">
          <div class="mev-icon">🏃</div>
          <div class="mev-name">Backrunning</div>
          <div class="mev-profit">~5% of MEV</div>
        </div>
      </div>

      <div class="mev-type-desc" id="mevDesc">
        <strong>DEX Arbitrage:</strong> When a large swap moves a DEX price away from the market price,
        a searcher can profit by trading on the price difference across DEXes (or DEX vs CEX).
        Example: A $500K USDC→ETH swap on Uniswap pushes ETH price up. The searcher buys ETH cheaper
        on SushiSwap and sells on Uniswap for a risk-free profit.
      </div>
    </section>

    <!-- Transaction Ordering Simulator -->
    <section class="ordering-section">
      <h2>📋 Transaction Ordering Simulator</h2>
      <p class="section-desc">Drag transactions to reorder them and see how MEV changes. The mempool is a dark forest.</p>

      <div class="ordering-viz">
        <div class="mempool-col">
          <div class="mp-label">📡 Mempool</div>
          <div class="mempool-list" id="mempoolList">
            <div class="tx-item" data-tx="0" draggable="true">
              <div class="tx-type swap">SWAP</div>
              <div class="tx-details">
                <div class="tx-from">User Alice</div>
                <div class="tx-action">500K USDC → ETH on Uniswap</div>
                <div class="tx-gas">Gas: 50 gwei</div>
              </div>
              <div class="tx-impact">🔺 +2.1% price impact</div>
            </div>
            <div class="tx-item" data-tx="1" draggable="true">
              <div class="tx-type transfer">XFER</div>
              <div class="tx-details">
                <div class="tx-from">User Bob</div>
                <div class="tx-action">Send 1 ETH to 0xdead...</div>
                <div class="tx-gas">Gas: 30 gwei</div>
              </div>
              <div class="tx-impact">— no MEV</div>
            </div>
            <div class="tx-item" data-tx="2" draggable="true">
              <div class="tx-type arb">ARB</div>
              <div class="tx-details">
                <div class="tx-from">🤖 Searcher</div>
                <div class="tx-action">Buy ETH on Sushi, sell on Uni</div>
                <div class="tx-gas">Gas: 200 gwei</div>
              </div>
              <div class="tx-impact">💰 $4,200 profit</div>
            </div>
            <div class="tx-item" data-tx="3" draggable="true">
              <div class="tx-type sandwich-front">FRONT</div>
              <div class="tx-details">
                <div class="tx-from">🤖 Searcher</div>
                <div class="tx-action">Buy ETH before Alice's swap</div>
                <div class="tx-gas">Gas: 300 gwei</div>
              </div>
              <div class="tx-impact">📈 Pushes price up</div>
            </div>
            <div class="tx-item" data-tx="4" draggable="true">
              <div class="tx-type sandwich-back">BACK</div>
              <div class="tx-details">
                <div class="tx-from">🤖 Searcher</div>
                <div class="tx-action">Sell ETH after Alice's swap</div>
                <div class="tx-gas">Gas: 300 gwei</div>
              </div>
              <div class="tx-impact">💰 Profit from Alice's slippage</div>
            </div>
          </div>
        </div>

        <div class="block-col">
          <div class="mp-label">📦 Block Being Built</div>
          <div class="block-preview" id="blockPreview">
            <div class="block-placeholder">Drag transactions here to build a block</div>
          </div>
          <div class="block-stats">
            <div class="bs-item">MEV Extracted: <strong id="mevExtracted">$0</strong></div>
            <div class="bs-item">Builder Bid: <strong id="builderBid">0 ETH</strong></div>
            <div class="bs-item">User Harm: <strong id="userHarm">$0</strong></div>
          </div>
        </div>
      </div>

      <div class="ordering-presets">
        <span class="preset-label">Quick orderings:</span>
        <button class="preset-btn" data-order="fair">⚖️ Fair (gas priority)</button>
        <button class="preset-btn" data-order="sandwich">🥪 Sandwich Alice</button>
        <button class="preset-btn" data-order="arb-only">🔄 Arb only (no sandwich)</button>
        <button class="preset-btn" data-order="empty">🔄 Reset</button>
      </div>

      <div class="ordering-result" id="orderingResult"></div>
    </section>

    <!-- PBS Pipeline -->
    <section class="pbs-section">
      <h2>🏗️ Proposer-Builder Separation</h2>
      <p class="section-desc">The MEV supply chain — from opportunity to block inclusion.</p>

      <div class="pbs-pipeline">
        <div class="pbs-stage" id="pbsSearcher">
          <div class="pbs-stage-icon">🔍</div>
          <div class="pbs-stage-name">Searchers</div>
          <div class="pbs-stage-desc">Find MEV opportunities, create bundles</div>
          <div class="pbs-stage-detail" id="pbsSearcherDetail">
            <div class="pbs-bundle">Bundle: frontrun + victim + backrun</div>
            <div class="pbs-bundle">Bundle: arb on Uni↔Sushi</div>
            <div class="pbs-bundle">Bundle: liquidate vault #4521</div>
          </div>
        </div>
        <div class="pbs-arrow">→</div>
        <div class="pbs-stage" id="pbsBuilder">
          <div class="pbs-stage-icon">🏗️</div>
          <div class="pbs-stage-name">Builders</div>
          <div class="pbs-stage-desc">Assemble optimal blocks from bundles + txs</div>
          <div class="pbs-stage-detail" id="pbsBuilderDetail">
            <div class="pbs-bid" data-builder="Titan">Titan: 0.15 ETH</div>
            <div class="pbs-bid" data-builder="Beaver">Beaver: 0.12 ETH</div>
            <div class="pbs-bid" data-builder="rsync">rsync: 0.09 ETH</div>
          </div>
        </div>
        <div class="pbs-arrow">→</div>
        <div class="pbs-stage" id="pbsRelay">
          <div class="pbs-stage-icon">📡</div>
          <div class="pbs-stage-name">Relays</div>
          <div class="pbs-stage-desc">Validate blocks, hide contents from proposer</div>
          <div class="pbs-stage-detail" id="pbsRelayDetail">
            <div class="pbs-relay-item">Flashbots relay ✓</div>
            <div class="pbs-relay-item">bloXroute relay ✓</div>
            <div class="pbs-relay-item">Ultra Sound relay ✓</div>
          </div>
        </div>
        <div class="pbs-arrow">→</div>
        <div class="pbs-stage" id="pbsProposer">
          <div class="pbs-stage-icon">✅</div>
          <div class="pbs-stage-name">Proposer</div>
          <div class="pbs-stage-desc">Picks highest bid, signs block header</div>
          <div class="pbs-stage-detail" id="pbsProposerDetail">
            <div class="pbs-selected">Selected: Titan (0.15 ETH)</div>
            <div class="pbs-profit">Proposer earns: 0.15 ETH 💰</div>
          </div>
        </div>
      </div>

      <div class="pbs-controls">
        <button id="pbsAnimateBtn" class="action-btn primary-btn">▶ Animate Pipeline</button>
        <button id="pbsResetBtn" class="action-btn reset-btn">🔄 Reset</button>
      </div>
    </section>

    <!-- MEV Metrics -->
    <section class="metrics-section">
      <h2>📊 MEV by the Numbers</h2>
      <div class="metrics-grid">
        <div class="metric-card">
          <div class="metric-value">$600M+</div>
          <div class="metric-label">Total MEV extracted (2024)</div>
        </div>
        <div class="metric-card">
          <div class="metric-value">90%+</div>
          <div class="metric-label">Blocks built via MEV-Boost</div>
        </div>
        <div class="metric-card">
          <div class="metric-value">~5</div>
          <div class="metric-label">Dominant builders</div>
        </div>
        <div class="metric-card">
          <div class="metric-value">12 sec</div>
          <div class="metric-label">Time to find & submit</div>
        </div>
      </div>
    </section>

    <!-- Explanations -->
    <section class="explain-section">
      <div class="explain-grid">
        <div class="explain-card highlight-card">
          <h3>💡 Why PBS Matters</h3>
          <p>
            Without PBS, validators would need sophisticated MEV software to compete, leading to
            <strong>centralization</strong>. PBS separates the "who proposes" from "who builds" —
            any home staker can earn MEV revenue by simply selecting the highest bid.
            Builders compete on extraction skill, proposers compete on stake. Both stay specialized.
          </p>
        </div>
        <div class="explain-card">
          <h3>🛡️ Flashbots Protect</h3>
          <p>
            Regular users can avoid sandwiches by submitting transactions to <strong>Flashbots Protect</strong>
            instead of the public mempool. Protect sends your tx directly to builders who pledge not to
            frontrun. No gas fees on failed transactions. MetaMask and many wallets support it natively.
          </p>
        </div>
        <div class="explain-card">
          <h3>⚡ The Latency Game</h3>
          <p>
            Top builders run co-located servers near relay infrastructure. They receive new blocks in
            ~100ms, simulate thousands of bundles, and must submit bids within the 12-second slot.
            The last few hundred milliseconds before the deadline are the most competitive —
            builders update bids until the very last moment.
          </p>
        </div>
        <div class="explain-card">
          <h3>🔮 The Future: SUAVE & ePBS</h3>
          <p>
            <strong>ePBS</strong> (enshrined PBS) moves builder selection into the protocol itself,
            eliminating trust in relays. <strong>SUAVE</strong> (Flashbots) proposes a separate chain
            for MEV auction. <strong>MEV-Share</strong> returns a portion of MEV back to users whose
            transactions create the opportunity.
          </p>
        </div>
      </div>
    </section>

    <footer class="viz-footer">
      <p>Based on <a href="https://docs.flashbots.net/" target="_blank">Flashbots Documentation</a> and <a href="https://ethereum.org/en/developers/docs/mev/" target="_blank">Ethereum MEV Docs</a></p>
    </footer>

    <div class="share-buttons">
      <span>Share:</span>
      <a href="https://twitter.com/intent/tweet?text=Interactive%20MEV%20%26%20Block%20Building%20Visualizer&url=https://systeminternals.dev/ethereum/mev-block-building/" target="_blank" class="share-btn">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://systeminternals.dev/ethereum/mev-block-building/" target="_blank" class="share-btn">in LinkedIn</a>
      <a href="https://news.ycombinator.com/submitlink?u=https://systeminternals.dev/ethereum/mev-block-building/&t=Interactive%20MEV%20%26%20Block%20Building%20Visualizer" target="_blank" class="share-btn">🟧 HN</a>
    </div>
  </div>
</BaseLayout>

<style>
  .viz-container { max-width: 1100px; margin: 0 auto; }
  .viz-header { text-align: center; margin-bottom: 40px; }
  .viz-header h1 { font-size: 2.5rem; margin-bottom: 10px; background: linear-gradient(90deg, #f97316, #ef4444, #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .subtitle { color: #888; font-size: 1.1rem; }
  h2 { font-size: 1.5rem; color: #fff; margin-bottom: 12px; }
  .section-desc { color: #888; margin-bottom: 24px; }

  .overview-section { margin-bottom: 50px; }
  .overview-card { background: linear-gradient(135deg, rgba(249,115,22,0.1), rgba(236,72,153,0.05)); border: 1px solid rgba(249,115,22,0.3); border-radius: 16px; padding: 24px 28px; font-size: 1.05rem; line-height: 1.8; color: #ccc; }
  .overview-card strong { color: #fff; }
  .overview-card em { color: #f97316; font-style: normal; font-weight: 500; }

  .action-btn { padding: 10px 20px; border: none; border-radius: 10px; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .action-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .primary-btn { background: linear-gradient(135deg, #f97316, #ea580c); color: white; }
  .primary-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(249,115,22,0.4); }
  .secondary-btn { background: linear-gradient(135deg, #60a5fa, #3b82f6); color: white; }
  .reset-btn { background: rgba(255,255,255,0.1); color: #aaa; }
  .reset-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  /* MEV Types */
  .mev-types-section { margin-bottom: 50px; }
  .mev-type-cards { display: flex; gap: 12px; margin-bottom: 16px; }
  .mev-card { flex: 1; padding: 16px; background: rgba(0,0,0,0.2); border: 2px solid rgba(255,255,255,0.1); border-radius: 14px; text-align: center; cursor: pointer; transition: all 0.3s; }
  .mev-card:hover { transform: translateY(-3px); }
  .mev-card.active { border-color: rgba(249,115,22,0.5); background: rgba(249,115,22,0.08); }
  .mev-icon { font-size: 1.8rem; margin-bottom: 6px; }
  .mev-name { font-size: 0.9rem; font-weight: 700; color: #fff; margin-bottom: 4px; }
  .mev-profit { font-size: 0.75rem; color: #f97316; }
  .mev-type-desc { padding: 14px 18px; background: rgba(249,115,22,0.06); border: 1px solid rgba(249,115,22,0.2); border-radius: 10px; font-size: 0.9rem; color: #aaa; line-height: 1.6; }
  .mev-type-desc strong { color: #f97316; }

  /* Transaction Ordering */
  .ordering-section { margin-bottom: 50px; }
  .ordering-viz { display: flex; gap: 20px; margin-bottom: 16px; }
  .mempool-col { flex: 1.2; }
  .block-col { flex: 1; }
  .mp-label { font-size: 0.85rem; font-weight: 700; color: #f97316; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px; }

  .mempool-list { display: flex; flex-direction: column; gap: 6px; }
  .tx-item { display: flex; align-items: center; gap: 10px; padding: 10px 14px; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; cursor: grab; transition: all 0.2s; }
  .tx-item:hover { border-color: rgba(249,115,22,0.3); background: rgba(249,115,22,0.04); }
  .tx-item.dragging { opacity: 0.4; }
  .tx-type { padding: 3px 8px; border-radius: 6px; font-size: 0.7rem; font-weight: 700; min-width: 50px; text-align: center; }
  .tx-type.swap { background: rgba(96,165,250,0.2); color: #60a5fa; }
  .tx-type.transfer { background: rgba(107,114,128,0.2); color: #9ca3af; }
  .tx-type.arb { background: rgba(52,211,153,0.2); color: #34d399; }
  .tx-type.sandwich-front { background: rgba(239,68,68,0.2); color: #ef4444; }
  .tx-type.sandwich-back { background: rgba(239,68,68,0.2); color: #ef4444; }
  .tx-details { flex: 1; }
  .tx-from { font-size: 0.75rem; color: #888; }
  .tx-action { font-size: 0.8rem; color: #ccc; }
  .tx-gas { font-size: 0.7rem; color: #666; }
  .tx-impact { font-size: 0.75rem; color: #f97316; white-space: nowrap; }

  .block-preview { min-height: 280px; background: rgba(0,0,0,0.2); border: 2px dashed rgba(249,115,22,0.2); border-radius: 14px; padding: 12px; display: flex; flex-direction: column; gap: 4px; }
  .block-placeholder { color: #444; text-align: center; padding: 100px 20px; font-size: 0.85rem; }
  :global(.block-tx) { padding: 8px 12px; border-radius: 8px; font-size: 0.8rem; display: flex; justify-content: space-between; animation: msgAppear 0.3s ease-out; }
  @keyframes msgAppear { from { opacity: 0; transform: translateX(-8px); } to { opacity: 1; transform: translateX(0); } }
  :global(.block-tx.swap) { background: rgba(96,165,250,0.1); border: 1px solid rgba(96,165,250,0.2); color: #93c5fd; }
  :global(.block-tx.transfer) { background: rgba(107,114,128,0.08); border: 1px solid rgba(107,114,128,0.15); color: #9ca3af; }
  :global(.block-tx.arb) { background: rgba(52,211,153,0.1); border: 1px solid rgba(52,211,153,0.2); color: #6ee7b7; }
  :global(.block-tx.frontrun) { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); color: #fca5a5; }
  :global(.block-tx.backrun) { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); color: #fca5a5; }

  .block-stats { display: flex; gap: 16px; margin-top: 10px; flex-wrap: wrap; }
  .bs-item { font-size: 0.85rem; color: #888; }
  .bs-item strong { color: #f97316; }

  .ordering-presets { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 12px; }
  .preset-label { font-size: 0.85rem; color: #888; }
  .preset-btn { padding: 6px 14px; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; background: rgba(255,255,255,0.05); color: #ccc; font-size: 0.8rem; cursor: pointer; transition: all 0.2s; }
  .preset-btn:hover { background: rgba(249,115,22,0.1); border-color: rgba(249,115,22,0.3); }
  .ordering-result { font-size: 0.9rem; color: #aaa; min-height: 24px; padding: 8px; text-align: center; }

  /* PBS Pipeline */
  .pbs-section { margin-bottom: 50px; }
  .pbs-pipeline { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 20px; overflow-x: auto; }
  .pbs-stage { flex: 1; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 16px; text-align: center; transition: all 0.5s; min-width: 160px; }
  .pbs-stage.active { border-color: rgba(249,115,22,0.5); background: rgba(249,115,22,0.08); }
  .pbs-stage.done { border-color: rgba(52,211,153,0.4); background: rgba(52,211,153,0.06); }
  .pbs-stage-icon { font-size: 2rem; margin-bottom: 8px; }
  .pbs-stage-name { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 4px; }
  .pbs-stage-desc { font-size: 0.75rem; color: #888; margin-bottom: 10px; }
  .pbs-stage-detail { display: flex; flex-direction: column; gap: 4px; opacity: 0; transition: opacity 0.5s; }
  .pbs-stage.active .pbs-stage-detail, .pbs-stage.done .pbs-stage-detail { opacity: 1; }
  .pbs-bundle, .pbs-bid, .pbs-relay-item, .pbs-selected, .pbs-profit { padding: 4px 8px; border-radius: 6px; font-size: 0.7rem; font-family: 'Monaco','Menlo',monospace; }
  .pbs-bundle { background: rgba(249,115,22,0.1); color: #fdba74; }
  .pbs-bid { background: rgba(96,165,250,0.1); color: #93c5fd; }
  .pbs-relay-item { background: rgba(167,139,250,0.1); color: #c4b5fd; }
  .pbs-selected { background: rgba(52,211,153,0.15); color: #6ee7b7; font-weight: 600; }
  .pbs-profit { background: rgba(251,191,36,0.15); color: #fde68a; font-weight: 600; }
  .pbs-arrow { font-size: 1.5rem; color: #555; padding-top: 40px; }
  .pbs-controls { display: flex; gap: 12px; }

  /* Metrics */
  .metrics-section { margin-bottom: 50px; }
  .metrics-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .metric-card { background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 24px; text-align: center; }
  .metric-value { font-size: 1.8rem; font-weight: 700; color: #f97316; margin-bottom: 6px; }
  .metric-label { font-size: 0.8rem; color: #888; }

  /* Explain */
  .explain-section { margin-bottom: 50px; }
  .explain-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .explain-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 24px; }
  .explain-card h3 { font-size: 1rem; color: #fff; margin-bottom: 10px; }
  .explain-card p { color: #aaa; line-height: 1.6; font-size: 0.9rem; }
  .explain-card strong { color: #f97316; }
  .explain-card em { color: #60a5fa; }
  .highlight-card { background: linear-gradient(135deg, rgba(249,115,22,0.08), rgba(236,72,153,0.08)); border-color: rgba(249,115,22,0.3); }

  .viz-footer { text-align: center; color: #666; font-size: 0.9rem; padding: 20px 0; border-top: 1px solid rgba(255,255,255,0.1); margin-bottom: 30px; }
  .viz-footer a { color: #f97316; }
  .share-buttons { display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; }
  .share-buttons span { color: #666; }
  .share-btn { padding: 10px 20px; background: rgba(255,255,255,0.1); border-radius: 8px; color: #fff; font-size: 0.9rem; transition: background 0.2s; }
  .share-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }

  @media (max-width: 768px) {
    .viz-header h1 { font-size: 1.8rem; }
    .mev-type-cards { flex-direction: column; }
    .ordering-viz { flex-direction: column; }
    .pbs-pipeline { flex-direction: column; align-items: stretch; }
    .pbs-arrow { transform: rotate(90deg); text-align: center; padding: 0; }
    .metrics-grid { grid-template-columns: repeat(2, 1fr); }
    .explain-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // ========== MEV TYPE DESCRIPTIONS ==========
  const MEV_DESCS: Record<string, string> = {
    arb: '<strong>DEX Arbitrage:</strong> When a large swap moves a DEX price away from the market price, a searcher can profit by trading on the price difference across DEXes (or DEX vs CEX). Example: A $500K USDC→ETH swap on Uniswap pushes ETH price up. The searcher buys ETH cheaper on SushiSwap and sells on Uniswap for a risk-free profit.',
    sandwich: '<strong>Sandwich Attack:</strong> The searcher spots a pending swap in the mempool. They place a buy <em>before</em> (frontrun) and a sell <em>after</em> (backrun) the victim\'s transaction. The frontrun pushes the price up, the victim buys at a worse price, and the backrun sells at the inflated price. The victim gets worse execution; the searcher profits from the difference.',
    liquidation: '<strong>Liquidation:</strong> When a DeFi loan becomes under-collateralized (e.g., ETH price drops), anyone can liquidate it for a reward (typically 5-10% of the collateral). Searchers monitor thousands of positions and race to liquidate the moment health factors drop below 1.0. First to land the transaction wins.',
    backrun: '<strong>Backrunning:</strong> Place your transaction immediately <em>after</em> a target transaction. Used for state-change arbitrage: after a large swap creates a price discrepancy, or after a new Uniswap pool is created with mispriced initial liquidity. Less harmful than frontrunning — you\'re cleaning up the aftermath, not causing worse execution.',
  };

  document.querySelectorAll('.mev-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.mev-card').forEach(c => c.classList.remove('active'));
      card.classList.add('active');
      document.getElementById('mevDesc')!.innerHTML = MEV_DESCS[(card as HTMLElement).dataset.type!];
    });
  });

  // ========== TRANSACTION ORDERING ==========
  interface TxInfo {
    id: number;
    label: string;
    type: string;
    cssClass: string;
    mev: number;
    harm: number;
  }

  const TXS: TxInfo[] = [
    { id: 0, label: "Alice: 500K USDC → ETH (Uniswap)", type: "swap", cssClass: "swap", mev: 0, harm: 0 },
    { id: 1, label: "Bob: Send 1 ETH", type: "transfer", cssClass: "transfer", mev: 0, harm: 0 },
    { id: 2, label: "🤖 Arb: Sushi→Uni ETH", type: "arb", cssClass: "arb", mev: 4200, harm: 0 },
    { id: 3, label: "🤖 Frontrun: Buy ETH before Alice", type: "frontrun", cssClass: "frontrun", mev: 0, harm: 0 },
    { id: 4, label: "🤖 Backrun: Sell ETH after Alice", type: "backrun", cssClass: "backrun", mev: 0, harm: 0 },
  ];

  let blockOrder: number[] = [];

  function renderBlock() {
    const preview = document.getElementById('blockPreview')!;
    if (blockOrder.length === 0) {
      preview.innerHTML = '<div class="block-placeholder">Drag transactions here to build a block</div>';
      document.getElementById('mevExtracted')!.textContent = '$0';
      document.getElementById('builderBid')!.textContent = '0 ETH';
      document.getElementById('userHarm')!.textContent = '$0';
      document.getElementById('orderingResult')!.textContent = '';
      return;
    }

    // Calculate MEV based on ordering
    let mev = 0;
    let harm = 0;
    const hasFront = blockOrder.includes(3);
    const hasBack = blockOrder.includes(4);
    const hasAlice = blockOrder.includes(0);
    const hasArb = blockOrder.includes(2);

    // Sandwich: frontrun before Alice, backrun after Alice
    if (hasFront && hasBack && hasAlice) {
      const frontIdx = blockOrder.indexOf(3);
      const aliceIdx = blockOrder.indexOf(0);
      const backIdx = blockOrder.indexOf(4);
      if (frontIdx < aliceIdx && aliceIdx < backIdx) {
        mev += 3100;
        harm += 3100;
      }
    }

    // Arb: after Alice's swap creates the opportunity
    if (hasArb && hasAlice) {
      const arbIdx = blockOrder.indexOf(2);
      const aliceIdx = blockOrder.indexOf(0);
      if (arbIdx > aliceIdx) {
        mev += 4200;
      } else {
        mev += 800; // less profitable if before the big swap
      }
    } else if (hasArb) {
      mev += 800;
    }

    preview.innerHTML = blockOrder.map((txId, pos) => {
      const tx = TXS[txId];
      return `<div class="block-tx ${tx.cssClass}">
        <span>#${pos + 1} ${tx.label}</span>
      </div>`;
    }).join('');

    const bidEth = (mev * 0.9 / 2500).toFixed(4);
    document.getElementById('mevExtracted')!.textContent = `$${mev.toLocaleString()}`;
    document.getElementById('builderBid')!.textContent = `${bidEth} ETH`;
    document.getElementById('userHarm')!.textContent = harm > 0 ? `$${harm.toLocaleString()} (Alice)` : '$0';

    let resultText = '';
    if (harm > 0) resultText = '🥪 Sandwich attack detected! Alice gets worse execution.';
    else if (mev > 3000) resultText = '🔄 Clean arbitrage — no users harmed.';
    else if (mev > 0) resultText = '📊 Some MEV extracted.';
    document.getElementById('orderingResult')!.textContent = resultText;
  }

  // Preset orderings
  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const order = (btn as HTMLElement).dataset.order!;
      switch (order) {
        case 'fair': blockOrder = [1, 0, 2]; break;
        case 'sandwich': blockOrder = [3, 0, 4, 2, 1]; break;
        case 'arb-only': blockOrder = [0, 2, 1]; break;
        case 'empty': blockOrder = []; break;
      }
      renderBlock();
    });
  });

  // Simple click-to-add (since drag-and-drop is complex in pure script)
  document.querySelectorAll('.tx-item').forEach(item => {
    item.addEventListener('click', () => {
      const txId = parseInt((item as HTMLElement).dataset.tx!);
      if (blockOrder.includes(txId)) {
        blockOrder = blockOrder.filter(id => id !== txId);
      } else {
        blockOrder.push(txId);
      }
      renderBlock();
    });
  });

  // ========== PBS ANIMATION ==========
  let pbsAnimating = false;
  document.getElementById('pbsAnimateBtn')?.addEventListener('click', async () => {
    if (pbsAnimating) return;
    pbsAnimating = true;

    const stages = ['pbsSearcher', 'pbsBuilder', 'pbsRelay', 'pbsProposer'];
    stages.forEach(id => {
      document.getElementById(id)!.classList.remove('active', 'done');
    });

    for (let i = 0; i < stages.length; i++) {
      const el = document.getElementById(stages[i])!;
      if (i > 0) document.getElementById(stages[i - 1])!.classList.remove('active');
      if (i > 0) document.getElementById(stages[i - 1])!.classList.add('done');
      el.classList.add('active');
      await new Promise(r => setTimeout(r, 1200));
    }
    document.getElementById(stages[stages.length - 1])!.classList.remove('active');
    document.getElementById(stages[stages.length - 1])!.classList.add('done');
    pbsAnimating = false;
  });

  document.getElementById('pbsResetBtn')?.addEventListener('click', () => {
    ['pbsSearcher', 'pbsBuilder', 'pbsRelay', 'pbsProposer'].forEach(id => {
      document.getElementById(id)!.classList.remove('active', 'done');
    });
  });

  // Init
  renderBlock();
</script>
</BaseLayout>
